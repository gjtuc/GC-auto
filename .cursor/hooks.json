{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/session_start_git_pull.ps1"
      }
    ],
    "stop": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/auto_git_sync.ps1"
      },
      {
        "command": "python .cursor/hooks/task_queue_continue.py",
        "loop_limit": null
      },
      {
        "command": "python .cursor/hooks/task_queue_quit_cursor.py",
        "loop_limit": null
      }
    ]
  }
}
