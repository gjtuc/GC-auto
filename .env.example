# Copy to Desktop\KCH\gc_automation.env (GC2/GC3) or Desktop\박은규\gc_automation.env (GC1)
# 전체 구조 설명: chemstation-gc-automation\gc_architecture.py
# Never commit .env or paste passwords in chat.

# GC2/GC3 (같은 사용자 — KCH)
# GC_INSTANCE=gc2
# EXCEL_OUTPUT_DIR=C:\Users\<user>\Desktop\KCH

# GC1 (박은규 PC)
# GC_INSTANCE=gc1
# EXCEL_OUTPUT_DIR=C:\Users\<user>\Desktop\박은규
# REQUIRED_HOTSPOT=iPhone
# CHEMSTATION_MODE=gc1
# GC1_REDUCTION_H2_AREA=20000
# GC1_REDUCTION_H2_TOL=0.35
# GC1_NOISE_AREA_MAX=100
# GC1_REACTION_CO_MIN=100
# AUTOCHRO_ENABLED=1
# AUTOCHRO_DATA_NAME=260616dre(3)ni-ce
# AUTOCHRO_WINDOW_TITLE_PATTERN=Autochro-3000
# AUTOCHRO_HANCOM_WAIT_SEC=180
# AUTOCHRO_AUTO_POSITION=1
# AUTOCHRO_WINDOW_X=40
# AUTOCHRO_WINDOW_Y=40
# AUTOCHRO_LIST_NEUTRAL_X_FRAC=0.78
# AUTOCHRO_PDF_FRESH_SEC=120
# GC1_PDF_READY_WAIT_SEC=90   # 한컴 창 닫힌 뒤 PDF 잠금 해제 대기(초). 저장 중 Acrobat 오류 시 120~180
# GC1_DROP_LAST_INCOMPLETE_CYCLE=1   # B 채널 전압선 길이로 마지막 주입 제거 여부 판단
# GC1_LAST_CYCLE_MIN_SCAN_MIN=18     # YL6500GC B 전압선이 이 시간(분) 미만이면 마지막 주입 제외
# GC1_HOTSPOT_RECONNECT_MIN_SEC=90   # watch: 이보다 짧은 끊김=순간 끊김(중복 없음), 길게 껐다 켜면 1회 더
# PDF 파일명: 제어목록 데이터명 자동 (예: 260616dre(3)ni-ce → 260616 dre@(3) ni-ce.pdf)

NAVER_EMAIL=kimcha0809@naver.com
NAVER_APP_PASSWORD=your_naver_app_password_here
MAIL_TO=kimcha0809@naver.com

# GC2/GC3 핫스팟 (기본값 — gc_config.py)
# REQUIRED_HOTSPOT=AndroidHotspot5841

# GC3 (Chem32) — Cursor 없을 때 시료명 (선택, 없으면 시료 폴더명에서 날짜 제거)
# SAMPLE_NAME=DRME 600C Ni0.1g8g_Ni5_Ce5

# GC3: chem32 / GC2: 8860 / auto (기본)
# CHEMSTATION_MODE=chem32

# force 실행 보호 (선택 — 설정 시 bat 또는 --force-token 필요)
# GC_FORCE_TOKEN=your_random_secret_here

# 오류 자동 복구 (watch error → 로그 → 재시작 → Cursor SDK)
# CURSOR_API_KEY=your_cursor_api_key
# GC_ERROR_HANDLER_ENABLED=1
# GC_ERROR_RESTART=1
# GC_ERROR_CURSOR=1
# GC_ERROR_RECOVERY_COOLDOWN_SEC=300
# GC_ERROR_CURSOR_COOLDOWN_SEC=1800
# GC_ERROR_CURSOR_MAX_PER_DAY=8
# GC_ERROR_STALE_HEARTBEAT_SEC=180
# GC_ERROR_CURSOR_MODEL=composer-2.5
# 5분 poll 등록: gc_install_error_poll.bat (1회)

# RSI screener (같은 env 파일에 추가 가능)
# SCREENER_FORCE_TOKEN=your_random_secret_here
# SCREENER_LLM_DAILY_MAX=30
