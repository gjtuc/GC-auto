# 은규 PC 전용 — gc_automation.env
# 위치: Desktop\.cursor\gc_automation.env  (장비 PC의 박은규/KCH env 와 **다른 파일**)
# 역할: IMAP 수신 계정. 장비 PC가 보낸 KCH 원본 메일을 **은규 PC**에서 읽음.
# 차헌 PC용은 동일 형식이나 계정·CALIB는 deploy/machine_profile.reference.chaheon.json 참고.
# PC 명칭: docs/PC_NAMING.md
#
# 이 파일을 복사하여 gc_automation.env 로 저장한 뒤 값을 채우세요.
NAVER_EMAIL=은규_네이버메일@naver.com
NAVER_APP_PASSWORD=16자리_앱비밀번호
MAIL_TO=은규_네이버메일@naver.com

# 은규 PC 핫스팟 감시 (--watch) — GC1과 동일 iPhone SSID
# 차헌 PC: deploy/gc_automation.env.chaheon.example (iptime 3종) 참고
REQUIRED_HOTSPOT=iPhone
# DATA_PC_AUTO_MAIL_COOLDOWN_HOURS=1
DATA_PC_AUTO_MAIL_COOLDOWN_HOURS=1
DATA_PC_WATCH_INTERVAL_SEC=15
# 순간 끊김 재연결 허용(초) — GC1 gc_watch 와 동일
DATA_PC_HOTSPOT_RECONNECT_MIN_SEC=90
# 테스트용: 1 이면 SSID 검사 생략
# DATA_PC_SKIP_WIFI_CHECK=0
# PC 꺼진 동안 도착한 메일 - 로그인 직후 1회 자동 처리 (1=켜기)
DATA_PC_BOOT_MAIL_CHECK=1
DATA_PC_BOOT_NETWORK_WAIT_SEC=90
# watchdog heartbeat 멈춤 판정(초)
DATA_PC_WATCH_HEARTBEAT_STALE_SEC=180
