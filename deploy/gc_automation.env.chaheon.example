# 차헌 PC — Desktop\.cursor\gc_automation.env 템플릿
# 은규 PC용: data_pc\gc_automation.env.example (REQUIRED_HOTSPOT=iPhone) — 혼동 금지
# PC 명칭: docs/PC_NAMING.md · deploy/machine_profile.reference.chaheon.json
# 자동 감시 가이드: deploy/DATA_PC_WATCH.md

NAVER_EMAIL=kimcha0809@naver.com
NAVER_APP_PASSWORD=16자리_앱비밀번호
MAIL_TO=kimcha0809@naver.com

# --- G: 감시 (--watch) — 데이터 PC는 Wi-Fi 게이트 비활성 ---
DATA_PC_SKIP_WIFI_CHECK=1
# REQUIRED_HOTSPOT=iptime,iptime 2,iptime_5G
# 부팅 시 iptime 자동 연결 — 데이터 PC 스케줄러에서 비활성 권장
IPTIME_WIFI_PSK=12121212

# --- --watch 자동 감시 (촉매 반응 계산.py --watch) ---
# 정상 완료·메일 없음: 1시간에 최대 1회 (GC2/GC3 AUTO_MAIL_COOLDOWN 과 동일)
DATA_PC_AUTO_MAIL_COOLDOWN_HOURS=1
# G: 잠금(SecuYouSB 미로그인): 15분 재시도 — 1시간 쿨다운 미적용
DATA_PC_GDRIVE_RETRY_SEC=900
# G: 접근 가능 시 폴링 간격(초)
DATA_PC_WATCH_INTERVAL_SEC=15
# 순간 Wi-Fi 끊김(초) — 동일 세션으로 처리
DATA_PC_HOTSPOT_RECONNECT_MIN_SEC=90
# 로그인 직후 PC 꺼진 동안 온 메일 1회 처리 (1=켜기)
DATA_PC_BOOT_MAIL_CHECK=1
DATA_PC_BOOT_NETWORK_WAIT_SEC=90
# watchdog heartbeat 멈춤 판정(초) — data_pc_watchdog.log 참고
DATA_PC_WATCH_HEARTBEAT_STALE_SEC=180

# 로그 위치 (pythonw 실행 시 파일로만 기록):
#   %USERPROFILE%\.cursor\gc-runtime-temp\data_pc_watch.log
#   %USERPROFILE%\.cursor\gc-runtime-temp\data_pc_watchdog.log

# --- P층 origin pipeline (P14–P16) ---
# JobRunner/Supervisor/--watch → live_imap (P층 경로)
DATA_PC_ORIGIN_PIPELINE=1
# DATA_PC_LEGACY_WATCH=1   # 긴급: 구 data_pc_watch 루프
# DATA_PC_SKIP_ORIGIN=0    # Origin COM full E2E
# DATA_PC_E2E_LIVE=1       # live_production_e2e --live 허용
