# 차헌 PC — Desktop\.cursor\gc_automation.env 템플릿
# 은규 PC용: data_pc\gc_automation.env.example (REQUIRED_HOTSPOT=iPhone) — 혼동 금지
# PC 명칭: docs/PC_NAMING.md · deploy/machine_profile.reference.chaheon.json

NAVER_EMAIL=kimcha0809@naver.com
NAVER_APP_PASSWORD=16자리_앱비밀번호
MAIL_TO=kimcha0809@naver.com

# Wi-Fi 게이트 — GC2/GC3 장비 PC와 동일 (구 AndroidHotspot5841)
REQUIRED_HOTSPOT=iptime,iptime 2,iptime_5G

# --watch 사용 시 (차헌 PC — GC2/GC3 장비와 동일 1시간 쿨다운)
DATA_PC_AUTO_MAIL_COOLDOWN_HOURS=1
DATA_PC_WATCH_INTERVAL_SEC=15
DATA_PC_HOTSPOT_RECONNECT_MIN_SEC=90
DATA_PC_BOOT_MAIL_CHECK=1
DATA_PC_BOOT_NETWORK_WAIT_SEC=90
