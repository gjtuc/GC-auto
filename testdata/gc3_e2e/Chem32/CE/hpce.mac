name Maintenance
    local mod$
    
    IF DEVHPCE <> 0 THEN
        mod$="HPCE"
    ELSE
    IF DEVHPCS <> 0 THEN
        mod$="HPCS"
    ENDIF
    ENDIF
    dum$ = SendModule$(mod$, "park 1")
endmacro

name hpib
    parameter  parm$

    local mod$
    
    IF DEVHPCE <> 0 THEN
        mod$="HPCE"
    ELSE
    IF DEVHPCS <> 0 THEN
        mod$="HPCS"
    ENDIF
    ENDIF
    print SendModule$(mod$, parm$)
endmacro


name SCRT
    parameter parms$, show default 0
    local     cmd$, reply$
    local mod$
    
    IF DEVHPCE <> 0 THEN
        mod$="HPCE"
    ELSE
    IF DEVHPCS <> 0 THEN
        mod$="HPCS"
    ENDIF
    ENDIF

    if len(parms$) = 0
       !----------------------------
       ! no parameters were supplied
       !----------------------------
       print "missing parameters"
       return
    else
       cmd$ = "scrt "+parms$
       reply$ = SendModule$(mod$, cmd$)
       if show = 0 then
          ;  ! no reply printing
       else
          print reply$
       endif
    endif
endmacro

name gray
    local reply$
    local mod$
    
    IF DEVHPCE <> 0 THEN
        mod$="HPCE"
    ELSE
    IF DEVHPCS <> 0 THEN
        mod$="HPCS"
    ENDIF
    ENDIF

    reply$ = SendModule$(mod$,"ndkt:rset;ndkt 0")
endmacro

!*********************************************
!  special production test commands
!*********************************************
name INDEX
    parameter parms$
    local     cmd$

    if len(parms$) = 0
       !----------------------------
       ! no parameters were supplied
       !----------------------------
       print "missing parameters"
       return
    else
       cmd$ = "scrt -313,"+parms$+",0"
       hpib cmd$
    endif
endmacro


name SysReset
    IF DEVHPCE <> 0 THEN
        dum$=SendModule$("HPCE","stop")
    ENDIF
    IF DEVHPCS <> 0 THEN
        dum$=SendModule$("HPCS","cler")
    ENDIF
    IF DEV1050DAD <> 0 THEN
        dum$=SendModule$("DAD", "stop")
    ENDIF
endmacro

name SysInit
    local  reply$
    local mod$
    
    IF DEVHPCE <> 0 THEN
        mod$="HPCE"
    ELSE
    IF DEVHPCS <> 0 THEN
        mod$="HPCS"
    ENDIF
    ENDIF

    IF devHPCE <> 0 OR devHPCS<>0 THEN
        firmware
        reply$ = SendModule$(mod$,"rset")
    ENDIF
    IF DEV1050DAD <> 0 THEN
        reply$ = SendModule$("DAD","lcur 0")
        reply$ = SendModule$("DAD","lamp 1")
        reply$ = SendModule$("DAD","prep")
    ENDIF
endmacro

!******************************************************************************
!   NAME
!       Init_HPCE
!
!   DESCRIPTION
!       Called once upon startup of ChemStation.
!       
!   RETURN
!       None
!******************************************************************************
name Init_HPCE
  LOCAL r

  SetHook "AcqRes", "HpceAcqResHook"
  SetHook "RepPreEnd", "HpcePostReportHook"

  !*** load additional macros.. ***
  if _offline =  0
    ! load only if online copy
    macro _ProductPath$+"firmware.mac"
  endif
  macro _ProductPath$+"cequant.mac"

  SetHook "PInstrCondition","PInstrConditionCE"
  
  !=========< vial table support >=========
ON ERROR GOTO RECOVER_1

  If Check(Variable, DevRCCE)=0 Then
     DevRCCE = 0
  EndIf

  IF DevRCCE = 0 AND _OFFLINE = 0 THEN
      LoadObj  _INSTPATH$ + "vialtbl.reg",,VIALTABLE
      EVALUATE "r=RegSize("+"VIALTABLE"+")"
      IF r>1 THEN
        EVALUATE "DelObj "+"VIALTABLE"+"[1]"
      ENDIF
      vtNotifyVialTableChanges
  ENDIF
ON ERROR;GOTO TRYEND_1;RECOVER_1:;ON ERROR
  
TRYEND_1:

  IF RegSize(VIALTABLE)>0 THEN
    IF ObjHdrType (VIALTABLE, "VialTable")=4 THEN
       
       IF TabHdrType (VIALTABLE, "VialTable", "vtwarnings") = 99 then
          _VTWARNINGS = 0
       ELSE
          _VTWARNINGS = TabHdrVal (VIALTABLE, "VialTable", "vtwarnings")
       ENDIF
       IF TabHdrType (VIALTABLE, "VialTable", "vtsymbolic") = 99 then
          _VTSYMBOLIC = 0
       ELSE
          _VTSYMBOLIC = TabHdrVal (VIALTABLE, "VialTable", "vtsymbolic")
       ENDIF
    ENDIF

    macro _ProductPath$+"hpvtbl.mac"
    SetHook "LoadMethodCheck", "vtLoadVialTable"
    SetHook "SaveMethod", "vtSaveVialTable"
    SetHook "LoadMethod", "vtCopyMethVT"
    SetHook "PrintInstMethod", "vtPrintVtblMethodPart"
    SetHook "CloseApp","vtCloseApp"
    vtInitSequenceChanged
  ENDIF

  ! --- generate dummy macro for HPCEMode-call ------
  if Check(Function, HPCEMode$) <> 1 then
	CPRequest CP2, "name HPCEMode$; parameter mode$; return _HPCEMode$(); endmacro"
  endif

  ! --- load fraction collection macros ------
  Macro _ProductPath$+"fractop.mac"

  ! --- load CE-specific calibration macros ------
  IF FileStat (MODE, _ProductPath$ + "MTCALIB.MCX") = 1
    Print "Loading " + _ProductPath$ + "MTCALIB.MCX"
    Macro _ProductPath$ + "MTCALIB.MCX" , GO
  ENDIF

  if TabHdrType (_Config[1], "MenusForViews", "FirstAdaptDone") = 99 then
    ! ensure that the menus come up as Full Menus
    SetTabHdrText _Config[1], "MenusForViews", "MenuCol", "FullMenuFile"

    ! Create flag to prevent unnecessary adaption at next bootup
    NewTabHdrVal _Config[1], "MenusForViews", "FirstAdaptDone", 1
  endif

  ! Initialize file name of the ce macro resource dialog dll
  NLSCeMacDLL$ = _ProductPath$ + "language\astxmac." + _Lang$
  if FileStat (Mode, NLSCeMacDLL$) = -1 then
    NLSCeMacDLL$ = _ProductPath$ + "language\astxmac.enu" ! PVCS # 13451
  endif

endmacro
