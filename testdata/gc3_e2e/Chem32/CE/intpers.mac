! and and make instrument specific modifications for each detector
! Store the modified tables as constant tables into _Config[2]
!############################################################################
local DetectorClass$, ToTable$

!_____________________________________________________________
 
! Diode array detector
 DetectorClass$="DAD"
 
 ToTable$="IntDetect_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0
 
! Modifications start here...

 endif
!_____________________________________________________________
 
! Analogue to digital converter
 DetectorClass$="ADC"
 
 ToTable$="IntDetect_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...

 endif
!_____________________________________________________________
 
! Fluoresence detector
 DetectorClass$="FLD"
 
 ToTable$="IntDetect_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...

 endif
!_____________________________________________________________
 
! Mass spectrometric detector
if _MassSpec>0
  DetectorClass$="MSD"
 
  ToTable$="IntDetect_"+DetectorClass$
  if CopyPersTab(FromTable$,ToTable$)<>0

 ! Modifications start here...

  endif
endif
!_____________________________________________________________
 
! Variable wavelength detector
 DetectorClass$="VWD"

 ToTable$="IntDetect_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...

 endif
!_____________________________________________________________
 
! Electron capture detector
 DetectorClass$="ECD"

 ToTable$="IntDetect_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...

 endif
!_____________________________________________________________

! Multiple wavelength detector
 DetectorClass$="MWD"

 ToTable$="IntDetect_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...

 endif
!_____________________________________________________________

endmacro


!############################################################################
name MakePersonalitiesForMethods

 Parameter FromTable$ default "IntMethodTemp"

! make instrument specific modifications to the template of the
! integration method table (intmethod)
!############################################################################
local ToTable$

if _MassSpec > 0
! Special IntMth table for Mass Spectra
  if ObjHdrType(_Config[2],FromTable$)=4
    ToTable$="IntMth6MSD"
    if CopyPersTab(FromTable$,ToTable$)<>0
    ! Modifications start here...
       SetTabHdrVal _config[2],ToTable$,"PeakTopType",0  ! use biggest
       SetTabHdrVal _config[2],ToTable$, "DecimalDigits", 1
    endif
  endif
endif

 ToTable$="IntMethod"
 if ObjHdrType(_Config[2],ToTable$)<>4
  RenTab _Config[2],FromTable$,ToTable$
 
! Modifications start here...

 endif
!_____________________________________________________________

endmacro


!############################################################################
name MakeIntegratorPersonalities

!############################################################################

 MakePersonalitiesForEvents
 MakePersonalitiesForDetectors
 MakePersonalitiesForMethods
 
endmacro
