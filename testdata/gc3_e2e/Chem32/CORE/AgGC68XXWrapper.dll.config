        <!-- ***                      "Error"                         *** -->
        <!-- ***                      "Critical"                      *** -->
        <!-- ***                      "Off"                           *** -->
        <!-- ************************************************************ -->
        <add name="RC68XXSourceSwitch" value="Off" />
        <add name="RCSignalBufferSourceSwitch" value="Off" />
      </switches>
      <trace autoflush="true" indentsize="4"></trace>
    </system.diagnostics>  
