    <system.diagnostics>
      <sources>
        <source name="RC68XX" switchName="RC68XXSourceSwitch" switchType="System.Diagnostics.SourceSwitch" >
          <listeners>
            <add name="FileOutput" type="System.Diagnostics.TextWriterTraceListener" initializeData="AgtTrace.GC68XXWrapper.CSMain.txt" />
            <add name="ConsoleOutput" type="System.Diagnostics.ConsoleTraceListener" initializeData="false" />
            <remove name="Default"  />
          </listeners>
        </source>
        <source name="RCSignalBuffer" switchName="RCSignalBufferSourceSwitch" switchType="System.Diagnostics.SourceSwitch" >
          <listeners>
            <add name="FileOutput" type="System.Diagnostics.TextWriterTraceListener" initializeData="AgtTrace.RCSignalBuffer.CSMain.txt" />
            <add name="ConsoleOutput" type="System.Diagnostics.ConsoleTraceListener" initializeData="false" />
            <remove name="Default"  />
          </listeners>
        </source>
      </sources>
      <switches>
        <!-- ************************************************************ -->
        <!-- *** You can set the level at which tracing is to occur!  *** -->
