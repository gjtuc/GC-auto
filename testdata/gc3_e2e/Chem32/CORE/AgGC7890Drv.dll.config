<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <system.diagnostics>
        <sources>
            <source name="GC7890SubscriptionChannel" switchValue="Debug" />
            <source name="GC7890DataHandler" switchValue="Debug" />
            <source name="GC7890Controller" switchValue="Debug" />
            <source name="GC7890Signal" switchValue="Debug" />
            <source name="IPHlpApi" switchValue="Debug" />
            <source name="GC7890NotificationThreadHost" switchValue="Debug" />
        </sources>
    </system.diagnostics>

    <appSettings>
        <!-- Setting to non-zero causes RTP to track events by re-subscribing at start and end of run. Value = 1 (start only) or 2. -->
        <add key="RtpShowsEvents" value="0"/>

        <!-- Setting AlwaysUpdateMethodSettings to false updates MethodUI only if new Method is different from current Method, true updates always -->
        <add key="AlwaysUpdateMethodSettings" value="false" />

        <!-- Setting AnnounceCTors to true causes message boxes announcing the process id of the creation of 
             RCProcessIF, RCMethodUI, RCConfigIF, RCConfigUI, and GCController objects.
             This is useful for attaching debug sessions. -->
        <add key="AnnounceCTors" value="false"/>

    </appSettings>
</configuration>
