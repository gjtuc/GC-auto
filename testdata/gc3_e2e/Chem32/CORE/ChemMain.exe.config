<?xml version="1.0" encoding="utf-8" ?>
<!--
app.config for Agilent ChemStation.
-->
<configuration>
  <configSections>
    <section name="Compliance" type="Agilent.ChemStation.Ecm.ComplianceConfig.ComplianceSection, Agilent.ChemStation.Ecm.ComplianceConfig" />  
  </configSections> 
  
  <appSettings>
    <add key="UseRemoting" value="1" />
    <add key="remotePortBase" value="0" />
  </appSettings>
  
  <!--
  System.Diagnostics config section.
  This section should not be edited except the configSource attribute. All necessary
  changes should be made in the related configSource file. You can create a new
  profile by copying an existing TraceProfile and change it accordingly.
  -->
  <system.diagnostics configSource="Configuration\system.diagnostics\TraceProfile.Default.config"/>
  
  <!--
  Compliance config section.
  This section is used if CS works in a connected mode with a backend system (Ecm).
  If so, the section gets encrypted if written by the EcmAdmin UI.
  -->
  <Compliance mandatorylogin="true" breaksessionlock="false" UseAdminSettings="true"
    TransferOnAcquisition="false" TransferOnReprocessing="false"
    TransferOnReprocessingIncludeNonAttached="false" TransferOnDataChange="false"
    CalculateOnTransfer="false" ManageTransferQueueOnConnect="false" ManageDataCleanupOnShutDown="false"
    MethodAuditTrail="false" ResultsAuditTrail="false" 
    ToolbarSessionLockPrivate="false" TimebasedSessionLockPrivate="false" EnterDisconnectedMode="false" />
  
  <runtime>
    <!--
    Runtime config section.
    %CSHOME%/CORE/Plugins is used to load optional plugins by plugin manager.
    -->
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
         <probing privatePath="Plugins"/>
      </assemblyBinding>
    
    <!-- 
    Temporary: Uncomment the next section if you want to use EcmApi 1.0.22.0
    with current ChemStation integrations.
    -->
    <!--
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="ECMAPI"
                          publicKeyToken="7227b784c4b10c46"
                          culture="Neutral" />
        <bindingRedirect oldVersion="1.0.18.0"
                         newVersion="1.0.22.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="ECMInterfaceRDS"
                          publicKeyToken="0f08eccc3191c66d"
                          culture="Neutral" />
        <bindingRedirect oldVersion="1.0.18.0"
                         newVersion="1.0.22.0"/>
      </dependentAssembly>
    </assemblyBinding>
    -->
    
    <!--
    See http://msdn.microsoft.com/en-us/library/bb629393.aspx. This is to improve
    startup performance. Mainly introduced due to Infragistics controls issues.
    -->
    <generatePublisherEvidence enabled="false"/>
  </runtime>
</configuration>