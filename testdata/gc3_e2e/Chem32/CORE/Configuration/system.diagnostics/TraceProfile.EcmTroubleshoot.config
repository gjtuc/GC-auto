<?xml version="1.0" encoding="utf-8" ?>
<!-- This system profile should deliver error information for all spaces, all information for Ecm related spaces. -->
<system.diagnostics>
  <sharedListeners>
    <add type="Agilent.ChemStation.Diagnostics.SessionContextXmlWriterTraceListener, Agilent.ChemStation.Diagnostics"
      name="ErrorListener"
      traceOutputOptions="DateTime, Timestamp, ProcessId, ThreadId, Callstack"
      initializeData="%_INSTPATH$%\TEMP\errors_%SessionRole%.svclog"
      RollSizeKB= "10000"
      RollFileExistsBehavior="Increment"
      TimestampPattern = "yyyy-MM-dd"
      MaximumArchiveFiles= "2">
      <filter type="System.Diagnostics.EventTypeFilter, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
        initializeData="Error" />
    </add>
    <add type="Agilent.ChemStation.Diagnostics.SessionContextXmlWriterTraceListener, Agilent.ChemStation.Diagnostics"
      name="AllListener"
      traceOutputOptions="DateTime, Timestamp, ProcessId, ThreadId"
      initializeData="%_INSTPATH$%\TEMP\all_%SessionRole%.svclog"
      RollSizeKB= "10000"
      RollFileExistsBehavior="Increment"
      TimestampPattern = "yyyy-MM-dd"
      MaximumArchiveFiles= "2">
      <filter type="System.Diagnostics.EventTypeFilter, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
        initializeData="Information" />
    </add>
    <add type="Agilent.ChemStation.Diagnostics.SessionContextXmlWriterTraceListener, Agilent.ChemStation.Diagnostics"
      name="SystemStateListener"
      traceOutputOptions="DateTime, Timestamp, ProcessId"
      initializeData="%_INSTPATH$%\TEMP\SystemState_%SessionRole%.svclog"
      RollSizeKB= "1000"
      RollFileExistsBehavior="Increment"
      TimestampPattern = "yyyy-MM-dd"
      MaximumArchiveFiles= "1">
      <filter type="System.Diagnostics.EventTypeFilter, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
        initializeData="All" />
    </add>
    <add type="Agilent.Diagnostics.InMemoryTraceListener, Agilent.Diagnostics"
         name="InMemoryListener">
      <filter type="Agilent.Diagnostics.RuntimeTraceFilter, Agilent.Diagnostics"/>
    </add>
  </sharedListeners>
  <trace autoflush="true">
    <listeners>
      <clear />
      <add name="ErrorListener"/>
    </listeners>
  </trace>
  <sources>
    <!--
    This source is for gathering SystemState information.
  -->
    <source name="Agilent.SystemState" switchValue="All">
      <listeners>
        <clear/>
        <add name="SystemStateListener"/>
      </listeners>
    </source>

    <!-- 
    The following sources are used by the CS shell.
    -->
    <source name="Shell" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="ViewManagerHoster" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="LogbookUI" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="IReport" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>

    <!--
    ChemStation Classic Components.
    The CP source is used by CPForwarder and CPTraceSource currently.
    The HPCore source is used by the HpCore .NET class. InteropServices are
    sources that provide CP functions.
    -->
    <source name="CP" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="HPCore" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="InteropServices"
            switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>

    <!-- 
    The following source names are used by RC.NET Adapter    
    -->
    <source name="AgtChemRCNetAdapter.RapidControlIF" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="AgtChemRCNetAdapter.RapidControlAdapter" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="AgtChemRCNetAdapter.ChemStationGenericControlIF" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>

    <!--
    The following source names are used by Agilent.Ecm.Services and ...
    -->
    <source name="Agilent.Openlab" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
        <add name="AllListener"/>
      </listeners>
    </source>
    <source name="Agilent.ChemStation.Facades" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
        <add name="AllListener"/>
      </listeners>
    </source>
    <source name="Agilent.ClientServices" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
        <add name="AllListener"/>
      </listeners>
    </source>
    <source name="VCS_INTEGRATION" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
        <add name="AllListener"/>
      </listeners>
    </source>
    
    <!-- Sources used in the AutomationEngine Adapter -->
    <source name="AE-Adapter"
            switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    <source name="AEPlugin"
            switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
    
    <!-- Import/Export/Migration components -->
    <source name="Acaml" switchValue="All">
      <listeners>
        <clear/>
        <add name="ErrorListener"/>
      </listeners>
    </source>
  </sources>
</system.diagnostics>