<?xml version="1.0" encoding="utf-8" ?>
<system.diagnostics>
  <!-- an (almost) empty section just to fulfill the link from app.config:configsource -->
  <sharedListeners>
    <add type="Agilent.ChemStation.Diagnostics.SessionContextXmlWriterTraceListener, Agilent.ChemStation.Diagnostics"
      name="SystemStateListener"
      traceOutputOptions="DateTime, Timestamp, ProcessId"
      initializeData="%_INSTPATH$%\TEMP\SystemState_%SessionRole%.svclog"
      RollSizeKB= "1000"
      RollFileExistsBehavior="Increment"
      TimestampPattern = "yyyy-MM-dd"
      MaximumArchiveFiles= "1">
      <filter type="System.Diagnostics.EventTypeFilter, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
        initializeData="All" />
    </add>
  </sharedListeners>
  <trace autoflush="true">
    <listeners>
      <clear/>
    </listeners>
  </trace>
  <sources>
    <!--
    This source is for gathering SystemState information.
  -->
    <source name="Agilent.SystemState" switchValue="All">
      <listeners>
        <clear/>
        <add name="SystemStateListener"/>
      </listeners>
    </source>
  </sources>
</system.diagnostics>
