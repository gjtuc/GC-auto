<configuration>
  <configSections>
    <section name="loggingConfiguration" type="Microsoft.Practices.EnterpriseLibrary.Logging.Configuration.LoggingSettings, Microsoft.Practices.EnterpriseLibrary.Logging, Version=3.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
    <section name="dataConfiguration" type="Microsoft.Practices.EnterpriseLibrary.Data.Configuration.DatabaseSettings, Microsoft.Practices.EnterpriseLibrary.Data, Version=3.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
  </configSections>
  <loggingConfiguration name="Logging Application Block" tracingEnabled="true"
    defaultCategory="" logWarningsWhenNoCategoriesMatch="true">
    <listeners>
      <add filesToKeep="20" fileName="rcdriver.trc" rollSizeKB="10000"
        timeStampPattern="yyyy-MM-dd HH.mm.ss" rollFileExistsBehavior="Overwrite"
        rollInterval="None" formatter="Text Formatter" header="" footer=""
        listenerDataType="Agilent.ChemStation.Util.InstrumentLogging.Configuration.RollingFlatFileTraceListenerData, Agilent.ChemStation.Util.InstrumentLogging, Version=0.0.1.2, Culture=neutral, PublicKeyToken=null"
        traceOutputOptions="None" type="Agilent.ChemStation.Util.InstrumentLogging.RollingFlatFileTraceListener, Agilent.ChemStation.Util.InstrumentLogging, Version=0.0.1.2, Culture=neutral, PublicKeyToken=null"
        name="ChemStation Instrument Rolling Flat File Trace Listener" />
    </listeners>
    <formatters>
      <add template="EventId: {eventid};Timestamp: {timestamp(local:dd/MM/yyyy hh:mm:ss.fff)};Thread Id: {win32ThreadId};Message: {message};Category: {category};Priority: {priority};Process Name: {processName};Extended Properties: {dictionary({key} - {value};)}"
        type="Microsoft.Practices.EnterpriseLibrary.Logging.Formatters.TextFormatter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=3.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a"
        name="Text Formatter" />
    </formatters>
    <logFilters>
      <add categoryFilterMode="AllowAllExceptDenied" type="Microsoft.Practices.EnterpriseLibrary.Logging.Filters.CategoryFilter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=3.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a"
        name="Category Filter">
        <categoryFilters>
          <add name="Data" />
          <add name="StatusUI" />
          <add name="Control" />
          <add name="Capture" />
          <add name="Appdata" />
          <add name="Rawdata" />
          <add name="UIControl_MoveChild" />
          <add name="UIControl_VisibleChangedChild" />
          <add name="UIControl_ResizeChild" />
          <add name="UIControl_TextChangedChild" />
          <add name="UIControl_NumericEditorValueChanged" />
          <add name="UIControl_Enter" />
          <add name="UIControl_MouseClick" />
          <add name="UIControl_Leave" />
          <add name="UIControl_Key" />
          <add name="UIControl_VisibleChanged" />
          <add name="UIControl_Resize" />
          <add name="UIControl_EnterChild" />
          <add name="UIControl_LeaveChild" />
          <add name="UIControl_GridRowInit" />
          <add name="UIControl_GridCellSelect" />
          <add name="UIControl_TextEditorValueChanged" />
          <add name="UIControl_CheckedChanged" />
          <add name="UIControls_Validated" />
          <add name="Trigger" />
          <add name="PumpTimeTable" />
        </categoryFilters>
      </add>
      <add minimumPriority="3" maximumPriority="5" type="Microsoft.Practices.EnterpriseLibrary.Logging.Filters.PriorityFilter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=3.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a"
        name="Priority Filter" />
    </logFilters>
    <specialSources>
      <allEvents switchValue="All" name="All Events">
        <listeners>
          <add name="ChemStation Instrument Rolling Flat File Trace Listener" />
        </listeners>
      </allEvents>
      <notProcessed switchValue="All" name="Unprocessed Category" />
      <errors switchValue="All" name="Logging Errors &amp; Warnings" />
    </specialSources>
  </loggingConfiguration>
</configuration>