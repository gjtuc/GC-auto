<?xml version="1.0" encoding="UTF-8"?>
<graphical_object>
	<toolbar Name="NavtableSeq" PosStyle="Top" DockRow="0" DockCol="1" Caption="ナビゲーション" PanelName="NavTable">
		<PushButton Name="SequenceTable" Help="シーケンス テーブルを編集します" Command="EdSequenceTable" ImageName="Seq_SeqTable20" ImageNameDisabled="Seq_SeqTable20_d"/>
		<PushButton Name="SequenceParameters" Help="シーケンス パラメータを編集します" Command="EdSequenceParms" ImageName="Seq_Paramter20" ImageNameDisabled="Seq_Paramter20_d"/>
		<PushButton Name="SaveSequence" Help="現在のシーケンスを保存します" Command="SaveCurrentSequence" ImageName="Save_sequence20" ImageNameDisabled="Save_sequence20_d"/>
		<PushButton Name="PrintSequence" Help="現在のシーケンスを印刷します" Command="PrintSequence" ImageName="Print20" ImageNameDisabled="Print20_d"/>
		<PushButton Name="SeqLogBook" Help="Show Sequence Logbook" Command="SeqX_OpenLogbook " ImageName="Sequence_logbook20" ImageNameDisabled="Sequence_logbook20_d"/>
