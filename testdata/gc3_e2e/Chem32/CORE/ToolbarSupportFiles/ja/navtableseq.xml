		<PushButton Name="StopSequence" Help="シーケンス停止" CpName="Cp3" Command="StopSequence_Wrap" ImageName="Seq_Stop20" ImageNameDisabled="Seq_Stop20_d" Enable="0"/>
		<StickyButton Name="PauseSequence" Help="シーケンス一時停止/再開" CpName="Cp3" CmdList="ResumePausedSequence_Wrap|PauseSequence_Wrap" ImageName="Seq_Pause20" ImageNameDisabled="Seq_Pause20_d" Enable="0"/>
		<StatusList Name="SysStatus" Help="ChemStation 再解析ステータス表示" NewGroup="1" Enable="1" Width="280" Font="Microsoft Sans Serif, 8, Bold" Border="NoBorder" Justify="Center" Height="20" BkColor="LightGreen" Text="レディ" UseElements="0|0|0|1|1|1" Alias="SysGreen=LightGreen|SysBlue=LightSteelBlue|SysRed=LightSalmon|SysYellow=LightYellow|SysMagenta=Orchid|SysCyan=Aquamarine|SysWhite=GhostWhite|MthGreen=LawnGreen|MthBlue=RoyalBlue|MthRed=Red|MthYellow=Yellow|MthMagenta=Magenta|MthCyan=Cyan|MthWhite=White" Separator="/" Symbols="SysGreen|SysBlue|SysRed|SysYellow|SysMagenta|SysCyan|SysWhite|MthGreen|MthBlue|MthRed|MthYellow|MthMagenta|MthCyan|MthWhite|" Elements="1|1|SysGreen|Ready|MthGreen|"/>
		<PushButton Name="NavTabClear" Help="Clear navigation table" NewGroup="1" Command="dummy=ResetDataContext()" ImageName="NavTable_Clear20" ImageNameDisabled="NavTable_Clear20_d"/>
		<PushButton Name="Help" Help="ナビゲーションテーブル ヘルプ" NewGroup="1" Command="NavTab_CallHelp" ImageName="Help20" ImageNameDisabled="Help20_d"/>
	</toolbar>
