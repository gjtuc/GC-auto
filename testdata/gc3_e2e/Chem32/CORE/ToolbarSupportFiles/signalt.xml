<?xml version="1.0" encoding="UTF-8"?>
<graphical_object>
	<toolbar Name="SignalT" PosStyle="TOP" DockRow="1" DockCol="1" Caption="Signal Cursor Toolbar" PanelName="Chem">
		<NonEditCombobox Name="Signal" Help="Signal(s) Displayed" NewGroup="1" Enable="1" DefCommand="TLB_DrawSignals " DefCmdParNumber="1" Width="200"/>
		<StickyButton Name="AnnotOnOff" Help="Display the Graphics Toolbar" CmdList="ANN_CloseTask|ANN_InitTask" Group="0" ImageName="Toggle_Graphic_Toolbar20" ImageNameDisabled="Toggle_Graphic_Toolbar20_d"/>
		<RadioButton Name="ZoomInWindow" Help="Zoom in on Window" Command="TLB_SetToZoomInWindow" Group="1" NewGroup="1" ImageName="Zoomin20" ImageNameDisabled="Zoomin20_d"/>
		<PushButton Name="ZoomOutWindow" Help="Zoom out active Window" Command="TLB_ZoomOutWindow 38" ImageName="Zoomout20" ImageNameDisabled="Zoomout20_d"/>
		<RadioButton Name="NoSel" Help="Set to Selection mode" Command="SIG_SetSignalMenuSelection NoSel,1" Group="2" NewGroup="1" ImageName="Select20" ImageNameDisabled="Select20_d"/>
		<RadioButton Name="AddTime" Help="Set time reference points to Chromatogram" Command="SIG_SetSignalMenuSelection AddTime,1" Group="2" ImageName="Signal_SetRef20" ImageNameDisabled="Signal_SetRef20_d"/>
		<RadioButton Name="MoveTime" Help="Move time reference points to new position in Chromatogram" Command="SIG_SetSignalMenuSelection MoveTime,1" Group="2" ImageName="Signal_MoveRef20" ImageNameDisabled="Signal_MoveRef20_d"/>
		<RadioButton Name="DelTime" Help="Delete time reference points from Chromatogram" Command="SIG_SetSignalMenuSelection DelTime,1" Group="2" ImageName="Signal_DelRef20" ImageNameDisabled="Signal_DelRef20_d"/>
		<RadioButton Name="DelObject" Help="Delete object from Chromatogram display" Command="SIG_SetSignalMenuSelection DelObject,1" Group="2" ImageName="Signal_DelSignal20" ImageNameDisabled="Signal_DelSignal20_d"/>
		<RadioButton Name="Overlay" Help="Display Overlay of signals" Command="SIG_SetSignalOption Overlay,1" Group="3" NewGroup="1" ImageName="Graph_SignalsOverlay20" ImageNameDisabled="Graph_SignalsOverlay20_d"/>
		<RadioButton Name="Separate" Help="Display Separate signals" Command="SIG_SetSignalOption Overlay,0" Group="3" ImageName="Graph_SignalsSeparate20" ImageNameDisabled="Graph_SignalsSeparate20_d"/>
		<RadioButton Name="FullScale" Help="Display each in Full Scale" Command="SIG_SetSignalOption FullScale,1" Group="4" ImageName="Graph_FullScale20" ImageNameDisabled="Graph_FullScale20_d"/>
		<RadioButton Name="SameScale" Help="Display each in the same Scale" Command="SIG_SetSignalOption FullScale,0" Group="4" ImageName="Graph_SameScale20" ImageNameDisabled="Graph_SameScale20_d"/>
	</toolbar>
</graphical_object>
