<?xml version="1.0" encoding="UTF-8"?>
<graphical_object>
	<toolbar Name="SpecT" PosStyle="TOP" DockRow="2" DockCol="0" Caption="Purify Cursor Toolbar" PanelName="Chem">
		<NonEditCombobox Name="Signal" Help="Signal(s) Displayed" NewGroup="1" Enable="1" DefCommand="TLB_DrawSignals " DefCmdParNumber="1" Width="200"/>
		<StickyButton Name="AnnotOnOff" Help="Display the Graphics Toolbar" CmdList="ANN_CloseTask|ANN_InitTask" Group="0" ImageName="Toggle_Graphic_Toolbar20" ImageNameDisabled="Toggle_Graphic_Toolbar20_d"/>
		<RadioButton Name="ZoomInWindow" Help="Zoom in on Window" Command="TLB_SetToZoomInWindow" Group="1" NewGroup="1" ImageName="Zoomin20" ImageNameDisabled="Zoomin20_d"/>
		<PushButton Name="ZoomOutWindow" Help="Zoom out active Window" Command="TLB_ZoomOutWindow 38" ImageName="Zoomout20" ImageNameDisabled="Zoomout20_d"/>
		<RadioButton Name="NoSel" Help="Set to Selection mode" Command="SPC_SetSpecMenuSelection NoSel,1" Group="2" NewGroup="1" ImageName="Select20" ImageNameDisabled="Select20_d"/>
		<RadioButton Name="Spec" Help="Select spectrum at any time position" Command="SPC_SetSpecMenuSelection Spec,1" Group="2" ImageName="Spec_SelectSpectrum20" ImageNameDisabled="Spec_SelectSpectrum20_d"/>
		<RadioButton Name="ApexSpec" Help="Select spectrum at peak apex position" Command="SPC_SetSpecMenuSelection ApexSpec,1" Group="2" ImageName="Spec_SelectPeak20" ImageNameDisabled="Spec_SelectPeak20_d"/>
		<RadioButton Name="AvgSpec" Help="Average a Selected set of spectra" Command="SPC_SetSpecMenuSelection AvgSpec,1" Group="2" ImageName="Spec_Average20" ImageNameDisabled="Spec_Average20_d"/>
		<RadioButton Name="PeakSpec" Help="Select a set of spectra of a peak" Command="SPC_SetSpecMenuSelection PeakSpec,1" Group="2" ImageName="Spec_PeakSpectra20" ImageNameDisabled="Spec_PeakSpectra20_d"/>
		<RadioButton Name="PeakPurity" Help="Select Peak to display Purity" Command="SPC_SetSpecMenuSelection PeakPurity,1" Group="2" ImageName="Spec_PeakPurity20" ImageNameDisabled="Spec_PeakPurity20_d"/>
		<RadioButton Name="Ref1Spec" Help="Select spectrum to set as first Reference" Command="SPC_SetSpecMenuSelection Ref1Spec,1" Group="2" ImageName="Spec_FirstRef20" ImageNameDisabled="Spec_FirstRef20_d"/>
		<RadioButton Name="Ref2Spec" Help="Select spectrum to set as second Reference" Command="SPC_SetSpecMenuSelection Ref2Spec,1" Group="2" ImageName="Spec_SecondRef20" ImageNameDisabled="Spec_SecondRef20_d"/>
		<NonEditCombobox Name="ActualReference" Help="Select Spectrum Reference Option" Enable="1" Selection="1" TextList="No Reference|Manual Reference|Automatic Reference" DefCommand="SPC_SetRefSpec 1," DefCmdParNumber="1" Width="200"/>
		<NonEditCombobox Name="SpcRefSel" Help="Select Spectral Tool" Visible="0" Selection="1" Table="ToolBar,1,SPCRefSel" IsPath="0" Width="160"/>
		<NonEditCombobox Name="MSDRefSel" Help="Select Spectral Tool" Visible="0" Selection="1" Table="ToolBar,1,MSDRefSel" IsPath="0" Width="160"/>
		<RadioButton Name="ZoomInMS" Help="Zoom in on MS window" Command='MSD_SetIonSelection ""' NewGroup="1" Visible="0" ImageName="Spec_ZoominMS20" ImageNameDisabled="Spec_ZoominMS20_d"/>
		<RadioButton Name="ExtractIon" Help="Extract Ion Chromatogram" Command='MSD_SetIonSelection "SelectIon"' Visible="0" ImageName="Spec_ExtractIons20" ImageNameDisabled="Spec_ExtractIons20_d"/>
		<RadioButton Name="TurnOnMathCalc" Help="Turn on Calculation Toolbar" Command='MSD_SetIonSelection "Calculation"' Visible="0" ImageName="Spec_MathToolbar20" ImageNameDisabled="Spec_MathToolbar20_d"/>
	</toolbar>
</graphical_object>
