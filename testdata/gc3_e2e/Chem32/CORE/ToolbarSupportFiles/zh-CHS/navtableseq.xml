<?xml version="1.0" encoding="UTF-8"?>
<graphical_object>
	<toolbar Name="NavtableSeq" PosStyle="Top" DockRow="0" DockCol="1" Caption="导航" PanelName="NavTable">
		<PushButton Name="SequenceTable" Help="编辑序列表" Command="EdSequenceTable" ImageName="Seq_SeqTable20" ImageNameDisabled="Seq_SeqTable20_d"/>
		<PushButton Name="SequenceParameters" Help="编辑序列参数" Command="EdSequenceParms" ImageName="Seq_Paramter20" ImageNameDisabled="Seq_Paramter20_d"/>
		<PushButton Name="SaveSequence" Help="保存当前序列" Command="SaveCurrentSequence" ImageName="Save_sequence20" ImageNameDisabled="Save_sequence20_d"/>
		<PushButton Name="PrintSequence" Help="打印当前序列" Command="PrintSequence" ImageName="Print20" ImageNameDisabled="Print20_d"/>
		<PushButton Name="SeqLogBook" Help="Show Sequence Logbook" Command="SeqX_OpenLogbook " ImageName="Sequence_logbook20" ImageNameDisabled="Sequence_logbook20_d"/>
		<PushButton Name="ReportBrowser" Help="查看已保存的序列总结报告文件" CpName="Cp3" Command="RPTV_ViewReportNewUI SeqSumRptGrp" ImageName="Browse_Sequence_Report20" ImageNameDisabled="Browse_Sequence_Report20_d"/>
		<PushButton Name="ReprocessSequence" Help="开始序列重处理" Command="RunSequence" NewGroup="1" ImageName="Seq_Reprocess20" ImageNameDisabled="Seq_Reprocess20_d"/>
		<PushButton Name="StopSequence" Help="停止序列" CpName="Cp3" Command="StopSequence_Wrap" ImageName="Seq_Stop20" ImageNameDisabled="Seq_Stop20_d" Enable="0"/>
		<StickyButton Name="PauseSequence" Help="暂停/恢复序列" CpName="Cp3" CmdList="ResumePausedSequence_Wrap|PauseSequence_Wrap" ImageName="Seq_Pause20" ImageNameDisabled="Seq_Pause20_d" Enable="0"/>
		<StatusList Name="SysStatus" Help="显示 ChemStation 重处理状态" NewGroup="1" Enable="1" Width="280" Font="Microsoft Sans Serif, 8, Bold" Border="NoBorder" Justify="Center" Height="20" BkColor="LightGreen" Text="就绪" UseElements="0|0|0|1|1|1" Alias="SysGreen=LightGreen|SysBlue=LightSteelBlue|SysRed=LightSalmon|SysYellow=LightYellow|SysMagenta=Orchid|SysCyan=Aquamarine|SysWhite=GhostWhite|MthGreen=LawnGreen|MthBlue=RoyalBlue|MthRed=Red|MthYellow=Yellow|MthMagenta=Magenta|MthCyan=Cyan|MthWhite=White" Separator="/" Symbols="SysGreen|SysBlue|SysRed|SysYellow|SysMagenta|SysCyan|SysWhite|MthGreen|MthBlue|MthRed|MthYellow|MthMagenta|MthCyan|MthWhite|" Elements="1|1|SysGreen|Ready|MthGreen|"/>
		<PushButton Name="NavTabClear" Help="Clear navigation table" NewGroup="1" Command="dummy=ResetDataContext()" ImageName="NavTable_Clear20" ImageNameDisabled="NavTable_Clear20_d"/>
		<PushButton Name="Help" Help="导航表帮助" NewGroup="1" Command="NavTab_CallHelp" ImageName="Help20" ImageNameDisabled="Help20_d"/>
	</toolbar>
</graphical_object>
