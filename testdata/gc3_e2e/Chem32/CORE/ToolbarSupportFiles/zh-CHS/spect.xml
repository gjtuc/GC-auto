<?xml version="1.0" encoding="UTF-8"?>
<graphical_object>
	<toolbar Name="SpecT" PosStyle="TOP" DockRow="2" DockCol="0" Caption="纯化游标工具栏" PanelName="Chem">
		<NonEditCombobox Name="Signal" Help="信号显示" NewGroup="1" Enable="1" DefCommand="TLB_DrawSignals " DefCmdParNumber="1" Width="200"/>
		<StickyButton Name="AnnotOnOff" Help="显示图形工具栏" CmdList="ANN_CloseTask|ANN_InitTask" Group="0" ImageName="Toggle_Graphic_Toolbar20" ImageNameDisabled="Toggle_Graphic_Toolbar20_d"/>
		<RadioButton Name="ZoomInWindow" Help="放大窗口" Command="TLB_SetToZoomInWindow" Group="1" NewGroup="1" ImageName="Zoomin20" ImageNameDisabled="Zoomin20_d"/>
		<PushButton Name="ZoomOutWindow" Help="缩小活动窗口" Command="TLB_ZoomOutWindow 38" ImageName="Zoomout20" ImageNameDisabled="Zoomout20_d"/>
		<RadioButton Name="NoSel" Help="设置为选择模式" Command="SPC_SetSpecMenuSelection NoSel,1" Group="2" NewGroup="1" ImageName="Select20" ImageNameDisabled="Select20_d"/>
		<RadioButton Name="Spec" Help="选择任意时间位置的光谱" Command="SPC_SetSpecMenuSelection Spec,1" Group="2" ImageName="Spec_SelectSpectrum20" ImageNameDisabled="Spec_SelectSpectrum20_d"/>
		<RadioButton Name="ApexSpec" Help="选择峰顶点位置的光谱" Command="SPC_SetSpecMenuSelection ApexSpec,1" Group="2" ImageName="Spec_SelectPeak20" ImageNameDisabled="Spec_SelectPeak20_d"/>
		<RadioButton Name="AvgSpec" Help="平均一组选定的光谱" Command="SPC_SetSpecMenuSelection AvgSpec,1" Group="2" ImageName="Spec_Average20" ImageNameDisabled="Spec_Average20_d"/>
		<RadioButton Name="PeakSpec" Help="选择峰的一组光谱" Command="SPC_SetSpecMenuSelection PeakSpec,1" Group="2" ImageName="Spec_PeakSpectra20" ImageNameDisabled="Spec_PeakSpectra20_d"/>
		<RadioButton Name="PeakPurity" Help="选择要显示纯度的峰" Command="SPC_SetSpecMenuSelection PeakPurity,1" Group="2" ImageName="Spec_PeakPurity20" ImageNameDisabled="Spec_PeakPurity20_d"/>
		<RadioButton Name="Ref1Spec" Help="选择光谱以设置为第一参比" Command="SPC_SetSpecMenuSelection Ref1Spec,1" Group="2" ImageName="Spec_FirstRef20" ImageNameDisabled="Spec_FirstRef20_d"/>
		<RadioButton Name="Ref2Spec" Help="选择光谱以设置为第二参比" Command="SPC_SetSpecMenuSelection Ref2Spec,1" Group="2" ImageName="Spec_SecondRef20" ImageNameDisabled="Spec_SecondRef20_d"/>
		<NonEditCombobox Name="ActualReference" Help="选择光谱参比选项" Enable="1" Selection="1" TextList="无参比|手动参比|自动参比" DefCommand="SPC_SetRefSpec 1," DefCmdParNumber="1" Width="200"/>
		<NonEditCombobox Name="SpcRefSel" Help="选择光谱工具" Visible="0" Selection="1" Table="ToolBar,1,SPCRefSel" IsPath="0" Width="160"/>
		<NonEditCombobox Name="MSDRefSel" Help="选择光谱工具" Visible="0" Selection="1" Table="ToolBar,1,MSDRefSel" IsPath="0" Width="160"/>
		<RadioButton Name="ZoomInMS" Help="放大 MS 窗口" Command="MSD_SetIonSelection &quot;&quot;" NewGroup="1" Visible="0" ImageName="Spec_ZoominMS20" ImageNameDisabled="Spec_ZoominMS20_d"/>
		<RadioButton Name="ExtractIon" Help="提取离子色谱图" Command="MSD_SetIonSelection &quot;SelectIon&quot;" Visible="0" ImageName="Spec_ExtractIons20" ImageNameDisabled="Spec_ExtractIons20_d"/>
		<RadioButton Name="TurnOnMathCalc" Help="打开计算工具栏" Command="MSD_SetIonSelection &quot;Calculation&quot;" Visible="0" ImageName="Spec_MathToolbar20" ImageNameDisabled="Spec_MathToolbar20_d"/>
	</toolbar>
</graphical_object>
