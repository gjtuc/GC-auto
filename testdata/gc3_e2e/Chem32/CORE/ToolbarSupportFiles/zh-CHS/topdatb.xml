<?xml version="1.0" encoding="UTF-8"?>
<graphical_object>
	<toolbar Name="TopDaTB" PosStyle="TOP" Caption="数据分析" DockRow="0" DockCol="0" PanelName="Main">
		<Static Name="Signals" Visible="1" Enable="1" Text="信号" NewGroup="1" Border="NoBorder"/>
		<PushButton Name="LoadSignal" Help="调用数据文件的信号和光谱" Command="LoadFile" ImageName="Load_signal20" ImageNameDisabled="Load_signal20_d"/>
		<PushButton Name="MergeSignal" Help="调用数据文件的信号并与当前信号重叠" Command="LoadFile ,1" ImageName="Overlay_signal20" ImageNameDisabled="Overlay_signal20_d"/>
		<Static Name="Methods" Visible="1" Enable="1" Text="方法" NewGroup="1" Border="NoBorder"/>
		<PushButton Name="LoadMethod" Help="调用方法" Command="TLB_LoadMethod" ImageName="Load_method20" ImageNameDisabled="Load_method20_d"/>
		<PushButton Name="SaveMethod" Help="保存当前方法" Command="TLB_SaveCurrentMethod" ImageName="Save_method20" ImageNameDisabled="Save_method20_d"/>
		<PushButton Name="RunTimeChecklist" Help="编辑运行时选项表" Command="METH.EDRUNTIMECHKLST" ImageName="Edit_RunTimeChecklist20" ImageNameDisabled="Edit_RunTimeChecklist20_d"/>
		<PushButton Name="MethodStatus" Help="方法修改状态" Command="" Enable="0" ImageName="Method20" ImageNameDisabled="Method20"/>
		<!--  <NonEditCombobox Name="MethodFile" Help="Select from most previously loaded Method Files" Enable="1" Table="_Config,1,MethodFile" Selection="1" Width="200"/> -->
		<StatusList Name="MethodFile" Text="" Font="Microsoft Sans Serif, 8, Regular" BkColor="white" Help="实际方法文件" Width="250" Enable="1" Border="NoBorder"/>
		<StickyButton Name="HideNavtable" Help="隐藏/显示浏览表" CmdList="NavTableShow Off|NavTableShow On" State="1" NewGroup="1" ImageName="Report_TableTool20" ImageNameDisabled="Report_TableTool20_d"/>
		<PushButton Name="Preferences" Help="打开“首选项”对话框" Command="CpRequest &quot;Cp2&quot;, &quot;DlgPreferences&quot;" Visible="1" ImageName="Preferences20" ImageNameDisabled="Preferences20_d"/>
		<PushButton Name="XSRMultiSeq" Help="启动 OpenLAB IR" Command="ECM_XSRMultiSeq" Visible="0" ImageName="XSRMulti20" ImageNameDisabled="XSRMulti20_d"/>
		<!-- ==================================================================== -->
		<PushButton Name="ChemstoreLock" Help="所定化学工作站会话" Command="ChemStoreLock.ChemStoreSessionLock 1,0" NewGroup="1" Visible="0" ImageName="Chemstore_Lock20" ImageNameDisabled="Chemstore_Lock20_d"/>
		<PushButton Name="ChemstoreClient" Help="Chemstore检查客户端" Command="ChemStoreShowReviewClient" Visible="0" ImageName="Chemstore_ReviewClient20" ImageNameDisabled="Chemstore_ReviewClient20_d"/>
	</toolbar>
</graphical_object>
