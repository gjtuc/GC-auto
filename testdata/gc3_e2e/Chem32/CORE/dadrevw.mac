


!--------------------------------------------------
! DADTest review macros
!------------------------------------------------------------------------
!--------------------------------------------------
! Menu macro for DADTest review
!------------------------------------------------------------------------
Name MenuDADTestReview

Local i,SearchDone,ObjCount
  
Local  ID_PHX3DSUPPORTFILES_DAD_TEST_REVIE_316
Local  ID_PHX3DSUPPORTFILES_NO_DAD_TEST_DA_317
  
  ID_PHX3DSUPPORTFILES_DAD_TEST_REVIE_316            =  17316  
  ID_PHX3DSUPPORTFILES_NO_DAD_TEST_DA_317            =  17317  

  ! get free table window
  if check(variable,hjbdebug) = 1; print "MenuDADTestReview called"; endif

  if check(variable,DADTWindow) = 1
    if  DADTWindow <> freewin(DADTWindow)
      ! the window does exist, check if register exists
      if RegSize(DADTestReview) > 0
        ! Window & Register exists
        Return
      else
        Clearwin DADTWindow
      endif
    ! else window does not exist
    endif
  endif

  DADTWindow  = freewin(REG_ObjListStart)
  if DADTWindow > REG_ObjListEnd
    value = alert (ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_NO_WINDOW_FREE_314)+chr$(13)+ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_CLEAR_A_LIST_W_315),3,Alert3Title$)
    RETURN
  endif

  CopyWindowRowAndSet 10,DADTWindow,0.5,1.0,0.05,1.0,-1
  DelReg DADTestReview
  if FileStat (MODE,DADTest_Path$+DADTest_File$) = 1
      Loadobj DADTest_Path$+DADTest_File$,,DADTestReview
      if regsize(DADTestReview) > 0

        ! the following code was introduced to make DADTEST registers acquired
        ! with A.01.00 readable
        if len(objhdrtext$(DADTestReview[1],Title)) = 0
          for i=1 to regsize(DADTestReview)
            if len(objhdrtext$(DADTestReview[i],Title)) = 0
              setobjhdrtext DADTestReview[i],Title,\
                            AnnText$(DADTestReview[i],1,Text)
            endif
          next i
        endif
        ! end of A.01.00 adaption code

        ! the following code was introduced to display DADTEST registers
        ! differently when CE header items "capDiameter" and "Bubble"
        ! are available

        ObjCount = regsize(DADTestReview)
        SearchDone = 0
        i = 1
        while (SearchDone = 0) and (i <=  ObjCount)
          if (objhdrtype(DADTestReview[i],"Bubble")) <> 99
            ! it is a register with CE type spectra records
            ! change DDT to display CE info
            SearchDone = 1
            if RowByText(_config[3],"dadtreviewdesc",,Source,"i=","capDiameter") < 0
               AddDescRow "dadtreviewdesc","Cap. Diameter",,1,15,"%6.0f",1,"capDiameter"
            endif
            if RowByText(_config[3],"dadtreviewdesc",,Source,"i=","Bubble") < 0
               AddDescRow "dadtreviewdesc","Bubble","Capillary|Bubble|High Sens.",3,20,"%s",1,"Bubble"
            endif
          endif
        i = i + 1
        EndWhile

        if SearchDone = 0
          ! No CE specific headeritems, remove from DDT
          i = RowByText(_config[3],"dadtreviewdesc",,Source,"i=","Bubble")
          if i > 0
            DelTabRow _config[3],"dadtreviewdesc",i
          endif
          i = RowByText(_config[3],"dadtreviewdesc",,Source,"i=","capDiameter")
          if i > 0
            DelTabRow _config[3],"dadtreviewdesc",i
          endif
        EndIf

        ! end of CE header items adaption code

        SetWinTitle DADTWindow,ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_DAD_TEST_REVIE_316)+_InstName$
        SetTabVal _config[1],window,DADTWindow,DefWinStyle,0x0007
        SetTabVal _config[1],window,DADTWindow,HelpContext,118
        EdObjTab DADTWindow,DADTestReview,dadtreviewdesc
        AppendSelect DADTWindow,DADTestReview[1]
      else
        i=Alert (ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_NO_DAD_TEST_DA_317),3,Alert3Title$);
      endif
  else
      i=Alert (ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_NO_DAD_TEST_DA_317),3,Alert3Title$);
  endif
endmacro
!-----------------------------------------------------------------------
! Table button macros for the DADTest review
!------------------------------------------------------------------------
!-----------------------------------------------------------------------
! macro to be called before a object is deleted
!------------------------------------------------------------------------
Name DADT_ListObjPreDelRow
    parameter regname$
    parameter row
    parameter col
    parameter colname$
Local ActWin
  
Local  ID_PHX3DSUPPORTFILES_DO_YOU_REALLY_318
Local ID_PHX3DSUPPORTFILES_THE_SELECTED_D_319
  
  
  ID_PHX3DSUPPORTFILES_DO_YOU_REALLY_318             =  17318  
  ID_PHX3DSUPPORTFILES_THE_SELECTED_D_319            =  17319  

    if check(variable,hjbdebug) = 1; print "DADT_ListObjPreDelRow called";endif
    !  print regname$,",row=",row,",col=",col,",colname=",colname$
    ActWin = ActiveWindow()

    if DADTestDelete = 0
      if alert (ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_DO_YOU_REALLY_318)+chr$(13)+ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_THE_SELECTED_D_319),4,Alert4Title$) = 1
        !delete allowed
        DADT_ListObjPreDelRowRetVal=1
        DADTestDelete=SelectSize(DADTWindow)-1
      else
        DADT_ListObjPreDelRowRetVal=0
        DADTestDelete=-SelectSize(DADTWindow)+1
      endif
    else
      if DADTestDelete < 0
        DADTestDelete=DADTestDelete+1
        DADT_ListObjPreDelRowRetVal=0
      else
        DADTestDelete=DADTestDelete-1
        DADT_ListObjPreDelRowRetVal=1
      endif
    endif

    SetActiveWindow ActWin

endmacro
!-----------------------------------------------------------------------
! macro to be called when a cell is selected
!------------------------------------------------------------------------
Name Btn_DADTReviewSelCell
    parameter regname$
    parameter row
    parameter col
    parameter colname$

    Local i,Time$,Title$
    if check(variable,hjbdebug) = 1; print "Btn_DADTReviewSelCell called"; endif
    !print "Select   ",regname$,",row=",row,",col=",col,",colname=",colname$
    AppendSelect DADTWindow,DADTestReview[row]
    Btn_DADTReviewSelRow regname$,row,col,colname$
    return
endmacro

!-----------------------------------------------------------------------
! macro to be called when lines are selected
!------------------------------------------------------------------------
Name Btn_DADTReviewSelRow
    parameter regname$
    parameter row
    parameter col
    parameter colname$

    Local i,Time$,Title$
    if check(variable,hjbdebug) = 1; print "Btn_DADTReviewSelRow called"; endif
    !print "Select   ",regname$,",row=",row,",col=",col,",colname=",colname$
    DADTestDelete=0
    Time$=ObjHdrText$(DADTestReview[row],DateTime)
    Title$=ObjHdrText$(DADTestReview[row],Title)
    if (check(Variable,DADTSpecWindow) = 1) and (RegSize (DADTSpecReg) > 0)
      if (FreeWin(DADTSpecWindow) <> DADTSpecWindow) and \
         (ObjHdrType(DADTSpecReg[1],DateTime) = 0)
        for i= 1 to RegSize (DADTSpecReg)
          if (Time$ = ObjHdrText$(DADTSpecReg[i],DateTime))  and \
             (Title$ = ObjHdrText$(DADTSpecReg[i],Title))
            AppendSelect DADTSpecWindow,DADTSpecReg[i]
            return
          endif
        next i
      endif
    endif
    if (check(Variable,DADTSpecWindow2) = 1) and (RegSize (DADTSpecReg2) > 0)
      if (FreeWin(DADTSpecWindow2) <> DADTSpecWindow2) and \
         (ObjHdrType(DADTSpecReg2[1],DateTime) = 0)
        for i= 1 to RegSize (DADTSpecReg2)
          if (Time$ = ObjHdrText$(DADTSpecReg2[i],DateTime)) and \
             (Title$ = ObjHdrText$(DADTSpecReg2[i],Title))
            AppendSelect DADTSpecWindow2,DADTSpecReg2[i]
            return
          endif
        next i
      endif
    endif

endmacro

!-----------------------------------------------------------------------
! macro to be called when lines are unselected
!------------------------------------------------------------------------
Name Btn_DADTReviewUnSelRow
    parameter regname$
    parameter row
    parameter col
    parameter colname$
    Local i,Time$,Title$
    if check(variable,hjbdebug) = 1; print "Btn_DADTReviewUnSelRow called"; endif
    !print "unselect ",regname$,",row=",row,",col=",col,",colname=",colname$
    DADTestDelete=0
    Time$=ObjHdrText$(DADTestReview[row],DateTime)
    Title$=ObjHdrText$(DADTestReview[row],Title)
    if (check(Variable,DADTSpecWindow) = 1)  and \
       (RegSize (DADTSpecReg) > 0)
      if (ObjHdrType(DADTSpecReg[1],DateTime) <> 0); return; endif
      For i= 1 to SelectSize(DADTSpecWindow)
        GetSelect DADTSpecWindow,i
        if (Time$  = ObjHdrText$(DADTSpecReg[sel_obj],DateTime)) and \
           (Title$ = ObjHdrText$(DADTSpecReg[sel_obj],Title))
          ClearSelect DADTSpecWindow,i
          return
        endif
      next i
    endif
    if (check(Variable,DADTSpecWindow2) = 1)  and \
       (RegSize (DADTSpecReg2) > 0)
      if (ObjHdrType(DADTSpecReg2[1],DateTime) <> 0); return; endif
      For i= 1 to SelectSize(DADTSpecWindow2)
        GetSelect DADTSpecWindow2,i
        if (Time$  = ObjHdrText$(DADTSpecReg2[sel_obj],DateTime)) and \
           (Title$ = ObjHdrText$(DADTSpecReg2[sel_obj],Title))
          ClearSelect DADTSpecWindow2,i
          return
        endif
      next i
    endif
endmacro

!-----------------------------------------------------------------------
! macro to be called when Intensity spectra should be displayed
!------------------------------------------------------------------------
Name DoBtn_DADTMergeDisplay

    Parameter SearchStr$,AxisTitle$
Local i,ScanNums
  
Local  ID_PHX3DSUPPORTFILES_DAD_TEST_REVIE_316
Local  ID_PHX3DSUPPORTFILES_NO_320
Local ID_PHX3DSUPPORTFILES__SPECTRA_FOUND_321
Local ID_PHX3DSUPPORTFILES_NO_FREE_WINDOW_329
  
  
  
  ID_PHX3DSUPPORTFILES_DAD_TEST_REVIE_316            =  17316  
  ID_PHX3DSUPPORTFILES_NO_320                        =  17320  
  ID_PHX3DSUPPORTFILES__SPECTRA_FOUND_321            =  17321  
  ID_PHX3DSUPPORTFILES_NO_FREE_WINDOW_329            =  17329  

    ! get free table window

    print ""
    if RegSize (DADTSpecReg) > 0
      DelObj DADTSpecReg[1:0]
    endif
    if check (Variable,DADTSpecWindow) = 0
        DADTSpecWindow  = freewin(REG_ObjListStart)
        if DADTSpecWindow > REG_ObjListEnd
          value = alert (ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_NO_FREE_WINDOW_329),3,Alert3Title$)
          RETURN
        endif
    endif
    WinUpdate off
    CopyWindowRowAndSet 39,DADTSpecWindow,0.0,0.5,0.05,1.0,-1
    SetWinTitle DADTSpecWindow,ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_DAD_TEST_REVIE_316)+_InstName$
    ScanNums=0
    for i=1 to RegSize(DADTestReview)
      if InStr(ObjHdrText$(DADTestReview[i],Title),SearchStr$) > 0
          CopyObj DADTestReview[i],DADTSpecReg
      SetDataVal DADTSpecReg[RegSize(DADTSpecReg)],1,Color,0xFF000000
      SetDataVal DADTSpecReg[RegSize(DADTSpecReg)],1,FieldWidth,10
      SetDataText DADTSpecReg[RegSize(DADTSpecReg)],1,AxisTitle,AxisTitle$
      ScanNums=ScanNums+1
      endif
    next i
    if ScanNums > 8
      SetTabVal _config[1],window,DADTSpecWindow,Topic,0xFFFFFFF0
    else
      SetTabVal _config[1],window,DADTSpecWindow,Topic,0xFFFFFFFF
    endif

    if RegSize (DADTSpecReg) > 0
      if check(Variable,DADTSpecWindow2) = 1
        Clearwin DADTSpecWindow2
        Remove DADTSpecWindow2
      endif
      Draw DADTSpecWindow,DADTSpecReg
      Winupdate on
      ClearSelect DADTSpecWindow
      for i=1 to SelectSize(DADTWindow)
        GetSelect DADTWindow,i
        Btn_DADTReviewSelRow "DADTestReview",sel_obj, -1, ""
      next i
      return
    else
      print ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_NO_320)+ SearchStr$ +ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES__SPECTRA_FOUND_321)
    endif
    WinUpdate on

endmacro



!-----------------------------------------------------------------------
! macro to be called when Holmium spectra should be displayed
!------------------------------------------------------------------------
Name Btn_DADTMergeHolmium
    parameter regname$
    parameter row
    parameter col
    parameter colname$
Local i
  
Local  ID_PHX3DSUPPORTFILES_BTN_DADTMERGEH_322
  
  ID_PHX3DSUPPORTFILES_BTN_DADTMERGEH_322            =  17322  
    !print regname$,",row=",row,",col=",col,",colname=",colname$

    if check(variable,hjbdebug) = 1; print ReadResource$("Phx3dSupport",ID_PHX3DSUPPORTFILES_BTN_DADTMERGEH_322); endif
    DoBtn_DADTMergeDisplay  "Holmium","mAU"


endmacro

!-----------------------------------------------------------------------
! macro to be called when Intensity spectra should be displayed
!------------------------------------------------------------------------
Name Btn_DADTMergeIntensity
    parameter regname$
    parameter row
    parameter col
