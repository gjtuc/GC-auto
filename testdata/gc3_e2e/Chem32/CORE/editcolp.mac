! $Header: /cag/PHX3D/parts/macros/editcolp.mac 4.7 2002-05-24 01:24:31-07 fkremser Exp $

! Column parameter handling    


!==============================================================================
Name printColumnParms
!------------------------------------------------------------------------------

! Print column parameters
  
parameter columnNum
parameter columns$ default "columns"

local value, Length, Diameter
local colDeadUnit, deadValue, particleSize, ColumnType
!..............................................................................
Local   ID_PHX3DSUPPORTFILES_DESCRIPTION_61
Local   ID_PHX3DSUPPORTFILES_COLUMN_ID_MODU_62
Local   ID_PHX3DSUPPORTFILES_COLUMN_ID_MODU_63
Local   ID_PHX3DSUPPORTFILES_INSTALLED_64
Local   ID_PHX3DSUPPORTFILES_INSTALLED_65
Local   ID_PHX3DSUPPORTFILES_PRODUCT_NO_66
Local   ID_PHX3DSUPPORTFILES_BATCH_NO_67
Local   ID_PHX3DSUPPORTFILES_SERIAL_NO_68
Local   ID_PHX3DSUPPORTFILES_DIAMETER_69
Local   ID_PHX3DSUPPORTFILES_LENGTH_70
Local   ID_PHX3DSUPPORTFILES_DIAMETER_71
Local   ID_PHX3DSUPPORTFILES_LENGTH_72
Local   ID_PHX3DSUPPORTFILES_DIAMETER_73
Local   ID_PHX3DSUPPORTFILES_LENGTH_74
Local   ID_PHX3DSUPPORTFILES_CELL_TYPE_75
Local   ID_PHX3DSUPPORTFILES_CELL_TYPE_76
Local   ID_PHX3DSUPPORTFILES_CELL_TYPE_77
Local   ID_PHX3DSUPPORTFILES_EFF__LENGTH_78
Local   ID_PHX3DSUPPORTFILES_FILM_THICKNESS_79
Local   ID_PHX3DSUPPORTFILES_PARTICLE_SIZE_80
Local   ID_PHX3DSUPPORTFILES_VOID_VOLUME_81
Local   ID_PHX3DSUPPORTFILES_VOID_VOLUME_82
Local   ID_PHX3DSUPPORTFILES_DEAD_TIME_83
Local   ID_PHX3DSUPPORTFILES____INJECTIONS_84
Local   ID_PHX3DSUPPORTFILES_MAX__PRESSURE_85
Local   ID_PHX3DSUPPORTFILES_MAX__PRESSURE_86
Local   ID_PHX3DSUPPORTFILES_MAX__PH_87
Local   ID_PHX3DSUPPORTFILES_MIN__PH_401
Local   ID_PHX3DSUPPORTFILES_MAX__TEMPERATU_88
Local   ID_PHX3DSUPPORTFILES_COMMENT_89
Local   NLSFileName_phx3dsupport$
Local   ID_PHX3DSUPPORTFILES_PRNT_DEVICE_SERIAL_404
Local   rcStr$

Local  ID_PHX3DSUPPORTFILES_MODEL_NO_406          
Local  ID_PHX3DSUPPORTFILES_INVENTORY_NO_407      
Local  ID_PHX3DSUPPORTFILES_MANUFACUTER_408       



  ID_PHX3DSUPPORTFILES_DESCRIPTION_61                =  17061  
  ID_PHX3DSUPPORTFILES_COLUMN_ID_MODU_62             =  17062  
  ID_PHX3DSUPPORTFILES_COLUMN_ID_MODU_63             =  17063  
  ID_PHX3DSUPPORTFILES_INSTALLED_64                  =  17064  
  ID_PHX3DSUPPORTFILES_INSTALLED_65                  =  17065  
  ID_PHX3DSUPPORTFILES_PRODUCT_NO_66                 =  17066  
  ID_PHX3DSUPPORTFILES_BATCH_NO_67                   =  17067  
  ID_PHX3DSUPPORTFILES_SERIAL_NO_68                  =  17068  
  ID_PHX3DSUPPORTFILES_DIAMETER_69                   =  17069  
  ID_PHX3DSUPPORTFILES_LENGTH_70                     =  17070  
  ID_PHX3DSUPPORTFILES_DIAMETER_71                   =  17071  
  ID_PHX3DSUPPORTFILES_LENGTH_72                     =  17072  
  ID_PHX3DSUPPORTFILES_DIAMETER_73                   =  17073  
  ID_PHX3DSUPPORTFILES_LENGTH_74                     =  17074  
  ID_PHX3DSUPPORTFILES_CELL_TYPE_75                  =  17075  
  ID_PHX3DSUPPORTFILES_CELL_TYPE_76                  =  17076  
  ID_PHX3DSUPPORTFILES_CELL_TYPE_77                  =  17077  
  ID_PHX3DSUPPORTFILES_EFF__LENGTH_78                =  17078  
  ID_PHX3DSUPPORTFILES_FILM_THICKNESS_79             =  17079  
  ID_PHX3DSUPPORTFILES_PARTICLE_SIZE_80              =  17080  
  ID_PHX3DSUPPORTFILES_VOID_VOLUME_81                =  17081  
  ID_PHX3DSUPPORTFILES_VOID_VOLUME_82                =  17082  
  ID_PHX3DSUPPORTFILES_DEAD_TIME_83                  =  17083  
  ID_PHX3DSUPPORTFILES____INJECTIONS_84              =  17084  
  ID_PHX3DSUPPORTFILES_MAX__PRESSURE_85              =  17085  
  ID_PHX3DSUPPORTFILES_MAX__PRESSURE_86              =  17086  
  ID_PHX3DSUPPORTFILES_MAX__PH_87                    =  17087  
  ID_PHX3DSUPPORTFILES_MIN__PH_401                   =  17401
  ID_PHX3DSUPPORTFILES_MAX__TEMPERATU_88             =  17088  
  ID_PHX3DSUPPORTFILES_COMMENT_89                    =  17089  
  ID_PHX3DSUPPORTFILES_PRNT_DEVICE_SERIAL_404        =  17404

  ID_PHX3DSUPPORTFILES_MODEL_NO_406                  =  17406
  ID_PHX3DSUPPORTFILES_INVENTORY_NO_407              =  17407
  ID_PHX3DSUPPORTFILES_MANUFACUTER_408               =  17408

  NLSFileName_phx3dsupport$="phx3dsupport"
  
  ColumnType = TabHdrVal (_Config[1], "Features", "ColumnType")
  print using #5, "//"
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DESCRIPTION_61), \
                  tabText$(_Config[1], columns$, columnNum, colDescription)

  if tabVal(_Config[1], columns$, columnNum, IsHW) = 1 then
      if tabVal(_Config[1], columns$, columnNum, ColumnPosition) = 1 then
          print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_COLUMN_ID_MODU_62)
      endif
      if tabVal(_Config[1], columns$, columnNum, ColumnPosition) = 2 then
          print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_COLUMN_ID_MODU_63)
      endif
  else
    if tabVal(_Config[1], columns$, columnNum, colInstalled) = 1 then
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_INSTALLED_64)
    else
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_INSTALLED_65)
    endif
  endIf

  if (ColumnType <> 3) then
     print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_PRODUCT_NO_66), \
                       tabText$(_Config[1], columns$, columnNum, productNum)
     print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_BATCH_NO_67), \
                       tabText$(_Config[1], columns$, columnNum, batchNum)
     print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_SERIAL_NO_68), \
                       tabText$(_Config[1], columns$, columnNum, serialNum)
  else
     ! GC
     print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_MODEL_NO_406), \
                       tabText$(_Config[1], columns$, columnNum, productNum)
     print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_MANUFACUTER_408), \
                       tabText$(_Config[1], columns$, columnNum, batchNum)
     print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_INVENTORY_NO_407), \
                       tabText$(_Config[1], columns$, columnNum, serialNum)
  endif
  
  ! switch on ColumnType for Length and Diameter
  Length = tabVal(_Config[1], columns$, columnNum, colLength)
  Diameter = tabVal(_Config[1], columns$, columnNum, colDiameter)
  evaluate "goto LD" + val$(ColumnType)
LD1:
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIAMETER_69), Diameter
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_LENGTH_70), Length
  goto EndSwitchLD
LD2:
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIAMETER_71), Diameter
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_LENGTH_72), Length
  goto EndSwitchLD
LD3:
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIAMETER_73), Diameter
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_LENGTH_74), Length
  goto EndSwitchLD
EndSwitchLD:

  if ColumnType = 2 then
    value = tabVal(_Config[1], columns$, columnNum, bubbleCapillary)
    if value = 0 then
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_CELL_TYPE_75)
    else; if value=1
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_CELL_TYPE_76);
    else;
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_CELL_TYPE_77); 
    endIf; endif
    print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_EFF__LENGTH_78), \
                    tabVal(_Config[1], columns$, columnNum, effLength)
  else
    particleSize = tabVal(_Config[1], columns$, columnNum, particleSize)
    if ColumnType = 3 then
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_FILM_THICKNESS_79), particleSize
    else
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_PARTICLE_SIZE_80), particleSize
    endif
    colDeadUnit = tabVal(_Config[1], columns$, columnNum, colDeadUnit)
    deadValue = tabVal(_Config[1], columns$, columnNum, colDead)
    if colDeadUnit = 0 then 
      print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_VOID_VOLUME_81), deadValue
    else
      if colDeadUnit = 1 then
        print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_VOID_VOLUME_82), deadValue
      else
        print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DEAD_TIME_83), deadValue
      endIf
    endIf
  endIf

  !if tabVal(_Config[1], columns$, columnNum, IsHW) = 1 then
  !do now for all columns
     value = tabVal(_Config[1], columns$, columnNum, NumInjections)
     if value > 0
        print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES____INJECTIONS_84), value
     endif   
  !endif

  if ColumnType <> 3 then
     if _PumpUseBar = 1
       print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_MAX__PRESSURE_85), tabVal(_Config[1], columns$, columnNum, MaxPressure)
     else
       print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_MAX__PRESSURE_86), tabVal(_Config[1], columns$, columnNum, MaxPressure)
     endif
  endif
  
  ! use ASCII(176) for degree char
  if ColumnType <> 3 then
    !move to here since only relevant for liquid phases
    print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_MAX__PH_87), tabVal(_Config[1], columns$, columnNum, MaxPh)
    on Error rcStr$ = "Min. pH:            #.#/"   !new resource
    rcStr$ = ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_MIN__PH_401)
    on Error 
    print using #5, rcStr$, tabVal(_Config[1], columns$, columnNum, "MinPh")
  endif
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_MAX__TEMPERATU_88), tabVal(_Config[1], columns$, columnNum, MaxTemp)
  print using #5, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_COMMENT_89), tabText$(_Config[1], columns$, columnNum, Comment)
  
  if ShowDeviceSerial_for_LCRCNet_THM_CCC() = 1
     on Error rcStr$ = "TCC Serial No.:     % /"   !new resource
     rcStr$ = ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_PRNT_DEVICE_SERIAL_404)
     on Error 
     print using #5, rcStr$, tabText$(_Config[1], columns$, columnNum, "DeviceSerial")
  endif

  print using #5, "/"
  return

endMacro ! printColumnParms

!==============================================================================
Name ShowDeviceSerial_for_LCRCNet_THM_CCC
!------------------------------------------------------------------------------
local bShowDeviceSerial 

  bShowDeviceSerial = 0
  if Check (Variable, DevRCnet) = 1 then
     if DevRCnet > 0 then
        if Check (Variable, DevRCCCC) > 0
           bShowDeviceSerial = 1
        endif   
     else   
        if Check (Variable, DevRCTHM) = 1 then
           if DevRCTHM > 1  then 
              !show only when there is more than one TCC there.
              bShowDeviceSerial = 1
           endif
        endif   
     endif   
  endif   

  return bShowDeviceSerial
endmacro

