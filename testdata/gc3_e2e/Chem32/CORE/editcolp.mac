!==============================================================================
Name SetDescRowEditState
PARAMETER Tab$
PARAMETER SourceCol$
PARAMETER control 
!------------------------------------------------------------------------------
local  RowNbr

  RowNbr = RowByText( _config[3],tab$,, "Source" , "i=" , SourceCol$ )
  if RowNbr > 0
     settabval  _config[3],tab$,RowNbr,"Control",control
  endif   
EndMacro



!==============================================================================
Name GenColumnDesc1_CellEditState_RowButtonState
! Define display description table for column parameters
!------------------------------------------------------------------------------

local ColumnType
Local CellEditable
Local InjEditable
Local ComboEditable
Local bRestrictColTabEditing  !since driver UI does a lot by itself

  bRestrictColTabEditing = 0

  ColumnType = TabHdrVal (_Config[1], "Features", "ColumnType")

  bRestrictColTabEditing = Is_GC_WithOwnColumnUI()
  !bRestrictColTabEditing = 1 ! for testing

  if _Offline = 1
     SetTabHdrVal  _Config[3],columnDesc1,DeleteProtected, 1
     SetTabHdrVal  _Config[3],columnDesc1,InsertProtected, 1
     CellEditable = 0
     InjEditable = 0
     ComboEditable = 3  !not editable combobox
  else
     if bRestrictColTabEditing = 1
        SetTabHdrVal  _Config[3],columnDesc1,DeleteProtected, 0
        SetTabHdrVal  _Config[3],columnDesc1,InsertProtected, 1
        CellEditable = 1
        InjEditable = 2
        ComboEditable = 3  !not editable combobox
     else   
        SetTabHdrVal  _Config[3],columnDesc1,DeleteProtected, 0
        SetTabHdrVal  _Config[3],columnDesc1,InsertProtected, 0
        CellEditable = 2
        InjEditable = 2
        ComboEditable = 4  !editable combobox
     endif
  endif
  
  
  ! make the table

  SetDescRowEditState "columnDesc1", "colInstalled", ComboEditable
  SetDescRowEditState "columnDesc1", "colDescription", CellEditable
  SetDescRowEditState "columnDesc1", "BatchNum", CellEditable
  !if (ColumnType = 1) or (ColumnType = 3) then
  !now for all types
  SetDescRowEditState "columnDesc1", "SerialNum", CellEditable
  !endIf
  SetDescRowEditState "columnDesc1", "ProductNum", CellEditable
  ! "NumInjections" - this we want to have editable !!!
  SetDescRowEditState "columnDesc1", "NumInjections", InjEditable
  SetDescRowEditState "columnDesc1", "MaxPressure", CellEditable
  SetDescRowEditState "columnDesc1", "MaxTemp", CellEditable
  if ColumnType <> 3 then
    SetDescRowEditState "columnDesc1", "MaxPh", CellEditable
    SetDescRowEditState "columnDesc1", "MinPh", CellEditable
  endif  
  SetDescRowEditState "columnDesc1", "colLength", CellEditable
  if ColumnType = 2 then
    !CE
    SetDescRowEditState "columnDesc1", "colDiameter", CellEditable
    SetDescRowEditState "columnDesc1", "bubbleCapillary", ComboEditable
    SetDescRowEditState "columnDesc1", "effLength", CellEditable
  else
    if ColumnType = 3 then
      !GC
      SetDescRowEditState "columnDesc1", "colDiameter", CellEditable
      SetDescRowEditState "columnDesc1", "particleSize", CellEditable
      SetDescRowEditState "columnDesc1", "colDead", CellEditable
    else
      !LC
      SetDescRowEditState "columnDesc1", "colDiameter", CellEditable
      SetDescRowEditState "columnDesc1", "particleSize", CellEditable
      SetDescRowEditState "columnDesc1", "colDead", CellEditable
      !don't now right, know how to make combobox not editable 
      !SetDescRowEditState "columnDesc1", "colDeadUnit", CellEditable
      SetDescRowEditState "columnDesc1", "colDeadUnit", ComboEditable
    endif
  endIf
  SetDescRowEditState "columnDesc1", "Comment", CellEditable
  
EndMacro



!==============================================================================
Name GenColumnDesc1
! Define display description table for column parameters
!------------------------------------------------------------------------------

local ColumnType
Local  NLSFileName_phx3dsupport$
Local  ID_PHX3DSUPPORTFILES_INSERT__40_3_3_105
Local  ID_PHX3DSUPPORTFILES_APPEND__73_3_3_106  
Local  ID_PHX3DSUPPORTFILES_DELETE_106_3_3_107  
Local  ID_PHX3DSUPPORTFILES_PRINT_______15_108  
Local  ID_PHX3DSUPPORTFILES_OK__________18_109  
Local  ID_PHX3DSUPPORTFILES_CANCEL______22_110  
Local  ID_PHX3DSUPPORTFILES_HELP______25_399   
Local  ID_PHX3DSUPPORTFILES_INSTALLED_111       
Local  ID_PHX3DSUPPORTFILES_NO_YES_112          
Local  ID_PHX3DSUPPORTFILES_DESCRIPTION_113     
Local  ID_PHX3DSUPPORTFILES_BATCH_114           
Local  ID_PHX3DSUPPORTFILES_SERIAL_115          
Local  ID_PHX3DSUPPORTFILES_PRODUCT_116         
Local  ID_PHX3DSUPPORTFILES_LENGTH_117          
Local  ID_PHX3DSUPPORTFILES_DIAMETER_118        
Local  ID_PHX3DSUPPORTFILES_CELL_119            
Local  ID_PHX3DSUPPORTFILES_EFF__LENGTH_120     
Local  ID_PHX3DSUPPORTFILES_DIAMETER_121        
Local  ID_PHX3DSUPPORTFILES_THICKNESS_122       
Local  ID_PHX3DSUPPORTFILES_DEADTIME_123        
Local  ID_PHX3DSUPPORTFILES_DIAMETER_124        
Local  ID_PHX3DSUPPORTFILES_SIZE_125            
Local  ID_PHX3DSUPPORTFILES_VOID_126            
Local  ID_PHX3DSUPPORTFILES_UNIT_127            
Local  ID_PHX3DSUPPORTFILES_COMMENT_128         
Local  ID_PHX3DSUPPORTFILES__MAX_P_BAR_211      
Local  ID_PHX3DSUPPORTFILES__MAX_P_10_5_PA_212  
Local  ID_PHX3DSUPPORTFILES__MAX_T_C_213        
Local  ID_PHX3DSUPPORTFILES__MAX_PH_214    
Local  ID_PHX3DSUPPORTFILES__MIN_PH_402
Local  ID_PHX3DSUPPORTFILES___INJECTIONS_130 

Local  ID_G11N_ADD_WHITESPACE_BTW_COLUMN_20003  
Local  ID_G11N_ADD_WIDTH_COLHEADER_20004        
