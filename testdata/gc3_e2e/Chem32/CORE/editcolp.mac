Local  rcStr$
Local  ID_PHX3DSUPPORTFILES_MANUFACT_409               
Local  ID_PHX3DSUPPORTFILES_INVENTORY_410              
Local  ID_PHX3DSUPPORTFILES_MODEL_411                  


  NLSFileName_phx3dsupport$="phx3dsupport"
  ID_PHX3DSUPPORTFILES_INSERT__40_3_3_105            =  17105  
  ID_PHX3DSUPPORTFILES_APPEND__73_3_3_106            =  17106  
  ID_PHX3DSUPPORTFILES_DELETE_106_3_3_107            =  17107  
  ID_PHX3DSUPPORTFILES_PRINT_______15_108            =  17108  
  ID_PHX3DSUPPORTFILES_OK__________18_109            =  17109  
  ID_PHX3DSUPPORTFILES_CANCEL______22_110            =  17110  
  ID_PHX3DSUPPORTFILES_HELP______25_399              =  17399  
  ID_PHX3DSUPPORTFILES_INSTALLED_111                 =  17111  
  ID_PHX3DSUPPORTFILES_NO_YES_112                    =  17112  
  ID_PHX3DSUPPORTFILES_DESCRIPTION_113               =  17113  
  ID_PHX3DSUPPORTFILES_BATCH_114                     =  17114  
  ID_PHX3DSUPPORTFILES_SERIAL_115                    =  17115  
  ID_PHX3DSUPPORTFILES_PRODUCT_116                   =  17116  
  ID_PHX3DSUPPORTFILES_LENGTH_117                    =  17117  
  ID_PHX3DSUPPORTFILES_DIAMETER_118                  =  17118  
  ID_PHX3DSUPPORTFILES_CELL_119                      =  17119  
  ID_PHX3DSUPPORTFILES_EFF__LENGTH_120               =  17120  
  ID_PHX3DSUPPORTFILES_DIAMETER_121                  =  17121  
  ID_PHX3DSUPPORTFILES_THICKNESS_122                 =  17122  
  ID_PHX3DSUPPORTFILES_DEADTIME_123                  =  17123  
  ID_PHX3DSUPPORTFILES_DIAMETER_124                  =  17124  
  ID_PHX3DSUPPORTFILES_SIZE_125                      =  17125  
  ID_PHX3DSUPPORTFILES_VOID_126                      =  17126  
  ID_PHX3DSUPPORTFILES_UNIT_127                      =  17127  
  ID_PHX3DSUPPORTFILES_COMMENT_128                   =  17128  
  ID_PHX3DSUPPORTFILES__MAX_P_BAR_211                =  17211
  ID_PHX3DSUPPORTFILES__MAX_P_10_5_PA_212            =  17212 
