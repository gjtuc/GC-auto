! $Header: /PHX3D/parts/macros/events.mac 4.0 1996-03-22 17:44:50-05 hmgr Exp $
!
! These are macros that emulate Phoenix 2D commands for the events table.
! They are here only for backwards compatibility.
! They should be used only if necessary. New macros should, whenever possible
! and reasonable, use the defined commands and functions directly.
!
! Note that these emulation macros are not robust in error checking. It is
! assumed that they are used only for reading the file EVENTS.MAC which is
! part of a Phoenix 2D method, and was generated by SAVEEVENTS command.

Name ClrEvents
  ! Clear all entries in the integrator event table and set the initial
  ! parameters to the default values.
  DelTab _DAMethod[1], "Event"
  CopyTab _Config[2], "Event", _DAMethod[1], "Event"
  return
endmacro

Name CreateEvent
parameter EventCode, Value, Time
  ! Insert or delete (if negative time) event into standard Event table.
  local row, nRows
  nRows = TabHdrVal (_DAMethod[1], "Event", "NumberOfRows")
  if Time >= 0 then
    ! Insert new event
    row = RowByVal (_DAMethod[1], "Event", , "Time", ">", Time)
    if row = -1 then
      ! append at end of table
      row = nRows + 1
    endif
    InsTabRow _DAMethod[1], "Event", row
    SetTabVal _DAMethod[1], "Event", row, "EventCode", EventCode
    SetTabVal _DAMethod[1], "Event", row, "Value", Value
    SetTabVal _DAMethod[1], "Event", row, "Time", Time
  else
    ! Find event and delete it
    Time = - Time
    row = 1
    while row <= nRows do
      row = RowByVal (_DAMethod[1], "Event", row:-1, "Time", "=", Time)
      if row = -1 then
        return
      endif
      if (TabVal (_DAMethod[1], "Event", row, "Value") = Value) and \
         (TabVal (_DAMethod[1], "Event", row, "EventCode") = EventCode) \
      then
        DelTabRow _DAMethod[1], "Event", row
        return
      endif
      row = row + 1
    endwhile
  endif
  return
endmacro

Name AreaReject
parameter Value, Time
  CreateEvent 13, Value, Time
  return
endmacro

Name AreaSum
parameter OnOff$ default "ON", Time
  if OnOff$ = "ON" then
    CreateEvent 7, 0, Time
  else
    CreateEvent -7, 0, Time
  endif
  return
endmacro

Name Baseline2
parameter Mode$
parameter Time default 0
  if Mode$ = "NOW" then
    CreateEvent 0, 0, Time
    return
  endif
  if Mode$ = "NEXTVALLEY" then
    CreateEvent 1, 0, Time
    return
  endif
  if Mode$ = "BACK" then
    CreateEvent 10, 0, Time
    return
  endif
  return
endmacro

Name Baseline3
parameter Mode$
parameter OnOff$ default "ON"
parameter Time default 0
  if Mode$ = "ALLVALLEY" then
    if OnOff$ = "ON" then
      CreateEvent 2, 0, Time
    else
      CreateEvent -2, 0, Time
    endif
    return
  endif
  if Mode$ = "HOLD" then
    if OnOff$ = "ON" then
      CreateEvent 5, 0, Time
    else
      CreateEvent -5, 0, Time
    endif
    return
  endif
  return
endmacro

Name InitReject
parameter Value
  SetTabHdrVal _DAMethod[1], "Event", "InitReject", Value
  return
endmacro

Name InitThresh
parameter Value
  if Check(VARIABLE,ThreshOffset) =  1 then
     Value = Value + ThreshOffset
  endif
  SetTabHdrVal _DAMethod[1], "Event", "InitThresh", Value
  return
endmacro

Name InitWidth
parameter Value
  SetTabHdrVal _DAMethod[1], "Event", "InitWidth", Value
  return
endmacro

Name Integrator
parameter OnOff$ default "ON", Time
  if OnOff$ = "ON" then
    CreateEvent -6, 0, Time
  else
    CreateEvent 6, 0, Time
  endif
  return
endmacro

Name NegPeaks
parameter OnOff$ default "ON", Time
  if OnOff$ = "ON" then
    CreateEvent 9, 0, Time
  else
    CreateEvent -9, 0, Time
  endif
  return
endmacro

Name PeakWidth
parameter Value, Time
  CreateEvent 14, Value, Time
  return
endmacro

Name Shoulders
parameter OnOff$ default "ON"
  if OnOff$ = "ON" then
    SetTabHdrVal _DAMethod[1], "Event", "ShouldersOn", 1
  else
    SetTabHdrVal _DAMethod[1], "Event", "ShouldersOn", 0
  endif
  return
endmacro

Name Solvents
parameter OnOff$ default "ON", Time
  if OnOff$ = "ON" then
    CreateEvent -4, 0, Time
  else
    CreateEvent 4, 0, Time
  endif
  return
endmacro

Name TanSkim
parameter Time
  CreateEvent 3, 0, Time
  return
endmacro

Name Threshold
parameter Value, Time
  if Check(VARIABLE,ThreshOffset) = 1 then
     Value = Value + ThreshOffset
  endif
  CreateEvent 12, Value, Time
  return
endmacro

Name LoadEvents
parameter FileName$
  ! This was no Phoenix 2D command.
  ! It is a specialized mini command interpreter.
  ! It's sole reason of existence is the
  ! ambiguity in the syntax of the BASELINE command.
  ! Otherwise the CP could parse the events macro file directly.
  local Line$, ok
  if FileStat (Mode, FileName$) = 1 then
    ! read the file line by line:
    Open FileName$ For Input As #6
    on error ok = 0
    ok = 1
    Input Using #6, "L", Line$
    while ok = 1 do
      ! Check for special lines, otherwise just evaluate the line:
      if (instr(Line$, "name") = 1) or \
         (instr(Line$, "NAME") = 1) or \
         (instr(Line$, "remove") = 1) or \
         (instr(Line$, "REMOVE") = 1) or \
	 (instr(Line$, "message") = 1) or \
	 (instr(Line$, "MESSAGE") = 1) or \
	 (instr(Line$, "RETURN") = 1) or \
         (instr(Line$, "return") = 1) \
      then
        ! just ignore the line
      else
        if instr(Line$, "BASELINE") = 1 then
          ! check, whether it is the two param or the three param case
          if (instr(Line$, "NOW") = 10) or \
             (instr(Line$, "NEXTVALLEY") = 10) or \
             (instr(Line$, "BACK") = 10) \
          then
            evaluate Line$[1:8] + "2" + Line$[9:len(Line$)]
          else
            evaluate Line$[1:8] + "3" + Line$[9:len(Line$)]
          endif
        else
          ! standard case, just evaluate the line:
          evaluate Line$
        endif
      endif
      Input Using #6, "L", Line$
    endwhile
    Close #6
  endif
  return
endmacro
