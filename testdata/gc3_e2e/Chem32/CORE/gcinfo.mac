        ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___HEATER_ZONE_104),db__htr$
        If ((db__type$="FID")Or(db__type$="NPD")Or(db__type$="FPD"))Then
          Print#33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MAKE_UP_GAS_123),conv_makeup_gas$(Val(db_m_gas$)),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___UTILITY_GAS_124),conv_util_gas$(Val(db_u_gas$))
        EndIf
        If ((db__type$="TCD")Or(db__type$="ECD")Or(db__type$="uECD"))Then
          Print#33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MAKE_UP_GAS_123),conv_makeup_gas$(Val(db_m_gas$))
        EndIf
      Else
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____REAR_DETEC_127)
      endif
    EndIf
      
  ! Process Thermal AUX information
    Print #33," "
    Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_ZONES_CONF_128)
    a1_cfg$=SendModule$(GC_type$,"A1CW ?")
    a1_cfg$=stripcmd$(a1_cfg$)
    a1_type$=stripval$(a1_cfg$)
    a1_cfg$=shift$(a1_cfg$)
    a1_htr$=a1_cfg$
    If a1_htr$ = "0" Then
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_1_HEATER_N_129)
    Else
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_1_130),conv_zone_present$(Val(a1_htr$)), \
      ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AND_CONFIGURED_131),Conv_therm_aux$(Val(a1_type$)),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HEATER_132)
    EndIf
    If GC_type$ = "68GC" Then
      a2_cfg$=SendModule$(GC_type$,"A2CW ?")
      a2_cfg$=stripcmd$(a2_cfg$)
      a2_type$=stripval$(a2_cfg$)
      a2_cfg$=shift$(a2_cfg$)
      a2_htr$=a2_cfg$
      If a2_htr$ = "0" Then
