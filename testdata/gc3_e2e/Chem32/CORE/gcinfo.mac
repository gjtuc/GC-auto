        db_htr$=stripval$(db_cfg$)
        db_cfg$=shift$(db_cfg$)
        db_epc$=stripval$(db_cfg$)
        db_cfg$=shift$(db_cfg$)
        db_cfg$=shift$(db_cfg$)
        db_cfg$=shift$(db_cfg$)
        db_cfg$=shift$(db_cfg$)
