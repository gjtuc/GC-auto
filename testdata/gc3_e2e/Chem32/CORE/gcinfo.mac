      Else
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_2_134),conv_zone_present$(Val(a2_htr$)), \
        ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AND_CONFIGURED_131),Conv_therm_aux$(Val(a2_type$)),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HEATER_132)
      EndIf
    EndIf
      
        
  ! Process Pneumatic AUX Information
    if gc_type$ = "68GC" then
      a3_cfg$=SendModule$(gc_type$,"A3CW ?")
      a3_cfg$=stripcmd$(a3_cfg$)
      a3_p_pres$=stripval$(a3_cfg$)
      If a3_p_pres$ = "1" Then
        a3_cfg$=shift$(a3_cfg$)
        a3_cfg$=shift$(a3_cfg$)
        a3_gas$=stripval$(a3_cfg$)
        a4_cfg$=SendModule$(gc_type$,"A4CW ?")
        a4_cfg$=shift$(a4_cfg$)
        a4_cfg$=shift$(a4_cfg$)
        a4_cfg$=shift$(a4_cfg$)
        a4_gas$=stripval$(a4_cfg$)
        a5_cfg$=SendModule$(gc_type$,"A5CW ?")
        a5_cfg$=shift$(a5_cfg$)
        a5_cfg$=shift$(a5_cfg$)
        a5_cfg$=shift$(a5_cfg$)
        a5_gas$=stripval$(a5_cfg$)
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES____PNEUMATIC_A_135)
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____AUX_3_136),conv_gas$(Val(a3_gas$)),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____AUX_4_137),\
        conv_gas$(Val(a4_gas$)),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____AUX_5_138),conv_gas$(Val(a5_gas$))
      Else
        print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____PNEUMATIC_139)
      EndIf
    EndIf
    
  ! Process Valve settings
    Print #33," "
    print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_CONFIGUR_140)
  !    Valve 1
    v1_cfg$=SendModule$(gc_type$,"V1CW ?")
    v1_cfg$=stripcmd$(v1_cfg$)
    v1_type$=stripval$(v1_cfg$)
    If v1_type$ <> "0" Then
      If v1_type$ = "2" Then
        v1_cfg$=shift$(v1_cfg$)
        v1_l_vol$=stripval$(v1_cfg$)
        v1_cfg$=shift$(v1_cfg$)
        v1_inlet$=stripval$(v1_cfg$)
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_1_TYPE_I_141),Val(v1_l_vol$),\
        ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v1_inlet$))
      Else
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_1_TYPE_I_143),Conv_valve_type$(Val(v1_type$))
      EndIf
    Else
      Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_1_NOT_IN_144)
    EndIf
    If gc_type$ = "68GC" Then
  !    Valve 2    
      v2_cfg$=SendModule$(gc_type$,"V2CW ?")
      v2_cfg$=stripcmd$(v2_cfg$)
      v2_type$=stripval$(v2_cfg$)
      If v2_type$ <> "0" Then
        If v2_type$ = "2" Then
          v2_cfg$=shift$(v2_cfg$)
          v2_l_vol$=stripval$(v2_cfg$)
          v2_cfg$=shift$(v2_cfg$)
          v2_inlet$=stripval$(v2_cfg$)
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_2_TYPE_I_145),Val(v2_l_vol$),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v2_inlet$))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_2_TYPE_I_146),Conv_valve_type$(Val(v2_type$))
        EndIf
      Else
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_2_NOT_IN_147)
      EndIf
  !    Valve 3
      v3_cfg$=SendModule$(gc_type$,"V3CW ?")
      v3_cfg$=stripcmd$(v3_cfg$)
      v3_type$=stripval$(v3_cfg$)
      If v3_type$ <> "0" Then
        If v3_type$ = "2" Then
          v3_cfg$=shift$(v3_cfg$)
          v3_l_vol$=stripval$(v3_cfg$)
          v3_cfg$=shift$(v3_cfg$)
          v3_inlet$=stripval$(v3_cfg$)
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_3_TYPE_I_148),Val(v3_l_vol$),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v3_inlet$))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_3_TYPE_I_149),Conv_valve_type$(Val(v3_type$))
        EndIf
      Else
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_3_NOT_IN_150)
      EndIf
  !    Valve 4
      v4_cfg$=SendModule$(gc_type$,"V4CW ?")
      v4_cfg$=stripcmd$(v4_cfg$)
      v4_type$=stripval$(v4_cfg$)
      If v4_type$ <> "0" Then
        If v4_type$ = "2" Then
          v4_cfg$=shift$(v4_cfg$)
          v4_l_vol$=stripval$(v4_cfg$)
          v4_cfg$=shift$(v4_cfg$)
          v4_inlet$=stripval$(v4_cfg$)
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_4_TYPE_I_151),Val(v4_l_vol$),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v4_inlet$))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_4_TYPE_I_152),Conv_valve_type$(Val(v4_type$))
        EndIf
      Else
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_4_NOT_IN_153)
      EndIf
  !    Valve 5
      v5_cfg$=SendModule$(gc_type$,"V5CW ?")
      v5_cfg$=stripcmd$(v5_cfg$)
      v5_type$=stripval$(v5_cfg$)
      If v5_type$ <> "0" Then
        If v5_type$ = "2" Then
          v5_cfg$=shift$(v5_cfg$)
          v5_l_vol$=stripval$(v5_cfg$)
          v5_cfg$=shift$(v5_cfg$)
          v5_inlet$=stripval$(v5_cfg$)
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_5_TYPE_I_154),Val(v5_l_vol$),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v5_inlet$))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_5_TYPE_I_155),Conv_valve_type$(Val(v5_type$))
        EndIf
      Else
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_5_NOT_IN_156)
      EndIf
  !    Valve 6
      v6_cfg$=SendModule$(gc_type$,"V6CW ?")
      v6_cfg$=stripcmd$(v6_cfg$)
      v6_type$=stripval$(v6_cfg$)
      If v6_type$ <> "0" Then
        If v6_type$ = "2" Then
          v6_cfg$=shift$(v6_cfg$)
          v6_l_vol$=stripval$(v6_cfg$)
          v6_cfg$=shift$(v6_cfg$)
          v6_inlet$=stripval$(v6_cfg$)
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_6_TYPE_I_157),Val(v6_l_vol$),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v6_inlet$))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_6_TYPE_I_158),Conv_valve_type$(Val(v6_type$))
        EndIf
      Else
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_6_NOT_IN_159)
      EndIf
  !    Valve 7
      v7_cfg$=SendModule$(gc_type$,"V7CW ?")
      v7_cfg$=stripcmd$(v7_cfg$)
      v7_type$=stripval$(v7_cfg$)
      If v7_type$ <> "0" Then
        If v7_type$ = "2" Then
          v7_cfg$=shift$(v7_cfg$)
          v7_l_vol$=stripval$(v7_cfg$)
          v7_cfg$=shift$(v7_cfg$)
          v7_inlet$=stripval$(v7_cfg$)
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_7_TYPE_I_160),Val(v7_l_vol$),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v7_inlet$))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_7_TYPE_I_161),Conv_valve_type$(Val(v7_type$))
        EndIf
      Else
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_7_NOT_IN_162)
      EndIf
  !    Valve 8
      v8_cfg$=SendModule$(gc_type$,"V8CW ?")
      v8_cfg$=stripcmd$(v8_cfg$)
      v8_type$=stripval$(v8_cfg$)
      If v8_type$ <> "0" Then
        If v8_type$ = "2" Then
          v8_cfg$=shift$(v8_cfg$)
          v8_l_vol$=stripval$(v8_cfg$)
          v8_cfg$=shift$(v8_cfg$)
          v8_inlet$=stripval$(v8_cfg$)
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_8_TYPE_I_163),Val(v8_l_vol$),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ML___CONNECTED_142),conv_gsv$(Val(v8_inlet$))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_8_TYPE_I_164),Conv_valve_type$(Val(v8_type$))
        EndIf
      Else
        Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VALVE_8_NOT_IN_165)
      EndIf
    EndIf
    
  ! Process Sampler Information
    a$=SendModule$(GC_type$,"CCPO 4")
    samp_cfg$=SendModule$(GC_type$,"04CONFIG")
    samp_cfg$=stripsampcmd$(samp_cfg$)
    If samp_cfg$[1:1] = ";" Then
      if gc_type$ = "68GC" then
        samp1$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_1_NOT_167)
      Else
        samp1$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_NOT_I_168)
      EndIf
      samp_cfg$=samp_cfg$[2:Len(samp_cfg$)]
    Else
      samp1$=stripval$(samp_cfg$[1:(Instr(samp_cfg$,";"))-1])
      samp_cfg$=samp_cfg$[Instr(samp_cfg$,";")+1:Len(samp_cfg$)]
    EndIf
    If samp_cfg$[1:1] = ";" Then
      samp2$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_2_NOT_169)
      samp_cfg$=samp_cfg$[2:Len(samp_cfg$)]
    Else
      samp2$=stripval$(samp_cfg$[1:(Instr(samp_cfg$,";"))-1])
      samp_cfg$=samp_cfg$[Instr(samp_cfg$,";")+1:Len(samp_cfg$)]
    EndIf
    If samp_cfg$[1:1] = "," Then
      cntrl$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_170)
      samp_cfg$=samp_cfg$[2:Len(samp_cfg$)]
    Else
      cntrl$=stripval$(samp_cfg$)
      samp_cfg$=shift$(samp_cfg$)
    EndIf
    tray$=stripval$(samp_cfg$)
    samp_cfg$=shift$(samp_cfg$)
    bcr$=shift$(samp_cfg$)
    print #33," "
    Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUTOSAMPLER_CO_171)
    If cntrl$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_170) Then
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUTOSAMPLER_NO_172)
    Else
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_CONTROLLER_FIR_173),cntrl$
      if GC_type$="68GC" then
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FRONT_INJECTOR_174),samp1$
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BACK_INJECTOR_175),samp2$
      Else
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_FIRMW_176),samp1$
      EndIf
    EndIf
    If gc_type$="68GC" Then
      If tray$ = "0" Then
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TRAY_NOT_INSTA_177)
      Else
        if cntrl$[1:5] <> "G1512" then
          T2614$=SendModule$(gc_type$,"04CPTR 00xxID")
          print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TRAY_FIRMWARE_178),T2614$[15:len(t2614$)]
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TRAY_IS_INSTAL_179)
        EndIf
      EndIf
      If bcr$ = "0" Then
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_180)
      Else
        If bcr$ = "2" Then
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_181)
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_182)
        EndIf
      EndIf
    EndIf
    a$=SendModule$(GC_type$,"CCPC 4")
  Else
    Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES______PARAMETER_183)
    Print #33, " "
    a$=SendModule$("GC","IC")
    If Len(a$)= 11 Then
      version=0   !series 1
    EndIf
    If Len(a$)= 16 Then
      version=1    !series II 2 chan
      print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SERIES_II__2_C_184)
    EndIf
    If Len(a$)= 20 Then
      version= 2  !series II 6 chan
      print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SERIES_II__6_C_185)
    EndIf 
    det_a$=cnv_det_5890$(val(a$[5:5]))
    det_b$=cnv_det_5890$(val(a$[6:6]))
    If val(a$[7:7]) = 0 Then
      flow_sensor$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FLOW_SENSOR_NO_186)
    Else
      flow_sensor$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FLOW_SENSOR_PR_187)
    EndIf
    If val(a$[8:8]) = 0 Then
      i_a_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_A_HEA_188)
    Else
      i_a_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_A_HEA_189)
    EndIf
    If val(a$[9:9]) = 0 Then
      d_a_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_A_HEA_190)
    Else
      d_a_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_A_HEA_191)
    EndIf
    If val(a$[10:10]) = 0 Then
      i_b_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_B_HEA_192)
    Else
      i_b_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_B_HEA_193)
    EndIf
    If val(a$[11:11]) = 0 Then
      d_b_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_B_HEA_194)
    Else
      d_b_zone$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_B_HEA_195)
    EndIf
    If version <>0 Then
      If Val(a$[12:12]) = 0 Then
        aux_gas$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_GAS_NOT_PR_196)
      Else
        aux_gas$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_GAS_PRESEN_197)
      EndIf
      If Val(a$[13:13]) = 0 Then
        epp_a$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_EPP_A_NOT_PRES_198)
      Else
        epp_a$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_EPP_A_PRESENT_199)
      EndIf
      If Val(a$[14:14]) = 0 Then
        epp_b$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_EPP_B_NOT_PRES_200)
      Else
        epp_b$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_EPP_B_PRESENT_201)
      EndIf
      If Val(a$[15:15]) = 0 Then
        inlet_a$="S/S"
      Else
        inlet_a$="PCOC"
      EndIf
      If Val(a$[16:16]) = 0 Then
        inlet_b$="S/S"
      Else
        inlet_b$="PCOC"
      EndIf
      If version = 2 Then
        If Val(a$[17:17]) = 0 Then
          Aux_f$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_F_NOT_PRES_202)
        Else
          aux_f$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_F_PRESENT_203)
        EndIf
        If Val(a$[18:18]) = 0 Then
          aux_e$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_E_NOT_PRES_204)
        Else
          aux_e$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_E_PRESENT_205)
        EndIf
        If Val(a$[19:19]) = 0 Then
          aux_d$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_D_NOT_PRES_206)
        Else
          aux_d$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_D_PRESENT_207)
        EndIf
        If Val(a$[20:20]) = 0 Then
          aux_c$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_C_NOT_PRES_208)
        Else
          aux_c$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUX_C_PRESENT_209)
        EndIf
      EndIf
    EndIf
    Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_A_210),det_a$
    Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_B_211),det_b$
    Print #33,flow_sensor$
    Print #33,i_a_zone$
    Print #33,i_b_zone$
    Print #33,d_a_zone$
    Print #33,d_b_zone$
    If version <>0 Then
      Print #33,aux_gas$
      Print #33,epp_a$
      Print #33,epp_b$
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INLET_A_IS_212),inlet_a$
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INLET_B_IS_213),inlet_b$
      If version = 2 Then
        Print #33,aux_c$
        Print #33,aux_d$
        Print #33,aux_e$
        Print #33,aux_f$
      EndIf
    EndIf
    
!  Check for autosampler
    If (testfordevice("INJ",0,"")) <> 0 Then
      samp_cfg$=SendModule$("INJ","CONFIG")
      samp_cfg$=strip73sampcmd$(samp_cfg$)
      If samp_cfg$[1:1] = ";" Then
        samp1$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_1_NOT_167)
        samp_cfg$=samp_cfg$[2:Len(samp_cfg$)]
      Else
        samp1$=stripval$(samp_cfg$[1:(Instr(samp_cfg$,";"))-1])
        samp_cfg$=samp_cfg$[Instr(samp_cfg$,";")+1:Len(samp_cfg$)]
      EndIf
      If samp_cfg$[1:1] = ";" Then
        samp2$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTOR_2_NOT_169)
        samp_cfg$=samp_cfg$[2:Len(samp_cfg$)]
      Else
        samp2$=stripval$(samp_cfg$[1:(Instr(samp_cfg$,";"))-1])
        samp_cfg$=samp_cfg$[Instr(samp_cfg$,";")+1:Len(samp_cfg$)]
      EndIf
      If samp_cfg$[1:1] = "," Then
        cntrl$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_170)
        samp_cfg$=samp_cfg$[2:Len(samp_cfg$)]
      Else
        cntrl$=stripval$(samp_cfg$)
        samp_cfg$=shift$(samp_cfg$)
      EndIf
      tray$=stripval$(samp_cfg$)
      samp_cfg$=shift$(samp_cfg$)
      bcr$=shift$(samp_cfg$)
      print #33," "
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUTOSAMPLER_CO_171)
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_CONTROLLER_FIR_173),cntrl$
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FRONT_INJECTOR_174),samp1$
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BACK_INJECTOR_175),samp2$
      If tray$ = "0" Then
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TRAY_NOT_INSTA_177)
      Else
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TRAY_IS_INSTAL_179)
      EndIf
      If bcr$ = "0" Then
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_180)
      Else
        If bcr$ = "2" Then
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_181)
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_182)
        EndIf
      EndIf
    Else
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AUTOSAMPLER_NO_172)
    EndIf
  EndIf
  close #33
!  ExecNoWait "NotePad "+_TEMPPATH$+"GCinfo.txt", 1

   cmdpath$ = chr$(34) +  _TEMPPATH$ + "GCinfo.txt" + chr$(34) 
   ExecNoWait "NotePad "+ cmdpath$, 1

Else
  Print ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_THIS_MACRO_ONL_214)
EndIf

Goto End
End:

endmacro

!  Strip the next value off of the string
Name stripval$
Parameter tempval$
  local stripped_val$
  if instr(tempval$,",")<>0 then
    Stripped_val$= tempval$[1:(Instr(tempval$,",")-1)]
  Else
    stripped_val$=tempval$
  EndIf
  Return stripped_val$
EndMacro

!  Shift the string to expose the next value
Name shift$
Parameter tempval$
  if instr(tempval$,",")<>0 then
    tempval$=tempval$[Instr(tempval$,",")+1:Len(tempval$)]
  Endif
  Return tempval$
EndMacro 

!  Strip the returned command off of the string
Name stripcmd$
Parameter tempval$
  tempval$=tempval$[6:Len(tempval$)]
  Return tempval$
EndMacro

!  Strip the returned sampler command off of the string
Name stripsampcmd$
Parameter tempval$
  tempval$=tempval$[10:Len(tempval$)]
  Return tempval$
EndMacro

!  Strip the returned sampler command off of the string
Name strip73sampcmd$
Parameter tempval$
  tempval$=tempval$[8:Len(tempval$)]
  Return tempval$
EndMacro

     
!  Convert the inlet code
Name conv_inlet$
Parameter Inlet_code

  local inlet$
  ID_ASTXDRIVERSMACFILES_UNKNOWN_215                 =  17215 
  ID_ASTXDRIVERSMACFILES_NONE_216                    =  17216  
  
NLSFileName_astxmac$ = "astxmac"

     inlet$= "---"
     if (inlet_code) = 0 then 
          Inlet$ = "P/P"
     endif
     if (inlet_code) = 1 then
          Inlet$ = "COC"
     endif
     if (inlet_code) = 2 then
          inlet$ = "S/S"
     endif
     if (inlet_code) = 3 then
          inlet$ = "PTV"
     endif
     if (inlet_code) = 4 then
          inlet$ = "P/P w/o EPC"
     endif
     if (inlet_code) = 5 then
          inlet$ = "COC w/o EPC"
     endif
     if (inlet_code) = 6 then
          inlet$ = "S/S w/o EPC"
     endif
     if (inlet_code) = 7 then
          inlet$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_UNKNOWN_215)
     endif
     if (inlet_code) = 8 then
          inlet$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NONE_216)
    EndIf
    If (Inlet_code) = 12 Then
      inlet$ = "PTV"
    EndIf
    If (Inlet_code) = 13 Then
      inlet$ = "AC Sim Dist"
    EndIf
      If (Inlet_code) = 16 Then
      inlet$ = "Volatile Inlet"
    EndIf
        
return Inlet$
EndMacro

!Convert the detector code for 68xx
Name conv_det$
Parameter Det_code
  local det$
  ID_ASTXDRIVERSMACFILES_NONE_216                    =  17216  
  NLSFileName_astxmac$ = "astxmac"
  
     det$="---"
     if (det_code) = 1 then
          Det$ = "FID"
     endif
     if (det_code) = 2 then
          Det$ = "TCD"
     endif
     if (det_code) = 3 then
          Det$ = "ECD"
     endif
     if (det_code) = 4 then
          Det$ = "NPD"
     endif
     if (det_code) = 5 then
          Det$ = "FPD"
     endif
     if (det_code) = 6 then
          Det$ = "AID"
     EndIf
     If (Det_code) = 7 Then
       Det$ = "uECD"
     EndIf
     If (Det_code) = 13 Then
       Det$ = "OEM AIB"
     EndIf
     If (Det_code) = 14 Then
       Det$ = "OEM FID"
     EndIf
     if (det_code) = 15 then
          Det$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NONE_216)
     endif
return Det$
EndMacro

