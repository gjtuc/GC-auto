EndMacro

!  Convert the utility gas code
Name conv_util_gas$
Parameter util_gas_code
  local util_gas$
  ID_ASTXDRIVERSMACFILES_UNKNOWN_215                 =  17215  
  ID_ASTXDRIVERSMACFILES_NITROGEN_227                =  17227  
  ID_ASTXDRIVERSMACFILES_HYDROGEN_228                =  17228  
  ID_ASTXDRIVERSMACFILES_HELIUM_229                  =  17229  
  ID_ASTXDRIVERSMACFILES_ARGON_METHANE_230           =  17230
  ID_ASTXDRIVERSMACFILES_OXYGEN_231                  =  17231  
  ID_ASTXDRIVERSMACFILES_AIR_232                     =  17232
  
  NLSFileName_astxmac$ = "astxmac"
  
     util_gas$="---"
     if (util_gas_code) = 0 then
          util_gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NITROGEN_227)
     endif
     if (util_gas_code) = 1 then
          util_gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HYDROGEN_228)
     endif
     if (util_gas_code) = 2 then
          util_gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HELIUM_229)
     endif
     if (util_gas_code) = 3 then
          util_gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ARGON_METHANE_230)
     endif
     if (util_gas_code) = 4 then
          util_gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OXYGEN_231)
     endif
     if (util_gas_code) = 5 then
          util_gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AIR_232)
     endif
     if (util_gas_code) = 6 then
          util_gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_UNKNOWN_215)
     endif
return util_gas$
endmacro
 
!  Convert the valve type code 
Name Conv_valve_type$
Parameter valve_type_code
Local valve_type$
  ID_ASTXDRIVERSMACFILES_NO_VALVE_239                =  17239 
  ID_ASTXDRIVERSMACFILES_MULTIPOSITION_240           =  17240 
  ID_ASTXDRIVERSMACFILES_GAS_SAMPLING_241            =  17241
  ID_ASTXDRIVERSMACFILES_SWITCHING_242               =  17242 
  ID_ASTXDRIVERSMACFILES_OTHER_243                   =  17243 
  
  NLSFileName_astxmac$ = "astxmac"
  
     valve_type$="---"
     if (valve_type_code) = 0 then
          valve_type$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_VALVE_239)
     endif
     if (valve_type_code) = 1 then
          valve_type$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MULTIPOSITION_240)
     endif
     if (valve_type_code) = 2 then
          valve_type$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_GAS_SAMPLING_241)
     endif
     if (valve_type_code) = 3 then
          valve_type$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SWITCHING_242)
     endif
     if (valve_type_code) = 4 then
          valve_type$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OTHER_243)
     endif
return valve_type$
endmacro

!  Convert the heated zone present code
Name conv_zone_present$
Parameter zone_present_code
Local zone_present$
  ID_ASTXDRIVERSMACFILES_HEATER_NOT_PRE_244          =  17244
  ID_ASTXDRIVERSMACFILES_MISSING_SENSOR_245          =  17245 
  ID_ASTXDRIVERSMACFILES_INVALID_HEATER_246          =  17246  
  ID_ASTXDRIVERSMACFILES_HEATER_PRESENT_247          =  17247  
  ID_ASTXDRIVERSMACFILES_HEATER_PRESENT_248          =  17248
  ID_ASTXDRIVERSMACFILES_HEATER_PRESENT_249          =  17249  
  
  NLSFileName_astxmac$ = "astxmac"
  
     zone_present$="---"
     if (zone_present_code) = 0 then
          zone_present$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HEATER_NOT_PRE_244)
     endif
     if (zone_present_code) = 1 then
          zone_present$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MISSING_SENSOR_245)
     endif
     if (zone_present_code) = 2 then
          zone_present$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INVALID_HEATER_246)
     endif
     if (zone_present_code) = 3 then
          zone_present$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HEATER_PRESENT_247)
     EndIf
     If (zone_present_code) = 7 Then
       zone_present$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HEATER_PRESENT_247)
     EndIf
     If (zone_present_code) = 11 Then
       zone_present$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HEATER_PRESENT_248)
     EndIf
     If (zone_present_code) = 19 Then
       zone_present$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HEATER_PRESENT_249)
     EndIf
     
return zone_present$
endmacro
!Convert the detector code for 5890
Name cnv_det_5890$
Parameter Det_code
Local det$
  ID_ASTXDRIVERSMACFILES_NOT_INSTALLED_250           =  17250  
  
  NLSFileName_astxmac$ = "astxmac"
  
     det$="---"
     if (det_code) = 0 then
          Det$ = "FID"
     endif
     if (det_code) = 1 then
          Det$ = "TCD"
     endif
     if (det_code) = 2 then
          Det$ = "NPD"
     endif
     if (det_code) = 3 then
          Det$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NOT_INSTALLED_250)
     endif
     if (det_code) = 4 then
          Det$ = "ECD"
     endif
     if (det_code) = 5 then
          Det$ = "FPD"
     EndIf
     If (Det_code) = 6 Then
       Det$ = "AIB"
     EndIf
return Det$
EndMacro

!Check to see if the GC is valid
Name Valid_GC
parameter xx
Local GC_Value
  GC_Value=0
  If (testfordevice("GC",0,""))<>0 Then
    GC_Value=1 !5890
  EndIf
  If (testfordevice("68GC",0,""))<>0 Then
    GC_Value=2 !6890
  EndIf
  If (testfordevice("6850GC",0,""))<>0 Then
    GC_Value=3 !6850
  EndIf
  If (testfordevice("7890",0,""))<>0 Then
    GC_Value=4 !7890
  EndIf
  Return GC_Value
EndMacro

