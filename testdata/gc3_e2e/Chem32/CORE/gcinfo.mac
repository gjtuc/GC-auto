ID_ASTXDRIVERSMACFILES_VALVE_7_NOT_IN_162          =  17162  
ID_ASTXDRIVERSMACFILES_VALVE_8_TYPE_I_163          =  17163  
ID_ASTXDRIVERSMACFILES_VALVE_8_TYPE_I_164          =  17164  
ID_ASTXDRIVERSMACFILES_VALVE_8_NOT_IN_165          =  17165    
ID_ASTXDRIVERSMACFILES_INJECTOR_1_NOT_167          =  17167  
ID_ASTXDRIVERSMACFILES_INJECTOR_NOT_I_168          =  17168  
ID_ASTXDRIVERSMACFILES_INJECTOR_2_NOT_169          =  17169  
ID_ASTXDRIVERSMACFILES_NO_170                      =  17170  
ID_ASTXDRIVERSMACFILES_AUTOSAMPLER_CO_171          =  17171  
ID_ASTXDRIVERSMACFILES_AUTOSAMPLER_NO_172          =  17172  
ID_ASTXDRIVERSMACFILES_CONTROLLER_FIR_173          =  17173  
ID_ASTXDRIVERSMACFILES_FRONT_INJECTOR_174          =  17174  
ID_ASTXDRIVERSMACFILES_BACK_INJECTOR_175           =  17175  
ID_ASTXDRIVERSMACFILES_INJECTOR_FIRMW_176          =  17176  
ID_ASTXDRIVERSMACFILES_TRAY_NOT_INSTA_177          =  17177  
ID_ASTXDRIVERSMACFILES_TRAY_FIRMWARE_178           =  17178  
ID_ASTXDRIVERSMACFILES_TRAY_IS_INSTAL_179          =  17179  
ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_180          =  17180  
ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_181          =  17181  
ID_ASTXDRIVERSMACFILES_BAR_CODE_READE_182          =  17182  
ID_ASTXDRIVERSMACFILES______PARAMETER_183          =  17183  
ID_ASTXDRIVERSMACFILES_SERIES_II__2_C_184          =  17184  
ID_ASTXDRIVERSMACFILES_SERIES_II__6_C_185          =  17185  
ID_ASTXDRIVERSMACFILES_FLOW_SENSOR_NO_186          =  17186  
ID_ASTXDRIVERSMACFILES_FLOW_SENSOR_PR_187          =  17187  
ID_ASTXDRIVERSMACFILES_INJECTOR_A_HEA_188          =  17188  
ID_ASTXDRIVERSMACFILES_INJECTOR_A_HEA_189          =  17189  
ID_ASTXDRIVERSMACFILES_DETECTOR_A_HEA_190          =  17190  
ID_ASTXDRIVERSMACFILES_DETECTOR_A_HEA_191          =  17191  
ID_ASTXDRIVERSMACFILES_INJECTOR_B_HEA_192          =  17192  
ID_ASTXDRIVERSMACFILES_INJECTOR_B_HEA_193          =  17193  
ID_ASTXDRIVERSMACFILES_DETECTOR_B_HEA_194          =  17194  
ID_ASTXDRIVERSMACFILES_DETECTOR_B_HEA_195          =  17195  
ID_ASTXDRIVERSMACFILES_AUX_GAS_NOT_PR_196          =  17196  
ID_ASTXDRIVERSMACFILES_AUX_GAS_PRESEN_197          =  17197  
ID_ASTXDRIVERSMACFILES_EPP_A_NOT_PRES_198          =  17198  
ID_ASTXDRIVERSMACFILES_EPP_A_PRESENT_199           =  17199  
ID_ASTXDRIVERSMACFILES_EPP_B_NOT_PRES_200          =  17200  
ID_ASTXDRIVERSMACFILES_EPP_B_PRESENT_201           =  17201  
ID_ASTXDRIVERSMACFILES_AUX_F_NOT_PRES_202          =  17202  
ID_ASTXDRIVERSMACFILES_AUX_F_PRESENT_203           =  17203  
ID_ASTXDRIVERSMACFILES_AUX_E_NOT_PRES_204          =  17204  
ID_ASTXDRIVERSMACFILES_AUX_E_PRESENT_205           =  17205  
ID_ASTXDRIVERSMACFILES_AUX_D_NOT_PRES_206          =  17206  
ID_ASTXDRIVERSMACFILES_AUX_D_PRESENT_207           =  17207  
ID_ASTXDRIVERSMACFILES_AUX_C_NOT_PRES_208          =  17208  
ID_ASTXDRIVERSMACFILES_AUX_C_PRESENT_209           =  17209  
ID_ASTXDRIVERSMACFILES_DETECTOR_A_210              =  17210  
ID_ASTXDRIVERSMACFILES_DETECTOR_B_211              =  17211  
ID_ASTXDRIVERSMACFILES_INLET_A_IS_212              =  17212  
ID_ASTXDRIVERSMACFILES_INLET_B_IS_213              =  17213  
ID_ASTXDRIVERSMACFILES_THIS_MACRO_ONL_214          =  17214  
ID_ASTXDRIVERSMACFILES_USE_LMD_SOFTWARE_313             = 17313						
ID_ASTXDRIVERSMACFILES_7890_INFO_314									  = 17314
ID_ASTXDRIVERSMACFILES_CONFIGURED_GC_NOT_SUPPORTED_315	= 17315
ID_ASTXDRIVERSMACFILES_7890_INVALID_GC_316							= 17316


NLSFileName_astxmac$ = "astxmac"
  
! Is this an online GC session?
If ((_license$ = "GC") And (_OFFLINE = 0)) Then
  
  If Valid_GC(retval) = 4 Then
    !RetVal=Alert("Please use the LMD software to obtain information about the 7890 GC",2,"7890 Information")
    RetVal=Alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_USE_LMD_SOFTWARE_313),2, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_7890_INFO_314))
    Goto end
  EndIf
  If Valid_GC(retval) = 0 Then
    !RetVal=Alert("Configured GC is not supported for information",3,"Invalid GC")
     RetVal=Alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_CONFIGURED_GC_NOT_SUPPORTED_315),3, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_7890_INVALID_GC_316))
    Goto end
  EndIf
  
didErr=0
On Error didErr=1

! Yes it is, proceed  
  Open _TEMPPATH$+"GCinfo.txt" For output as #33
  ! Was there a problem opening the output file?
  If(didErr=1) Then
    ! Yes, try to close it
    didErr=0
    Close #33
    ! Was there a problem closing the output file?
    If(didErr=0) Then
      ! No, now open it
      Open _TEMPPATH$+"GCinfo.txt" For output as #33
    Else
      ! Yes, Tilt and get out
      RetVal=Alert("ERROR *** Filenum 33 is inaccessable",3,"File Open Problem")
      Goto end
    EndIf
  EndIf

!   
! What kind of a GC are we talking to?
!
  if (testfordevice("GC",0,"")) = 0 then !Is it not a 5890?
    if (testfordevice("68GC",0,"")) <> 0 then  !Is it a 6890?
      GC_type$ = "68GC"
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES______PARAMETER_86)
    else                                       !Must be a 6850
      GC_type$ = "6850GC"
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES______PARAMETER_87)
    endif
    print #33, " "
    wfi$ = SendModule$ (GC_type$, "CCIW ?")
    wfi$=shift$(wfi$)
    wfi$=shift$(wfi$)
    wfi$=shift$(wfi$)
    wfi$=shift$(wfi$)
    Ser_num$=stripval$(wfi$)
    print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SERIAL_NUMBER_88),ser_num$
    ID$ = SendModule$ (GC_type$, "CCID")
    id$=stripcmd$(id$)
    Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FIRMWARE_REVIS_89),ID$
    PU_cfg$ = SendModule$ (GC_type$, "GCPU ?")
    pu_cfg$=stripcmd$(pu_cfg$)
    pu_factor=68947.57
    If pu_cfg$ = "1" Then
      pu_factor=1000000
    EndIf
    If pu_cfg$ = "2" Then
      pu_factor=10000
    EndIf
    Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESSURE_UNITS_90), conv_pu$(val(PU_cfg$))
      
        
  ! Process oven information     
    OV_cfg$ = SendModule$ (GC_type$, "OVCW ?")
    ov_cfg$ = stripcmd$(ov_cfg$)     
    ov_type$=stripval$(OV_cfg$)
    OV_cfg$=shift$(ov_cfg$)
    ov_cfg$=shift$(ov_cfg$)
    cryo_type$=stripval$(ov_cfg$)
    ov_cfg$=shift$(ov_cfg$)
    ov_max$=ov_cfg$
    print #33," "
    Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OVEN_PARAMETER_91)
    oven_type$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_REGULAR_OVEN_92)
    If ov_type$ = "0" Then
      oven_type$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FAST_OVEN_93)
    endif
    Print #33,oven_type$,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES____CRYO_94),(Conv_cryo$(Val(cryo_type$))),\
    ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___OVEN_MAX_95),ov_max$,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DEGREES_96)
      
  ! Process Inlet information
    Print #33," "
    If gc_type$ = "68GC" Then
      Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FRONT_INLET_CO_97)
    Else
      Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INLET_CONFIGUR_98)
    EndIf
    IF_cfg$ = SendModule$ (GC_type$, "IFCW ?")
    if_cfg$=stripcmd$(if_cfg$)
    if_type$=stripval$(if_cfg$)
    if_cfg$=shift$(if_cfg$)
    if_htr$=stripval$(if_cfg$)
    if_cfg$=shift$(if_cfg$)
    if_epc$=stripval$(if_cfg$)
    if_cfg$=shift$(if_cfg$)
    if_pres$=stripval$(if_cfg$)
    if_cfg$=shift$(if_cfg$)
    if_gas$=stripval$(if_cfg$)
    if__cfg$=conv_inlet$(Val(if_type$))
    if__htr$=conv_zone_present$(Val(if_htr$))
    if__epc$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NOT_PRESENT_99)
    If if_epc$ = "1" Then
      if__epc$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESENT_100)
    EndIf
    if__pres=(Val(if_pres$)/pu_factor)
    if__gas$=conv_gas$(Val(if_gas$))
    Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INLET_TYPE_101),if__cfg$,"| EPC",if__epc$,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___CARRIER_IS_102),if__gas$
    print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MAX_PRESSURE_103),trunc(if__pres),Conv_pu$(Val(PU_cfg$)),\
    ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___HEATER_ZONE_104),if__htr$
    If GC_type$ = "68GC" Then
      print #33," "
      Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_REAR_INLET_CON_105)
      IB_cfg$ = SendModule$ (GC_type$, "IBCW ?")
      ib_cfg$=stripcmd$(ib_cfg$)
      ib_type$=stripval$(ib_cfg$)
      ib_cfg$=shift$(ib_cfg$)
      ib_htr$=stripval$(ib_cfg$)
      ib_cfg$=shift$(ib_cfg$)
      ib_epc$=stripval$(ib_cfg$)
      ib_cfg$=shift$(ib_cfg$)
      ib_pres$=stripval$(ib_cfg$)
      ib_cfg$=shift$(ib_cfg$)
      ib_gas$=stripval$(ib_cfg$)
      ib__cfg$=conv_inlet$(Val(ib_type$))
      ib__htr$=conv_zone_present$(Val(ib_htr$))
      ib__epc$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NOT_PRESENT_99)
      If ib_epc$ = "1" Then
        ib__epc$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESENT_100)
      EndIf
      ib__pres=(Val(ib_pres$)/pu_factor)
      ib__gas$=conv_gas$(Val(ib_gas$))
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INLET_TYPE_101),ib__cfg$,"| EPC",ib__epc$,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___CARRIER_IS_102),ib__gas$
      print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MAX_PRESSURE_103),trunc(ib__pres),Conv_pu$(Val(PU_cfg$)),\
      ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___HEATER_ZONE_104),ib__htr$
    EndIf
        
  ! Process column information 
    Print #33," "
    If gc_type$ = "68GC" Then
      Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_COLUMN_1_CONFI_106)
    Else
      Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_COLUMN_CONFIGU_107)
    EndIf
    C1_cfg$ = SendModule$ (GC_type$, "C1CW ?")
    c1_cfg$=stripcmd$(c1_cfg$)
    c1_length$=stripval$(c1_cfg$)
    c1_cfg$=shift$(c1_cfg$)
    c1_dia$=stripval$(c1_cfg$)
    c1_cfg$=shift$(c1_cfg$)
    c1_f_thick$=stripval$(c1_cfg$)
    c1_cfg$=shift$(c1_cfg$)
    c1_in$=stripval$(c1_cfg$)
    c1_cfg$=shift$(c1_cfg$)
    c1_out$=stripval$(c1_cfg$)
    c1_cfg$=shift$(c1_cfg$)
    c1_opcv$=stripval$(c1_cfg$)
    c1_cfg$=shift$(c1_cfg$)
    c1_vac$=stripval$(c1_cfg$)
    c1_cfg$=shift$(c1_cfg$)
    c1_opc$=stripval$(c1_cfg$)
    if c1_in$ <> "5" then
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_LENGTH_108),(Val(c1_length$)/100),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_METERS__DIAMET_109),\
      Val(c1_dia$),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_UM__FILM_THICK_110),(Val(c1_f_thick$)/100),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_UM_111)
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VACUUM_CORRECT_112),(Conv_on_off$(Val(c1_vac$)))
      If c1_opc$ = "0" Then
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESSURE_CORRE_113),(Conv_on_off$(Val(c1_opc$)))
      Else
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESSURE_CORRE_113),(Conv_on_off$(Val(c1_opc$))),\
        ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___PRESSURE_COR_114),(Val(c1_opcv)/pu_factor),\
        Conv_pu$(Val(pu_cfg$))
      EndIf
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_COLUMN_IN_115),Conv_col_in$(Val(c1_in$)),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___COLUMN_OUT_116),\
      Conv_col_det$(Val(c1_out$))
    Else
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____COLUMN_1_N_117)
    EndIf
    
    If GC_type$ = "68GC" Then
      print #33," "
      Print #33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_COLUMN_2_CONFI_118)
      C2_cfg$ = SendModule$ (GC_type$, "C2CW ?")
      c2_cfg$=stripcmd$(c2_cfg$)
      c2_length$=stripval$(c2_cfg$)
      c2_cfg$=shift$(c2_cfg$)
      c2_dia$=stripval$(c2_cfg$)
      c2_cfg$=shift$(c2_cfg$)
      c2_f_thick$=stripval$(c2_cfg$)
      c2_cfg$=shift$(c2_cfg$)
      c2_in$=stripval$(c2_cfg$)
      c2_cfg$=shift$(c2_cfg$)
      c2_out$=stripval$(c2_cfg$)
      c2_cfg$=shift$(c2_cfg$)
      c2_opcv$=stripval$(c2_cfg$)
      c2_cfg$=shift$(c2_cfg$)
      c2_vac$=stripval$(c2_cfg$)
      c2_cfg$=shift$(c2_cfg$)
      c2_opc$=stripval$(c2_cfg$)
      if c2_in$ <> "5" then
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_LENGTH_108),(Val(c2_length$)/100),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_METERS__DIAMET_109),\
        Val(c2_dia$),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_UM__FILM_THICK_110),(Val(c2_f_thick$)/100),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_UM_111)
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VACUUM_CORRECT_112),(Conv_on_off$(Val(c2_vac$)))
        If c2_opc$ = "0" Then
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESSURE_CORRE_113),(Conv_on_off$(Val(c2_opc$)))
        Else
          Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESSURE_CORRE_113),(Conv_on_off$(Val(c2_opc$))),\
          ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___PRESSURE_COR_114),(Val(c2_opcv)/pu_factor),\
          Conv_pu$(Val(pu_cfg$))
        EndIf
        Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_COLUMN_IN_115),Conv_col_in$(Val(c2_in$)),ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___COLUMN_OUT_116),\
        conv_col_det$(val(c2_out$))
      Else
            Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____COLUMN_2_N_119)
      EndIf
    EndIf
      
  ! Process Detector information
    print #33," "
    If gc_type$="68GC" Then
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_FRONT_DETECTOR_120)
    Else
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_CONFI_121)
    EndIf
    DF_cfg$ = SendModule$ (GC_type$, "DFCW ?")
    df_cfg$=stripcmd$(df_cfg$)
    df_type$=stripval$(df_cfg$)
    if df_type$ <> "15" then
      df_cfg$=shift$(df_cfg$)
      df_htr$=stripval$(df_cfg$)
      df_cfg$=shift$(df_cfg$)
      df_epc$=stripval$(df_cfg$)
      df_cfg$=shift$(df_cfg$)
      df_cfg$=shift$(df_cfg$)
      df_cfg$=shift$(df_cfg$)
      df_cfg$=shift$(df_cfg$)
      df_u_gas$=stripval$(df_cfg$)
      df_cfg$=shift$(df_cfg$)
      df_m_gas$=df_cfg$
      df__type$=conv_det$(Val(df_type$))
      df__htr$=conv_zone_present$(Val(df_htr$))
      df__epc$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NOT_PRESENT_99)
      If df_epc$ = "1" Then
        df__epc$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRESENT_100)
      EndIf
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DETECTOR_TYPE_122),df__type$,"| EPC",df__epc$,\
      ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___HEATER_ZONE_104),df__htr$
      If ((df__type$="FID")Or(df__type$="NPD")Or(df__type$="FPD"))Then
        Print#33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MAKE_UP_GAS_123),conv_makeup_gas$(Val(df_m_gas$)),\
        ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES___UTILITY_GAS_124),conv_util_gas$(Val(df_u_gas$))
