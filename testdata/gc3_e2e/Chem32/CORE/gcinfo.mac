!  Convert the carrier gas code
Name conv_gas$
Parameter gas_code
  local gas$
  ID_ASTXDRIVERSMACFILES_UNKNOWN_215                 =  17215  
  ID_ASTXDRIVERSMACFILES_NOT_CONFIGURED_226          =  17226  
  ID_ASTXDRIVERSMACFILES_NITROGEN_227                =  17227  
  ID_ASTXDRIVERSMACFILES_HYDROGEN_228                =  17228  
  ID_ASTXDRIVERSMACFILES_HELIUM_229                  =  17229  
  ID_ASTXDRIVERSMACFILES_ARGON_METHANE_230           =  17230  
  ID_ASTXDRIVERSMACFILES_OXYGEN_231                  =  17231  
  ID_ASTXDRIVERSMACFILES_AIR_232                     =  17232
  ID_ASTXDRIVERSMACFILES_ARGON_233                   =  17233
  
  NLSFileName_astxmac$ = "astxmac"
  
  
     Gas$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NOT_CONFIGURED_226)
     if (gas_code) = 0 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NITROGEN_227)
     endif
     if (gas_code) = 1 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HYDROGEN_228)
     endif
     if (gas_code) = 2 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_HELIUM_229)
     endif
     if (gas_code) = 3 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ARGON_METHANE_230)
     endif
     if (gas_code) = 4 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OXYGEN_231)
     endif
     if (gas_code) = 5 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_AIR_232)
     endif
     if (gas_code) = 6 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ARGON_233)
     endif
     if (gas_code) = 7 then
          gas$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_UNKNOWN_215)
     endif
return gas$
EndMacro

