        Print#33, ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_MAKE_UP_GAS_123),conv_makeup_gas$(Val(df_m_gas$))
      EndIf
    Else
      Print #33,ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_____FRONT_DETE_125)
