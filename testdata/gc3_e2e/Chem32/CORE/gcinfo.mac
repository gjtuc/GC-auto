
!********************************************************
!     List GC parameters for 6850,6890 and 5890
!
!
!********************************************************
!  $Header: /cag/DRIVERS/leodef/gc/misc/GCinfo.mac 1.7 2003-04-30 11:32:06-07 lindalin Exp $
!     Rev 0 (14-Apr-03) Original release
!     Rev 1 (17-Apr-03) Added reporting of G2614 tray firmware
!     Rev 2 (22-Apr-03) Checks for online GC session before proceeding
!     Rev 3 (25-Apr-03) Declared 'Local' for all variables
!     Rev 4 (27-Feb-07) Added code to handle 7890 and Gen GC
!     Rev 5 (21-Mar-07) Added code to handle File #33 already open
!
!********************************************************
!  This macro is to be run from within an instrument session
!  and will interrogate the GC and ALS for the current settings.
!
!  The macro will work for 5890 series I, II with 2 and 6
!  channel EPP, 6890A/N and 6850.
! 
!  The 5890 will report the physical setup
!  The 6890/6850 will report the setup as currently defined
!  in the method.
!
!  The 7890 detection will alert the user to use the LMD software for help
!
!  If none of the above, an alert will be shown to declare non-support
!
!
!  The autosamplers will report the firmware revisions of each
!  autosampler and the controller.  It will also report the
!  presence of a tray and bar code reader.
!
!*********************************************************
!  Louis James
!  Technical Support Engineer
!  Little Falls Site
!  Telnet 633-8308  FAX 302-T633-8913
!  louis_james@agilent.com 
!*********************************************************
!  To run:
!  macro "gcinfo.mac" ,go
!    or
!    macro "gcinfo.mac"
!    gcinfo
!*********************************************************

Name GCinfo
Local wfi$,ser_num$,id$,gc_type$,pu_cfg$,pu_factor,ov_cfg$,ov_type$,ov_max$
Local cryo_type$,if_cfg$,if_type$,if_htr$,if_epc$,if_pres$,if_gas$,if__cfg$
Local if__htr$,if__epc$,if__pres,if__gas$,ib_cfg$,ib_type$,ib_htr$,ib_epc$
Local ib_pres$,ib_gas$,ib__cfg$,ib__htr$,ib__epc$,ib__pres$,ib__gas$,c1_cfg$
Local c1_length$,c1_dia$,c1_f_thick$,c1_in$,c1_out$,c1_opcv$,c1_vac$,c1_opc$
Local c2_length$,c2_dia$,c2_f_thick$,c2_in$,c2_out$,c2_opcv$,c2_vac$,c2_opc$
Local c2_cfg$,df_cfg$,df_type$,df_htr$,df_epc$,df_u_gas$,df_m_gas$,df__type$
Local df__htr$,df__epc$,db_cfg$,db_type$,db_htr$,db_epc$,db_u_gas$,db_m_gas$
Local db__type$,db__htr$,db__epc$,a1_cfg$,a1_type$,a1_htr$,a2_cfg$,a2_type$
Local a2_htr$,a3_cfg$,a4_cfg$,a5_cfg$,a3_gas$,a4_gas$,a5_gas$,a3_p_pres$
Local v1_cfg$,v2_cfg$,v3_cfg$,v4_cfg$,v5_cfg$,v6_cfg$,v7_cfg$,v8_cfg$
Local v1_type$,v2_type$,v3_type$,v4_type$,v5_type$,v6_type$,v7_type$,v8_type$
Local v1_l_vol$,v2_l_vol$,v3_l_vol$,v4_l_vol$,v5_l_vol$,v6_l_vol$,v7_l_vol$
Local v8_l_vol$,v1_inlet$,v2_inlet$,v3_inlet$,v4_inlet$,v5_inlet$,v6_inlet$
Local v7_inlet$,v8_inlet$,samp_cfg$,samp1$,samp2$,cntrl$,tray$,bcr$,t2614$
Local a$,version,det_a$,det_b$,flow_sensor$,i_a_zone$,i_b_zone$,d_a_zone$
Local d_b_zone$,aux_gas$,epp_a$,epp_b$,inlet_a$,inlet_b$,aux_c$,aux_d$
Local aux_e$,aux_f$,oven_type$,RetVal,didErr

ID_ASTXDRIVERSMACFILES______PARAMETER_86           =  17086
ID_ASTXDRIVERSMACFILES______PARAMETER_87           =  17087
ID_ASTXDRIVERSMACFILES_SERIAL_NUMBER_88            =  17088
