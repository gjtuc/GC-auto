name SelectNewFileDir$

    parameter title$, initpath$ default "", initdir$ default ""

    ! Select the new directory for the file(s)
    local button, fstat

    if initpath$ = "" then
	initpath$ = _datapath$
    endif

    fstat = 0

    while fstat <> 2 do
	button = SelectFile(2,Title$,,initpath$,initdir$,fstat)

        ! button = 0; Cancel
        ! button = 1; path AND file unchanged
        ! button = 2; path OR  file did change
        ! fstat  = 0; does not exist
        ! fstat  = 1; is a file
        ! fstat  = 2; is a directory

        if button = 0 then
	   return ""
	endif
    endwhile
    return initpath$+initdir$
endmacro     ! SelectNewFileDir$


name Import3365File

     parameter  newpath$ default "", path$ default "", file$ default ""
     local button, fstat, offset, FileParmsError, cutpoint,chksum, dummy
     local currpath$, currfile$, newfile$, tempdir$, tempfile$, savepath$

   ID_PHX3DSUPPORTFILES__DOES_NOT_EXIS_23             =  17023  
   ID_PHX3DSUPPORTFILES_FILENAME_AND_D_41             =  17041  
   ID_PHX3DSUPPORTFILES_IMPORT_DATA_FI_42             =  17042  
   ID_PHX3DSUPPORTFILES_HP3365_DATA_FI_43             =  17043  
   ID_PHX3DSUPPORTFILES_SELECT_NEW_PAT_44             =  17044  
   ID_PHX3DSUPPORTFILES_IMPORT_HP3365_45              =  17045  
   ID_PHX3DSUPPORTFILES_HP3365_DATA_FI_46             =  17046  
   ID_PHX3DSUPPORTFILES__IS_NOT_A___D_47              =  17047  
   ID_PHX3DSUPPORTFILES_NEW_DATA_PATH_48              =  17048  
   ID_PHX3DSUPPORTFILES_IMPORT_HP3365_49              =  17049  
   ID_PHX3DSUPPORTFILES_DIRECTORY_50                  =  17050  
   ID_PHX3DSUPPORTFILES__ALREADY_EXIST_51             =  17051  
   ID_PHX3DSUPPORTFILES_DIRECTORY_52                  =  17052  
   ID_PHX3DSUPPORTFILES__ALREADY_EXIST_53             =  17053  
   ID_PHX3DSUPPORTFILES_DIRECTORY_ALRE_54             =  17054  
   ID_PHX3DSUPPORTFILES_HP3365_DATA_FILE_217          =  17217
NLSFileName_phx3dsupport$="phx3dsupport"
     
	 if len(path$) = 0 AND len(file$) = 0
	if newpath$ = "" then
	    newpath$ = _DataPath$
	endif
	if DialogExists("dImportSingle") = 0 then
	    ! display dialog box for selecting paths 
            LoadDialog  NLSCoreMacDLL$, "dImportSingle", "dImportSingle"
	    EditBoxParm 10001, file$,1
	    EditBoxParm 10004,newpath$,1
            enddialog
	endif

	IdNumber = 10002
	while IdNumber > 1 do
ReDisplay:
	    IdNumber=showDialog("dImportSingle")
            if IdNumber = 1 then
               if len(file$) = 0 OR len(newpath$) = 0 then
                   dummy = alert (ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_FILENAME_AND_D_41),3)
                   goto ReDisplay
               endif
            endif 
	    if IdNumber = 10002 then
               savepath$ = file$
	        cutpoint = cutpath(file$)
	        if (cutpoint <= 0) then
	            path$ = file$
		    file$ = ""
	        else
	            path$ = file$[1:cutpoint]
		    file$ = file$[cutpoint+1:len(file$)]
                endif
	        button = selectfile(1, ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_IMPORT_DATA_FI_42),ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_HP3365_DATA_FILE_217),path$,file$,fstat)
                if button = 0
	            file$=savepath$
	        else
		    file$ = path$+file$
	        endif
            else
		if IdNumber = 10003 then
		    savepath$ = newpath$
		    if newpath$ = "" then 
	                cutpoint = cutpath(file$)
			if cutpoint > 0 then
			    newpath$ = file$[1:cutpoint]
			else
			    newpath$ = file$
		        endif
		    endif
		    cutpoint = cutpath(newpath$)
		    if cutpoint > 0 then
		        tempdir$ = newpath$[1:cutpoint]
			tempfile$ = newpath$[cutpoint+1:len(newpath$)]
			tempfile$ = RemoveSlash$(tempfile$)
		    else
			tempdir$ = path$
			tempfile$= ""
		    endif
		    newpath$ = SelectNewFileDir$(ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_SELECT_NEW_PAT_44),tempdir$,tempfile$)
		    if newpath$ = "" then
		        newpath$ = savepath$
		    endif
		endif
	    endif
	endwhile
        removedialog("dImportSingle")
	if IdNumber = 0 then
	   print ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_IMPORT_HP3365_45)
	   return 1
        endif
	cutpoint = cutpath(file$)
	if (cutpoint <= 0) then
	    path$ = file$
	    file$ = ""
	else
	    path$ = file$[1:cutpoint]
	    file$ = file$[cutpoint+1:len(file$)]
        endif
     else
        ! at least one param given - don't show SelectFile box
        if len(path$) = 0
           path$ = _datapath$
        endif
        if len(file$) = 0
           file$ = _datafile$
        endif
     endif

     path$ = RemoveSlash$(path$)
     if filestat(MODE, path$ + "\" + file$) <> 1   ! not a file
        print ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_HP3365_DATA_FI_46) + file$ + ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES__DOES_NOT_EXIS_23)
        return 1
     else
	offset = instr(file$,".D")
	if (offset = 0)
            print file$ + ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES__IS_NOT_A___D_47)
            return 1
        else
            ! file exists
	    newfile$ = file$[1:offset - 1]
            currpath$ = _datapath$
            currfile$ = _datafile$

	    if newpath$ = "" then
		cutpoint = cutpath(path$)
		if cutpoint > 0 then
		    tempdir$ = path$[1:cutpoint]
		    tempfile$ = path$[cutpoint+1:len(path$)]
		    tempfile$ = RemoveSlash$(tempfile$)
		else
		    tempdir$ = path$
		    tempfile$= ""
		endif
		newpath$ = SelectNewFileDir$(ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_NEW_DATA_PATH_48) + newfile$ + ": ",tempdir$,tempfile$)

		if newpath$ = "" then
		   print ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_IMPORT_HP3365_49)
		   return 1
		endif
	    endif
	    if newpath$[len(newpath$)] <> "\" then
	        newpath$ = newpath$ + "\"
	    endif
         endif
     
     if FileStat(MODE, NewPath$ + File$) <> -1 Then

         if Option3365 = 1 then
             message ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIRECTORY_50) + NewPath$ + File$ + ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES__ALREADY_EXIST_51)
         else
             message ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIRECTORY_52) + NewPath$ + File$ + ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES__ALREADY_EXIST_53)
             if (alert(ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIRECTORY_ALRE_54),4) = 0) then
                 return 0
             endif 
          
         endif
         
     else

         MkDir NewPath$ + file$

         Detector = GetDetectorNumber(File$,Path$)

         ChFile$ = "ADC"
         if Detector = 1 then
	     ChFile$ = "TCD"
	 endif
	 if Detector = 2 then
	     ChFile$ = "FID"
	 endif
	 if Detector = 3 then
	     ChFile$ = "ECD"
	 endif
	 if Detector = 4 then
	     ChFile$ = "NPD"
	 endif
	 if Detector = 5 then
	     ChFile$ = "FPD"
	 endif
	 if Detector = 6 then
	     ChFile$ = "AIB"
	 endif

        Copy Path$ + "\" + File$, NewPath$ + File$ + "\" + ChFile$ + "1A.CH"
        if Option3365 = 1 
            LoadFile NewPath$ + File$
        endif
    endif
endif 
return 1  
	    
endmacro  ! Import3365File


name ImportAllLoop

    parameter fromdir$,todir$
    local done, position, datafile$, filelist$

    ! Iterate through the list of .d's in fromdir$
    ! and import each of them into todir$

    filelist$ =  findfile$(RemoveSlash$(fromdir$)+"\*.d","N") 
    done=0
    if filelist$ = "" then
       done=1
    endif

    while done = 0 do
        position = instr(filelist$,"|")
	if (position = 0) then
	   done = 1
	   datafile$ = filelist$
	else
	   datafile$ = filelist$[1:position-1]
	   filelist$ = filelist$[position+1:len(filelist$)]
        endif

	if datafile$="" then
	    done=1
	else
	    if (Import3365File (todir$, fromdir$, datafile$) = 0) then
                return
            endif
	endif
    endwhile
endmacro     ! ImportAllLoop


name ImportAllFiles

    ! Select the .d directory and iterate through the list of files

    
    local button, path$, fstat, dummy
    local fromdir$, newdir$
    local temppath$, tempdir$
    ID_PHX3DSUPPORTFILES_DIRECTORIES_MU_55             =  17055  
    ID_PHX3DSUPPORTFILES_IMPORT_FROM_DA_56             =  17056  
    ID_PHX3DSUPPORTFILES_DIRECTORY_FOR_57              =  17057  
    ID_PHX3DSUPPORTFILES_IMPORT_HP3365_58              =  17058  
    NLSFileName_phx3dsupport$="phx3dsupport"
    fromdir$ = ""
    newdir$ = ""


 
    if DialogExists("dImportAll") = 0 then

	! display dialog box for selecting paths 
        LoadDialog  NLSCoreMacDLL$, "dImportAll", "dImportAll"
	EditBoxParm 10001,fromdir$,1
	EditBoxParm 10004,newdir$,1
	endDialog 
    endif

    IdNumber = 10002
    while IdNumber > 1 do

ReDisplay:	

        IdNumber=showDialog("dImportAll")
        if IdNumber = 1 then
            if len(fromdir$) = 0 OR len(newdir$) = 0 then
                dummy = alert (ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIRECTORIES_MU_55),3)
                goto ReDisplay
            endif
        endif  
	if IdNumber = 10002 then
	    tempdir$ = fromdir$
	else
	    tempdir$ = newdir$
	endif

	if IdNumber > 1 then
	    cutpoint = cutpath(tempdir$)
	    if cutpoint > 0 then
		tempdir$ = tempdir$[cutpoint+1:len(tempdir$)]
		tempdir$ = RemoveSlash$(tempdir$)
	    endif
            temppath$ = _instpath$
	    if IdNumber = 10002 then
		tempdir$ = SelectNewFileDir$(ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_IMPORT_FROM_DA_56),temppath$,tempdir$)
	    else
		tempdir$ = SelectNewFileDir$(ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_DIRECTORY_FOR_57),temppath$,tempdir$)
	    endif
	    if tempdir$ <> "" then
		if IdNumber = 10002 then
		    fromdir$ = tempdir$
		else
		    newdir$ = tempdir$
		endif
	    endif
	endif
        if IdNumber = 0 then
	   print ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_IMPORT_HP3365_58)
	   return 
        endif

    endwhile
    removedialog("dImportAll")
    if IdNumber > 0 then
        fromdir$ = RemoveSlash$(fromdir$) + "\"
        ImportAllLoop fromdir$,newdir$
    endif
    print ""
endmacro     !ImportAllFiles

name Choose3365ImpFile

    ID_PHX3DSUPPORTFILES_IMPORTING_A_SI_59             =  17059  
    ID_PHX3DSUPPORTFILES_IMPORTING_ALL_60              =  17060  
    NLSFileName_phx3dsupport$="phx3dsupport"
	! Display dialog box for choosing whether we are importing a single data
    ! file or a whole directory. 
    
    if DialogExists("ChooseMode") = 0 then
        LoadDialog  NLSCoreMacDLL$, "ChooseMode", "ChooseMode"
	Option3365=1
	OptionGroupParm 10001, Option3365
	endDialog 
    endif

    print ""
    if showDialog("ChooseMode") > 0 then
	if Option3365=1 then
	    print ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_IMPORTING_A_SI_59)
	    x = Import3365File()
	else
	    print ReadResource$(NLSFileName_phx3dsupport$,ID_PHX3DSUPPORTFILES_IMPORTING_ALL_60)
	    ImportAllFiles
	endif
    else
        print ""
    endif

    removeDialog "ChooseMode"
    remove Option3365

endMacro ! Choose3365ImpFile

