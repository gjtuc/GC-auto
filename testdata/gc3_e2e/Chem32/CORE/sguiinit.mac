!############################################################################
name GUIDiagramMenuAdd

parameter   AreaToken$ default "" ! "SAMPLINGAREA" ,  "METHODAREA" , "SEPARATOR"
parameter   Label$
parameter   Item$
parameter   Message$   default ""
parameter   MenuOrderNumber   default 0
!overloading guigener.mac in case CRTxResolution > 640
!############################################################################

if AreaToken$ = "SAMPLINGAREA"
   if DevLeoAls+Dev1090Inject+Dev1050Sampler+DevHPCE > 0
      if Check ( VARIABLE, GUISampleAreaStateForMenu ) = 0
         GUISampleAreaStateForMenu=1  !enabled and unchecked
      endif
      menuadd Label$, Item$, "TLB_SwitchAcqTask  ,3" , , Message$ , GUISampleAreaStateForMenu , , , MenuOrderNumber 
   endif
   if DevRCnet > 0
      On Error Print ""
      if RCTrayAvailable() = 1 
      if Check ( VARIABLE, GUISampleAreaStateForMenu ) = 0
         GUISampleAreaStateForMenu=1  !enabled and unchecked
      endif
      menuadd Label$, Item$, "TLB_SwitchAcqTask  ,3" , , Message$ , GUISampleAreaStateForMenu , , , MenuOrderNumber 
!        if check(variable,_TrayUIVisible)<>1
!          _TrayUIVisible=1
!        endif
!        menuadd Label$, Item$, "RCShowTray" , , "" , _TrayUIVisible , , , MenuOrderNumber 
      endif
      On Error
   endif
else
if AreaToken$ = "METHODAREA" 
   if DevHPCE > 0
      if Check ( VARIABLE, GUIDiagramStateForMenu ) = 0
         GUIDiagramStateForMenu=1  !enabled and unchecked
      endif
      menuadd Label$, Item$, "Diagram" ,, Message$ ,GUIDiagramStateForMenu, , , MenuOrderNumber 
   else
   if DevLeoPump+DevLeoAls+DevLeoThm+DevLeoClc+GuiDevGuiDets > 0
      !if anyone is present
      if Check ( VARIABLE, GUIDiagramStateForMenu ) = 0
         GUIDiagramStateForMenu=1  !enabled and unchecked
      endif
      menuadd Label$, Item$, "GUIShowSystemDiagram  3" , , Message$ , \
              GUIDiagramStateForMenu , , , MenuOrderNumber 
   else
      if (Mrc_IsRcNetUi() > 0)
        if Check ( VARIABLE, GUIDiagramStateForMenu ) = 0
          GUIDiagramStateForMenu=1  !enabled and unchecked
        endif
        menuadd Label$, Item$, "GUIShowSystemDiagram 3" , , Message$ , \
        GUIDiagramStateForMenu , , , MenuOrderNumber 
      endif
   endif
   endif           
else
if AreaToken$ = "SEPARATOR" 
   if DevLeoPump+DevLeoAls+DevLeoThm+DevLeoClc+GuiDevGuiDets+ \ 
      Dev1090Inject+Dev1050Sampler+DevHPCE > 0
      !if then the above items will show there for only then need a separator
      menuadd Label$, ,"SEPARATOR" , , , , , , MenuOrderNumber 
   endif
endif
endif
endif

endmacro

    
!############################################################################
name GUIShowSystemDiagram

parameter  ShowType   default  0  ! 0 is show in switch view (test if applicable)
                                  ! others may be defined by product specific macros
                                  ! example 1 create and show , 2 destroy, 3 toggle


!bootstrap macro for load on demand on a menu call to display the GUI
!DEFINITION:
!in the systgui.mac on the product dir there must exist a macro  
!    GUIShowSystemDiagramCode    to show the system diagram and does state
!setting via CP variable  GUIDiagramStateForMenu
!############################################################################

if check ( macro, GUIShowSystemDiagramCode ) = 0
   GUIProductMacDemandLoading "SystGui.mac" , "Init_systgui"
endif

if check ( macro, GUIShowSystemDiagramCode ) = 1
   if GUIProtocolHotlinkDLL = 0
      !is offline and hotlink dll is not installed yet
      GUIInstallLeoHotlinkDll
   endif

   GUIShowSystemDiagramCode ShowType
endif

endmacro
    
    
!############################################################################
name GUIShowSamplingDiagram

parameter  RequestedTaskMode$ default ""  !means reinstall last one used
                                          !find out from view tbl hdr CurrentTask
                                          !values: TOPSEQ, TOPRUN
parameter  ShowType   default  0  ! 0 is show in switch view (test if applicable)
                                  ! others may be defined by product specific macros
                                  ! 1 create and show , 2 destroy (does not remove sidebar), 
                                  ! 3 toggle (does create/remove sidebar),
                                  ! 4 show only in new mode if already there or 
                                  ! saved there as to be there,
                                  ! 5 is close in CloseView macro (remove sidebar)
                                  ! 6 destroy (removes sidebar)


!bootstrap macro for load on demand on a menu call to display the GUI
!DEFINITION:
!in the systgui.mac on the product dir there must exist a macro  
!    GUIShowSamplingDiagramCode    to show the system diagram and does state
!setting via CP variable  GUISampleAreaStateForMenu
!some how core calls this also if no sample diag is configured
!############################################################################

local CurrentViewTable$                                                                                              
local row


!init in case it TabHdrVal "SampleAreaOn" is not there
CurrentViewTable$=TabHdrText$(_config[1], "Window", "CurrentView")
if CurrentViewTable$ = "" 
   CurrentViewTable$="TOP"
endif
CurrentViewTable$="View_"+CurrentViewTable$
if ObjHdrType(_config[1],CurrentViewTable$) = 4
   if TabHdrType(_config[1],CurrentViewTable$,"SampleAreaOn") = 99
      NewTabHdrVal  _config[1],CurrentViewTable$,"SampleAreaOn",0 , , 3
   endif
   if ShowType = 4
      if TabHdrVal(_config[1],CurrentViewTable$,"SampleAreaOn") = 1
         ShowType=0
      else
         ShowType=6
      endif
   endif                       
else
   return
endif      

if RequestedTaskMode$ = ""
   !anton sets this info before calling here
   RequestedTaskMode$=View_CurrentTaskName$()
endif


if DevRCnet > 0
  if RCTrayAvailable() = 1
    if ShowType=0 Or ShowType=1 Or ShowType=4
      GUISamplingRCShowTray 1, CurrentViewTable$, 1, 3
    endif
    if ShowType=2 Or ShowType=6
      GUISamplingRCShowTray 0, CurrentViewTable$, 0, 1
    endif
    if ShowType=5
      if TabHdrVal(_config[1],CurrentViewTable$,"SampleAreaOn") = 1
        GUISamplingRCShowTray 0, CurrentViewTable$, 1, 3
      endif        
    endif
    if ShowType=3
      if TabHdrVal(_config[1],CurrentViewTable$,"SampleAreaOn") = 1
        GUISamplingRCShowTray 0, CurrentViewTable$, 0, 1
      else
        GUISamplingRCShowTray 1, CurrentViewTable$, 1, 3
      endif        
    endif
  endif
else
  row = RowByVal(_CONFIG[1], CurrentViewTable$,,"WINNUM","=",GuiSamplingDiagramWinNo)
  if (row <> -1)
    SetTabVal  _config[1], CurrentViewTable$, row, "Visible", 0
  endif
endif


if DevLeoAls+Dev1090Inject+Dev1050Sampler+DevHPCE > 0
   if check ( macro, GUIShowSamplingDiagramCode ) = 0 \
      AND  ShowType<>5  AND  ShowType<>6
      !olny then really load in the code
      GUIProductMacDemandLoading "SystGui.mac" , "Init_systgui"
   endif
   if check ( macro, GUIShowSamplingDiagramCode ) = 1
      if GUIProtocolHotlinkDLL = 0
         !is offline and hotlink dll is not installed yet
         GUIInstallLeoHotlinkDll
      endif
   endif
   if check ( macro, GUIShowSamplingDiagramCode ) = 1
      GUIShowSamplingDiagramCode RequestedTaskMode$, ShowType
   endif
endif

endmacro
    

Name GUISamplingRCShowTray

  parameter tray
  parameter currentviewtable$
  parameter samplearea
  parameter menustate

  RCShowTray ,tray
  SetTabHdrVal _config[1],CurrentViewTable$,"SampleAreaOn", samplearea
  GUISampleAreaStateForMenu = menustate

endmacro
    
