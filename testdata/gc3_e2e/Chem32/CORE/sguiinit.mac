!############################################################################
name GUIBootLeo1050ADDetectors

!add configured dets here so menu decision logic can decide 
!if menu item and GUI to show or not
!also fill in the GuiReConfigDet Hook table
!############################################################################


GuiDevGuiDets=GuiDevGuiDets+DevLeoDAD+DevLeoMWD+DevLeoVWD+DevNucVWD+DevLeoRID+adcdevice+DevLeoFLD+DevNucDad+DevNucMwd
        
GuiDevNonGuiDets=GuiDevNonGuiDets+dev1050DAD+dev1050MWD+dev1050VWD+dev1046FLD+dev1049ECD

SetHook  "GuiReConfigDet" , \
         "GUICheckProductMacDemandLoading ""GuiLcDet.mac"", ""GUIReConfigureLeoDetectors"" "
SetHook  "GuiReConfigDet" , \
         "GUICheckProductMacDemandLoading ""GuiLcDet.mac"", ""GUIReConfigure1050Detectors"" "
SetHook  "GuiReConfigDet" , \
         "GUICheckProductMacDemandLoading ""GuiLcDet.mac"", ""GUIReConfigureADConv"" "

endmacro





!############################################################################
name GUIInitialize

!Initializes GUI modules after all Addons are registered and StartAddons
!in top.mac was done
!installs the GUI protocol DLL
!############################################################################

local erroriii


NewHook  "GuiReConfigDet"
NewHook  "GuiHotlEmfBubbl"

NewHook  "GuiMthDiagrmExt"
NewHook  "GuiTopMthExt"
NewHook  "GuiPreMthExt"
NewHook  "GuiPostMthExt"

GuiNewHookVeneer  "GuiQuickLst"

NewHook  "GuiSampleTask"
NewHook  "GuiMethSampLnks"
NewHook  "GuiReConfigGUI"


GuiDevGuiDets=0
GuiDevNonGuiDets=0

ExecHook  "GuiBootstrap"

 
!the LEO gui hotlink DLL must reinit its BSP connections to the now available drivers
if _offline = 0
   !so pure repocressing copies don't have so many BSP connections
   if DevLeoPump+DevLeoAls+DevLeoThm+DevLeoClc+GuiDevGuiDets > 0
      !if leo module is there (serve at least for EMF warning which is in status bar)
      GUIInstallLeoHotlinkDll   1
   endif   
endif   


on error  erroriii=1

CpStart "CPGui"

!CpStart "CPGuiAsync" don't just was started CPs

!make sure 3. CP is started in top.mac
!use 3. cp for GUI callback macros since GUI is acceccable only when there is no
!second layer dialog box up

CpStart "CP3"

on error 

endmacro






!############################################################################
name Init_SGuiInit

!bootstrap macro        
!initialized the HOOKS
!initialized global vars
!############################################################################



InitSystGuiGlobalVars

InitSystGuiRegisters


!moved to guigener.mac  so res < 800 also work with addons NewHook  "GuiBootstrap"

SetHook  "GuiBootstrap" , "GUICheckProductMacDemandLoading ""sguiinit.mac"", ""GUIBootLeo1050ADDetectors"" "


endmacro



