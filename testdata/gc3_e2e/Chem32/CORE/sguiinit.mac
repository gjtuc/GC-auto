  on error print ""
  
  if (devGCI > 0)
     if devRCnet > 0 then
      if _offline = 1
        if ObjHdrType(_Config[1], "RcWlsIsWellPlateTray") = 99
          NewObjHdrVal _Config[1], "RcWlsIsWellPlateTray", 0, 0, 1
