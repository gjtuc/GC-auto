GUIInstallLeoHotlinkDll
 
!here comes a more powerful macro in systgui.mac when it was loaded

endmacro








!############################################################################
name GUICheckFreeDiskSpace

!callback from Gui hotlink dll every 15 min to check
!the global (top.mac) FreeDiskLimit is now absolute
!############################################################################

local DiskSpaceAbsolute       
local Protocol$
local SamplingGomIni$
local a$

local NLSFileName_astxmac$
local ID_ASTXDRIVERSMACFILES_DISK_SPACE_51

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_DISK_SPACE_51 = 17051

if (GomExist(,GUISamplingDiagGOM$ ) = 1 Or Mrc_IsRcNetUi() = 1)

  if GomExist(,GUISamplingDiagGOM$ ) = 1
    SamplingGomIni$=GUIBuildSequenceSamplingINI$()
    
    if GomExist(GUISamplingDiagGOM$,SamplingGomIni$ ) = 0
       SamplingGomIni$=GUIBuildSingleSampleINI$()
    endif
  endif
  !always place the info there for seq and single sample
  DiskSpaceAbsolute=FreeDiskSpace(_DataPath$[1])  !default ABSOLUT
  if DiskSpaceAbsolute < FreeDiskLimit
     if DiskSpaceAbsolute > ObjHdrVal ( _Config, "GuiMBFreeError" )
        !put up a warning yellow disk drive 
        Protocol$="DISKWARNING|"        
        WriteToLogbook ReadResource$(NLSFileName_AstxMac$, ID_ASTXDRIVERSMACFILES_DISK_SPACE_51)+val$(floor(FreeDiskLimit/(1024*1024)))+" MB"
     else
        Protocol$="DISKFULL|"
     endif   
  else   
     Protocol$="DISKOK|"
  endif      
  ! YD  if DiskSpaceAbsolute > 1000000000  ! 1GB  
  !if DiskSpaceAbsolute >= 2147483000
  !   a$=" >2.0 GB"
  !else                                
    ! YD a$=val$(floor((DiskSpaceAbsolute)/1000000))+" MB"
  !endif
  if (DiskSpaceAbsolute<(1024*1024*1024))   ! free disk space < 1GB show MB
    a$=Val$(Floor((DiskSpaceAbsolute)/(1024*1024)))+" MB"
  Else
    If  (DiskSpaceAbsolute<(10*1024*1024*1024)) ! free disk space between 1GB and 10GB
      a$=Val$((Floor((DiskSpaceAbsolute*10)/(1024*1024*1024)))/10)+" GB"
    Else  ! free disk space >10 GB
      a$=" >10 GB"
    endif
  endif
  
  Protocol$=Protocol$+_DataPath$[1:2]+a$
  if RegSize(GUI) > 0
     SetObjHdrText GUI, "DiskSpace", Protocol$
  endif
  if GomExist(,GUISamplingDiagGOM$ ) = 1
    if GomExist(GUISamplingDiagGOM$,SamplingGomIni$,"DiskSpace" ) = 1
      GomSetText GUISamplingDiagGOM$,SamplingGomIni$,"DiskSpace","elements",Protocol$ 
    endif
  endif
   
endif

endmacro
        

        



    
    
!############################################################################
name GUIDebugObjHdrs

parameter   RegName$
parameter   ObjNr default 1
!lists all NDRs of an RegObj
!############################################################################

local  NdrName$
local  iii                     
local  iType                     
local  a$,b$ 

NdrName$=" "   
iii=1    
a$=" : "    
b$="""" 
!listmessages on
print "-------------------------------------------------"
print RegName$+"["+val$(ObjNr)+"]   at  time: "+sprintf$(mtime(),"%.0lf")
evaluate "NdrName$=ObjHdrName$("+RegName$+"[ObjNr],iii)"
while  NdrName$ <> ""
   evaluate "iType=ObjHdrType("+RegName$+"[ObjNr],NdrName$)"
   if iType=0
      evaluate "print  NdrName$+a$+b$+ObjHdrText$("+RegName$+"[ObjNr],NdrName$)+b$"
   else
   if iType=1
      evaluate "print  NdrName$+a$+val$(ObjHdrVal("+RegName$+"[ObjNr],NdrName$))"
   else
   if iType=4
      print  NdrName$+" (table) "
   endif
   endif
   endif
   iii=iii+1
   evaluate "NdrName$=ObjHdrName$("+RegName$+"[ObjNr],iii)"
endwhile
endmacro

   

    
