!############################################################################
name GUIInstallLeoHotlinkDll

parameter  bForce  Default 0 ! 1 does unload and forces a load again

!NOTE: 
!if CP variable _FiaOn exists by now HpLGuH00.dll will start with 
! FIA evaluation enabled
!

!############################################################################



!also the LEO gui hotlink DLL must reinit its BSP connections to the now available drivers
if GUIProtocolHotlinkDLL <> 0
   if bForce = 0
      return
   else
      removecmds GUIProtocolHotlinkDLL
      if Check ( VARIABLE, GUIHpSam008DLL ) = 1
         removecmds GUIHpSam008DLL
      ENDIF   
      if Check ( VARIABLE, GUIHpLeo008DLL ) = 1
         removecmds GUIHpLeo008DLL
      ENDIF   
   endif   
endif

GUIProtocolHotlinkDLL=0
GUIHpSam008DLL=0
GUIHpLeo008DLL=0

!install the protocol hotlink DLL
if Check ( VARIABLE, DacTst ) = 1
   if DacTst = 1
      GUIProtocolHotlinkDLL=InstallCmds("c:\drivers\leo\gui\src\HpLGuH00.dll")
      GUIHpLeo008DLL=InstallCmds("c:\drivers\leo\gui\800\pictdll\HpLeo008.dll")
      GUIHpSam008DLL=InstallCmds("c:\drivers\leo\gui\800\pictsamp\HpSam008.dll")
   else
      GUIProtocolHotlinkDLL=InstallCmds(_DriverPath$+"HpLGuH00.dll")
      GUIHpLeo008DLL=InstallCmds(_DriverPath$+"800\HpLeo008.dll")
      GUIHpSam008DLL=InstallCmds(_DriverPath$+"800\HpSam008.dll")
   endif   
else
   !standard branch

   GUIProtocolHotlinkDLL=InstallCmds(_DriverPath$+"HpLGuH00.dll")
   !workaround for NT sporadic LoadLibrary bug 
   if FileStat (Mode, _DriverPath$+"800\HpLeo008.dll") = 1 then
      !in HPCE only chemstation HpLeo008.dll does not exist
      GUIHpLeo008DLL=InstallCmds(_DriverPath$+"800\HpLeo008.dll")
   endif   
   if FileStat (Mode, _DriverPath$+"800\HpSam008.dll") = 1 then
      GUIHpSam008DLL=InstallCmds(_DriverPath$+"800\HpSam008.dll")
   endif   

endif

!addons must register info at hotlink
ExecHook  "GuiHotlEmfBubbl"



endmacro



