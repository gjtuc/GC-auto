   if ObjHdrType(NucVwdStatus2, "UVLamp") = 99
      _DebugPrint "missing objhdr UVLamp" ,""
      setobjhdrval  NucVwdStatus2 , "UVLamp" ,0
   endif   
endif
if DevNucVwd > 2
   if ObjHdrType(NucVwdStatus3, "UVLamp") = 99
      _DebugPrint "missing objhdr UVLamp" ,""
      setobjhdrval  NucVwdStatus3 , "UVLamp" ,0
   endif   
endif
if DevLeoRid > 0
!   if ObjHdrType(LeoRidStatus1, "UVLamp") = 99
!      _DebugPrint "missing objhdr UVLamp" ,""
!      setobjhdrval  LeoRidStatus1 , "UVLamp" ,0
!   endif   
endif
if DevLeoRid > 1
!   if ObjHdrType(LeoRidStatus2, "UVLamp") = 99
!      _DebugPrint "missing objhdr UVLamp" ,""
!      setobjhdrval  LeoRidStatus2 , "UVLamp" ,0
!   endif   
endif
if DevLeoDad > 0
   if ObjHdrType(LeoDadStatus1, "UVLamp") = 99
      _DebugPrint "missing objhdr UVLamp" ,""
      setobjhdrval  LeoDadStatus1 , "UVLamp" ,0
   endif   
   if ObjHdrType(LeoDadStatus1, "VisLamp") = 99
      _DebugPrint "missing objhdr VisLamp" ,""
      setobjhdrval  LeoDadStatus1 , "VisLamp" ,0
