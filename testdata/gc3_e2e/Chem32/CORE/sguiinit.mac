!############################################################################
name GUICheckProductMacDemandLoading

parameter  MacFileName$
parameter  ExecMacroName$   default ""
parameter  AddonPath$       default ""
parameter  Params$          default ""

!checks if the macro InitMacroName$ exists, otherwise does a
!demand load of MacroName$ macro on the product directroy
!will also run the macro named  ExecMacroName$
!############################################################################
local  bExist

evaluate "bExist=Check ( macro , "+ExecMacroName$+" )"
if bExist = 0
   GUIProductMacDemandLoading  MacFileName$, ExecMacroName$ , AddonPath$ , Params$
else
   evaluate  ExecMacroName$ + " " + Params$
endif

endmacro




!############################################################################
name GuiExecHook

  parameter Hook$              ! the name of the hook
                               ! parameters may be transfered as
                               ! table hdr items in this hook table
  parameter Parms$             ! for parameters which can be appended directly

! This executes all commands defined in the hook Hook$.
! The macro is used by the core product at each defined hook.
! It may also be used by a special analyzer for hooks in its own code.
! extended to give parameters to called macors
!############################################################################

  local row, nRows

  nRows = TabHdrVal (Hook[1], Hook$, "NumberOfRows")
  for row = 1 to nRows
      SetTabHdrVal  Hook[1], Hook$, "ExecRow" ,  row     !for orientation in called macro
      evaluate TabText$ (Hook[1], Hook$, row, "Command") +" "+ Parms$
  next row

  return
endmacro


!############################################################################
name GuiNewHookVeneer

  parameter VeneerTab$            ! the name of the veneer table

!############################################################################

RemoveHook  VeneerTab$
NewHook     VeneerTab$  

!additional information to be stored
NewTabHdrVal   Hook[1], VeneerTab$, "ExecRow" ,  0    , , 3
NewColText     Hook[1], VeneerTab$, "RowID"

endmacro


!############################################################################
name GuiSetVeneerHook

  parameter VeneerTab$         ! the name of the veneer table
  parameter RowID$             ! veneer name
  parameter Command$
  
!############################################################################

if RowID$ <> ""
   row=RowByText(Hook[1], VeneerTab$, , "RowID", "i=" , RowID$ ) 
else
   row=-1  !no name found
endif   
if row = -1                     
   SetHook VeneerTab$,Command$
   row = RowByText (Hook[1], VeneerTab$, , "RowID", "i=", "")
   if row > -1
      SetTabText Hook[1],VeneerTab$,row,"RowID"   ,RowID$
   endif
!else ERROR   
endif   

endmacro



!############################################################################
name GuiExecVeneerHook

  parameter VeneerTab$         ! the name of the veneer table
  parameter RowID$             ! veneer name
  parameter Parms$             ! for parameters which can be appended directly
!############################################################################

if RowID$ <> ""
   row=RowByText(Hook[1], VeneerTab$, , "RowID", "i=" , RowID$ ) 
else
   row=-1  !no name found
endif   
if row <> -1
   SetTabHdrVal  Hook[1], VeneerTab$, "ExecRow" ,  row     !for orientation in called macro
   evaluate TabText$(Hook[1], VeneerTab$, row, "Command") +" "+Parms$
!else ERROR   
endif   

endmacro




!############################################################################
name GuiFindDetHookSymbolicName

parameter  SymbolicName$
!returns the detector number
!############################################################################
local Tab$

Tab$="GuiDetectors"
return  RowByText(Hook[1], Tab$, , "SymbolicName", "i=" , SymbolicName$ ) 

endmacro





