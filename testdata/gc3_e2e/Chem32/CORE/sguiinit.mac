if DevLeoMwd > 1
   if ObjHdrType(LeoMwdStatus2, "UVLamp") = 99
      _DebugPrint "missing objhdr UVLamp" ,""
      setobjhdrval  LeoMwdStatus2 , "UVLamp" ,0
   endif   
   if ObjHdrType(LeoMwdStatus2, "VisLamp") = 99
