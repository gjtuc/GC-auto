   endif   
   if ObjHdrType(LeoPumpStatus3, "WarnBottleB") = 99
      SetObjHdrVal LeoPumpStatus3, "WarnBottleB",0.1
   endif   
   if ObjHdrType(LeoPumpStatus3, "WarnBottleC") = 99
      SetObjHdrVal LeoPumpStatus3, "WarnBottleC",0.1
   endif   
   if ObjHdrType(LeoPumpStatus3, "WarnBottleD") = 99
      SetObjHdrVal LeoPumpStatus3, "WarnBottleD",0.1
   endif   
endif
if DevLeoAls = 1
   if ObjHdrType(LeoAlsStatus1, "PrepProgress") = 99
      !_DebugPrint "missing objhdr PrepProgress",""
      SetObjHdrVal LeoAlsStatus1, "PrepProgress",0   !allow simulation of injection prep progress
   endif   
   if ObjHdrType(LeoAlsStatus1, "ACT_FIAINJREP") = 99
      !_DebugPrint "missing objhdr ACT_FIAINJREP",""
      SetObjHdrVal LeoAlsStatus1, "ACT_FIAINJREP",0   
   endif   
endif
if DevLeoTHM > 0
   if ObjHdrType(LeoThermostatStatus1, "TempDiffLimit") = 99
      _DebugPrint "missing objhdr TempDiffLimit" ,""
      setobjhdrval  LeoThermostatStatus1 , "TempDiffLimit" ,1
   endif   
   if ObjHdrType(LeoThermostatStatus1, "LeftTemp") = 99
      _DebugPrint "missing objhdr LeftTemp" ,""
      setobjhdrval  LeoThermostatStatus1 , "LeftTemp" ,17
   endif   
   if ObjHdrType(LeoThermostatStatus1, "RightTemp") = 99
      _DebugPrint "missing objhdr RightTemp" ,""
      setobjhdrval  LeoThermostatStatus1 , "RightTemp" ,20
   endif   
endif
if DevLeoTHM > 1
   if ObjHdrType(LeoThermostatStatus2, "TempDiffLimit") = 99
      _DebugPrint "missing objhdr TempDiffLimit" ,""
      setobjhdrval  LeoThermostatStatus2 , "TempDiffLimit" ,1
   endif   
