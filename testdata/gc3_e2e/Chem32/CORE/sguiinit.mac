   endif   
   if ObjHdrType(LeoThermostatStatus2, "RightTemp") = 99
      _DebugPrint "missing objhdr RightTemp" ,""
      setobjhdrval  LeoThermostatStatus2 , "RightTemp" ,20
   endif   
endif
if DevLeoCLC > 0
   if ObjHdrType(LeoChipCubeStatus1, "ACT_CHIPTYPE") = 99
      _DebugPrint "missing objhdr ACT_CHIPTYPE" ,""
      setobjhdrtext  LeoChipCubeStatus1 , "ACT_CHIPTYPE" ,""
   endif
endif
if DevLeoVwd > 0
   if ObjHdrType(LeoVwdStatus1, "UVLamp") = 99
      _DebugPrint "missing objhdr UVLamp" ,""
      setobjhdrval  LeoVwdStatus1 , "UVLamp" ,0
   endif   
