!############################################################################
name InitSystGuiGlobalVars

!############################################################################


if Check ( VARIABLE, _SeqCurrLine1 ) = 0
   _SeqCurrLine1=0 ! seq engine inits it only when seq is started
endif


if Check ( VARIABLE, GUILastSequenceTrayGOM$ ) = 0
   GUILastSequenceTrayGOM$=""   
   !contains the subgom containing left and right parts of the tray
endif
if Check ( VARIABLE, GUISystemDiagGOM$ ) = 0
   GUISystemDiagGOM$="LSysCont"
endif
if Check ( VARIABLE, GUISamplingDiagGOM$ ) = 0   
   if Dev1050Sampler > 0
      GUISamplingDiagGOM$="LSamplsw"
   else
   if DevHPCE > 0
      GUISamplingDiagGOM$="CSamples"
   else
      !Leo ALS and 1090
      GUISamplingDiagGOM$="LSamples"
   endif
   endif
endif
if Check ( VARIABLE, GUIQuickListGOM$ ) = 0
   GUIQuickListGOM$="LQuickLs"
endif
if Check ( VARIABLE, GUIProtocolHotlinkDLL ) = 0
   GUIProtocolHotlinkDLL=0
endif
if Check ( VARIABLE, GUIHpSam008DLL ) = 0
   GUIHpSam008DLL=0
endif
if Check ( VARIABLE, GUIHpLeo008DLL ) = 0
   GUIHpLeo008DLL=0
endif

if Check ( VARIABLE, GUIDiagramStateForMenu ) = 0
   GUIDiagramStateForMenu=1  !enabled and unchecked
endif

if Check ( VARIABLE, GUISampleAreaStateForMenu ) = 0
   GUISampleAreaStateForMenu=1  !enabled and unchecked
endif

if Check ( VARIABLE, GuiDAProgressLoopRuning ) = 0
   GuiDAProgressLoopRuning=0 
endif                 

GuiDAProgressEnd=0    !for reset
        
if Check ( VARIABLE, GuiModuleNrdyInfoMenu ) = 0
   GuiModuleNrdyInfoMenu=0 
endif                 

if Check ( VARIABLE, GuiALSNrdyInfoMenu ) = 0
   GuiALSNrdyInfoMenu=0   !module NRDY and Run mode info
endif                 


if Check ( VARIABLE, GuiSeqRunMode ) = 0
   GuiSeqRunMode=0  !let Gui hotlink know, in order to gray injector correctly
endif
if Check ( VARIABLE, GuiUserCalledNrdyInfo$ ) = 0
   GuiUserCalledNrdyInfo$=""  !let Gui hotlink know if it needs to update a bubble message info
endif



if Check ( VARIABLE, DevLeoPump ) = 0
   DevLeoPump=0
endif
if Check ( VARIABLE, DevLeoAls ) = 0
   DevLeoAls=0
endif
if Check ( VARIABLE, DevLeoTHM ) = 0
   DevLeoTHM=0
endif
if Check ( VARIABLE, DevLeoCLC ) = 0
   DevLeoCLC=0
endif
if Check ( VARIABLE, DevLeoDAD ) = 0
   DevLeoDAD=0
endif
if Check ( VARIABLE, DevNucDAD ) = 0
   DevNucDAD=0
EndIf
if Check ( VARIABLE, DevNucMwd ) = 0
   DevNucMwd=0
endif
if Check ( VARIABLE, DevLeoMWD ) = 0
   DevLeoMWD=0
endif
if Check ( VARIABLE, DevLeoVWD ) = 0
   DevLeoVWD=0
endif
if Check ( VARIABLE, DevNucVWD ) = 0
   DevNucVWD=0
endif
if Check ( VARIABLE, DevLeoRID ) = 0
   DevLeoRID=0
endif
if Check ( VARIABLE, DevLeoFLD ) = 0
   DevLeoFLD=0
endif
if Check ( VARIABLE, Dev1946MSD ) = 0
   Dev1946MSD=0
endif

if Check ( VARIABLE, GuiSystemDiagramWinNo ) = 0
   GuiSystemDiagramWinNo=63
endif

        
if Check ( VARIABLE, GuiOffline ) = 0
   GuiOffline=_Offline   !better possiblity to do full testing offline
endif                 
        
if Check ( VARIABLE, GuiDevGuiDets ) = 0
   GuiDevGuiDets=0
endif
        
if Check ( VARIABLE, GuiDevNonGuiDets ) = 0
   GuiDevNonGuiDets=0
endif

        
if Check ( VARIABLE, SeqEndStatus ) = 0
   SeqEndStatus=0   !seq only sets this after 1. run
endif                 

if Check ( VARIABLE, GUIDetRunAnimation ) = 0
   GUIDetRunAnimation=0 
endif                 

if Check ( VARIABLE, GuiSamplingDiagramWinNo ) = 0
   GuiSamplingDiagramWinNo=72
endif

endmacro



!############################################################################
name InitSystGuiRegisters

!############################################################################


if ObjHdrType ( _Config, "GuiMBFreeError" ) = 99
   SetObjHdrVal   _Config, "GuiMBFreeError" , 500000    
   !put up yellow sign when above this and below FreeDiskLimit
   !red when below this
endif


if RegSize (Gui) < 1
   NewObj Gui,1,0,0
endif
   
   SetObjHdrText  Gui,"ModMsgType","NONE"
   SetObjHdrText  Gui,"ModMsgModName",""
   SetObjHdrText  Gui,"ModMsgText",""
   SetObjHdrVal   Gui,"ModMsgHelpNo",0




!things not done by drivers in all cases
if DevLeoPump > 0
   if ObjHdrType(LeoPumpStatus1, "WarnBottleA") = 99 
      SetObjHdrVal LeoPumpStatus1, "WarnBottleA",0.1  !filling level warning when below this limit
   endif   
   if ObjHdrType(LeoPumpStatus1, "WarnBottleB") = 99
      SetObjHdrVal LeoPumpStatus1, "WarnBottleB",0.1
   endif   
   if ObjHdrType(LeoPumpStatus1, "WarnBottleC") = 99
      SetObjHdrVal LeoPumpStatus1, "WarnBottleC",0.1
   endif   
   if ObjHdrType(LeoPumpStatus1, "WarnBottleD") = 99
      SetObjHdrVal LeoPumpStatus1, "WarnBottleD",0.1
   endif   
endif
if DevLeoPump > 1
   if ObjHdrType(LeoPumpStatus2, "WarnBottleA") = 99 
      SetObjHdrVal LeoPumpStatus2, "WarnBottleA",0.1  !filling level warning when below this limit
   endif   
   if ObjHdrType(LeoPumpStatus2, "WarnBottleB") = 99
      SetObjHdrVal LeoPumpStatus2, "WarnBottleB",0.1
   endif   
   if ObjHdrType(LeoPumpStatus2, "WarnBottleC") = 99
      SetObjHdrVal LeoPumpStatus2, "WarnBottleC",0.1
   endif   
   if ObjHdrType(LeoPumpStatus2, "WarnBottleD") = 99
      SetObjHdrVal LeoPumpStatus2, "WarnBottleD",0.1
