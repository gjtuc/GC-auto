Name IsCPRunning
  Parameter Name$
  
  Local Ret, ActName$, i
  
  ret = 0
  i = 1
  Repeat
    ActName$ = CPName$(i)
    If ActName$ = Name$
      Ret = 1
    EndIf
  
    i = i+1
  Until Ret = 1 Or ActName$ = ""
  
  return Ret
EndMacro

NAME InstallUserMac
	!    This macro  *** MUST ***  be the last one in the file, 
	!    so that it can be called with "macro STARTCHT.MAC,GO"

	!___ Tell the user about... give warning, and chance to abort
local WhatToDo	
 SetScreen1
 If IsCPRunning("CC_CP5") <> 1
   CPStart "CC_CP5"
 EndIf
 	WHATTODO = -99
	WHATTODO = ShowDialog("addCC")
	IF WHATTODO = 0  
		! cancel
	else
		CKKUSER
	endif
        RemoveDialog ("addCC")
  sleep 0.01
	CPTerminate "CC_CP5"
RETURN
ENDMACRO


