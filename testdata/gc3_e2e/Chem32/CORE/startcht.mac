Name ReadccTable 
Parameter rou
		!	 gets data for One peak:
   NameName$  =TabText$(ConChart,"ccDetail",rou, "CompoundName")
   Paramname$ =TabText$(ConChart,"ccDetail",rou, "PlotVariable")
   doit       =TabVal  (ConChart,"ccDetail",rou, "ChartingOn")
   midvalue   =TabVal  (ConChart,"ccDetail",rou, "ExpValue")
   lowvalue   =TabVal  (ConChart,"ccDetail",rou, "LowLimit")
   highvalue  =Tabval  (ConChart,"ccDetail",rou, "HighLimit")

   nowvalue = GetNowValue(namename$)     !jamount
Return
EndMacro

name StoreUpdatedTable
	! the ConChart/"ccDetail" has been modified.
	! copy it back to _DAMethod

	DELTAB _DAMethod, "ccDetail"
	COPYTAB Conchart, "ccDetail", _DAMethod, "ccDetail"

Return
EndMacro

Name PowerONinterrupts
  CPrequest "CC_CP", "OnEvent ""ParamName$"",""ClickonVar"" ,,""CP"" "
  CPrequest "CC_CP", "OnEvent ""lowvalue"", ""ClickonLow"" ,,""CP"" "
  CPrequest "CC_CP", "OnEvent ""midvalue"", ""ClickonMid"" ,,""CP"" "
  CPrequest "CC_CP", "OnEvent ""highvalue"",""ClickonHigh"",,""CP"" "
  CPrequest "CC_CP", "OnEvent ""doit"",     ""ClickonOn "" ,,""CP"" "
  CPrequest "CC_CP", "OnEvent ""NameName$"",""ClickonName"",,""CP"" "
Return
EndMacro

Name PowerOFFinterrupts
	OnEvent "Paramname$",,, "CP"
	OnEvent "Namename$" ,,, "CP"
	OnEvent "lowvalue"  ,,, "CP"
	OnEvent "midvalue"  ,,, "CP"
	OnEvent "highvalue" ,,, "CP"
	OnEvent "doit"      ,,, "CP"
Return
EndMacro

Name TryScream

!________________________ BUG A
!	1. Only use CC_CP
!	2. Don't use Loop in ShowDialog
!	3. On exit from ShowDialog, only possibilities are 0 and 3
!	4. Take out JLineNum and loop

! global whattodo
  If IsCPRunning("CC_CP") <> 1
    CPStart "CC_CP"       
  EndIf

	PowerONinterrupts
   !commented for space issues
	! Namename$ = " "   
		! This forces initial selection to be blank, to solve a bug with 
		! first choice

    	WhatToDo = -99
    	!  While WhatToDo < 0  
 	    WhatToDo = ShowDialog ("CcScreen") 
    	!  EndWhile
	If WhatToDo = 0 then            !___ Cancel
		! do nothing 
	Else 				!____OK
        	SaveOneRow
		StoreUpdatedTable
	Endif
	PowerOFFinterrupts

  sleep 0.01
	CPTerminate "CC_CP"
Return
Endmacro


Name AfterDialog
! 		set (file output), as "Report"
! 		set .XLS
! 		set post-run macro 
! 		set post-run macro name "HPCNTL.MAC,GO"

local Roow
! TEST FOR ANY CHARTED PEAKS

Roow = RowByVal(ConChart, "ccDetail" ,, "ChartingOn", "=", 1)
If Roow > 0 then  	!___ there are charts
	
	SetTabHdrVal _DAMETHOD, RptParm, FileTypeXLS, 1
	SetTabHdrVal _DAMETHOD, RptParm, DestFile,    1
       SetTabHdrText _DAMETHOD, RptParm, FileName,    "Report"
	RUN_POSTRUN  = 1 
	Run_PostRun$ =  "MACRO HPCNTL.MAC,GO"
else			!__ No charts, so erase tables & Postrun
	DELREG ConChart
	DELTAB _DAMethod, "ccDetail"
	RUN_POSTRUN  = 0
	Run_PostRun$ =  ""
endif

Return
EndMacro


NAME StartCht  
	! Main entry  point for editing or reviewing
 !    the Control Chart setpoints    
 
 NLSFileName_legomac$ = "legomac"

 ID_LEGOMACFILES_GET_A_CALIBRAT_31                  =  17031  
 
	Set3Screens
	SearchConchart
        IF TabHdrVal( ConChart,"ccDetail",NumberOfRows) > 0 THEN
	   ReadccTable (1)
	   TryScream
  	ELSE
PRINT ReadResource$(NLSFileName_legomac$,ID_LEGOMACFILES_GET_A_CALIBRAT_31)	
        ENDIF
	AfterDialog
	RemoveDialog ("ccHelp")
	RemoveDialog ("ccScreen")

return
ENDMACRO


name ckkuser
	   !    called by InstallUserMac	
	   ! 1. see if User.MAC EXISTS
	   ! 2. If it does, see if it contains the magic lines.
	   ! 3. If not, APPEND/ADD the three lines, and RUN two lines.
	local testdone
	local foundmac
	local S$

NLSFileName_legomac$ = "legomac"

ID_LEGOMACFILES_PRESS__REPORT_37                   =  17037  


S$ = findfile$(user.mac)
IF S$ = "" then
	! write a new file
	OPEN "USER.MAC" FOR OUTPUT AS #8
	PRINT #8, "MACRO STARTCHT.MAC"
	PRINT #8, "setHook ""PreViewMenu"", ""CCinstallmenu"" "
	PRINT #8, "setHook ""PostQuant"", ""CCCopyTable"" "
	CLOSE #8
	setHook "PreViewMenu", "CCinstallmenu"
	setHook "PostQuant"  , "CCCopyTable"
        ccInstallMenu
ELSE
	! see if the key lines are in the file
	OPEN "USER.MAC" FOR INPUT AS #8
	ON ERROR testdone = 1
	testdone = 0	
	foundmac = 0
	WHILE testdone = 0
                INPUT #8, S$
		IF S$ = "MACRO STARTCHT.MAC"  THEN
		    foundmac = 1
		    testdone = 1
		ENDIF 	 
	ENDWHILE
        CLOSE #8
	ON ERROR

	IF foundmac = 1 then
		! do nothing
	ELSE
	   ! append macro commands
	   OPEN "USER.MAC" FOR APPEND AS #8
	   PRINT #8, "MACRO STARTCHT.MAC"
	   PRINT #8, "setHook ""PreViewMenu"", ""CCinstallmenu"" "
	   PRINT #8, "setHook ""PostQuant"", ""CCCopyTable"" "
	   CLOSE #8
	   setHook "PreViewMenu", "CCinstallmenu"
	   setHook "PostQuant"  , "CCCopyTable"
           ccInstallMenu
	ENDIF
ENDIF
print ReadResource$(NLSFileName_legomac$,ID_LEGOMACFILES_PRESS__REPORT_37)
return
endmacro

