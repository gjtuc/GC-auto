name ccCopyTable
   !    This macro is called by a hook at PostQuant time.
   !    Check if Control Charts Table is in _DAMethod, "ccDetail"
   !    If so, copy it to ChromRes[1],so it will go to REPORT01.XLS

LOCAL Numbb

	Numbb = ObjHdrType (_DAMethod, "ccDetail")
	IF Numbb = 4 then
		!         table exists
	     DELTAB ChromRes[1], "ccDetail"
	     COPYTAB  _DAMethod, "ccDetail", ChromRes[1], "ccDetail"
	Else
	        ! do nothing
	Endif
Return
EndMacro


name CCinstallmenu
	!        This macro is called at startup by USER.MAC.  
	!        It installs the pull-down menu item "Control Charts"

Local CurrentView$
  
  NLSFileName_legomac$ = "legomac"

  ID_LEGOMACFILES_AMOUNT_94		 =  17094  	
  ID_LEGOMACFILES__REPORT_3                          =  17003  
  ID_LEGOMACFILES_CONTROL_CHARTS_4                   =  17004 
  ID_LEGOMACFILES_SETUP_EXCEL_BA_5                   =  17005  

  CurrentView$ = Uppercase$( TabHdrText$ (_CONFIG[1],Window, "CurrentView" ))
  IF (CurrentView$ = "DA") 
     MenuAdd ReadResource$(NLSFileName_legomac$,ID_LEGOMACFILES__REPORT_3), ReadResource$(NLSFileName_legomac$,ID_LEGOMACFILES_CONTROL_CHARTS_4), "Startcht",,\ 
      ReadResource$(NLSFileName_legomac$,ID_LEGOMACFILES_SETUP_EXCEL_BA_5),, 10201 ,,63025000
  endif
return
endmacro



name MakeBlankTable
	NewObj ConChart, 1,0,0     ! user register, no rows or columns
	NewTab ConChart, "ccDetail"
	SetTabHdrText ConChart,"ccDetail","title", "ControlChartData"
        SetTabHdrText ConChart, "ccDetail", "MethodName", _METHFILE$
	NewColText  ConChart, "ccDetail", "CompoundName", "--"
	NewColText  ConChart, "ccDetail", "PlotVariable", ReadResource$(NLSFileName_legomac$,ID_LEGOMACFILES_AMOUNT_94)
	NewColVal   ConChart, "ccDetail", "ChartingOn",    0
	NewColVal   ConChart, "ccDetail", "LowLimit",      -999
	NewColVal   ConChart, "ccDetail", "ExpValue",      -999
	NewColVal   ConChart, "ccDetail", "HighLimit",     -999
return
endMacro


Name Transcribe1Compound
		! gets data for One peak:
Parameter jLineNum
local jcompnum, jName$, Rowe
   jcompnum = 0
   jName$ = ""
   jcompNum =	TabVal  (_DAMethod, "Peak",jLineNum,"Compound")
   IF jcompNum > 0 then
    jName$ =TabText$(_DAMethod,"Compound",jcompNum, "Name")
    if jName$ <> "" then
      	InsTabRow   ConChart, "ccDetail"  
   	Rowe =TabHdrVal (ConChart, "ccDetail", "NumberOfRows")
   	SetTabText ConChart, "ccDetail", Rowe, "CompoundName", jName$
    endif
  ENDIF
Return
EndMacro


Name MakeFirstTable
!  This makes the ccDetail Table for the first time, as user table.
local LineNum

	jNumRows  = -1
	jNumRows  = TabHdrVal (_DAMethod, "Peak", "NumberOfRows")
	MakeBlankTable
	LineNum = 1
	While LineNum <= jNumrows
	      Transcribe1Compound (LineNum)
	      LineNum = LineNum + 1
	EndWhile
RETURN
EndMacro

name FindCalibUpdates !++++++++++++++++++++++++++++++++++++++++++++++

	! Check to see if any compounds have been added since ccDetail
	!   was last edited
return
EndMacro

name SearchConChart
	!  checks _DAMethod for ccDetail
	!    or makes a new one in ConChart
	! then creates the string var for names

local  Numbb, Existt, Nomen$, LastRoww, lastmark, RowNumm
! global:  CastList$
	!           Erase the ConChart Register
	 Existt = RegSize (ConChart)
	 if Existt <> -1 then   ! exists
		DELREG ConChart
EndIf
 CompoundRow = 1
	!           Does The _DAMethod Table Exist?
	Numbb = ObjHdrType (_DAMethod, "ccDetail")
	IF Numbb = 4 then     !    table exists
	   NEWOBJ ConChart, 1,0,0
	   COPYTAB _DAMethod, "ccDetail", ConChart, "ccDetail"
	   FindCalibUpdates
	ELSE
	   MakeFirstTable
	ENDIF
   	LastRoww =TabHdrVal (ConChart, "ccDetail", "NumberOfRows")
        RowNumm = 1
	CastList$ = ""
		! Last line forces the first name in the list to be blank
		!  This solves a bug with "first selection"
 While RowNumm <= LastRoww
     Nomen$=TabText$(ConChart,"ccDetail",RowNumm,"CompoundName") 
     If RowNumm = 1 Then
            NameName$ = Nomen$ 
     endif 
	   CastList$ = CastList$ + Nomen$ + "|"
	   RowNumm = RowNumm + 1
  EndWhile 
  ! new addition 
   
  	lastmark = len(CastList$) -1
        if lastmark > 0 then
	   CastList$ = CastList$[1:lastmark]  
	endif
return
EndMacro

name GetNowValue
Parameter jName$
	! nowvalue comes from _DAMethod, depends on ParamName$
        Local Rowwe, PKrow, jCalibNum, jamt, jarea, Nvalue
        Nvalue = 0
        Rowwe = -99
	PKrow = -99
   	Rowwe =RowByText(_DAMethod,"Compound",,"Name", "i=", jname$)
	PKrow=  TabVal  (_DAMethod, "Compound",Rowwe,"FirstPeak")
   jcalibNum =	TabVal  (_DAMethod, "Peak", PKrow, "firstcalpoint")

	if Paramname$ = "Amount"  then
	    NValue=TabVal(_DAMethod, "CalPoint",jcalibNum,"Amount")
	endif
	if Paramname$ = "Area"  then
	    NValue=TabVal(_DAMethod, "CalPoint",jcalibNum,"Area")
	endif
	if Paramname$ = "Height"  then
	    NValue=TabVal(_DAMethod, "CalPoint",jcalibNum,"Height")
	endif
	if Paramname$ = "Retention Time"  then
	    NValue=TabVal(_DAMethod, "Peak", PKrow, "ExpRetTime")
	endif
	if Paramname$ = "Response Factor"  then
	   jamt =TabVal(_DAMethod, "CalPoint",jcalibNum,"Amount")
	   jarea = TabVal(_DAMethod, "CalPoint",jcalibNum,"Area") 
	   if jarea > 0 then
	    	    NValue = jamt/jarea
	   endif
	endif
return Nvalue
EndMacro


name GetOneRow
    Parameter Roww
    		!         The desired row
! NameName$  =TabText$  (ConChart, "ccDetail", Roww, "CompoundName") 
  ParamName$= TabText$  (ConChart, "ccDetail", Roww, "PlotVariable")
  doit      = TabVal    (ConChart, "ccDetail", Roww, "ChartingOn") 
  lowvalue  = TAbVal    (ConChart, "ccDetail", Roww, "LowLimit") 
  midvalue  = TabVal    (ConChart, "ccDetail", Roww, "ExpValue") 
  highvalue = TabVal    (ConChart, "ccDetail", Roww, "HighLimit")
   Nowvalue = GetNowValue(NameName$)
return
EndMacro


name ClickonName
	! When the user selects a compound name, all the data on the 
	! screen is updated, and the "current" compound is selected.
	! Global vars: NameName$, CompoundRow

parameter a1$, a2$, a3$, a4$
	! 	Get the row number for NameName$
	CompoundRow = 0
	on error print
	PowerOFFinterrupts

	CompoundRow = FindOneRow (NameName$)
	on error
	if CompoundRow > 0 then
	   GetOneRow (CompoundRow)
        endif
	PowerONinterrupts
Return
EndMacro


name ClickonVar
	! When user selects PlotVariable, Table is updated 
	! Global var: Paramname$, NameName$
   parameter a1$, a2$, a3$, a4$
   local Nuvalue
!   globals  Compoundrow
  
	PowerOFFinterrupts

	Nuvalue = instr(TL$, PARAMNAME$)
	IF Nuvalue < 1 then	    ! this is user-modified name, 
				    !  so replace with original value
	   ParamName$= TabText$(ConChart,"ccDetail",CompoundRow,"PlotVariable")
	Endif

 SetTabText ConChart,"ccDetail",CompoundRow,"PlotVariable",ParamName$
   Nuvalue = GetNowValue(NameName$)
   IF Nowvalue <> Nuvalue then 
        Nowvalue  = Nuvalue
	lowvalue  = -999
	midvalue  = -999
	highvalue = -999
   EndIf
	PowerONinterrupts
Return
EndMacro

!===========================

name ClickonLow
	! When user selects LowLimit, Table is updated.
	! Global var: lowvalue
   parameter a1$, a2$, a3$, a4$
   SetTAbVal  ConChart, "ccDetail", CompoundRow, "LowLimit",lowvalue
Return
EndMacro


name ClickonMid
	! When the user selects Expected Value (Mid value), 
	!		this data is updated in the table.
	! Global var: midvalue
   parameter a1$, a2$, a3$, a4$
   SetTabVal  ConChart, "ccDetail", CompoundRow, "ExpValue",midvalue
Return
EndMacro

name ClickonHigh
	! When user selects HighLimit, Table is updated.
	! Global var: highvalue
   parameter a1$, a2$, a3$, a4$
   SetTabVal  ConChart,"ccDetail",CompoundRow, "HighLimit",highvalue
Return
EndMacro

name ClickonOn
	! When user selects ChartingOn, Table is updated.
	! Global var: doit
Parameter a1$, a2$, a3$, a4$
  
   SetTabVal  ConChart, "ccDetail", CompoundRow, "ChartingOn",doit
Return
EndMacro



name SaveOneRow
! the global is    CompoundRow 

!   SetTabText ConChart, "ccDetail", CompoundRow, "CompoundName", NameName$
   SetTabText ConChart, "ccDetail", CompoundRow, "PlotVariable", Paramname$
   SetTabVal  ConChart, "ccDetail", CompoundRow, "ChartingOn", doit
   SetTAbVal  ConChart, "ccDetail", CompoundRow, "LowLimit", lowvalue
   SetTabVal  ConChart, "ccDetail", CompoundRow, "ExpValue", midvalue
   SetTabVal  ConChart, "ccDetail", CompoundRow, "HighLimit",highvalue
return
EndMacro

name FindOneRow
   Parameter jname$ 
local Roww
	!Returns the row number in ccDetail for the named compound
        Roww= -99
   	Roww= RowByText(ConChart,"ccDetail",,"CompoundName","i=",jname$)
 Return Roww
EndMacro

