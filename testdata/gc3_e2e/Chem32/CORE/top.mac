!############################################################################
name  SetDeviceVars_RCNET
!############################################################################

  local Modules$
  local Module$
  local Module
  local GCIInstance
  local ModuleInstance
  local ModuleID$

  !new for GCI

  on error print ""

  if Check (Variable, RapidControlEnabled) = 0 then
    RapidControlEnabled=0
  endif
  _GCISignalDesc$ = ""
  devRCnet = 0
  devRCnetFirst = 0
  if Check (Variable, devGCI) = 0 then
    devGCI = 0
  else
    if (devGCI > 0)
      if Check(Function, GCIGetBaseType$) = 1 then
         for l = 1 to devGCI
           if InStr(GCIGetBaseType$(l), "RAPIDCONTROL") > 0 then
              devRCnet = devRCnet + 1
              if devRCnetFirst = 0 then
                 devRCnetFirst = l
              endif
           endif
        next l        
      endif
    endif
  endif



  if Check(Function, RCListDevices$) > 0 then
    Modules$ = RCListDevices$()
    Module = 1
    repeat
      Module$ = SubString$(Modules$, Module)
      if Module$ <> "" then
        GCIInstance = 0
        ModuleID$ = ""
        ModuleInstance = 0
        GCIInstance = RCGetGCIInstanceNumber(Module$)
        ModuleID$ = RCGetDeviceModuleID$(Module$)
        ModuleInstance = RCGetDeviceModuleInstanceNumber(Module$)

        if (GCIInstance > 0) and (ModuleID$ <> "") and (ModuleInstance > 0) then
          evaluate "_GCI"+Val$(GCIInstance)+"ALIAS$=ModuleID$"
          evaluate "_GCI"+Val$(GCIInstance)+"ALIAS=ModuleInstance"
        endif

      endif
      Module = Module + 1
    until Module$ = ""
  endif


  if Check(Variable, RCSingleStatusRequired) = 0 then
    RCSingleStatusRequired=0
  endif

endmacro


