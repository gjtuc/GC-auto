  If Check(VARIABLE, XMLEnableExport) = 0 Then
    	XMLEnableExport = PrivateProfileInt("PCS","XMLEnableExport","chemstation.ini",0)
  EndIf
  
  If Check(VARIABLE, XMLAutomation) = 0 Then
    	XMLAutomation = PrivateProfileInt("PCS","XMLAutomation","chemstation.ini",0)
  EndIf
  
  If Check(VARIABLE,XMLExportDestUNC$) = 0 Then
    	XMLExportDestUNC$ = PrivateProfileString$("PCS,"+Val$(_Instrument),"XMLExportDestUNC$","chemstation.ini","")
  EndIf
  
  If Check(VARIABLE,XMLExportLocalRecovPath$) = 0 Then
     XMLExportLocalRecovPath$ = PrivateProfileString$("PCS","XMLExportLocalRecovPath$","chemstation.ini","")
  EndIf
 
  If Check(VARIABLE,XMLImportPath$) = 0 Then
    	XMLImportPath$ = PrivateProfileString$("PCS,"+Val$(_Instrument),"XMLImportPath$","chemstation.ini",_EXEPATH$)
  EndIf

  If Check(VARIABLE,XML_ExportAlwaysExtPerf) = 0 Then
    XML_ExportAlwaysExtPerf = PrivateProfileInt("PCS","XML_ExportAlwaysExtPerf","chemstation.ini",0)
  EndIf

  If Check(VARIABLE,XML_ExportOnPrint) = 0 Then
    XML_ExportOnPrint = PrivateProfileInt("PCS","XML_ExportOnPrint","chemstation.ini",0)
  EndIf

endmacro



!############################################################################
name  Setup_CoreExtension_Hooks
!############################################################################

  ! setup all hook entry points that the core product provides
  !PreViewMenu and MenuLoadComplete hooks triggered first time each menu is displayed.
  ! 1)"Base menu" is build (items BEFORE View Menu Item)
  ! 2)PreViewMenu hook triggered
  ! 3)View, Abort, and Help menus are added
  ! 4)MenuLoadComplete hook triggered
  NewHook "DAMethodChanged"
  NewHook "PreViewMenu"           ! can be used to add a new menu before the View menu
  NewHook "PostMenuLoad"   
  NewHook "LoadMethod"            ! can be used to load additional files
  NewHook "SaveMethod"            ! can be used to save additional files
  NewHook "EditMethod"            ! can be used to edit additional parameters
  NewHook "EditInstMethod"        ! can be used to edit additional
  NewHook "PrintMethod"           ! can be used to print additional parameters
  NewHook "PrintInstMethod"       ! can be used to print additional
  NewHook "PreRun"                ! can be used to modify Runtime checklist
  NewHook "AcqRes"                ! can be used to add info to the AcqRes register
  NewHook "PostAcq"               ! can be used to do instrument-specific control
  NewHook "PreLoadFile"           ! can be used to change file name and other vars
  NewHook "PreInteg"              ! can be used to modify the loaded signals, e.g.
                                  ! by scaling or shifting, subtract blank run, etc.
  NewHook "PostInteg"             ! can be used to do manual integ, or
                                  ! re-integrate with optimized parameters.
  NewHook "PreQuant"              ! can be used to modify the ident results in ChromRes
  NewHook "PostQuant"             ! transfer info about used DA method to ChromRes
  NewHook "RepPostBegin"
  NewHook "RepPreChrom"           ! can be used to print/plot additional info
  NewHook "RepPostChrom"          ! can be used to print/plot additional info
  NewHook "RepPreEnd"
  NewHook "PostDA"                ! can be used to transfer result files
  NewHook "PostRun"               ! can be used to wrap up the instrument run
  NewHook "PostMethodDone"        ! executed after run has finished even on abort

  NewHook "PreSeq"
  NewHook "PauseSeq"
  NewHook "ResumeSeq"
  NewHook "PrePostSeq"
  NewHook "PostSeq"
  NewHook "OnSeqStop"
  NewHook "SeqStartErr"
  
  SetHook "PreRun",  "CapturePreRunColumnsTable", 80
  SetHook "PostAcq", "SeqX_PostAcq", 80
  SetHook "PostRun", "SeqX_PostRun", 80
  SetHook "SeqStartErr","SeqX_PostSequence", 80

  NewHook "AllowCloseApp"
  NewHook "CloseApp"
  NewHook "SeqLbkClosed"
  NewHook "SeqFinalize"
  NewHook "DASignalsLoaded"
  NewHook "LoadTopTaskBar",       "", "Task$"
  NewHook "TopSwitchTask",  "String", "ButtonName$"
  NewHook "DaSwitchTask",   "String", "ButtonName$"
  NewHook "TopStatusTB"
  NewHook "PreViewSwitch", "Scalar", "NextViewName$"
  NewHook "PreCopyClip"
  NewHook "PostCopyClip"
  NewHook "PreWindowOpt"
  NewHook "PostWindowOpt"
  NewHook "OnEventChromReg",  , "Action$, Topic$, TopicName$, " + \
  	                             "Object1,Object2, Item$, IndexX,IndexX2," + \
		                       		     "ItemPart$, IndexY, IndexY2"

  NewHook "LoadMethodCheck", Scalar, "methpath$"
  NewHook "DiagAddModule"      ! hook to plug in new modules
  NewHook "OQPVAddTests"
  NewHook "PInstrCondition",,"Destination$"

  NewHook "PostSeqImport", "", "FileName$"
  NewHook "PreSeqImport",  "", "FileName$"
  
  !new hook executed when _config[1].preferences table changed
  NewHook "OnEvPrefsUpdate"
  OnEvent "_Config[1]._Tab.Preferences", "OnEvPrefsUpdate_HookWOParams",, ROB
  !OnEvPrefsUpdate_HookWOParams calls ExecHook_OnEvPrefsUpdate without parameters to simplify
  
  NewHook "SettingsChanged"
  NewHook "AuthentChanged"

  ! new hooks for XML Export
  if Check(VARIABLE,XMLEnableExport) = 1
  	  if 1 = XMLEnableExport 
  		    NewHook "XML_PreExport"
        NewHook "XML_PostExport"
        NewHook "XML_PostUpload"
   		   SetHook "PostAcq","XML_GenerateLimsFile",200
		      SetHook "PostDA","XML_PostDAExport",200
	    endif
  endif

  SetHook "OnEventChromReg", "CalculateAreaPerc"
  ! Init_Filldown removed rl 06/18/02
  
  !manual integration event
  !B.04.01 MT
  Init_DFManIntHooks

endmacro


!############################################################################
name  LoadCore_CmdExtentions
!############################################################################

  ! preload all resource dlls 
  dummy = InstallCmds(_ExePath$ + "hplock00.dlc")
  _LoadServiceLockDLL
  
  if Check(Command, CpStart) = 0 then
    ! load the dll for multiple CPs
    idBGCP_DLL = InstallCmds(_ExePath$ + "hpbgcp00.dll")
  endif
  CpStart "CP2"        ! start the 2nd CP
  CpStart "CP3"        ! start the 3rd CP
  _LoadServiceNotify_CpFullReadyEvent ! event handler for hpcorApi

  !Execwait _ExePath$ + "win2kchk.exe"
  progcmd$ = chr$(34) + _ExePath$ + "win2kchk.exe" + chr$(34)
  SetCWD  _ExePath$
  Execwait progcmd$

  ! Load the hpgtw_01.dlc if it is not loaded.
  If Check(Command, EdTab) = 0 Then
    ! load the DLC which holds the missing command
    idGTW_DLC = InstallCmds(_EXEPATH$ + "hpgtw_01.dlc")
  endif

  if Check(Command, CalibratePeaks) = 0 then
    ! load the Abacus dll
    idQANT_DLL = InstallCmds(_ExePath$ + "hpqant00.dll")
  endif

  if Check(Command, ShowReport) = 0 then
    ! load the dll for Report Viewer Window
    idRPTV_DLL = InstallCmds(_ExePath$ + "hprptv00.dll")
  endif

  if Check(Command, Beep) = 0 then
    ! load the dll for Beep, SendString, SysInfo$(), printf$(), ConvertText$()
    ! and TopWndSize() 
    idBEEP_DLL = InstallCmds(_ExePath$ + "hpbeep00.dll")
  endif

  if Check(Command, CopyObjTabRow) = 0 then
    ! load the dlc for some table utility commands like CopyObjTabRow
    idTUTI_DLC = installcmds(_EXEPATH$ + "hptuti00.dlc" )
  endif

  if Check(Command, MenuRead) = 0 then
    ! load the macro and dlc to install the new menu commands
    macro _ExePath$ + "menucmds.mac"
    SeeIfMenuCmdsLoaded
  endif

  if Check(Command, DoHTMLReport) = 0 then
    ! load the dll for HTML-reports
    idHTML_DLL = InstallCmds(_ExePath$ + "hphtml00.dlc")
  endif

  if Check(Command, Publish) = 0 then
    l = PrivateProfileInt( "PCS","OLEAutomation","chemstation.ini", 42)
    if (l = 42) then
      l = PrivateProfileInt( "PCS,"+val$(_Instrument),"OLEAutomation","chemstation.ini", 42)
    endif
    if (l=1)or (l=2) then
      idEXTIFC=installcmds("agtextifc00.dll")              ! load the OLE automation framework
      publish _Instrument,"Instrument"+val$(_Instrument),_Offline,2-l,l-1 
    endif
  endif

endmacro

!############################################################################
name SetBetterPdfReportFont
     !for better pdf report appearence under Win7 ( XP does not have consolas font family )
     !this gives much better ledigbe fonts under Vista and Win7 in the classic pdf reports
!############################################################################

  local  DosVerNumber 
  DosVerNumber = Val(SysInfo$("dos version"))
  
  !Win7 has DosVerNumber=6.1  XP has DosVerNumber=5.1
  !and also make sure it is only on non JPN CHN system so that they have their way from installation for all OS

  if DosVerNumber >= 6
     !then it is Win7 and not XP
     if (_Lang$ <> "CHS") AND (_Lang$ <> "CHN") AND (_Lang$ <> "JPN") Then
        SetPrivateProfileString "PCS", "pdf_ReportFontName"  , "Consolas", "chemstation.ini"
        SetPrivateProfileString "PCS", "pdf_ReportFontSize"  , "10"      , "chemstation.ini"
        SetPrivateProfileString "PCS", "pdf_ReportFontWeight", "700"     , "chemstation.ini"
     endif   
  else
     !then it is XP
     if (_Lang$ <> "CHS") AND (_Lang$ <> "CHN") AND (_Lang$ <> "JPN") Then
        SetPrivateProfileString "PCS", "pdf_ReportFontName"  , "Courier New", "chemstation.ini"
        SetPrivateProfileString "PCS", "pdf_ReportFontSize"  , "10"      , "chemstation.ini"
        SetPrivateProfileString "PCS", "pdf_ReportFontWeight", "700"     , "chemstation.ini"
     endif   
     
     !also shut off usage of report viewer in TO Screen ONLY in sequence reprocessing , 
     !since user object leak in i-explorer control kills usage of all apps under OS XP-SP3
     !     (no menus dialog etc come up anymore)
     ! this is to create, higher reliability but less features for XP users
     SetPrivateProfileString    "PCS", "Pdf_viewer_DAReprocess", "0"     , "chemstation.ini"
  endif
endmacro


!############################################################################

name Top

! The autostart macro which is called from C-code at startup
!############################################################################


local dummy,StartUpView$,ProductMacFile$, l

local NLSFileName_top$
local ID_TOP__ONLINE_9
local ID_TOP__F1_HELP_21
local ID_TOP__F5_STARTRUN_23
local ID_TOP__F6_STARTSEQRU_25
local ID_TOP__F8_STOP_27
local ID_TOP__F9_START_HYPE_29
local ID_TOP__F10_STOP_HYPE_31
local ID_TOP__F11_NEXTWINDO_33
local ID_TOP_LOADING_HPSPC1_34
local ID_TOP_LOADING_35
local ID_TOP_36
local ID_TOP_WELCOME_TO_37
local ID_TOP_LOADING_USER_M_38
local ID_TOP_LOADING_MOST_R_39
local ID_TOP_LOADING_TOPLEV_40
local ID_TOP_FREE_DISK_SPAC_41
local ID_TOP_CURRENT_FREE_S_42
local ID_TOP__HELP_43
local ID_TOP_ABOUT_YOUR__GC_44
local ID_TOP_SHOW_SETUP_OF_45

local szMthLoadDelay$

  NLSFileName_top$                  =  "top"
  ID_TOP__ONLINE_9                  =  17009
  ID_TOP__F1_HELP_21                =  17021
  ID_TOP__F5_STARTRUN_23            =  17023
  ID_TOP__F6_STARTSEQRU_25          =  17025
  ID_TOP__F8_STOP_27                =  17027
  ID_TOP__F9_START_HYPE_29          =  17029
  ID_TOP__F10_STOP_HYPE_31          =  17031
  ID_TOP__F11_NEXTWINDO_33          =  17033
  ID_TOP_LOADING_HPSPC1_34          =  17034
  ID_TOP_LOADING_35                 =  17035
  ID_TOP_36                         =  17036
  ID_TOP_WELCOME_TO_37              =  17037
  ID_TOP_LOADING_USER_M_38          =  17038
  ID_TOP_LOADING_MOST_R_39          =  17039
  ID_TOP_LOADING_TOPLEV_40          =  17040
  ID_TOP_FREE_DISK_SPAC_41          =  17041
  ID_TOP_CURRENT_FREE_S_42          =  17042
  ID_TOP__HELP_43                   =  17043
  ID_TOP_ABOUT_YOUR__GC_44          =  17044
  ID_TOP_SHOW_SETUP_OF_45           =  17045
  
  !setverbose 3
  !logging 7,"c:\log.txt"
  LinesPerGraph = 8     ! global variable used by print report macs as minimum graph size

  szMthLoadDelay$ = PrivateProfileString$("PCS", "methodLoadDelay", "chemstation.ini", "")
  If szMthLoadDelay$ <> "" Then
    methodLoadDelay = Val(szMthLoadDelay$)
  EndIf

  !Custom Fields - moved to PrintSeq.mac
  !If Check(Variable, SEQ_PrintSeqTblCFSamp) = 0 Then
  !  SEQ_PrintSeqTblCFSamp = 0  !gloabl variable used in print sequence for sample custom fields 
  !EndIf

  !If Check(Variable, SEQ_PrintSeqTblCFCmpd) = 0 Then
  !  SEQ_PrintSeqTblCFCmpd = 0 !gloabl variable used in print sequence for coumpound custom fields 
  !endif

  Sec_DisableCalibPatch = 1 !disable security pack interims patch for calibration task buttons
  CS_Disable4699Patch = 1   !disable ChemStore patch

  ! Variable initialization for 16 Bit checks
  _Mth16Bit = 0
  _Seq16Bit = 0
  _Batch16Bit = 0
  _FRPT16Bit = 0
  _Hyper16Bit = 0
  _SPC16Bit = 0

  UseExternalInjector = 0
  UseExternalInjectorMenu = 1
  OnEvent "UseExternalInjector", "UseXternalInjMenu",, CP

  PrepPumps = 0

  If Check(Variable, _PumpUseBar) = 0 Then
    _PumpUseBar = 1
  endif

  If Check(Variable, _GuiPump) = 0 Then
    _GuiPump = 1
  endif

  If Check(Variable, _MainPump) = 0 Then
    _MainPump = 1
  endif

  If Check(Variable, _PrepA) = 0 Then
    _PrepA = 1
  endif

  If Check(Variable, _PrepB) = 0 Then
    _PrepB = 1
  endif

  if Check(Variable,VCS_INTEGRATION)=0
    VCS_INTEGRATION = 0
    VCS_NOTINTEGRATED = 1
  EndIf
    
  !--------------------------------------------------------
  ! Batch environment
  If Check(Variable, _BatchVisible) = 0 Then
    _BatchVisible = 0
  EndIf

  If Check(Variable, _BatchNotVisible) = 0 Then
    _BatchNotVisible = 1
  EndIf
  
  !pvcs 15942 - BatchReview enabled by default, ECM suppresses the BatchReview functionality 
  !             chemstation.ini entry overrides the behaviour 
  If Check(VARIABLE,_BatchReview) = 0 Then
    _BatchReview = PrivateProfileInt("PCS","_BatchReview","chemstation.ini",10) !-1 doesn't work as default
    !if entry found it has always priority
    !if entry not found in chemstation.ini, enable review, disable only with ECM
    If _BatchReview = 10 Then
      If VCS_INTEGRATION = 1 Then
        _BatchReview = 0
      Else
        _BatchReview = 1 
      EndIf
    EndIf
    
  EndIf

  If Check(VARIABLE,_DataAuditTrailDisabled) = 0 Then
    _DataAuditTrailDisabled = 1
  EndIf
  

  
  !--------------------------------------------------------

  LoadCore_CmdExtentions
  !remove one time macro again
  remove  LoadCore_CmdExtentions

  !listmessages on,on,8000


  ! set the path of the cursor dll for the Draw cmd
  ! Note: This must adapted if more than just the 800 resolution exists.
  SetTabHdrText _Config[1], "Window", "DrawCursorDLL", \
                _ExePath$ + "800\hpcur008.dll"

  ! This MethodChangedOK flag is needed to get through initialization with 
  ! out getting an error for undefined macros.  Apparently, so C code      
  ! during initialization is setting MethodCHanged, which causes    
  ! SetMethModTime to get called before any macros are even loaded.  
  ! This flag prevents any calls from being scheduled until the macro
  ! subsystem is up and running.   (See part\top\top.c for more info) 
  ! ---------------------------------------------------------------------- 
  _MethodChangedOK = 1
  OnEvent _DAMethod, "SetMethodChanged"
  dummy = Event (_DAMethod, ON)

  Alert1Title$ = _InstName$
  Alert2Title$ = _InstName$
  Alert3Title$ = _InstName$
  Alert4Title$ = _InstName$
  Alert5Title$ = _InstName$

  ! minimal free diskspace to check for is set to 200 MB
  FreeDiskLimit = 200000000
  if _Instance > 1
    _menu_memory = 2    ! default is 4 menus - held in memory
  endif

  SetDeviceVars_Modular1050_1090_CE
  !remove ontime macro again
  remove  SetDeviceVars_Modular1050_1090_CE
  
  if Check (Variable, EDEVENTS_DialogOff) = 0 then
    EDEVENTS_DialogOff = 1
  EndIf
  
  if Check (Variable, bAllowMethodEvents) = 0 then
    bAllowMethodEvents = 1
  EndIf
  
  if Check (Variable, RunDisableExt) = 0 then
    RunDisableExt = 0
  endif

  SetDeviceVars_RCNET
  !remove ontime macro again
  remove  SetDeviceVars_RCNET


  ! _MassSpec is converted into a system variable by the add-on
  ! product.  Set it here based on the feature table for anything
  ! that requires the variable before the add-on starts
  if Check (Variable, _MassSpec) = 0 then
    _MassSpec = TabHdrVal(_Config[1], "Features", "MSAllowed")
  endif

  if ObjHdrType(_Config[1], "LoadSigBox") = 99 then
    NewObjHdrVal _Config[1], "LoadSigBox", 1, 1, 1
  endif

  if ObjHdrType(_Config[1], "RTPMethodSet") = 99 then
    NewObjHdrVal _Config[1], "RTPMethodSet", 0, 1, 1
  endif


  !AFC Ticks Add-On
  if ObjHdrType(_Config[1], "AFCTicksVisible") = 99 then
    NewObjHdrVal _Config[1], "AFCTicksVisible", 0, 1, 1
  endif

  ! This variable (along with the object header
  ! keeps track of the mode of the Load Signal dialog box.  
  ! 0 = Full
  ! 1 = Short
  ChroLoadSigBox = ObjHdrVal(_Config[1], "LoadSigBox")

  SetDeviceVars_LEOModules
  !remove ontime macro again
  remove  SetDeviceVars_LEOModules


  HypSeq_Always = 0 
  _HyperIdleLn = 1

  !!! new for 1946 MSD; 
  !!! variable must exist even for LC-only and MS add-on does not get installed
  if Check (Variable, Dev1946Msd) = 0 then
    Dev1946Msd = 0
  endif

  if Check (Variable, _APPILAMPON) = 0 then
    _APPILAMPON = 0
  endif

  if Check (Variable, _APPILAMPOFF) = 0 then
    _APPILAMPOFF = 0
  endif
  
  Macro "A_EPC.MCX"


  InitDevices_LEOModules_DebugSettings
  !remove ontime macro again
  remove  InitDevices_LEOModules_DebugSettings


  ! Initialize method load/save state
  MethLoadSaveIdle = 1



  ! Load the DLC if it is not loaded.
  If Check(Function, PrivateProfileInt) = 0 Then
    ! load the DLC which holds the missing command
    idPROF_DLC = InstallCmds(_EXEPATH$ + "HPPROF01.DLC")
  endif

  ! Load the HPUAL_01.DLC if it is not loaded.
  If Check(FUNCTION, ChangeAccessLevel) = 0 Then
    ! load the DLC which holds the missing command
    idUAL_DLC = InstallCmds(_EXEPATH$ + "HPUAL_01.DLC")
  endif

  if idUAL_DLC = 0 then
     If Check(VARIABLE, bManagerLevelAccess) = 0 Then
        bManagerLevelAccess = 0    ! global variable used for menu item links
     endif    
  endif



  SetXMLImportExport_Variables
  !remove ontime macro again
  remove  SetXMLImportExport_Variables

  
  If Check(VARIABLE,UpdateDAMethodOnReport) = 0 Then
    UpdateDAMethodOnReport =  PrivateProfileInt("PCS","UpdateDAMethodOnReport","chemstation.ini",0)
  EndIf
  
  !!! CustomFields MT 4.01
  If Check(VARIABLE,CustomFieldsAllowed) = 0 Then
    CustomFieldsAllowed = PrivateProfileInt("PCS","CustomFieldsAllowed","chemstation.ini",1)
  EndIf
  !!! CustomFields MT 4.01 END
  
  If Check(VARIABLE, PrintSeqOldLayout) = 0 Then
    PrintSeqOldLayout = PrivateProfileInt("PCS", "PrintSeqOldLayout", "chemstation.ini", 0)
  EndIf

  !pvcs 14293 - multiplier and dilution shouldn't be used in percent reports
  !customers who rely on this bug though can disable the fix
  If Check(VARIABLE,FactorsInPercReports) = 0 Then
    FactorsInPercReports = PrivateProfileInt("PCS","FactorsInPercReports","chemstation.ini",0)
  EndIf



  ! Write our DDE Name to WIN.INI
  if _offline = 1
     SetPrivateProfileString "PCS,"+Val$(_Instrument), "_DDEOffLine", _DDEName$, "chemstation.ini"
  else
     SetPrivateProfileString "PCS,"+Val$(_Instrument), "_DDEOnLine", _DDEName$, "chemstation.ini"
  endif

  if Check (Variable, _SequenceOn) = 0 then
    _SequenceOn = 0
  endif
 
  if Check (Variable, _PartialSequenceOn) = 0 then
    _PartialSequenceOn = 0
  endif
 
  if Check (Variable, _SLAVEIDLE) = 0 then
    _SLAVEIDLE = 1
  endif

  if Check (Variable, _Lang$) = 0 then
    _Lang$ = ProfileString$ ("intl", "sLanguage", "enu")
  EndIf
  
  if Check (Variable, _NotOldSequenceData) = 0 then
    _NotOldSequenceData = 1
  EndIf
  
  _PDFPrinterInstalled = IsPDFPrinterInstalled()

  ! Initialize file name of the core macro dialog dll  
  !NLSCoreMacDLL$ = _ExePath$ + "language\hbmacr00." + _Lang$
  !G11n, modified on 30-09-04
  !Select hl or hb according to the system locale.
  If (_Lang$ = "enu" or _Lang$ = "ENU")    
    G11nVar$ = "b"    
  Else
    G11nVar$ = "l"    
  EndIf  
  NLSCoreMacDLL$ = _ExePath$ + "language\h" + G11nVar$ + "macr00." + _Lang$
  
  if FileStat (Mode, NLSCoreMacDLL$) = -1 then
    NLSCoreMacDLL$ = _ExePath$ + "language\hbmacr00.enu"
  endif

  ! Initialize variable for default method integrator setting and set a menu item link
  ! for the update opportunity to the enhanced integrator
  if Check (Variable, _GENIEMETHOD) = 0 then
    _GENIEMETHOD = 1      ! The default method is always a GENIE method
  endif 

  if filestat(MODE, _autopath$ + "applics.mac") = 1   ! exists - is a file
    macro "applics.mac"   ! activate ChemStations applications
  endif

  !_DA_PartReprocess = 0 will switch off the "Partial Sequence" menu item of DA view
  !_DA_PartReprocess = 1 make it work according to other variables
  If Check(Variable,_DA_PartReprocess) = 0
    _DA_PartReprocess = 1
  endif
  
  If _ProductType$ = "GC" Then
    LoadMacro "Emethods.mac"
    ACQNOTREADYWAIT = 30  ! default for GC
  EndIf
  
  LoadMacro "signal.mcx"
  LoadMacro "report.mcx"
  LoadMacro "ecmmcx.mcx"
  Init_Signal
  LoadMacro "ssp.mcx"
  Init_SeqSum

  IREnabled = PrivateProfileInt("PCS,"+Val$(_Instrument),"IREnabled","chemstation.ini",0)
  ! Initialization of Review Part I
  if FileStat(Mode,_EXEPATH$ + "ireport.mcx") = 1
    LoadMacro "ireport.mcx"
    IR_InitReportingView  
  endif

  ! initialization of the HyperSequence 
  If _wellplatesampler<>0 Or HypSeq_Always=1
    If STK_EXISTS=0 and HypSeq_Always=0
      Hyper_HideActuals
    EndIf
    Hyper_Init
  Else
    Hyper_HideActuals
  EndIf
  
  ! restoring the old DataPath after Chemstation crash 
  ! If PrivateProfileString$("PCS,"+Val$(_Instrument),"_OLDDATAPATH$","chemstation.ini")<>""
	 !   _DATAPATH$=PrivateProfileString$("PCS,"+Val$(_Instrument),"_OLDDATAPATH$", "chemstation.ini")
  !	  SetPrivateProfileString "PCS,"+val$(_Instrument),"_OLDDATAPATH$","","chemstation.ini"
  ! EndIf

  If Check(Variable,_OLDDATAPATH$) = 0
    _OLDDATAPATH$ = _DATAPATH$
  endif

  !Initialize directory variables and table
  DIR_InitDirectories

  ! initializing CP Variable for showing if Sequence Edit Table is openend
  SeqTabEdOpen=0
  
  LoadMacro "txt_imp.mcx" !load the text import macro - since 05 Feb 03 contains also xml import/export macros
  
  !CustomFields 4.01 MT
  isGCFlag = 0
  If _ProductType$ = "GC" Then
    isGCFlag = 1 
  EndIf
  !CustomFields 4.01. MT END
  
  SetFKey_VIEW "TOP"

  print "Loading postacq.mac..."
  macro "postacq.mac"


  Setup_CoreExtension_Hooks
  !remove ontime macro again
  remove  Setup_CoreExtension_Hooks


  !moved Init_NavTab and Init_CustomFields after all hooks are set
  Init_NavTab
  
  !CustomFields 4.01 MT
  Init_CustomFields


  !update of sample.mac/batch file on reporting
  !B.04.01 MT
  Init_Quant
  
  ! load and initialize batch review
  LoadMcxOrMac _AutoPath$ + "batch", "BatchInit"

  if TabHdrVal (_Config[1], "Features", "SpectraAllowed") = 1 then
    ! Load spectral macros
    print ReadResource$(NLSFileName_top$,ID_TOP_LOADING_HPSPC1_34)
    macro "hpspc1.mcx",go
  endif

  ! For offline da/reporting to improve cycle time
  if filestat(MODE, _autopath$ + "OffLnDA.mac") = 1   ! exists - is a file
    LoadMacro "OffLnDA.mac"
    OfflineDA_Init
  endif
  
  if (VCS_INTEGRATION = 1) then
    VCS_NOTINTEGRATED = 0
    InitAcaml
  endif

  if (VCS_INTEGRATION = 1) then
     !_datasubdir$ not allowed even when CS is migrated to ECM usage on TT #21191
     _DATASUBDIR$ = "" 
  endif


  ! call the start macro of each configured add-on that wants to
  ! use the above defined hooks
  
  _InstType$ = PrivateProfileString$("PCS,"+Val$(_Instrument),"InstType","chemstation.ini","")
  If (_InstType$ = "68GC" Or _InstType$ = "5890" Or _InstType$ = "6850GC" or _InstType$ = "78GC" or _InstType$ = "7820GC")
     l = Instr(_AUTOPATH$, "\CORE")
     If l = 0
        l = Instr(_AUTOPATH$, "\core")
     EndIf
     
     _AutoPUIPath$ = _AUTOPATH$[1:l]+"GC\"
     PUITopMac$ = _AutoPUIPath$ + "PUITOP.MAC"
     If FileStat(MODE, PUITopMac$) = 1
        Macro PUITopMac$, Go
     EndIf
           
     _AutoRTLPath$ = _AUTOPATH$[1:l]+"GC\"
     RTLTopMac$ = _AutoRTLPath$ + "RTLTOP.mac"
     If fileStat (Mode, RTLTopMac$) = 1
        Macro RTLTopmac$, Go
     endif

  EndIf
  
  StartAddons
  
  If Check(System_Variable, _IsRegulated) = 1 Then
    If _IsRegulated = 1 Then
      If Check(Macro, ChemStoreSelectDB) = 0 Then
        AddOnPath$ = PrivateProfileString$("PCS", "Path", "chemstation.ini", "c:\hpchem") + "\chemstor\"
        Macro AddOnPath$+"hpdbif00.mcx", go
        remove AddOnPath$
      EndIf
      LoadMacro "security.mcx"
    EndIf
  EndIf

  PostAddOnAdjustMenusForViewsTab

  ! initialize the GUI with all that the Addons might have brought in
  GUICoreInitialize
  
  ! call the hp<_ProductType$>.mac, if it exists
  ProductMacFile$ = _ProductPath$ + "hp" + _ProductType$ + ".mac"
  if FileStat(MODE, ProductMacFile$) = 1 then       ! is a regular file
    print ReadResource$(NLSFileName_top$,ID_TOP_LOADING_35) + ProductMacFile$ + ReadResource$(NLSFileName_top$,ID_TOP_36)
    macro ProductMacFile$, go
  endif

! Only until leonardo instrument control does it
  if DevLeoAccess > 0 or devGCI > 0 then
    macro _driverpath$+"hpclst00.mcx",go
  EndIf


  ! Load method and sequence
  ! Set method changed to zero since this is the
  ! first time we are loading a method and the method should
  ! not be dirty.  This is an attempt to fix the defect where
  ! an 6890 is making the method dirty before the first method is
  ! loaded.  -JTG  950131
  _MethodChanged = 0

  ! do we start after a broken purify study run? Then restore some important values  
  If (PrivateProfileString$ ("PURIFY", "StudySequence", "chemstation.ini", "") <> "")
    On error print
    Delete _seqpath$ + PrivateProfileString$ ("PURIFY", "StudySequence", "chemstation.ini",""), DONTASK
    _seqfile$ = PrivateProfileString$ ("PURIFY", "OldSequence", "chemstation.ini", _seqfile$)
    _MethPath$ = PrivateProfileString$ ("PURIFY", "MethPath", "chemstation.ini", _MethPath$)
    _DataPath$ = PrivateProfileString$ ("PURIFY", "DataPath", "chemstation.ini", _DataPath$)

    
    ! clear entries now
    SetPrivateProfileString "PURIFY", "StudySequence", "", "chemstation.ini"
    SetPrivateProfileString "PURIFY", "OldSequence", "", "chemstation.ini"
    SetPrivateProfileString "PURIFY", "MethPath", "", "chemstation.ini"
    SetPrivateProfileString "PURIFY", "DataPath", "", "chemstation.ini"
    On error
  EndIf
  ! reset paths in case of a crash
  If (PrivateProfileString$("PCS," + Val$(_Instrument),"ACQSEQPATH","chemstation.ini","")<>"") and \
     ( (IsOnlineRunning()=0) or (_offline=0))
      on error print
      Delete PrivateProfileString$("PCS," + Val$(_Instrument),"ACQSEQPATH","chemstation.ini","") + "ACQUIRING.TXT", DONTASK
      SetPrivateProfileString "PCS," + Val$(_Instrument),"ACQSEQPATH","","chemstation.ini"
      On Error
  endif
  ! loading method if fails then load def_xx.m
  On error MethodNew
  
  !14792 - START - reprocessing copy should take over the method from the online
  Local tmp_methpath$
  Local tmp_methfile$
  
  If _offline = 1 and IsOnlineRunning()=1 Then
    If FileStat(MODE,_TempPath$+"currmeth.txt") <> -1 Then
      Open _tempPath$+"currmeth.txt" For Input as #42
      Input #42, tmp_methpath$
      Input #42, tmp_methfile$
      Close #42
      delete _TempPath$+"currmeth.txt", DONTASK
    EndIf
  EndIf

  If Check(Command, ClusterTccStartup) = 1 Then
    ClusterTccStartup
  EndIf
  If Check(Command, ClusterPmpStartup) = 1 Then
    ClusterPmpStartup
  EndIf
  
  If (_ProductType$ = "CE") And (CheckChangedCEMode() = 1) Then
    MethodNew
  Else
    If tmp_methpath$ <> "" And tmp_methfile$ <> "" And FileStat(MODE,tmp_methpath$+tmp_methfile$) <> -1 Then
      LoadMethod tmp_methpath$,tmp_methfile$
    Else
      LoadMethod _methpath$,_methfile$
    EndIf
  EndIf
  !14792 - END

  
  On Error SequenceNew
  LoadSequence _seqpath$,_seqfile$, , 0
  On Error

  If Check(command,_LoadServiceNotify_AddNewViewEvent)>0 then
    _LoadServiceNotify_AddNewViewEvent
  Endif
  RunStartupViewMacros    ! load everything that views need

  ! Initialization of Intelligent Reporting 
  if FileStat(Mode,_EXEPATH$ + "ireport.mcx") = 1
    IR_Init
  endif

  !now initialize the Security Pack
  if CheckSecPack() > 0 then
    InitializeSecurityPack
  EndIf
  
  !now call all that personalizes this chemstation in the user.mac
  !for instance with user contributed libraries
  TopWelcomeMsg$ = ReadResource$(NLSFileName_top$,ID_TOP_WELCOME_TO_37) + \
                   TabHdrText$ (_Config[1], "Features", "AppTitleText") +\
                   ". "
                   !will be printed when all startup has been completed
                   !Set here so can be altered in user.mac

  if filestat(MODE, _autopath$ + "user.mac") = 1   ! exists - is a file
    print ReadResource$(NLSFileName_top$,ID_TOP_LOADING_USER_M_38)
    macro "user.mac"
  EndIf
  


  !now do no more loading of functionality. (after user.mac)
  !just prepear the display and menu,
  !and put up diskspace warning and user levels at
  !the very end of initialization
  !after quitting those the chemstation is ready for use

  if TabHdrVal (_Config[1], "Features", "Background") = 0 then
    Background
  endif

  !ChemStore version supporting B.03.01+ will set those variables according to their needs. 
  If Check(variable,_NavTab_LoadFirstFileWithDataSet) = 0 Then
    _NavTab_LoadFirstFileWithDataSet = 1 
  EndIf

  If Check(variable,_NavTab_AlwaysHide) = 0 Then
    _NavTab_AlwaysHide = 0
  EndIf


  StartUpView$=TabHdrText$(_config[1],"window","CurrentView")
  if StartUpView$ <> ""
    print ReadResource$(NLSFileName_top$,ID_TOP_LOADING_MOST_R_39)
    ! have the menu show before the chemstation says welcome
    SwitchMenuInView   StartUpView$
    SwitchView TabHdrText$(_config[1],"window","CurrentView")
  else
    print ReadResource$(NLSFileName_top$,ID_TOP_LOADING_TOPLEV_40)
    LoadMenu 1             ! load the menu from the various files
    SwitchView "TOP"
    StartUpView$="TOP"
  endif
  if (VCS_INTEGRATION = 1)
    if StartUpView$ = "TOP"
      _ECM_AUTOUPLOAD_ACQ_ENABLED = 1
    else
      _ECM_AUTOUPLOAD_ACQ_ENABLED = 0
    endif
  endif
  
  ! if the edit columns screen was left on, need the processing macros
  if tabtext$(_config[1],"window",68,"command") <> "" then
    macro "editcolp.mac"
  endif

  ! Now update hppcssvc.ini for the MMV maintenance CD ROM title.
  UpdateMaintenanceCDIniFile

  dummy=FreeDiskSpace(_DataPath$[1])
  if  dummy < FreeDiskLimit
    dummy= Alert(ReadResource$(NLSFileName_top$,ID_TOP_FREE_DISK_SPAC_41)\
                 +Val$(FreeDiskLimit/1000000)+ " MB."\
                 +CHR$(13)+CHR$(10)\
                 +ReadResource$(NLSFileName_top$,ID_TOP_CURRENT_FREE_S_42)\
                 +Val$(ceil(FreeDiskSpace(_DataPath$[1])/1000)/1000)\
                 +" MB.",3)
  endif

  ! Initialize user access levels.  The user will be prompted to select
  ! an access level if the "PromptAtStartup" flag is set.
  InitializeUAL  

  ! switch yielding to server yield
  _LoadService_ToggleYield
  ! Fraction Collector intialization routine
  LoadMacro "fraccoll.mcx"
  FracColl_Init
  if _HPCE<>0 then
      MSTimeout = 3600
  endif



  ! run gcinfo.mac - available only for GC ChemStation
  !Defect fix: PVCS#7025 
  local menufile$
  menufile$ = TabHdrText$(_config[1],"MenusForViews","MenuCol")
   
  fullmenu = TabHdrVal(_config[1], "UAL", "SetFullMenu")
  
  !If ((_ProductType$ = "GC") And (_OFFLINE = 0) And (adcdevice = 0)) Then
  !If (((_ProductType$ = "GC") And (adcdevice = 0)) or (((_ProductType$ = "GC") And (_OFFLINE = 0)) And (adcdevice = 0)) ) Then

  ! TT #917 This menu item should only appear for a 5890.  EMP Aug 25 2009
  If ((_ProductType$ = "GC") And (TestForDevice("GC", 0, "") <> 0)) Then
    If ((menufile$ = "FullMenuFile") Or (fullmenu = 1 ))Then
      MenuAdd ReadResource$(NLSFileName_top$,ID_TOP__HELP_43),ReadResource$(NLSFileName_top$,ID_TOP_ABOUT_YOUR__GC_44),"macro ""gcinfo.mac"" ,GO",,\
      ReadResource$(NLSFileName_top$,ID_TOP_SHOW_SETUP_OF_45)
    EndIf
  EndIf
  
  !initialize automation engine
  macro "ae.mac"
  
  DeleteUnneededDeviceNLSRegisters
  remove  DeleteUnneededDeviceNLSRegisters

  !for better pdf report appearence under Win7 ( XP does not have consolas font family )
  !also shut off usage of report viewer in TO Screen only in sequence reprocessing , since user object leak kills usage of all apps under OS XP-SP3
  SetBetterPdfReportFont
  remove  SetBetterPdfReportFont

endmacro
