!############################################################################
Name DIR_Create
!
!############################################################################

    If ObjHdrType(_Config[1], "Directories") = 99 Then
        NewTab _Config[1], "Directories"

        NewColText _Config[1],"Directories", "Path"
        NewColVal _Config[1], "Directories", "Data"
        NewColVal _Config[1], "Directories", "Method"
        NewColVal _Config[1], "Directories", "Sequence"
        NewColVal _Config[1], "Directories", "Report"
        NewColVal _Config[1], "Directories", "UVLib"
        NewColVal _Config[1], "Directories", "MSTune"
    EndIf
    If TabColType(_Config[1], "Directories", "RecentSingleSample") = 99 Then
        NewColVal _Config[1], "Directories", "RecentSingleSample"
    EndIf

    If TabHdrType(_Config[1], "LoadFileOpts", "LoadMeth_Seq") = 99 Then
        If _ProductType$ = "GC" Then
            NewTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_Seq", 0,, 3
        Else
            NewTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_Seq", 1,, 3
        EndIf
    Else
        If TabHdrVal(_Config[1], "LoadFileOpts", "LoadMeth_Seq") = -1 Then
            If _ProductType$ = "GC" Then
                SetTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_Seq", 0
            Else
                SetTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_Seq", 1
            EndIf
        EndIf
    EndIf
      
    If TabHdrType(_Config[1], "LoadFileOpts", "LoadMeth_SFs") = 99 Then
        If _ProductType$ = "GC" Then
            NewTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_SFs", 0,, 3
        Else
            NewTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_SFs", 1,, 3
        EndIf
    Else
        If TabHdrVal(_Config[1], "LoadFileOpts", "LoadMeth_SFs") = -1 Then
            If _ProductType$ = "GC" Then
                SetTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_SFs", 0
            Else
                SetTabHdrVal _Config[1], "LoadFileOpts", "LoadMeth_SFs", 1
            EndIf
        EndIf
    EndIf 

    If ObjHdrType(_Config[1], Preferences) = 99 Then
       ! the creation of this table is now done in hpcoreApi
        NewTab _Config[1], "Preferences"

        !NewTabHdrText _Config[1], Preferences, "SeqNameTemplate", "|Se| |Da| |Ti|"
        NewTabHdrText _Config[1],"Preferences", "SeqNameTemplate", "<SeqN><Date><Time>"
        NewTabHdrText _Config[1],"Preferences", "PCName", ""
        NewTabHdrVal _Config[1], "Preferences", "Counter", 1,, 3
        NewTabHdrVal _Config[1], "Preferences", "SeqPackage", 1
    Else
        If TabHdrType(_Config[1], "Preferences", "PCName") = 99 Then
            NewTabHdrText _Config[1],"Preferences", "PCName", ""
            NewTabHdrVal _Config[1], "Preferences", "Counter", 1,, 3
        EndIf
        If TabHdrType(_Config[1], "Preferences", "SeqPackage") = 99 Then
            NewTabHdrVal _Config[1], "Preferences", "SeqPackage", 1
        EndIf
    EndIf
    
EndMacro 

!############################################################################
Name DIR_UseSingleSampleDataDir
!
Parameter Directory$ default _DATAPATH$
!############################################################################
local Row, Loop, NumRows

    If ObjHdrType(_Config[1], "Directories") = 4 Then
        Directory$ = ConvertText$("trim", Directory$)
        If Directory$ = "" Then
            Return
        EndIf

        !add trailing backslash
        If Directory$[Len(Directory$)] <> "\" Then
            Directory$ = Directory$ + "\"
        EndIf

        Row = RowByText(_Config[1], "Directories",, "Path", "i=", Directory$) 
        NumRows = TabHdrVal(_Config[1], "Directories", "NumberOfRows")
        Loop = 1
        while (Loop > 0)
            if ((Loop > 0) and (Loop <> Row))
                SetTabVal  _Config[1], "Directories", Loop, "RecentSingleSample", 0
            EndIf
            if (Loop < NumRows)
                Loop = RowByVal(_Config[1], "Directories", Loop+1:-1, "RecentSingleSample", "<>", 0)
            else
                Loop = -1
            EndIf
        endwhile
            
        If Row > 0 Then
            SetTabVal  _Config[1], "Directories", Row, "RecentSingleSample", 1
        EndIf

    EndIf
EndMacro 

!############################################################################
Name DIR_AddDirectory
!
Parameter Directory$
Parameter Data      Default 0
Parameter Method    Default 0
Parameter Sequence  Default 0
Parameter Report    Default 0
Parameter UVLib     Default 0
Parameter MSTune    Default 0
!
!############################################################################

Local Row

    If ObjHdrType(_Config[1], "Directories") = 4 Then
        
        Directory$ = ConvertText$("trim", Directory$)
        If Directory$ = "" Then
            Return
        EndIf

        !add trailing backslash
        If Directory$[Len(Directory$)] <> "\" Then
            Directory$ = Directory$ + "\"
        EndIf

        Row = RowByText(_Config[1], "Directories",, "Path", "i=", Directory$)
        If Row < 0 Then
            InsTabRow _Config[1], "Directories", 1
            Row = 1
            SetTabText _Config[1], "Directories", Row, "Path", Directory$
        EndIf

        If Data <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Data", 1
        EndIf
        If Method <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Method", 1
        EndIf
        If Sequence <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Sequence", 1
        EndIf
        If Report <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Report", 1
        EndIf
        If UVLib <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "UVLib", 1
        EndIf
        If MSTune <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "MSTune", 1
        EndIf

    EndIf

EndMacro 



!############################################################################
Name DIR_RemoveDirectory
!
Parameter Directory$
Parameter Data          Default 0
Parameter Method        Default 0
Parameter Sequence      Default 0
Parameter Report        Default 0
Parameter UVLib         Default 0
Parameter MSTune        Default 0
Parameter FinallyRemove Default 0
!
!############################################################################

Local Row

    If ObjHdrType(_Config[1], "Directories") = 4 Then
        
        Directory$ = ConvertText$("trim", Directory$)
        If Directory$ = "" Then
            Return
        EndIf

        !add trailing backslash
        If Directory$[Len(Directory$)] <> "\" Then
            Directory$ = Directory$ + "\"
        EndIf

        Row = RowByText(_Config[1], "Directories",, "Path", "i=", Directory$)
        If Row < 0 Then
            Return
        EndIf

        If Data <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Data", 0
        EndIf
        If Method <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Method", 0
        EndIf
        If Sequence <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Sequence", 0
        EndIf
        If Report <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "Report", 0
        EndIf
        If UVLib <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "UVLib", 0
        EndIf
        If MSTune <> 0 Then
            SetTabVal _Config[1], "Directories", Row, "MSTune", 0
        EndIf

        If (FinallyRemove = 1) And \
            (TabVal(_Config[1], "Directories", Loop, "Data") = 0) And \
            (TabVal(_Config[1], "Directories", Loop, "Method") = 0) And \
            (TabVal(_Config[1], "Directories", Loop, "Sequence") = 0) And \
            (TabVal(_Config[1], "Directories", Loop, "Report") = 0) And \
            (TabVal(_Config[1], "Directories", Loop, "UVLib") = 0) And \
            (TabVal(_Config[1], "Directories", Loop, "MSTune") = 0) Then
            DelTabRow _Config[1], "Directories", Row
        EndIf
    EndIf

EndMacro 



!############################################################################
Name DIR_InitDirectories
!
!############################################################################

    DIR_Create
    DIR_AddDirectory _DataPath$ , 1
    DIR_AddDirectory _ConfigMetPath$ ,, 1 
    DIR_AddDirectory _ConfigSeqPath$  ,,, 1 
    DIR_UpdateDirectories
    CpRequest "CP2", "OnEvent ""_Config[1]._Tab.Directories"", ""DIR_UpdateDirectories"",, ""ROD"""

EndMacro 



!############################################################################
Name DIR_UpdateDirectories
!
Parameter EventCause$			Default ""
Parameter EventLevel$			Default ""
Parameter EventSubjName$  Default ""
Parameter EventObj				Default 0
Parameter EventObj2 			Default 0
Parameter EventPartName$  Default ""
Parameter EventIndex			Default 0
Parameter EventIndex2     Default 0
Parameter EventNVName$    Default ""
!
!############################################################################


Local NumRows
Local Loop
Local Path$

    if (EventLevel$ = "Tab_Cell") ! don't care about recent single sample data directory
        if (EventNVName$ = "RECENTSINGLESAMPLE")
            return
        EndIf
    EndIf

    _DATAPATHS$ = ""
    _METHODPATHS$ = ""
    _SEQUENCEPATHS$ = ""
    _REPORTPATHS$ = ""
    _UVLIBPATHS$ = ""
    _MSTUNEPATHS$ = ""

    If ObjHdrType(_Config[1], "Directories") = 4 Then
        
        NumRows = TabHdrVal(_Config[1], "Directories", "NumberOfRows")
        For Loop = 1 To NumRows

            Path$ = TabText$(_Config[1], "Directories", Loop, "Path")
            if (len(Path$)>0) Then
                If TabVal(_Config[1], "Directories", Loop, "Data") > 0 Then
                    if _DATAPATHS$ <> ""
                       Path$ = "|" + Path$
                    endif   
                    _DATAPATHS$ = _DATAPATHS$ + Path$
                EndIf

                If TabVal(_Config[1], "Directories", Loop, "Method") > 0 Then
                    if _METHODPATHS$ <> ""
                       Path$ = "|" + Path$
                    endif   
                    _METHODPATHS$ = _METHODPATHS$ + Path$
                EndIf

                If TabVal(_Config[1], "Directories", Loop, "Sequence") > 0 Then
                    if _SEQUENCEPATHS$ <> ""
                       Path$ = "|" + Path$
                    endif   
                    _SEQUENCEPATHS$ = _SEQUENCEPATHS$ + Path$
                EndIf

                If TabVal(_Config[1], "Directories", Loop, "Report") > 0 Then
                    if _REPORTPATHS$ <> ""
                       Path$ = "|" + Path$
                    endif   
                    _REPORTPATHS$ = _REPORTPATHS$ + Path$
                EndIf

                If TabVal(_Config[1], "Directories", Loop, "UVLib") > 0 Then
                    if _UVLIBPATHS$ <> ""
                       Path$ = "|" + Path$
                    endif   
                    _UVLIBPATHS$ = _UVLIBPATHS$ + Path$
                EndIf

                If TabVal(_Config[1], "Directories", Loop, "MSTune") > 0 Then
                    if _MSTUNEPATHS$ <> ""
                       Path$ = "|" + Path$
                    endif   
                    _MSTUNEPATHS$ = _MSTUNEPATHS$ + Path$
                EndIf
            EndIf

        Next Loop

    EndIf

EndMacro 


!############################################################################
Name SetFKey_VIEW

Parameter view$
!############################################################################
  
local NLSFileName_top$
local ID_TOP__F1_HELP_21
local ID_TOP__F5_STARTRUN_23
local ID_TOP__F6_STARTSEQRU_25
local ID_TOP__F8_STOP_27
local ID_TOP__F9_START_HYPE_29
local ID_TOP__F10_STOP_HYPE_31
local ID_TOP__F11_NEXTWINDO_33

  NLSFileName_top$         = "top"
  ID_TOP__F1_HELP_21       =  17021
  ID_TOP__F5_STARTRUN_23   =  17023
  ID_TOP__F6_STARTSEQRU_25 =  17025
  ID_TOP__F8_STOP_27       =  17027
  ID_TOP__F9_START_HYPE_29 =  17029
  ID_TOP__F10_STOP_HYPE_31 =  17031
  ID_TOP__F11_NEXTWINDO_33 =  17033
 
  view$=UPPERCASE$(view$)

  SetFKey "F1","!",ReadResource$(NLSFileName_top$,ID_TOP__F1_HELP_21)

  if view$="TOP" then
    !set shortcut Function keys (must be same in all menus shown as \tF5 etc)
    If AUTHORIZATIONSERVICE_ISPERMITTED(AS_Privilege_RunRun)=0 Then
      SetFkey "F5",""
      SetFkey "F6",""
      SetFKey "F8",""
      SetFKey "F9",""
      SetFKey "F10",""
    else
      SetFkey "F5","RunMethod",ReadResource$(NLSFileName_top$,ID_TOP__F5_STARTRUN_23)
      SetFkey "F6","RunSequence",ReadResource$(NLSFileName_top$,ID_TOP__F6_STARTSEQRU_25)
      SetFKey "F8","HPLC.STOPMETHOD",ReadResource$(NLSFileName_top$,ID_TOP__F8_STOP_27)
      ! add shortcut functions for Hyperseq only in online mode when AutoInterface installed
      if (_wellplatesampler<>0 and (STK_EXISTS=1 and _offline=0)) or HypSeq_Always=1
        SetFKey "F9","Hyper_Run",ReadResource$(NLSFileName_top$,ID_TOP__F9_START_HYPE_29)
        SetFKey "F10","Hyper_Stop",ReadResource$(NLSFileName_top$,ID_TOP__F10_STOP_HYPE_31)
      EndIf
    endif
    SetFKey "F11","view.win ,""next""",ReadResource$(NLSFileName_top$,ID_TOP__F11_NEXTWINDO_33)
  Else
    SetFkey "F5",""
    SetFkey "F6",""
    SetFKey "F8",""
    SetFKey "F9",""
    SetFKey "F10",""
    SetFkey "F11",""
  EndIf
  
EndMacro


