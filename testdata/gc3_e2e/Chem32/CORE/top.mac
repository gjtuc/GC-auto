!############################################################################
name  DeleteUnneededDeviceNLSRegisters
!############################################################################
!this should lighten CS process memory by 130 MB
local  index

  if _ProductType$ <> "GC" then
     DelReg NLS6850
     DelReg NLSgc0a
     DelReg NLSgc6a
     DelReg NLSin0a
  endif

  ! check which modules are present at all
  if (DevLeoPump = 0)
     DelReg NLSlpmp
  endif
  if (DevLeoAls = 0)
     DelReg NLSlals
     !both go via same var
     DelReg NLSlwls
  endif
  if (DevLeoThm = 0)
     DelReg NLSlthm
  endif
  if (DevLeoClc = 0)
     DelReg NLSlclc
  endif
  if (DevLeoVwd = 0)
     DelReg NLSlvwd
  endif
  if (DevLeoRid = 0)
     DelReg NLSlrid
  endif
  if (DevLeoDad = 0)
     DelReg NLSldad
  endif    
  if (DevNucDad = 0)
     DelReg NLSndad
  EndIf
  if (DevNucMwd = 0)
     DelReg NLSnmwd
  endif
  if (DevNucVwd = 0)
     DelReg NLSnvwd
  EndIf
  if (DevLeoMwd = 0)
     DelReg NLSlmwd
  endif
  if (DevLeoFld = 0)
     DelReg NLSlfld
  endif
  if (DevLeoAfc = 0)
     DelReg NLSlafc
  endif
  if (DevLeoVlv = 0)
     DelReg NLSlvlv
  endif
  
  !containing quite a lot of string infos  
  for index = 1 to 3
      if ObjHdrType (NLSCore[1], "Columns"+val$(index)) = 4 then
         DelTab NLSCore[1], "Columns"+val$(index)
      endif
  next index


endmacro


