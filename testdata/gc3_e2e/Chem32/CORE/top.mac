!############################################################################
name CmdChangeAccessLevel

! called from the menu item to change the access level.
! The macro's only reason for existence is to avoid creating a global
! variable to hold the return value of ChangeAccessLevel.
!############################################################################

local r_val

  r_val = ChangeAccessLevel(1)

  ! See if to change the toolbar buttons
  TLB_SetANN_GraphTaskAccess

endmacro

!############################################################################
name GotoStandBy

! Called in the Instrument|System Off menu item
!############################################################################
 
local reply$, base$, lastitem$, Type$
 
local NLSFileName_top$
local ID_TOP_SWITCH_OFF_LC_1
local ID_TOP_SWITCH_OFF_CE_2
local ID_TOP__AND_3
local ID_TOP_LAMP_S_4
local ID_TOP___THERMOSTAT_5
local ID_TOP_SWITCH_OFF_6
local ID_TOP_MSD__STANDBY_M_7

  NLSFileName_top$				              =  "top"
  ID_TOP_SWITCH_OFF_LC_1            =  17001  
  ID_TOP_SWITCH_OFF_CE_2            =  17002  
  ID_TOP__AND_3                     =  17003
  ID_TOP_LAMP_S_4                   =  17004  
  ID_TOP___THERMOSTAT_5             =  17005  
  ID_TOP_SWITCH_OFF_6               =  17006  
  ID_TOP_MSD__STANDBY_M_7           =  17007

  if _ProductType$ = "GC" then
    return
  endif

  if _offline<>0 then
    return
  endif

  ! initialize reply$ string parts
  if _HPCE=0 then
    base$ = ReadResource$(NLSFileName_top$,ID_TOP_SWITCH_OFF_LC_1)
  else
    base$ = ReadResource$(NLSFileName_top$,ID_TOP_SWITCH_OFF_CE_2)
  endif
  and$  = ReadResource$(NLSFileName_top$,ID_TOP__AND_3)
  lastitem$ = ReadResource$(NLSFileName_top$,ID_TOP_LAMP_S_4)
  
  ! add thermostat
  if (devleothm > 0) or (devRCnet > 0) then
    base$ = base$ + ReadResource$(NLSFileName_top$,ID_TOP___THERMOSTAT_5)
  endif

  ! add MSD
  if dev1946msd > 0  then
	if MSOnlyConfigCheck() = 1 then
	  base$ = ReadResource$(NLSFileName_top$,ID_TOP_SWITCH_OFF_6)
	  and$ = " "
	else
      base$ = base$ + ", " + lastitem$
	endif
    lastitem$ = ReadResource$(NLSFileName_top$,ID_TOP_MSD__STANDBY_M_7) 
  endif

  ! build final string
  reply$ = base$ + and$ + lastitem$ + "?"

  ON ERROR _ASK4APPILAMP = 0
  if alert (reply$, 4, Alert4Title$) = 1 then
    ! This _ASK4APPILAMP flag is needed to set to 1. C code will check the value
    ! if set to 1, will pop up a dialog box ask for shut down APPI Lamp or not
    ! if set to 0, no farther action
    _ASK4APPILAMP = 1
    StandBy
    ! switch off FLD lamp
    if dev1046FLD = 1
      if _offline = 0
        reply$ = SendModule$ ("FLD", "LAMP=0")
      endif
    endif
  endif
  ON ERROR

endmacro

!############################################################################
name SetUALValues
!############################################################################

local menutype$

  if bManagerLevelAccess = 1 then
    menutype$ = TabHdrText$(_config[1],"MenusForViews","MenuCol")
    if menutype$ = "FullMenuFile" then
      SetTabHdrVal _Config[1], "UAL", "SetFullMenu", 1
    else
      SetTabHdrVal _Config[1], "UAL", "SetFullMenu", 0
    endif
  EndIf
  
endmacro

!############################################################################
name ClosePhx

Parameter no_prompt default 0
Parameter start_LabDev default 0

! Called from the Exit menu item
!############################################################################

local ok, mode$, ok1
local dummy

local NLSFileName_top$
local ID_TOP__OFFLINE_8
local ID_TOP__ONLINE_9
Local ID_TOP_CLOSE_10
Local ID_TOP_STARTLABDEV_46

  NLSFileName_top$                  =  "top"
  ID_TOP__OFFLINE_8                 =  17008
  ID_TOP__ONLINE_9                  =  17009
  ID_TOP_CLOSE_10                   =  17010
  ID_TOP_STARTLABDEV_46             =  17046

  if _offline = 1
    Mode$ = ReadResource$(NLSFileName_top$,ID_TOP__OFFLINE_8)
  else
    Mode$ = ReadResource$(NLSFileName_top$,ID_TOP__ONLINE_9)
  endif
    
  if start_LabDev=0
  
    !!!
    !!! ClosePhx is called (via CpRequest) from the UAL code.
    !!! We don't want a prompt if the user tries to Cancel out
    !!! without supplying a login id.
    !!!
    if no_prompt <> 1 then
      ok = alert(ReadResource$(NLSFileName_top$,ID_TOP_CLOSE_10) + _instname$ + mode$ + "?", 4, Alert4Title$)
      if ok = 1 AND _offline = 0
        if  DevRCNet+DevLeoAfc+DevLeoPump+DevLeoAls+DevLeoThm+DevLeoDad+DevLeoMwd+DevNucDad+DevNucMwd+DevNucVwd+DevLeoFld+DevLeoVwd+DevLeoRid+Dev1946Msd > 0
          GotoStandBy
        endif
      endif
    else
      ok = 1
    endif
  Else
    if no_prompt <> 1 then
      ok=Alert(sPrintf$(_instname$+mode$,ReadResource$(NLSFileName_top$,ID_TOP_STARTLABDEV_46)),4,Alert4Title$)
    Else
      ok=1
    endif
  endif
  
  if ok = 1     ! ok - close application
  
    SwitchViewCloseAllWindows 1 !non view manager windows
  
    ! Check if current view was "Diagnose". If so, save the diagnosis register and
    ! clear the method changed and sequence changed flag.
    if TabHdrType(_CONFIG[1], WINDOW, CurrentView) <> 99 then
      if ConvertText$(upper,TabHdrText$(_CONFIG[1], WINDOW, CurrentView)) = "DIAGNOSE" then
        ! Also check whether DiagGUIReg exits because in the case of exiting the ChemStore
        ! logon dialog the ChemStation is closed before DiagGUIReg is loaded.
        if RegSize(DiagGUIReg) > 0 then
          SaveObj DiagGUIReg, _INSTPATH$ + "dgguireg.reg", NEW
        endif
        _MethodChanged = 0
        _SequenceChanged = 0
      endif
    endif


    ! Check if current view was "Verify". If so, close the verification file.
    ! clear the method changed and sequence changed flag.
    if TabHdrText$(_Config[1], "Window", "CurrentView") = "Verify" then
      If IVResClose() = 0
        return
      endif
      _MethodChanged = 0
      _SequenceChanged = 0
    endif

    ! Check if current view was "RPTLAYOUT". If so, check for changed template
    if TabHdrText$(_Config[1], "Window", "CurrentView") = "RPTLAYOUT" then
      CloseRptLayoutView 1
    endif

    If ClearUpDirtyMethod() = 0
      return
    EndIf
    
    If ClearUpDirtySequence() = 0
      return
    EndIf

    ! Check for Dirty HyperSequence if exists
    If Check(VARIABLE,STK_EXISTS)=1 Then
      If (STK_EXISTS=1 or HypSeq_Always=1)
        If ClearUpDirtyHyperSequence() = 0
          Return
        endif
      endif
    EndIf

    !Man Int Events in data file
    If DFEvents_CheckDirty() = 0 Then
      Return
    EndIf

    If VC_ClearUpDirtyData() = 0
      return
    EndIf

    VC_Shutdown


    !Check if GC product is running
    If Check(Variable, ShowGCGUI$) <> 0 Then
      ! GC application is running
      ! Close all GC windows
      ShowGCGUI$ = "0000"
    EndIf


    ! Clear the _DDE variables in WIN.INI
    if _offline = 1
      SetPrivateProfileString "PCS,"+Val$(_Instrument), "_DDEOffLine", "", "chemstation.ini"
    else
      SetPrivateProfileString "PCS,"+Val$(_Instrument), "_DDEOnLine", "", "chemstation.ini"
    endif

    ! Delete rawdata file if marked for delete.
    if CheckSecPack() > 0  ! Operator and manger in security mode
    Sec_DeleteRawdataFiles 0
    endif

    ! Close addon products
    ExecHook "CloseApp"

    _LoadServiceNotify_ShutdownEvent

    ! Save Insert Vial Range Box state in object header
    if ObjHdrType(_Config[1], "InsVialRngBox") <> 99 AND \
      Check(Variable, SEQTAB_InsVialRngBox) = 1 then
      SetObjHdrVal _Config[1], "InsVialRngBox", SEQTAB_InsVialRngBox
    endif

    ! Save Load Signal Box state in object header
    if ObjHdrType(_Config[1], "LoadSigBox") <> 99 AND \
      Check(Variable, ChroLoadSigBox) = 1 then
      SetObjHdrVal _Config[1], "LoadSigBox", ChroLoadSigBox
    endif

    SetUALValues

    if TabHdrText$(_Config[1],"window","CurrentView") = "TOP"
       ACQSetTheNewDisplayTab  TabHdrText$(_Config[1],"View_TOP",\
                               "CurrentDisplay"),  1 , 0
    endif

    ! switch yielding back to normal mode (refer to top) to avoid
    ! server access during shut down
    _LoadService_ToggleYield
    
    
    ! start Lc diagnositcs
    If start_LabDev=1
      StartUpLabDev
    EndIf
    
    !to be clean at next startup of CS : 
    !clear if _DATASUBDIR$ does not exist, assuming it was then created on scondary datapath only
    !this is important for single samples info
    if _DATASUBDIR$ <> ""  and  FileStat (Mode, _DATAPath$ + _DATASUBDIR$) <> 2 then
       _DATASUBDIR$ = "" 
    endif
    
    
    BYE
  endif
  
endmacro

!############################################################################
name SetMethodChanged

parameter EventCause$
parameter EventLevel$
parameter EventReg$
parameter EventObj
parameter EventPartName$
parameter EventIndex

! Called when anything in the _DAMethod register is changed
!############################################################################

  _MethodChanged = 1
  GUICondenseDAMethodParameters

  On Error Print
  ExecHook "DAMethodChanged"
  On Error

endmacro

!############################################################################
name MethodWait

parameter waittime default 5

! Called by sequence after a new method is loaded
!############################################################################

local l1

local NLSFileName_top$
local ID_TOP_METHOD_WAIT_11
  
NLSFileName_top$                  =  "top"
ID_TOP_METHOD_WAIT_11             =  17011

  
  if Check (Variable, NewSeqMethod) = 0
    return
  endif

  if NewSeqMethod = 1
    ! new method loaded in sequence
    l1 = waittime * 60

    while l1 > 0
      print using "% #.## % /", ReadResource$(NLSFileName_top$,ID_TOP_METHOD_WAIT_11), l1/60, " min"
      sleep 1
      l1 = l1 - 1
    endwhile
    print ""
  endif
  
endmacro

!############################################################################
name CheckDisk

parameter MinSize Default 1000000    ! 1MB

! Checks for free disk space and prints warning if below MinSize
!############################################################################
 
local DiskSpace

local NLSFileName_top$
local ID_TOP_NOT_ENOUGH_DIS_13
local ID_TOP_DISK_SPACE_IS_14
local ID_TOP_NOT_ENOUGH_DIS_15
local ID_TOP_DISK_SPACE_16

  NLSFileName_top$                  =  "top"
  ID_TOP_NOT_ENOUGH_DIS_13          =  17013
  ID_TOP_DISK_SPACE_IS_14           =  17014
  ID_TOP_NOT_ENOUGH_DIS_15          =  17015
  ID_TOP_DISK_SPACE_16              =  17016


  DiskSpace=FreeDiskSpace(_DataPath$[1])
  if  DiskSpace <= MinSize
    if _sequenceon = 1
      WriteToLogbook ReadResource$(NLSFileName_top$,ID_TOP_NOT_ENOUGH_DIS_13)
      _abort = 1
    else
      if _MethodOn = 1
        if Alert (ReadResource$(NLSFileName_top$,ID_TOP_DISK_SPACE_IS_14),4) = 0
          WriteToLogbook ReadResource$(NLSFileName_top$,ID_TOP_NOT_ENOUGH_DIS_15)
          _abort = 1
        endif
      else
        Message (ReadResource$(NLSFileName_top$,ID_TOP_DISK_SPACE_16)+Val$(DiskSpace/1000000)+" MB")
      endif
    endif
  else
    if _sequenceon = 1
      WriteToLogbook ReadResource$(NLSFileName_top$,ID_TOP_DISK_SPACE_16)+Val$(Ceil(DiskSpace/1000)/1000)+" MB"
    else
      Message (ReadResource$(NLSFileName_top$,ID_TOP_DISK_SPACE_16)+Val$(Ceil(DiskSpace/1000)/1000)+" MB")
    endif
  endif
  
endmacro

!############################################################################
name InitializeUAL

! Initialize user access levels.  The user will be prompted to select
! an access level if the "PromptAtStartup" flag is set.
! Called at end of autostart macro.
!############################################################################

! ############## Attention !!! ######################################
! This macro is overloaded by HP ChemStore CS !
! In case of any changes please inform ChemStore people in Waldbronn.
! (Hartmut Doenges or Gerd Heinje)
! Thanks.
! ###################################################################

local bPromptAtStartup, r_val, szPassword$

local NLSFileName_top$
local ID_TOP_INITIALIZING_U_17

  NLSFileName_top$                  =  "top"
  ID_TOP_INITIALIZING_U_17          =  17017  

  If AUTHORIZATIONSERVICE_ISPERMITTED(AS_Privilege_CommandLineRun)=0 Then
    CmdLine off  
    bManagerLevelAccess = 1
    Return
  EndIf


  ! If the UAL DLC does not exist, default to "Manager" level.
  if FileStat(MODE, _EXEPATH$ + "HPUAL_01.DLC") <> 1 Then
    bManagerLevelAccess = 1
    CmdLine on
    Return
  endif

  ! Initialize user access levels.
  print ReadResource$(NLSFileName_top$,ID_TOP_INITIALIZING_U_17)

  ! Create the UAL table if it does not exist.
  if ObjHdrType (_config[1], "UAL") = 99 then
    NewTab _config[1], "UAL"
    NewTabHdrVal _config[1], "UAL", "PromptAtStartup", 0, 1, 3, 0, 1
    NewTabHdrVal _config[1], "UAL", "SetFullMenu", 0, 1, 3, 0, 1
    NewTabHdrVal _config[1], "UAL", "UserLevel", 0, 1, 3, 0, 1
  endif

  if idUAL_DLC = 0 THEN
    bManagerLevelAccess = 1
    CmdLine on
  endif

  ! If "PromptAtStartup" is set, then prompt for access level.
  bPromptAtStartup = TabHdrVal(_config[1], "UAL", "PromptAtStartup")
  if bPromptAtStartup = 1 Then
    ! Pass a "1" as the first parameter to "ChangeAccessLevel" to enable
    ! the dialog's "Cancel" button.

    ! r_val < 0 error
    ! r_val = 0 Ok Button
    ! r_val = 1 Cancel Button
    ! r_val = 2 Help Button

    ! If the User cancels out of UAL during initialization
    ! take it as a signal to shut down Step 1B.

    r_val = ChangeAccessLevel( 1 )
    if r_val = 1 then
      ClosePhx 1
    endif
  else
    ! If the level is operator, but there is no manager password,
    ! start up as manager
    if bManagerLevelAccess = 0 then

	      szPassword$ = PrivateProfileString$("PCS", "level", "chemstation.ini")
       if szPassword$ = "" then
          bManagerLevelAccess = 1
       endif
    endif

    ! Default to last set level if a prompt is not given.
    if bManagerLevelAccess = 1 then
       bSetFullMenu = TabHdrVal(_config[1], "UAL", "SetFullMenu")
       if bSetFullMenu = 1 Then
         SwitchMenuInView ,"FULL"
       else
         SwitchMenuInView ,"SHORT"
       endif       
    endif
  endif

  if bManagerLevelAccess = 1 Then
    CmdLine on
  EndIf
  
endmacro

!############################################################################
Name CheckSecPack
! 
!     The macro CheckSecPac has to be installed in all ChemStations
!     to control the cases where #ModBySecPac#  Statements controlling
!     the standard behaviour.
!   
!     Check, wether the security Pack is installed and which security mode we are in
!     Return Codes are: 
!     2 if Security Pack active and manager logged on
!     1 if Security Pack active and operator logged on
!		  0 if no Security pack (but ChemStore installed)
! 		-1 if no Chemstore installed
!
!############################################################################
 
  If _IsChemStore = 0 Then
    ! ChemStore not installed
    Return -1
  EndIf
  
  If _IsRegulated = 1 and bManagerLevelAccess = 0 Then
    ! ChemStore installed and security pack is in operator mode
    Return 1
  EndIf

  If _IsRegulated = 1 and bManagerLevelAccess = 1 Then
    ! ChemStore installed and security pack is in manager  mode
    Return 2
  EndIf
  
  If _IsRegulated = 0  Then
    ! ChemStore installed and security pack not installed
    Return 0
  EndIf
   
EndMacro
  
  

!############################################################################
NAME UpdateMaintenanceCDIniFile

! Update hppcssvc.ini according the actual instrument configuration to be
! used with the MMV maintenance CD ROM title.
!############################################################################

LOCAL NoOfRows, Row, ModuleRef, IniFileRef$, Section$
LOCAL System$, Pump$, Degasser$, Oven$, Sampler$, Detector1$, Detector2$
LOCAL HP1090Found, HP1050Found, HP1100Found

  HP1090Found = 0; HP1050Found = 0; HP1100Found = 0
  IniFileRef$ = "hppcssvc.ini"
  Section$ = "PCS" + val$(_INSTRUMENT)
  SetPrivateProfileString Section$, TOC, "HP1100_" + val$(_INSTRUMENT) +".MVB", IniFileRef$

  System$    = ""
  Pump$      = "HPNONE.MVB"
  Degasser$  = "HPNONE.MVB"
  Oven$      = "HPNONE.MVB"
  Sampler$   = "HPNONE.MVB"
  Detector1$ = "HPNONE.MVB"
  Detector2$ = "HPNONE.MVB"
  
  NoOfRows = TabHdrVal(_CONFIG, ModuleINFO, NumberOfRows)
  FOR Row = 1 TO NoOfRows
    ModuleRef = TabVal(_CONFIG, ModuleINFO, Row, "nameRef")
    ModuleID$ = "_" ! to prevent problems with ModuleID$ consisting entirely of digits
    ModuleID$ = ModuleID$ + TabText$(_CONFIG, Modules, ModuleRef, "Var")
    ModuleID$ = ModuleID$ + TabText$(_CONFIG, Modules, ModuleRef, "PartNumber")
    ModuleID$ = ModuleID$ + TabText$(_CONFIG, Modules, ModuleRef, "BasePartNumber")

    ON ERROR GOTO UnknownModule
     EVALUATE "GOTO " + ModuleID$

     ! 1090 Modules

     _SDS1090:  ;ON ERROR; Pump$ = "HP1090.MVB"
                HP1090Found = 1
                GOTO Continue

     _AS1090:   ;ON ERROR; Sampler$ = "HP1090.MVB"
                HP1090Found = 1
                GOTO Continue

     _AI1090:   ;ON ERROR; Sampler$ = "HP1090.MVB"
                HP1090Found = 1
                GOTO Continue

     _OV1090:   ;ON ERROR; Oven$ = "HP1090.MVB"
                HP1090Found = 1
                GOTO Continue
     _FPD1090:
     _DAD79880: ;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP1090.MVB"
                ELSE
                  Detector2$ = "HP1090.MVB"
                ENDIF
                HP1090Found = 1
                GOTO Continue

     ! 1050 Modules

     _MWD79854:
     _VWD79853:
     _DAD79854C: ;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP1050.MVB"
                ELSE
                  Detector2$ = "HP1050.MVB"
                ENDIF
                HP1050Found = 1
                GOTO Continue
     _SDS79851:
     _SDS79852:  ;ON ERROR; Pump$ = "HP1050.MVB"
                HP1050Found = 1
                GOTO Continue

     _AS79855:   ;ON ERROR; Sampler$ = "HP1050.MVB"
                HP1050Found = 1
                GOTO Continue

     ! Leonardo Modules

     _LPMPG1310A:;ON ERROR; Pump$ = "HP11_ISO.MVB"
                HP1100Found = 1
                GOTO Continue

     _LPMPG1311A:;ON ERROR; Pump$ = "HP11_QUA.MVB"
                HP1100Found = 1
                GOTO Continue

     _LPMPG1312A:;ON ERROR; Pump$ = "HP11_BIN.MVB"
                HP1100Found = 1
                GOTO Continue

     _LALSG1313A:;ON ERROR; Sampler$ = "HP11_ALS.MVB"
                HP1100Found = 1
                GOTO Continue

     _LVWDG1314A:;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP11_VWD.MVB"
                ELSE
                  Detector2$ = "HP11_VWD.MVB"
                ENDIF
                HP1100Found = 1
                GOTO Continue

     _LDADG1315A:;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP11_DAD.MVB"
                ELSE
                  Detector2$ = "HP11_DAD.MVB"
                ENDIF
                HP1100Found = 1
                GOTO Continue

     _LDADG1315B:;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP11_DAD.MVB"
                ELSE
                  Detector2$ = "HP11_DAD.MVB"
                ENDIF
                HP1100Found = 1
                GOTO Continue

     _LMWDG1365A:;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP11_MWD.MVB"
                ELSE
                  Detector2$ = "HP11_MWD.MVB"
                ENDIF
                HP1100Found = 1
                GOTO Continue

     _LMWDG1365B:;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP11_MWD.MVB"
                ELSE
                  Detector2$ = "HP11_MWD.MVB"
                ENDIF
                HP1100Found = 1
                GOTO Continue

     _LRIDG1362A:;ON ERROR
                IF Detector1$ = "HPNONE.MVB" THEN
                  Detector1$ = "HP11_RID.MVB"
                ELSE
                  Detector2$ = "HP11_RID.MVB"
                ENDIF
                HP1100Found = 1
                GOTO Continue

     _LTHMG1316A:;ON ERROR; Oven$ = "HP11_TCC.MVB"
                HP1100Found = 1
                GOTO Continue

     _ADC35900:
     _ECD1049:
     _FLD1046:   ;ON ERROR ! Remains on HPNONE.MVB
                GOTO Continue

     UnknownModule: ;ON ERROR

     Continue:

  NEXT Row

  ! Process rules to determine system title.
  Sys = HP1100Found * 4 + HP1050Found * 2 + HP1090Found
  IF Sys >= 4 THEN  ! At least one Leonardo module in the system
    System$ = "HP11_SYS.MVB"
  ENDIF
  IF Sys = 3 THEN  ! A mixed system of 1090 and 1050
    System$ = "HP1090.MVB"
  ENDIF
  IF Sys = 2 THEN  ! A pure 1050 system
    System$ = "HP1050.MVB"
  ENDIF
  IF Sys = 1 THEN  ! A pure 1090 system
    System$ = "HP1090.MVB"
  ENDIF

  ! Process rules to determine degassing method
  IF INSTR(Pump$,"HP11_") > 0 THEN
    IF INSTR(Pump$,"ISO") = 0 THEN
      Degasser$ = "HP11_DEG.MVB"
    ENDIF
  ELSE
    Degasser$ = Pump$
  ENDIF

  ! Process rules to determine injector
  IF Sampler$ = "HPNONE.MVB" THEN  ! no als found
    IF INSTR(Pump$,"HP11_") > 0 THEN  ! if it's a leo pump
      Sampler$ = "HP11_MAN.MVB"   ! then it's a leo Manual Valve
    ELSE     ! otherwise,
      Sampler$ = Pump$    ! manual valve type is pump type
    ENDIF
  ENDIF

  ! Process rules to determine oven
  IF Oven$ = "HPNONE.MVB" THEN   ! no oven found
    IF INSTR(Pump$,"HP11_") > 0 THEN  ! if it's a leo pump
      Oven$ = "HP11_NOO.MVB"   ! then use leo "no oven" option
    ELSE     ! otherwise,
      Oven$ = Pump$    ! oven type is pump type
    ENDIF
  ENDIF

  SetPrivateProfileString Section$, System,    System$,    IniFileRef$
  SetPrivateProfileString Section$, Pump,      Pump$,      IniFileRef$
  SetPrivateProfileString Section$, Degasser,  Degasser$,  IniFileRef$
  SetPrivateProfileString Section$, Oven,      Oven$,      IniFileRef$
  SetPrivateProfileString Section$, Sampler,   Sampler$,   IniFileRef$
  SetPrivateProfileString Section$, Detector1, Detector1$, IniFileRef$
  SetPrivateProfileString Section$, Detector2, Detector2$, IniFileRef$

ENDMACRO


!############################################################################
name LoadNLSRegister

parameter ProductArea$               ! for meaning see nlsmake.mac
parameter Path$ default _AutoPath$   ! path for the code macro files
parameter bNew default 1             ! if 1 register is loaded regardless
                                     ! else only if it doesn't exist

! loads the NLS register for the specified ProductArea$.
!############################################################################

local File$, Reg$, rs

  Reg$ = "NLS" + ProductArea$

  if bNew = 0 then
    evaluate "rs = RegSize(" + Reg$ + ")"
    if rs >= 0 then                      ! register already exists
      return
    endif
  endif

  Path$ = Path$ + "language\"
  File$ = _Lang$ + ProductArea$ + ".reg"

  if FileStat (Mode, Path$ + File$) <> 1 then
    ! file not found
    File$ = "enu" + ProductArea$ + ".reg"
  endif

  evaluate "DelReg " + Reg$
  evaluate "LoadObj Path$ + File$,," + Reg$

  return
endmacro

!############################################################################
name LoadMacro

parameter FileName$                  ! macro file to be loaded

! loads a macro while a message is displayed on the msg line.
!############################################################################

  print using TabHdrText$ (NLSCore[1], "Util", "Loading"), FileName$
  macro FileName$
  print                                ! to clear the msg line
  return
endmacro

!############################################################################
name LoadMcxOrMac

parameter File$                    ! file to be loaded without extension
parameter StartMacro$ default ""   ! Macro to be executed after loading

! loads a mcx or mac-file while a message is displayed on the msg line.
!############################################################################

  if filestat(MODE, File$ + ".mcx") = 1   ! exists - is a file
    print using TabHdrText$ (NLSCore[1], "Util", "Loading"), File$+".mcx"
    evaluate "macro " + """" + File$ + ".mcx" + """" 
  else  ! mcx file does not exist try mac file (without test)
    print using TabHdrText$ (NLSCore[1], "Util", "Loading"), File$+".mac"
    evaluate "macro " + """" + File$ + ".mac" + """" 
  endif
  print                                ! to clear the msg line
  Evaluate StartMacro$

  return
endmacro


!############################################################################
Name EndJobBeforeBeginJob               !3-02PR recover from previous BeginJob without an EndJob
!global print report 'On Error' macros
!############################################################################

local NLSFileName_top$
local ID_TOP_ABOVE__BEGINJO_18

NLSFileName_top$                  =  "top"
ID_TOP_ABOVE__BEGINJO_18          =  17018

  On Error 
  print _ErrMsg$
  Print ReadResource$(NLSFileName_top$,ID_TOP_ABOVE__BEGINJO_18)
  EndJob;
  BeginJob      !and try again
EndMacro


!############################################################################
Name CloseDeviceBeforeOpenDevice		!3-02PR recover from previously unclosed OpenDevice...
!############################################################################

local NLSFileName_top$
local ID_TOP_ABOVE__OPENDEV_19

  NLSFileName_top$                  =  "top"
  ID_TOP_ABOVE__OPENDEV_19          =  17019


  On Error      !do normal error handling here
  print _ErrMsg$
  Print ReadResource$(NLSFileName_top$,ID_TOP_ABOVE__OPENDEV_19)
  Close #5
  BeginJob      !get latest printer 'setup' parameters
  EndJob        !end this pseudo job so any new printer setup is used
  OpenDevice "Printer" as #5	        !and try again
EndMacro


!############################################################################
Name GetCurrentPrinterSetup
!print report utility macro to utilize current printer setup(portrait vs landscape, letter vs A4....)
!############################################################################

  On Error EndJobBeforeBeginJob           !3-02PR recover and continue
  !3-02PR - do this BeginJob/EndJob to get latest printer parameters (done during BeginJob)
  BeginJob       !get latest printer parameters
  On Error print _ErrMsg$
  EndJob         !end this pseudo job so the BeginJob below is all set to work
  On Error       !do normal error handling here
  
EndMacro


