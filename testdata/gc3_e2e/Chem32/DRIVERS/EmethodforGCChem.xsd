  <xs:complexType name="DirectoryImage">
    <xs:sequence minOccurs="0" maxOccurs="unbounded">
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element name="File" minOccurs="0">
          <xs:annotation>
            <xs:documentation>Represents a binary (incl text) file image in the directory represented by the enclosing directory element.  The content of the file is the text of the element, usually represented as "bin.base64" (hence has an explicit type declaration).  MOst files are compressed as specified by the Compression, OriginalSIze and CompressedSize attributes.</xs:documentation>
          </xs:annotation>
          <xs:complexType mixed="true">
            <xs:attribute name="name" type="xs:string" use="optional">
              <xs:annotation>
                <xs:documentation>May be an absolute or relative path. Relative paths are interpreted with respect to the (efefctive) path of the enclosing element.</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="Compression" type="xs:string" use="optional" default="Xceed.BWTCompression.1">
              <xs:annotation>
                <xs:documentation>ProgID or GUID identifying the compression scheme used for the file content.</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="OriginalSize" type="xs:decimal" use="optional">
              <xs:annotation>
                <xs:documentation>The original size of the file (bytes).  Used when expanding a file to determine the approipriate size of a buffer for the expanded image.</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="CompressedSize" type="xs:decimal" use="optional">
              <xs:annotation>
                <xs:documentation>The size of the file (bytes) , in its compressed format.  Used when expanding a compressed file to determine the number of bytes to expand.</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:anyAttribute />
          </xs:complexType>
        </xs:element>
        <xs:element name="Directory" type="DirectoryImage" minOccurs="0">
          <xs:annotation>
            <xs:documentation>Represents a directory in a file system.  A directory may contain other directories or may contain individual files.  The order of (dub)directory and file elements is not significant.</xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:choice>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="optional">
      <xs:annotation>
        <xs:documentation>Name of the directory.  May be an absolute or relative path. Relative paths are interpreted with respect to the (efefctive) path of the enclosing element.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>
