<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified">
  <xs:element name="AgEMRoot">
    <xs:annotation>
      <xs:documentation>Root element of all eMethod content</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:all minOccurs="0">
        <xs:element name="Transform" minOccurs="0">
          <xs:annotation>
            <xs:documentation>Transforms not specifically associated with a specific platform.</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:all minOccurs="0">
              <xs:element name="Start" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>The start thread, used to bootstrap the wizard.</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                  <xs:complexContent>
                    <xs:extension base="TransformElement" />
                  </xs:complexContent>
                </xs:complexType>
              </xs:element>
              <xs:element name="Source" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>The thread for exporting the eMethod.  Contains transforms needed to load a concrete method and convert to internal eMethod form.</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                  <xs:complexContent>
                    <xs:extension base="TransformThread">
                      <xs:attribute name="DestinationPath" type="xs:string" use="optional">
                        <xs:annotation>
                          <xs:documentation>The absolute file path and file name into which we will write the final output (eMethod or concrete method)</xs:documentation>
                        </xs:annotation>
                      </xs:attribute>
                    </xs:extension>
                  </xs:complexContent>
                </xs:complexType>
              </xs:element>
              <xs:element name="Target" type="TransformThread" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>The thread for importing the eMethod.  Contains transforms needed to translate the emethod content to a valid concrete method.</xs:documentation>
                </xs:annotation>
              </xs:element>
            </xs:all>
          </xs:complexType>
        </xs:element>
        <xs:element name="Hash" minOccurs="0">
          <xs:annotation>
            <xs:documentation>Element containing Hash code corresponding to the emethod file -specific elements.</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:complexContent>
              <xs:extension base="TransformElement">
                <xs:attribute name="HashCode" type="xs:string" use="required" />
              </xs:extension>
            </xs:complexContent>
          </xs:complexType>
        </xs:element>
        <xs:element name="Platforms" minOccurs="0">
          <xs:annotation>
            <xs:documentation>Element containing platform (DataSystem) -specific elements.</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:sequence minOccurs="0" maxOccurs="unbounded">
              <xs:element name="G2070" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>Data specific to the G2070(GC ChemStation) Data System</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                  <xs:all minOccurs="0">
                    <xs:element name="Target" minOccurs="0">
                      <xs:complexType>
                        <xs:complexContent>
                          <xs:extension base="TransformThread" />
                        </xs:complexContent>
                      </xs:complexType>
                    </xs:element>
                    <xs:element name="Source" minOccurs="0">
                      <xs:complexType>
                        <xs:complexContent>
                          <xs:extension base="TransformThread">
                            <xs:all minOccurs="0">
                              <xs:element name="ConcreteMethod" type="DirectoryImage" minOccurs="0" />
                            </xs:all>
                            <xs:attribute name="SourcePath" type="xs:string" use="optional" />
                          </xs:extension>
                        </xs:complexContent>
                      </xs:complexType>
                    </xs:element>
                  </xs:all>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="System" minOccurs="0">
          <xs:annotation>
            <xs:documentation>Element containing generic data elements specific to the eMethod "System".</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:all minOccurs="0">
              <xs:element name="Target" minOccurs="0">
                <xs:complexType>
                  <xs:attribute name="Listing" type="xs:string" use="optional">
                    <xs:annotation>
                      <xs:documentation>Contains the formatted method listing (as HTML) that will be appended to the import exit notes.</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                </xs:complexType>
              </xs:element>
              <xs:element name="Source" minOccurs="0">
                <xs:complexType>
                  <xs:attribute name="Introduction" type="xs:string" use="optional">
                    <xs:annotation>
                      <xs:documentation>If the first character is '&lt;', then the value of this attribute is taken as literal text.  Otherwise, it is base-64 encoded.</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                  <xs:attribute name="Notes" type="xs:string" use="optional">
                    <xs:annotation>
                      <xs:documentation>Natural-language (coded in HTML) notes describing the eMethod.  The notes are written by the exporting user (in the Edit Notes Screen) and displayed to teh importing user immediately after selecting the eMethod.  The importing user uses the notes to confirm/determine the applicability of the eMethod to their application.</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                </xs:complexType>
              </xs:element>
            </xs:all>
          </xs:complexType>
        </xs:element>
      </xs:all>
    </xs:complexType>
  </xs:element>
