NAME GetGCAuxZoneStatus$
PARAMETER dChannel
LOCAL iReturn, szString$, szReturn$

  ! Check if the values are within range

  IF ((dChannel < 1) OR (dChannel > 2))
    MESSAGE "Aux. channel must be 1 to 2"
    RETURN ""
  ENDIF

  !  Build the command

  szString$ = "A" + VAL$(dChannel) + "ST"
  ! iReturn = alert (szString$)
  szReturn$ =  SENDMODULE$ ("6850GC", szString$)
  RETURN szReturn$
ENDMACRO

NAME GetGCAuxPnuematicStatus$
PARAMETER dChannel
LOCAL iReturn, szString$, szReturn$

  ! Check if the values are within range

  IF ((dChannel < 3) OR (dChannel > 5))
    MESSAGE "Aux. channel must be 3 to 5"
    RETURN ""
  ENDIF

  !  Build the command

