NAME SetGCColCompConfig
PARAMETER dColumn, szColCompDet$
LOCAL szString$, szDet$

  ! Check if the values are within range

  IF ((szColCompDet$ <> "FRONT") AND (szColCompDet$ <> "BACK"))
    MESSAGE "Column Comp Detector must be FRONT or BACK"
    RETURN
  ENDIF

  IF ((dColumn < 1) OR (dColumn > 2))
    MESSAGE "Column number must be 1 or 2"
    RETURN
  ENDIF

  ! Find out if the detector is front or back 

  IF szColCompDet$ = "FRONT"
    szDet$ = " 0"
  ELSE
    szDet$ = " 1"
  ENDIF

  szString$ = "CCC" + VAL$(dColumn) + szDet$

  WRITEMODULE "6850GC", szString$
ENDMACRO

NAME StartGCColCompRun
PARAMETER dColumn
LOCAL szString$, szReturn$

  ! Check if the values are within range

  IF ((dColumn < 1) OR (dColumn > 3))
    MESSAGE "Column number must be 1, 2, or 3 (both)"
    RETURN
  ENDIF

  szString$ = "CCCR" + VAL$(dColumn)

  szReturn$ =  SENDMODULE$ ("6850GC", szString$)

  IF szReturn$ = "CCCR 0"
    MESSAGE "Column comp run started"
    RETURN
  ELSE
    MESSAGE "Column comp run error: " + szReturn$
    RETURN
  ENDIF
ENDMACRO

