NAME GetGCSignalStatus$
PARAMETER dSignal
LOCAL szString$, iReturn, szReturn$

  ! Check if the values are within range

  IF ((dSignal < 1) OR (dSignal > 2))
    MESSAGE "Signal must be 1 to 2"
    RETURN ""
  ENDIF

  !  Build the command

