  RETURN szReturn$
ENDMACRO

NAME GetGCDetStatus$
PARAMETER szDetector$
LOCAL iReturn, szString$, szReturn$

  ! Check if the Detector is "FRONT" or "BACK"

  IF ((szDetector$ <> "FRONT") AND (szDetector$ <> "BACK"))
    MESSAGE "Detector must be front or back"
    RETURN ""
  ENDIF

  !  Build the command

  IF (szDetector$ = "FRONT")
    szString$ = "DFST"
  ELSE
    szString$ = "DBST"
  ENDIF
  ! iReturn = alert (szString$)
  szReturn$ =  SENDMODULE$ ("6850GC", szString$)
  RETURN szReturn$
ENDMACRO

