!############################################################################
name MakePersonalitiesForMethods

 Parameter FromTable$ default "IntMethodTemp"

! make instrument specific modifications to the template of the
! integration method table (intmethod)
!############################################################################
local ToTable$

 ToTable$="IntMethod"
 if ObjHdrType(_Config[2],ToTable$)<>4
  RenTab _Config[2],FromTable$,ToTable$

! Modifications start here...
 SetTabHdrVal _Config[2],ToTable$,"PeakStartSigma",3.0
 SetTabHdrVal _Config[2],ToTable$,"PeakEndSigma",4.0
 SetTabHdrVal _Config[2],ToTable$,"TailingFactor",1.0
 SetTabHdrVal _Config[2],ToTable$,"BaseLineWidth",1.0
 SetTabHdrVal _Config[2],ToTable$,"DeadVolTime",0.0
 SetTabHdrVal _Config[2],ToTable$,"MinimumWidth",0.0
 SetTabHdrVal _Config[2],ToTable$,"Plates",0.0
 SetTabHdrVal _Config[2],ToTable$,"PeakWidthBroad",1.0
 SetTabHdrVal _Config[2],ToTable$,"PeakTopType",1
 SetTabHdrVal _Config[2],ToTable$,"BaseDetectMode",1
 SetTabHdrVal _Config[2],ToTable$,"TanSkimMode",2
 SetTabHdrVal _Config[2],ToTable$,"WidthCalc",4
 SetTabHdrVal _Config[2],ToTable$,"PlatesCalcMode",0.0
 SetTabHdrVal _Config[2],ToTable$,"PeakSepCalc",0.0

 endif
!_____________________________________________________________

endmacro


!############################################################################
name MakeIntegratorPersonalities

!############################################################################

 MakePersonalitiesForEvents
 MakePersonalitiesForDetectors
 MakePersonalitiesForMethods

endmacro
