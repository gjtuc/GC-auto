!============================================================================

! GC Instrument specific personalities for the new enhanced integrator

! intpers.mac

! This macro describes the personalities of the new enhanced integrator.
! The settings that are made here represent the optimized integration
! parameters for each detector used with this instrument.
!============================================================================


!############################################################################
name CopyPersTab

 Parameter FromTable$
 Parameter ToTable$

! Helper function
! Do only copy the table if the table does not already exist
!############################################################################
local result

 if ObjHdrType(_Config[2],ToTable$)<>4
  CopyTab _Config[2],FromTable$,_Config[2],ToTable$
  result = 1
 else
  result = 0
 endif

 return result

endmacro


!############################################################################
name MakePersonalitiesForEvents

 Parameter FromTable$ default "Event12"

! Copy the default template of the integration event table (event12)
! and and make instrument specific modifications for each detector
! Store the modified tables as default tables into _Config[2]
!############################################################################
local DetectorClass$, ToTable$

!_____________________________________________________________

! Thermal conductivity detector
 DetectorClass$="TCD"

 ToTable$="Event_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...
 SetTabHdrVal _Config[2],ToTable$,"InitReject",1.0
 SetTabHdrVal _Config[2],ToTable$,"InitThresh",100.0
 SetTabHdrVal _Config[2],ToTable$,"InitWidth",0.04
 SetTabHdrVal _Config[2],ToTable$,"ShouldersOn",0
 SetTabHdrVal _Config[2],ToTable$,"InitHeight",1.0
 SetTabHdrVal _Config[2],ToTable$,"InitBaseDrift",0.0
 SetTabHdrVal _Config[2],ToTable$,"SplitSolvThres",0.0
 SetTabHdrVal _Config[2],ToTable$,"SolventThres",0
 SetTabHdrVal _Config[2],ToTable$,"StartIntegMode",2
 SetTabHdrVal _Config[2],ToTable$,"StartIntegValue",0
 SetTabHdrVal _Config[2],ToTable$,"EndIntegMode",2
 SetTabHdrVal _Config[2],ToTable$,"EndIntegValue",0
 SetTabHdrVal _Config[2],ToTable$,"BaselineClamp",-1.0e+38
 SetTabHdrVal _Config[2],ToTable$,"BaseResetThres",1.0e+38

 endif
!_____________________________________________________________

! Analogue to digital converter
 DetectorClass$="ADC"

 ToTable$="Event_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...
 SetTabHdrVal _Config[2],ToTable$,"InitReject",1.0
 SetTabHdrVal _Config[2],ToTable$,"InitThresh",20.0
 SetTabHdrVal _Config[2],ToTable$,"InitWidth",0.04
 SetTabHdrVal _Config[2],ToTable$,"ShouldersOn",0
