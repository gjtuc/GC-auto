 SetTabHdrVal _Config[2],ToTable$,"EndIntegValue",0
 SetTabHdrVal _Config[2],ToTable$,"BaselineClamp",-1.0e+38
 SetTabHdrVal _Config[2],ToTable$,"BaseResetThres",1.0e+38
 endif
!_____________________________________________________________

! Flame ionization detector
 DetectorClass$="FID"

 ToTable$="Event_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...
 SetTabHdrVal _Config[2],ToTable$,"InitReject",1.0
