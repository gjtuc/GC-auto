!############################################################################
name MakePersonalitiesForDetectors

 Parameter FromTable$ default "IntDetect"

! Copy the default template of the integration detector table (intdetect)
! and and make instrument specific modifications for each detector
! Store the modified tables as constant tables into _Config[2]
!############################################################################
local DetectorClass$, ToTable$

!_____________________________________________________________

! Thermal conductivity detector
 DetectorClass$="TCD"

 ToTable$="IntDetect_"+DetectorClass$
 if CopyPersTab(FromTable$,ToTable$)<>0

! Modifications start here...
 SetTabHdrVal _Config[2],ToTable$,"MaxDataLimit",1.0e+38
 SetTabHdrVal _Config[2],ToTable$,"MaxLinearLimit",1.0e+38
 SetTabHdrVal _Config[2],ToTable$,"MinDataLimit",-1.0e+38
 SetTabHdrVal _Config[2],ToTable$,"MinLinearLimit",-1.0e+38

