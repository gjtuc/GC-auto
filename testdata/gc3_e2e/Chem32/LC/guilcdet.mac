!############################################################################
name GuiADCSingleDetectorReconfig

parameter  DetectorsINIFile$
parameter  iDetectorNumber
parameter  DetectorShortName$
parameter  MenuTabName$
parameter  CpVarName$  default "GuiDetNN$" 
!############################################################################
             
local HelpMessage$
local ToolBaseName$
local Command$             
local VarExists
local RunState$

ID_ASTXDRIVERSMACFILES_BALANCE_75                  =  17075  
NLSFileName_astxmac$ = "astxmac"

!move balance button out of sight very early (looks better if done so)
GomSetVal GUISystemDiagGOM$, DetectorsINIFile$ , ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BALANCE_75)+val$(iDetectorNumber) , y , 1000

ToolBaseName$="Detector"

GUILeoSingleDetectorUIReconfig  DetectorsINIFile$, iDetectorNumber,  \
                                DetectorShortName$, MenuTabName$, ToolBaseName$


!install hotlinks to this one
!make hotlink connection all detectors have in GUI CpVar  : CpVarNameBase$+val$(DevNoOfThisModule)+"$"
GUISetToolEvent  DetectorsINIFile$, ToolBaseName$+val$(iDetectorNumber), "elements" , \
                 , ,CpVarName$

 
endmacro
    



!############################################################################
name GUIADCDetSetGuiDetectorsOrderedHook

parameter  DevMaxCnt 
parameter  DetShortBaseName$
parameter  MenuTabBaseName$
parameter  CpVarBaseName$             !without $ at end
parameter  Priority
!############################################################################

local  DevCnt
local  a$,c$
local  ExecCommand$
local  ModPriority
local  CpVarName$


for DevCnt=1 to DevMaxCnt
    if DevMaxCnt <= 1
       a$=""
       c$="1"
    else
       a$=val$(DevCnt)
       c$=a$
    endif

DetShortName$=DetShortBaseName$+a$



                    
    MenuTabName$=MenuTabBaseName$+a$
    CpVarName$=CpVarBaseName$
    if CpVarName$ <> ""
       CpVarName$=""""+CpVarBaseName$+c$+"$"+""""
    endif   
    ModPriority=Priority-1+DevCnt
    
    ExecCommand$="GUIADCSingleDetectorReconfig "+\
                 "TabHdrText$(Hook[1],""GuiDetectors"",""DetStackIniFile"") , " +\
                 "TabHdrVal(Hook[1],""GuiDetectors"",""ExecRow"") , " +\
                 DetShortName$+","+\
                 MenuTabName$+","+\
                 CpVarName$
                 
    GuiSetDetectorOrderedHook  ModPriority , ExecCommand$ ,  ,  ,  ,  , DetShortName$+":"

next DevCnt



endmacro




!############################################################################
name GUICorrect35900ModuleMenus
!############################################################################
local irow
local tab$, tabBase$            
local iii,jjj,kkk,present  
local adccmd$  

tabBase$="AD35900"

for jjj=1 to adcdevice
    tab$=tabBase$
    if adcdevice>1
       tab$=tabBase$+val$(jjj)
    else   
       tab$=tabBase$
    endif            
    if GuiOffline=1
       tab$=tab$+"OC"
    endif  
    
    if adctimetab = 0            
       !delete the TT menu row
       for iii=1 to 2
           !go through all menu objcets
           if ObjHdrType( menu[iii], tab$) = 4
              irow = RowByText( menu[iii], tab$, , "SearchKey", "i=" , "ADTIMETABLE" )
              if irow > 0
                 DelTabRow menu[iii],tab$,irow
              endif   
           endif      
       next iii   
    endif
    for kkk = 1 to 18 
        !this is only true in full menus menu[1]
        if ObjHdrType( menu[1], tab$) = 4
           evaluate "present = check(variable,adcnhpmenucmd"+val$(kkk)+"$)"
           if present = 1
              evaluate "adccmd$=adcnhpmenucmd"+val$(kkk)+"$"
              irow = RowByText( menu[1], tab$, , "SearchKey", "i=" , "HELP" )
              !insert before HELP
              if irow > 0 
                 if kkk=1
                    !insert a separator
                    InsTabRow menu[1], tab$, irow
                    SetTabText menu[1], tab$, irow , "Action" , "SEPARATOR" 
                    !don't increment irow put new item before separator
                 endif
                 InsTabRow menu[1], tab$, irow
              else
                 !add at end
                 if kkk=1
                    !insert a separator
                    InsTabRow menu[1], tab$
                    irow=TabHdrVal(menu[1], tab$, "numberofrows" )
                    SetTabText menu[1], tab$, irow , "Action" , "SEPARATOR" 
                 endif   
                 InsTabRow menu[1], tab$ 
                 irow=TabHdrVal(menu[1], tab$, "numberofrows" )
              endif   
              evaluate "SetTabText menu[1],tab$,irow,""Item"",adcnhpmenuitem"+val$(kkk)+"$" 
              evaluate "SetTabText menu[1],tab$,irow,""Message"",adcnhpmenuhelp"+val$(kkk)+"$" 
              SetTabText menu[1], tab$, irow , "Action" , "LC35900ADC."+adccmd$ 
              SetTabText menu[1], tab$, irow , "Link" ,"MethLoadSaveIdle"
              SetTabText menu[1], tab$, irow , "BitmapName" ,"methedit_bmp"
           endif
        endif   
    next kkk
next jjj 

endmacro




!############################################################################
name GUIReConfigureADConv

!configure menus
!set GuiDetectors ordered hook
!assume here that LeoTemp reg is loaded , and that menu register is
!sorted [1] = FULL
!############################################################################

GUISetupMenuRegForConfiguration

GUICheckMenuTablesForModNumber adcdevice

GUIConfigureModuleNumberMenus  "AD35900", adcdevice                                           
GUICorrect35900ModuleMenus     
GUIADCDetSetGuiDetectorsOrderedHook  adcdevice, "ADC", "AD35900" , "ADCStatus" , 80

GuiDevGuiDets=GuiDevGuiDets+adcdevice

endmacro


