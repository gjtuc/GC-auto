!############################################################################
name GUIReSizeMiniPlot
                             
parameter  PlotIniFile$  default "L1Plot"

!############################################################################
local yLoc
local yHeight
local yHeightOrig

if GomExist( GUISystemDiagGOM$, PlotIniFile$ ) = 1         
   yLoc=GomVal( , GUISystemDiagGOM$, , "Y")  \
        + GomVal(GUISystemDiagGOM$, PlotIniFile$ , , "Y")  \
        + GomVal(GUISystemDiagGOM$, PlotIniFile$ , "Plot1" , "Y") 
   yHeightOrig=GomVal(GUISystemDiagGOM$, PlotIniFile$ , "Plot1" , "HEIGHT")
   if yLoc+yHeightOrig > AppMetrics("MDIY" )
      !must reduce to be fully visible
      if AppMetrics("MDIY" ) - yLoc > 80
         yHeight=AppMetrics("MDIY" ) - yLoc
         GomSetVal GUISystemDiagGOM$, PlotIniFile$ , "Plot1" , "HEIGHT" , yHeight
         !also place selection button at new location
         if GomExist( GUISystemDiagGOM$, PlotIniFile$, "SELECTPLOT1" ) = 1
            if GuiOffline = 1
               GomSetVal  GUISystemDiagGOM$, PlotIniFile$ , "SELECTPLOT1" , x , 1000
            else
               yLoc=GomVal(GUISystemDiagGOM$, PlotIniFile$ , "SELECTPLOT1" , "Y")
               yLoc=yLoc-(yHeightOrig-yHeight)
               GomSetVal GUISystemDiagGOM$, PlotIniFile$ , "SELECTPLOT1" , "y" , yLoc
            endif     
         endif
      endif
   else
      if GomExist( GUISystemDiagGOM$, PlotIniFile$, "SELECTPLOT1" ) = 1 \
         AND  GuiOffline = 1
         GomSetVal  GUISystemDiagGOM$, PlotIniFile$ , "SELECTPLOT1" , x , 1000
      endif
   endif
endif

endmacro

!############################################################################
name GUICornerCoordGomVal

parameter  Type$     default "X"                !or "Y" or "BOTTOM" or  "RIGHT"
parameter  RootGom$                             !return is relative to this one
                                                !if no sub goms given then
                                                !then just width height of this
parameter  SubGom$
parameter  ToolName$
!############################################################################
local Loc
local GomHierarchy$
local GomCoord$
                  
GomHierarchy$=RootGom$ +","+ SubGom$ +","+ToolName$
evaluate "Loc=GomExist("+GomHierarchy$+")"
if Loc = 1
   if Type$ = "BOTTOM"
      GomCoord$="Y"
   else
   if Type$ = "RIGHT"
      GomCoord$="X"
   else
      GomCoord$=Type$
   endif 
   endif 

   evaluate "Loc=GomVal("+GomHierarchy$+", GomCoord$)"

   if Type$ = "BOTTOM"
      GomCoord$="HEIGHT"
   else
   if Type$ = "RIGHT"
      GomCoord$="WIDTH"
   else
      GomCoord$=""
   endif 
   endif 

   if GomCoord$ <> ""
      !add width or height
      evaluate "Loc=Loc+GomVal("+GomHierarchy$+" , GomCoord$)"
   endif
endif

return Loc

endmacro


!############################################################################
name GUIFindGomCornerCoord

parameter  Type$     default "X"                !or "Y" or "BOTTOM" or  "RIGHT"
parameter  RootGom$                             !return is relative to this one
                                                !if no sub goms given then
                                                !then just width height of this
parameter  SubGom1$
parameter  SubGom2$
parameter  SubGom3$
parameter  ToolName$
!############################################################################
local Loc
local GomHierarchy$
local GomHierarchy1$
local GomCoord$
                  
Loc=0                                 
if Type$ = "BOTTOM"
   GomCoord$="Y"
else
if Type$ = "RIGHT"
   GomCoord$="X"
else
   GomCoord$=Type$
endif 
endif 

if SubGom1$ = ""  
   if ToolName$ <> ""
      Loc=GUICornerCoordGomVal( Type$, , RootGom$, ToolName$ )
   endif   
else   
if SubGom2$ = "" 
   if ToolName$ = ""
      Loc=GUICornerCoordGomVal( Type$, RootGom$ , SubGom1$ ) 
   else
      Loc=GUICornerCoordGomVal( GomCoord$, RootGom$ , SubGom1$ ) 
      Loc=Loc+GUICornerCoordGomVal( Type$, RootGom$, SubGom1$, ToolName$ )
   endif   
else
if SubGom3$ = ""
   GomHierarchy$=RootGom$+"|"+SubGom1$ 
   Loc= GUICornerCoordGomVal( GomCoord$, RootGom$      , SubGom1$  )  
   if ToolName$ = ""
      Loc=Loc+GUICornerCoordGomVal( Type$, GomHierarchy$ , SubGom2$ ) 
   else       
      Loc=Loc+GUICornerCoordGomVal( GomCoord$, GomHierarchy$ , SubGom2$ ) 
      Loc=Loc+GUICornerCoordGomVal( Type$, GomHierarchy$, SubGom2$, ToolName$ )
   endif   
else
   GomHierarchy1$=RootGom$+"|"+SubGom1$
   GomHierarchy$=GomHierarchy1$+"|"+SubGom2$ 
   Loc= GUICornerCoordGomVal( GomCoord$, RootGom$, SubGom1$  )  \
       +GUICornerCoordGomVal( GomCoord$, GomHierarchy1$, SubGom2$ ) 
   if ToolName$ = ""
      Loc=Loc+GUICornerCoordGomVal( Type$, GomHierarchy$, SubGom3$ ) 
   else
      Loc=Loc+GUICornerCoordGomVal( GomCoord$, GomHierarchy$, SubGom3$ ) 
      Loc=Loc+GUICornerCoordGomVal( Type$, GomHierarchy$, SubGom3$, ToolName$ )
   endif   
endif
endif
endif


return Loc

endmacro



!------------------------------------------------------------------------
Name Mrc_GUIShowSystemDiagramCode

  parameter ShowType default 0


  if (ShowType = 3)
    if (Mrc_Exists() = 0)
      Mrc_PreStart
      Mrc_Create
      GUIDiagramStateForMenu=1+2  !enabled plus checked
    else
      if (Mrc_IsVisible() = 0)
        Mrc_Show
        GUIDiagramStateForMenu=1+2  !enabled plus checked
      else
        Mrc_Hide
        GUIDiagramStateForMenu=1  !enabled and unchecked
      endif
    endif
  else
    if (ShowType = 2)
    Mrc_Destroy
    GUIDiagramStateForMenu=1  !enabled and unchecked
  else
    if (ShowType = 1)
    Mrc_PreStart
    Mrc_Create
    GUIDiagramStateForMenu=1+2  !enabled plus checked
  else 
    if (ShowType = 0)
      if (Mrc_Exists() = 1)
        Mrc_Show
      else
        Mrc_PreStart
        Mrc_Create
      endif
      SetTabText _config[1], "window", GuiSystemDiagramWinNo, "Command", "GUIShowSystemDiagram 0"
      SetTabVal  _config[1], "window", GuiSystemDiagramWinNo, "HelpContext", 0
      GUIDiagramStateForMenu=1+2  !enabled plus checked

    endif
  endif
  endif
  endif

endmacro



!---------------------------------------------------------------------
Name Mrc_PreStart

  MrcDaRunStatus$="None"
  SetTabVal  _config[1], "window", GuiSystemDiagramWinNo, "DefWXHigh", 1
  SetTabVal  _config[1], "window", GuiSystemDiagramWinNo, "DefWYLow", 0.0  ! 0.3
  GUICheckFreeDiskSpace
  Mrc_EnablePause = 0
  Mrc_EnableResume = 0
  
  if RCTrayAvailable() = 1 
    MRC_RcTrayAvailable = 1
  else
    MRC_RcTrayAvailable = 0
  endif
  
  If _OFFLINE = 1 Then
    Mrc_Online = 0
  Else
  	Mrc_Online = 1  
  Endif

endmacro


!---------------------------------------------------------------------
Name Mrc_LoadTestMacro

  if check ( macro, GuiDemoSystemDiagramCode ) = 0
    GUIProductMacDemandLoading  "SystGuiD.mac"
  endif

endmacro




!############################################################################
name GUIShowSystemDiagramCode

parameter  ShowType   default  0  ! 0 is show in switch view (test if applicable)
                                  ! others may be defined by product specific macros
                                  ! example 1 create and show , 2 destroy, 3 toggle


! this macro is called for example in a switchview 
!(entry in the window table command column done automatically by this macro)
! an existing system diagram is not deleted
! does not do any building when the diagram is visible
! sets start macro command in window table Command column

! stores in _config[1],LeoGuiDemo if user wanted to see the demo
!############################################################################
                                       
local b$
local LeoType   
local ProdArea$
local DetNos
local RunState                           
local xLast
local iii
local iMax
local a$
local tab$
local CountLeoThm

if (Mrc_IsRcNetUi() > 0)
  Mrc_GUIShowSystemDiagramCode ShowType
  return
endif

if ShowType = 0                                       
   if DevLeoPump+DevLeoAls+DevLeoThm+DevLeoClc+GuiDevGuiDets = 0
      !in this case the diagram does not make sense in the view
      GUIDiagramStateForMenu=1  !enabled and unchecked
      return 
   endif     
endif   

if ShowType = 3 AND FreeWin(GuiSystemDiagramWinNo) = GuiSystemDiagramWinNo \
   AND GomExist( , GUISystemDiagGOM$) = 1
   !was hidden with GuiShowHide
   GuiShowHide 1
   return
endif

if GomExist( , GUISystemDiagGOM$) = 1
   if ShowType = 2 OR ShowType = 3
      GUIDiagramStateForMenu=1  !enabled and unchecked
      GomDelete , GUISystemDiagGOM$
   else
      !update menu checkmark
      GUIDiagramStateForMenu=1+2  !enabled plus checked
   endif
else
if ShowType <> 2
   
   GUIDiagramStateForMenu=1+2  !enabled plus checked
   
   ProdArea$="DRIVERS"
   GOMShowGUI  , GUISystemDiagGOM$  , ProdArea$ , , GuiSystemDiagramWinNo

   ExecHook "GuiMethSampLnks"  !do early since goes to a highly visible border

   if GuiOffline = 1
      GomSetVal  , GUISystemDiagGOM$, "SYSTEMON"  , y , 2000
      GomSetVal  , GUISystemDiagGOM$, "SYSTEMOFF" , y , 2000
   endif
   
   !put now in case some later crashes or error exits don't allow this later
   SetTabText _config[1], "window", GuiSystemDiagramWinNo, "Command",  \
                                         "GUIShowSystemDiagram 0"  !call via bootstrap macro

   !NOTE: if any of GOMShowGUI did not find something , must set CRTxResolution to 800
   !and redo all since we garantee at 800 is ALL there
   
   GOMShowGUI GUISystemDiagGOM$, "LMethod"  , ProdArea$

   if _PumpUseBar = 1
      b$="LInjPump"
   else
      b$="JInjPump"
   endif
   GOMShowGUI GUISystemDiagGOM$, b$ , ProdArea$ 
   if DevLeoAls = 0  
      GomSetVal  GUISystemDiagGOM$, b$, "Injection" , "Enable" , 0
      RunState = 1
   else
      RunState=ObjHdrVal(LeoAlsStatus1, "RunState")
   endif             
   if RunState = 1
      !move ALS HOME out of sight
      GomSetVal GUISystemDiagGOM$, b$ , "ALSHome" , y , 1000
   endif   
   if DevLeoPump = 0
      GomSetVal  GUISystemDiagGOM$, b$, "Pump" , "Enable" , 0
   endif

   !do all left side extension hooks now, also for combo box extensions
   !do early since highy visible on left side
   xLast=-100
   tab$="GuiTopMthExt"
   if TabHdrVal(Hook[1],tab$, "NumberOfRows") > 0
      xLast=GUIFindGomCornerCoord ( "X", GUISystemDiagGOM$,  "LMethod" )  
      SetTabHdrVal Hook[1],tab$,"xStartPos", xLast
      SetTabHdrVal Hook[1],tab$,"yStartPos", \
                   GUIFindGomCornerCoord ( "BOTTOM", GUISystemDiagGOM$,  "LMethod" )
      GuiExecHook  tab$
   endif

   GuiShowBubbleMessage "LAST"  !so does not get bad edges through hooks "GuiTopMthExt"

   tab$="GuiPreMthExt"   
   if TabHdrVal(Hook[1],tab$, "NumberOfRows") > 0 
      if xLast = -100
         xLast=GUIFindGomCornerCoord ( "X", GUISystemDiagGOM$,  "LMethod" )  
      endif   
      SetTabHdrVal Hook[1],tab$,"xStartPos", xLast !syringe start more left for DRAW mode
      if _PumpUseBar = 1
         SetTabHdrVal Hook[1],tab$,"yStartPos", \
                      GUIFindGomCornerCoord ( "BOTTOM", GUISystemDiagGOM$,  "LInjPump" )
      else
         SetTabHdrVal Hook[1],tab$,"yStartPos", \
                      GUIFindGomCornerCoord ( "BOTTOM", GUISystemDiagGOM$,  "JInjPump" )
      endif
      GuiExecHook  tab$
   endif   
   
   if DevLeoPump > 0
      evaluate "LeoType=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""PumpType"")"
      evaluate "RunState=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""RunState"")"
      if LeoType > 0  AND LeoType < 10
         b$=GUIBuildSolventsINI$(-1)
      else 
         !don't know what to do then , default for now 
         b$=GUIBuildSolventsINI$(0)
      endif   
   else
      RunState=1  !offline
      !default for now 
      b$=GUIBuildSolventsINI$(0)
   endif   
                
   !reinit hotlinks to be sure in unknow NN module cases we are correct
   GUIInstallSolventsHotlinks
   
   GOMShowGUI GUISystemDiagGOM$, b$ , ProdArea$    !solvent composistion and bottles
   if DevLeoPump = 0
      GomSetVal  GUISystemDiagGOM$, b$, "Composition" , "Enable" , 0
      GomSetVal  GUISystemDiagGOM$, b$, "Bottles"     , "Enable" , 0
   endif

   if RunState = 1
      !move pump on off button out of sight
      GomSetVal GUISystemDiagGOM$, b$ , "PumpOnOff" , y , 1000
   endif             
   
   
   b$=GUIBuildColumnINI$()
   if b$ <> ""
      GOMShowGUI GUISystemDiagGOM$, b$ , ProdArea$ 
   endif   

   CountLeoThm = DevLeoThm
   if Check(Variable, _ClusteredTcc$) = 1 then
      if InStr(_ClusteredTcc$, "1") > 0 then
         CountLeoThm=1
         GomSetVal GUISystemDiagGOM$, b$ , "ThmOnOff2" , y , 1000
         GomSetVal GUISystemDiagGOM$, b$ , "column2" , y , 1000

         GomSetVal GUISystemDiagGOM$, b$ , "column1" , y5 , 29
         GomSetVal GUISystemDiagGOM$, b$ , "column1" , x5 , 50
         GomSetText GUISystemDiagGOM$, b$ , "column1" , justify5 , centered
         GomSetVal GUISystemDiagGOM$, b$ , "column1" , y6 , 16
         GomSetVal GUISystemDiagGOM$, b$ , "column1" , x6 , 2
         GomSetText GUISystemDiagGOM$, b$ , "column1" , justify6 , left
	 else
         if InStr(_ClusteredTcc$, "2") > 0 then
            CountLeoThm=2

			GomSetVal GUISystemDiagGOM$, b$ , "column2" , y5 , 29
	        GomSetVal GUISystemDiagGOM$, b$ , "column2" , x5 , 50
	        GomSetText GUISystemDiagGOM$, b$ , "column2" , justify5 , centered
	        GomSetVal GUISystemDiagGOM$, b$ , "column2" , y6 , 16
	        GomSetVal GUISystemDiagGOM$, b$ , "column2" , x6 , 2
	        GomSetText GUISystemDiagGOM$, b$ , "column2" , justify6 , left
         endif
      endif
   endif

   if CountLeoThm > 1 and DevLeoClc = 0
      RunState=ObjHdrVal(LeoThermostatStatus2, "RunState")
      if RunState = 1
         GomSetVal GUISystemDiagGOM$, b$ , "ThmOnOff2" , y , 1000
      endif             
   endif
   if CountLeoThm > 0
      RunState=ObjHdrVal(LeoThermostatStatus1, "RunState")
      if RunState = 1
         GomSetVal GUISystemDiagGOM$, b$ , "ThmOnOff1" , y , 1000
      endif             
   !else without thm no on off button
   endif             

   if DevLeoClc > 0
      b$=GUIBuildClcINI$()
      GOMShowGUI GUISystemDiagGOM$, b$ , ProdArea$
   endif
      
   !count out how many detectors are there
   !LeoType=GuiDevGuiDets+dev1050DAD+dev1050MWD+dev1050VWD+dev1046FLD \
   !       +dev1049ECD+adcdevice   !+Dev1946MSD
   LeoType=GuiDevGuiDets+GuiDevNonGuiDets
   if LeoType < 1
      !assume foreign one and set it grayed
      DetNos=1
   else
   if LeoType <= 4
      DetNos=LeoType  
   else
      !take the max of four   
      DetNos=4  
   endif   
   endif   

   b$="L"+val$(DetNos)+"Detect"
   GOMShowGUI GUISystemDiagGOM$, b$ , ProdArea$ 
    
   GuiLeoDetectorReconfiguration  b$, LeoType 
   
   xLast=GUIAddMoreDetectors()
   if xLast = 0
      xLast=GomVal(GUISystemDiagGOM$,b$,,"X")
      xLast=xLast+GomVal(GUISystemDiagGOM$,b$,,"WIDTH")
   endif   

   ! insert fraction collector gui
   If Check(Variable, DevLeoAfc) <> 0
	  If DevLeoAfc > 0
	     GOMShowGUI GUISystemDiagGOM$, "afraco" , ProdArea$ , , , xLast
	   	 xLast = xLast + GomVal(GUISystemDiagGOM$,"afraco",,"WIDTH")
   	  EndIf
   EndIf

   !now come DA parts  
   !justify them to right of last modules
   GOMShowGUI GUISystemDiagGOM$, "LDaSimpl" , ProdArea$ , , , xLast
   
   !now come Plot windows 
   !Question HOW many to configure ?
   !if Check ( VARIABLE, DacTst ) = 0
   !does not work in dactst since hprtpl00 is not initialized
   b$="L1Plot"
   GOMShowGUI GUISystemDiagGOM$, b$    , ProdArea$
   GUIReSizeMiniPlot b$
   !endif

   !do all right side extension hooks now, also for combo box extensions
   tab$="GuiPostMthExt"   
   if TabHdrVal(Hook[1],tab$, "NumberOfRows") > 0  
      SetTabHdrVal Hook[1],tab$,"xStartPos", \
                   GUIFindGomCornerCoord ( "X", GUISystemDiagGOM$,  "LDaSimpl" )
      SetTabHdrVal Hook[1],tab$,"yStartPos", \
                   GUIFindGomCornerCoord ( "BOTTOM", GUISystemDiagGOM$,  "LDaSimpl" )
      GuiExecHook  tab$
   endif   

   GuiExecHook  "GuiMthDiagrmExt"

   !now come Details, will be done by a command putting the selection right etc
   GUIListingArea "" 
   
   !remove the possibility for EMF in offline copy
   if GuiOffline = 1
      b$="Details"
      !GomSetText , GUISystemDiagGOM$ , b$ , "Text4" , ""
      if GomExist( , GUISystemDiagGOM$, b$) = 1
         iMax=GomVal( , GUISystemDiagGOM$, b$, "MaxListSize")
         for iii=1 to iMax
             a$=GomText$( , GUISystemDiagGOM$, b$, "Command"+val$(iii) )
             if InStr(a$,"EMF") > 0 
                GomSetText  , GUISystemDiagGOM$, b$, "Text"+val$(iii) , ""
                iii=iMax+1
             endif
         next iii
      endif
   endif                     

  !remove the possibility for ECM if no ecm is installed
  if VCS_NOTINTEGRATED = 1
      b$="Details"
      if GomExist( , GUISystemDiagGOM$, b$) = 1
         iMax=GomVal( , GUISystemDiagGOM$, b$, "MaxListSize")
         for iii=1 to iMax
             a$=GomText$( , GUISystemDiagGOM$, b$, "Command"+val$(iii) )
             if InStr(a$,"ECM") > 0 
                GomSetText  , GUISystemDiagGOM$, b$, "Text"+val$(iii) , ""
                iii=iMax+1
             endif
         next iii
      endif
   endif                     

   !for later reconstruction of diagram in switchview
   SetTabText _config[1], "window", GuiSystemDiagramWinNo, "Command",  \
                                         "GUIShowSystemDiagram 0"  !call via bootstrap macro
   SetTabVal  _config[1], "window", GuiSystemDiagramWinNo, "HelpContext", 0
   
   !! 
endif
endif

ExecHook "GuiMethSampLnks"  !for final cleanup do here also


endmacro



!############################################################################
name GUIShowHide

parameter  ShowType  ! 0 is hide, 1 is show

!for better look in edit entire method, just does Gom hide and show
!and not a complete timeconsuming rebuild (this is just for repaint
!optimization)
!############################################################################

if GomExist( , GUISystemDiagGOM$) = 1
   if ShowType = 1
      GomShow , GUISystemDiagGOM$, ON 
   else
      GomShow , GUISystemDiagGOM$, OFF 
   endif   
   if ShowType = 0
      GUIDiagramStateForMenu=1+0  !enabled plus unchecked
   else
      GUIDiagramStateForMenu=1+2  !enabled plus checked
      !for later reconstruction of diagram in switchview
      SetTabText _config[1], "window", GuiSystemDiagramWinNo, "Command",  \
                                     "GUIShowSystemDiagram 0"  !call via bootstrap macro
   endif
   
   !! 
endif

endmacro





!############################################################################
name GUIRebuildSystemDiagram

!removes old picture and builds new one only if it was visible before
!############################################################################


if GomExist( ,GUISystemDiagGOM$) = 1
   GUIShowSystemDiagramCode  2
   !rebuild only if it was there and visible 
   GUIShowSystemDiagramCode  1
endif

endmacro




!############################################################################
name GUIReconfigureSystemDiagram

parameter  bForce  Default 0 ! 1 forces to reinit hotlink DLL
!indirectly called from Leonardo cluster controller if the Leonardo Module 
!configruation has changed,
!only deletes and reshows the diagram if it was there before
!loads all necessary floating menus and installs the GOM hotlinks
!this is the more powerful macro than in SGuiInit.mac
!############################################################################

local ID_ASTXDRIVERSMACFILES_SYSTEM_DIAGRAM_29
local ID_ASTXDRIVERSMACFILES_LOADING_GUI_M_304
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_SYSTEM_DIAGRAM_29           =  17029  
ID_ASTXDRIVERSMACFILES_LOADING_GUI_M_304           =  17304

NLSFileName_astxmac$= "astxmac"
!also the LEO gui hotlink DLL must reinit its BSP connections to the now available drivers
GUIInstallLeoHotlinkDll  bForce
                              
                              
!juggle all the menu registers around to the destination
print ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_LOADING_GUI_M_304)
GUIConfigureSystemDiagramMenus

!builds all necessary hotlinks
!but do anyway reconfigure the data hotlinks
if (Mrc_IsRcNetUi() = 0) ! but we don't need this for the new MRC UI
  GUIConfigureGOMHotlinks
endif

ExecHook  "GuiReConfigGUI"

!do since in hook GuiReConfigGUI menus are loaded and juggled in objs by 
!addon at other parts of GUI
DelReg LeoTemp
GUIAdaptFullShortMenus

! init fraction collector gui
AfcGuiInit

!removes old picture or parts and builds new one if visible
print ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SYSTEM_DIAGRAM_29)
GUIRebuildSystemDiagram

endmacro




!############################################################################
name GUISetDARunStatus

parameter  DASectionName$     default "@"   
                              ! "INTEG", "QUANT", "REPORT" , "GLPSAVE", "DONE" , "RESET"
 
!for run progress display in system diagram hook DA progress into here
!############################################################################

MrcDaRunStatus$ = DASectionName$
GUIStartDAProgressDisplay  DASectionName$

endmacro




!############################################################################
name GUIStartDAProgressDisplay

parameter  FctArea$       default "DefaultCase" 
                          ! "INTEG" , "QUANT" , "REPORT" , "GLPSAVE" , "DONE" , "RESET"

!called when intergateObj or quantify or reporting or GLP save is on
!############################################################################

Local SubGom$, Tool$, Pict$, RunDAPart

local ID_ASTXDRIVERSMACFILES_INTEGRATE_30
local ID_ASTXDRIVERSMACFILES_RUN_31
local ID_ASTXDRIVERSMACFILES_CALIBRATE_32
local ID_ASTXDRIVERSMACFILES_REPORT_33
local ID_ASTXDRIVERSMACFILES_INTEGRATE_23
local ID_ASTXDRIVERSMACFILES_REPORT_25
local NLSFileName_astxmac$
  
ID_ASTXDRIVERSMACFILES_INTEGRATE_30                =  17030  
ID_ASTXDRIVERSMACFILES_RUN_31                      =  17031  
ID_ASTXDRIVERSMACFILES_CALIBRATE_32                =  17032  
ID_ASTXDRIVERSMACFILES_REPORT_33                   =  17033  
ID_ASTXDRIVERSMACFILES_INTEGRATE_23                =  17023  
ID_ASTXDRIVERSMACFILES_REPORT_25                   =  17025  
NLSFileName_astxmac$= "astxmac"
                   
                 
!terminate all last progresses
!if GuiDAProgressEnd = 0
   !SetSemaphore only needed when 2 threads write on this variable
   !while SetSemaphore(GuiDAProgressEnd) = 0
   !      _DebugPrint "SetSemaphore(GuiDAProgressEnd)" , ,0
   !      sleep 1
   !endwhile
   !when this loop terminates GuiDAProgressEnd is 1
!endif   

if (Mrc_IsRcNetUi() > 0)
  return
endif

if FctArea$= "ECM"
  return
endif

If FctArea$ = "RESET"
    GuiDAProgressEnd = 1
    GuiDAProgressLoopRuning = 0
endif

!PVCS 6166, changed the if to while
while GuiDAProgressLoopRuning=1
   !terminate all last progresses in all cases
   GuiDAProgressEnd = 1
   sleep 1  !for 2. CP to catch it
endwhile

if GomExist ( , GUISystemDiagGOM$ ) = 0
   return
endif   

if FctArea$ = ""
   FctArea$="DefaultCase"
endif
on error goto DefaultCase
evaluate "GoTo "+ FctArea$
   INTEG:;on error
     Tool$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INTEGRATE_30)
     Pict$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_31)
     goto endswitch
   QUANT:;on error
     Tool$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_CALIBRATE_32)
     Pict$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_31)
     goto endswitch
   REPORT:;on error
     Tool$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_REPORT_33)
     Pict$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_31)
     goto endswitch
   GLPSAVE:;on error
     Tool$="GlpSave"
     Pict$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_31)
     goto endswitch
   DONE:;on error 
     return 
     goto endswitch
   RESET:;on error 
     if GomExist ( GUISystemDiagGOM$, "LDaSimpl" ) = 1
        RunDAPart=RUN_DA
        if RunDAPart = 1 AND    GuiSeqRunMode = 1         
           if TabHdrVal(_sequence, "SeqParm" , "SeqMode") <> 1
              RunDAPart = 1
           else
              RunDAPart = 0  !Seq ACQ only
           endif
        endif
        Pict$=val$(RunDAPart)

        Tool$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INTEGRATE_23)
        GomSetText GUISystemDiagGOM$ , "LDaSimpl", Tool$,"image1", Pict$

        Tool$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_CALIBRATE_32)
        GomSetText GUISystemDiagGOM$ , "LDaSimpl", Tool$,"image1", Pict$

        Tool$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_REPORT_25)
        GomSetText GUISystemDiagGOM$ , "LDaSimpl", Tool$,"image1", Pict$

        Pict$=val$(RUN_SAVEGLPDATA)
        Tool$="GlpSave"
        GomSetText GUISystemDiagGOM$ , "LDaSimpl", Tool$,"image1", Pict$
     endif   
     return 
     goto endswitch
   DefaultCase:;on error
     return 
     goto endswitch
endswitch:

GuiDAProgressEnd=0   ! end condition is 1 in semaphore  GuiDAProgressEnd
                     ! must do here since in very short actions like REPORT and DONE
                     ! come nearly instantly after each other before CPGUI
                     ! has started the macro where GuiDAProgressEnd was initialized 
SubGom$="LDaSimpl"                                                    
if GomExist ( GUISystemDiagGOM$, SubGom$, Tool$ ) = 1
   CpRequest "CPGUI", "GUIShowDAProgressDisplay "+SubGom$+","+ Tool$+","+Pict$
   Sleep 1 !PVCS 6166
endif   

endmacro



!############################################################################
name GUIShowDAProgressDisplay

  parameter  SubGom$
  parameter  Tool$
  parameter  Pict$
  
!############################################################################
local iii
                           
   iii=1
   GuiDAProgressLoopRuning=1
   while  GuiDAProgressEnd=0 
       GomSetText GUISystemDiagGOM$ , SubGom$, Tool$,"image1", Pict$+val$(iii)
       sleep 1
 
       if iii<5
          iii=iii+1
       else
          iii=1  !restart
       endif
   endwhile
   iii=5
   GomSetText GUISystemDiagGOM$ , SubGom$, Tool$,"image1", Pict$+val$(iii)
   GuiDAProgressLoopRuning=0


endmacro




        
        
!############################################################################
name GuiPrepearDataFile                          

!############################################################################
local err
local SampleAreaWidth 
local SamplingIni$                                                 
local ScreenWidth
                                  
if FreeWin(38) = 38 
   !draw window does not exist so show something            
   on error err=1
   if RegSize(ChromReg) < 1
      if GuiOffline = 1
         LoadFile TabText$(_Config[1],"DataFile", 1,"PathAndName")
      else   
         !or of current or last run
         LoadFile _DATAPath$+_DATAFILE1$
      endif   
   endif   
   on error
   if RegSize(ChromReg) > 0
      IntegSignals 
      !set better default start values in window table if still original
      if TabVal(_config[1], "window", 38 , "DefWXLow" ) < 0.05 \
         AND  TabVal(_config[1], "window", 38 , "DefWXHigh" ) > 0.95  
         if GomExist(GUISystemDiagGOM$,GUIBuildSequenceSamplingINI$()) = 1
            SamplingIni$=GUIBuildSequenceSamplingINI$()
         else
         if GomExist(GUISystemDiagGOM$,GUIBuildSingleSampleINI$()) = 1  
            SamplingIni$=GUIBuildSingleSampleINI$()
         else
            SamplingIni$=""
         endif
         endif
         if SamplingIni$ <> ""
            SampleAreaWidth=GomVal(GUISystemDiagGOM$,SamplingIni$,,"WIDTH")
            ScreenWidth=TabHdrVal(_config[1], "window", "CrtxResolution")  
            !only good for default app size
            SetTabVal _config[1], "window", 38 , "DefWXLow", SampleAreaWidth/ScreenWidth
            SetTabVal _config[1], "window", 38 , "DefWXHigh", 0.7
         endif   
      endif   
      DrawSignals
   endif   
endif                                  

endmacro

        
