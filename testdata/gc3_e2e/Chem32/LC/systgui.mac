GuiSetVeneerHook  "GuiQuickLst" , "METHODDA" ,      GuiShowQuickDAMethodListing
GuiSetVeneerHook  "GuiQuickLst" , "CHEMICALNAMES" , GuiShowQuickChemicalsListing
