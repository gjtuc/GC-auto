!############################################################################
name GUIEcmTranslateToYesNo$


!############################################################################
parameter p

  if (p = 0)
    return "no"
  else
    return "yes"
  endif

endmacro

!############################################################################
name GUICondenseEcmParameters


!############################################################################

local A$       
local iii
local irow
local b$
local ProdArea$ 
local QuickListGom$

  QuickListGom$=GUISystemDiagGOM$+"|"+GUIQuickListGOM$
  b$="ecmstatus"

  if GomExist( QuickListGom$, b$) = 0
     return  !don't need this
  endif

  A$ = "LCDF Preferences: "
  if VC_IsAcquisitionWithUpload() = 1
    A$ = A$ + VcsFacade_AutoRepositoryLocation_get$()
  else
    A$ = A$ + "-\-\-\-"
  endif

  A$ = A$ + "|Operator: " + _Operator$

  A$ = A$ + "|Automatic transfer after acquisition: " + GUIEcmTranslateToYesNo$(Vcs_get_TransferOnAcquisition())
  A$ = A$ + "|Automatic transfer after reprocessing: " + GUIEcmTranslateToYesNo$(Vcs_get_TransferOnReprocessing())
  A$ = A$ + "|Automatic transfer after any data modification: " + GUIEcmTranslateToYesNo$(Vcs_get_TransferOnDataChange())
  A$ = A$ + "|Automatic import after reprocessing: " + GUIEcmTranslateToYesNo$(Vcs_get_TransferOnReprocessingIncludeNonAttached())
  A$ = A$ + "|Calculate peak performance: " + GUIEcmTranslateToYesNo$(Vcs_get_CalculateOnTransfer())

  GomSetText QuickListGom$, b$, "EcmInfos","elements", A$

endmacro
    
 
 
 

!############################################################################
name GUIPowerFailAlertBox
                                             
parameter  StatusReg$
parameter  ModName$
!############################################################################

local iii                            
local a$

evaluate "iii=RegSize("+StatusReg$+")"
   
if iii > 0
   !RunState 2 means powerfail
   evaluate "a$=ObjHdrText$("+StatusReg$+",ErrorTextLong)"
   if a$ = ""
      evaluate "a$=ObjHdrText$("+StatusReg$+",ErrorTextShort)"
   endif
   if a$ = ""
      a$="POWERFAIL"
   endif
   iii=alert(ModName$+": "+a$+"." , 3 ,Alert3Title$)
endif
 
return iii

endmacro 

!############################################################################
name GUITogglePump
                                             
!############################################################################

local iii                            
local a$
local x

local ID_ASTXDRIVERSMACFILES_SWITCH_OFF_ALL_18
local ID_ASTXDRIVERSMACFILES_TURN_PUMP_303
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_SWITCH_OFF_ALL_18 = 17018
ID_ASTXDRIVERSMACFILES_TURN_PUMP_303     = 17303
NLSFileName_astxmac$= "astxmac"

evaluate "x = RegSize(LeoPumpStatus"+Val$(_GuiPump)+")"
if x > 0
   evaluate "iii=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+",""RunState"")" 
   if iii = 2
      !2 means powerfail
      iii=GUIPowerFailAlertBox("LeoPumpStatus"+Val$(_GuiPump),"Pump")
   else   
   if iii <>  4
      !4 means standby
      iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SWITCH_OFF_ALL_18),4,Alert4Title$)
      if iii = 1
         PumpAll off
      endif   
   else
      iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TURN_PUMP_303),4,Alert4Title$)
      if iii = 1
         PumpAll on
      endif   
   endif   
   endif   
endif

endmacro




!############################################################################
name GUIToggleThermostat

parameter  ModuleNumber  default  1                                             
!############################################################################

local iii
local RegName$                          
local a$
local ModuleName$

local ID_ASTXDRIVERSMACFILES_SWITCH_OFF_THE_19
local ID_ASTXDRIVERSMACFILES_TURN_ON_THE_TH_20
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_SWITCH_OFF_THE_19           =  17019  
ID_ASTXDRIVERSMACFILES_TURN_ON_THE_TH_20           =  17020  
NLSFileName_astxmac$= "astxmac"
   

RegName$="LeoThermostatStatus"+val$(ModuleNumber)
evaluate "iii=RegSize("+RegName$+")"
if iii > 0
   evaluate "iii=ObjHdrVal("+RegName$+",RunState)"
   ModuleName$="LTHM"+val$(ModuleNumber)
   if iii = 2
	  !2 means powerfail
	  iii=GUIPowerFailAlertBox(RegName$,"Thermostat")
   else   
   if iii <>  4
	  !4 means standby
	  iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SWITCH_OFF_THE_19),4,Alert4Title$)
	  if iii = 1
	    if Check(Variable, _ClusteredTcc$) = 1 then
		    if _ClusteredTcc$ <> "" then
				ClusterTccSwitchTcc OFF
			else
				a$=SendModule$(ModuleName$,"THRM 0")
			endif
		endif
	  endif   
   else
	  iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TURN_ON_THE_TH_20),4,Alert4Title$)
	  if iii = 1
	    if Check(Variable, _ClusteredTcc$) = 1 then
		    if _ClusteredTcc$ <> "" then
				ClusterTccSwitchTcc ON
			else
				a$=SendModule$(ModuleName$,"THRM 1")
			endif
		endif
	  endif   
   endif   
   endif   
endif

endmacro







