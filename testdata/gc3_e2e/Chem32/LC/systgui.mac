!############################################################################
name GUIInstallInstrumentHotlinks
                                             
!for pump ALS and column and Legend
!and for method listing, and comsumption
!############################################################################

local LeoType
local SubGomIni$
local CountLeoThm

if _PumpUseBar = 1
   SubGomIni$="LInjPump"
else
   SubGomIni$="JInjPump"
endif
GUISetToolEvent  SubGomIni$, "injection", "elements",   "Gui",  "INJACT1"
if DevLeoAls > 0
   !only then is Cp var "_LALSInjectIdle" there 
   GUISetToolEvent  SubGomIni$, "AlsHome",   "enable",        ,  , "_LALSInjectIdle"
endif   
GUISetToolEvent  SubGomIni$, "pump",      "elements",   "Gui",  "FLOWPRESSURE1"

GUIInstallSolventsHotlinks




SubGomIni$=GUIBuildColumnINI$()

CountLeoThm = DevLeoThm
if Check(Variable, _ClusteredTcc$) = 1 then
   if InStr(_ClusteredTcc$, "1") > 0 then
      CountLeoThm=1
   else
      if InStr(_ClusteredTcc$, "2") > 0 then
         CountLeoThm=2
      endif
   endif
endif

if CountLeoThm > 0 or DevLeoClc = 0
   GUISetToolEvent  SubGomIni$, "column1", "elements",       "Gui",  "ThmTEMPTIME1"
endif
if CountLeoThm > 1 and DevLeoClc = 0
   GUISetToolEvent  SubGomIni$, "column2", "elements",    "Gui",  "ThmTEMPTIME2"
endif

if DevLeoClc > 0
   SubGomIni$=GUIBuildClcINI$()
   GUISetToolEvent  SubGomIni$, "ChipCube", "elements",       "Gui",  "CLCACT1"
!                                ToolName ,  ToolItem ,        Reg ,  NDR for Holink
endif
endmacro              



!############################################################################
name GUIConfigureGOMHotlinks
                                             
!initially sets up all data hotlinks for a working GUI system diagram                                             
!############################################################################


!deltabrow _config, gomdatalinks, -1    !clean up from last time

!builds all necessary hotlinks
!future just delete out syscont sub items !!!
GOMDeleteToolEvent  , GUISystemDiagGOM$    !maybe do this only the first time at bootup


!hotlinks for non instrument stuff
GUIInstallNonInstrumentHotlinks  


!hotlinks for instrument configuration dependant stuff
if DevLeoPump+DevLeoAls+DevLeoThm+DevLeoClc+GuiDevGuiDets > 0
   !if anyone is present (same as in Menuadd for system diagram)
   GUIInstallInstrumentHotlinks  
endif   



endmacro





!############################################################################
name GUISamplingGomNameForMode$

parameter  SamplingMode$     default "DefaultCase"
!############################################################################


if SamplingMode$ = ""
   SamplingMode$="DefaultCase"
endif
on error goto DefaultCase
evaluate "GoTo "+ SamplingMode$
   TOPRUN:;on error
     return GUIBuildSingleSampleINI$()
     goto endswitch
   TOPSEQ:;on error
     return GUIBuildSequenceSamplingINI$()
     goto endswitch
   DefaultCase:;on error
     return GUIBuildSingleSampleINI$()
     goto endswitch
endswitch:

endmacro


!############################################################################
name CorrectCaseOfMode$

parameter  SamplingMode$      default "DefaultCase"  !give default
!############################################################################


if SamplingMode$ = ""
   SamplingMode$="TOPRUN"
endif
on error goto DefaultCase
evaluate "GoTo "+ SamplingMode$
   TOPRUN:;on error
     return "TOPRUN"
     goto endswitch
   TOPSEQ:;on error
     return "TOPSEQ"
     goto endswitch
   DefaultCase:;on error
     !return "UNKNOWN"
     return SamplingMode$
     goto endswitch
endswitch:

endmacro



    





    
    

    
    
    
    
    
    
    
    


!############################################################################
name GuiLeoDetectorReconfiguration

parameter  DetectorsINIFile$
parameter  TotalNoOfDetectors
!############################################################################


!!WARNING
!! here have exactly the same steps in numbering the detectors as in 
!! GUIShowBubbleMessage or : GUIBalanceDetector (but no longer needed )

             
local icnt
local iDetectorNumber
local HelpMessage$
local ToolName$
local DetName$
             
iDetectorNumber=1

!redo help message
!set the correct floating menu call
!do hotlink connection

if TotalNoOfDetectors > 4
   TotalNoOfDetectors=4
endif

if TotalNoOfDetectors < 1
   !foreign one
   !if this happens guilcdet.mac was not loaded
   GUICheckProductMacDemandLoading "guilcdet.mac", "GuiLeoSingleDetectorReconfig" , , \
                                   DetectorsINIFile$ +","+ val$(iDetectorNumber) +"," \
                                   + """?"" , , ""LeoVwdStatus"" " 
else                                 
!!

if 0=1
!OLD if at release
if Dev1946MSD > 0 AND check(MACRO, GUI1946MSDDetectorReconfiguration) = 1
   GUI1946MSDDetectorReconfiguration   GUISystemDiagGOM$, DetectorsINIFile$,  TotalNoOfDetectors, iDetectorNumber
   iDetectorNumber=iDetectorNumber+Dev1946MSD
else
   for icnt=1 to Dev1946MSD
       if check(MACRO, GUI1946MSDSingleDetectorReconfiguration) = 1
          !not yet done this way
          !do as in GuiLeoSingleDetectorReconfig 
          GUI1946MSDSingleDetectorReconfiguration DetectorsINIFile$,iDetectorNumber,Dev1946MSD,
                                       icnt,"MSD","LeoMSD","LeoMSDStatus","LeoMSDStatus","LMSD"
       else
          Gui1050SingleDetectorReconfig DetectorsINIFile$,iDetectorNumber,Dev1946MSD,\
                                        icnt,"MSD","LeoMSD","LeoMSDStatus"
       endif                         
       iDetectorNumber=iDetectorNumber+1
       if iDetectorNumber > TotalNoOfDetectors
          return
       endif                           
    next icnt                          
endif
endif


!set DetStackIniFile parameter for GuiExecHook in table hdr
SetTabHdrText Hook[1],"GuiDetectors","DetStackIniFile",DetectorsINIFile$
GuiExecHook   "GuiDetectors"

!calls:  GUILeoSingleDetectorReconfig     in GuiLcDet.mac
!        Gui1050SingleDetectorReconfig    in GuiLcDet.mac
!        GuiADCSingleDetectorReconfig     in GuiLcDet.mac
   


endif



endmacro
             
             
                   

!############################################################################
name GUIRemoveMenuRow

  parameter  RegName$     
  parameter  ObjNr        default 1
  parameter  MenuTab$
  parameter  SearchKey$                                                

!############################################################################

local irow
local HelpCommand$
local HelpOffset
local HelpSubSystem$
local iColPresent
                 
evaluate "iColPresent=TabColType( "+RegName$+"[ObjNr], MenuTab$, ""SearchKey"" )"
if iColPresent <> 99
   evaluate "irow = RowByText( "+RegName$+\
                               "[ObjNr], MenuTab$, , ""SearchKey"", ""i="" , SearchKey$ )"
    
   if irow > 0                              
      evaluate "DelTabRow "+RegName$+"[ObjNr], MenuTab$, irow "
   endif
endif

endmacro                   
                   
             
             
             
!############################################################################
name GUICopyDiagramMenuTabs

parameter  MenuTab$
parameter  ModuleCount
parameter  StatusRegNameBase$    default ""                             
parameter  HelpSubSystem$  default ""  !to override whats coded                                                
parameter  HelpOffset      default 0   !to override whats coded                                                
parameter  DoRemove		   default 1
parameter  SourceReg$	   default "LeoTemp"
parameter  SrcMenuTab$     default ""
 
!assumes menu tables to be copied to reside in LeoTemp reg
!does menu correction for missing contacts option in modules
!  NDR name : "CONT_INSTALLED" and search key row "CONTACTS"
!does menu correction for online help sub system call
!  this calls GOMRunTimeCorrectFloatingMenuHelpCalls
!assumes also that tablename with OC at end is also there for offline copy menus
!############################################################################
   
local RegSizeSource, RegSizeDest
local icnt, imax                                                                  
local OriginalTab$
local iExists
local KeepContactsMenuItem
local KeepReleaseVialMenuItem
local KeepPurgeMenuItem
local KeepFCCMenuItem
local KeepGuiMenuItem
local KeepBottleMenuItem
local Clusteres
local PumpType
local Pos
local Mod$

local KeepAfc4
local KeepAfc3
local KeepAfc2
local Action$
local iRow

local KeepPurgeSyringeMenuItem

local NumRows
local Found
local Loop
local NameRef
local PartNumber$

local KeepIllumination
local KeepIllumination1
local KeepIllumination2
local KeepIllumination3
local KeepIllumination4
local Device$
local ModNumber
local SerialNumber$
local First1200
local SerNo

Local Type$
Local KeepRunRecov


KeepAfc4 = 0
KeepAfc3 = 0
KeepAfc2 = 0

! Defaults for 'Purge' menu item
PumpType		  = 0 
KeepPurgeMenuItem = 1	  ! Always 'Keep or do nothing' if NO pump menu at all 
KeepFCCMenuItem = 1       ! or capillary pump menu, (pumptype 5)

if SrcMenuTab$ = ""
   SrcMenuTab$ = MenuTab$
endif

! Test Autosampler  
! Always 'Keep or do nothing' if ALS is present. Remove menu item 
! if WLS is present
KeepReleaseVialMenuItem = 1
KeepPurgeSyringeMenuItem = 0
if MenuTab$ = "LeoALS"
	if check ( VARIABLE, _WellPlateSampler ) = 1
		if _WellPlateSampler = 1
			KeepReleaseVialMenuItem = 0

            InjType = ObjHdrVal (LeoAlsStatus1[1], "ALS_TYPE")
	        if InjType = 3
			    KeepPurgeSyringeMenuItem = 1
			endif
	    endif
	endif
endif
	
Evaluate "RegSizeSource=RegSize("+SourceReg$+")"   
RegSizeDest=RegSize(Menu)                 

if RegSizeDest < RegSizeSource
   imax=RegSizeDest
else
   imax=RegSizeSource
endif

if SourceReg$ = "Menu"
   imax = 1
endif
if GuiOffline = 0
   OriginalTab$=SrcMenuTab$
else
   OriginalTab$=SrcMenuTab$+"OC"   ! "OC" for Offline Copy menus table names
endif                                                                   

KeepRunRecov=1

if StatusRegNameBase$ <> ""
   StatusRegNameBase$=StatusRegNameBase$+val$(ModuleCount)    

   evaluate "KeepContactsMenuItem=RegSize("+StatusRegNameBase$+")"
   if KeepContactsMenuItem > 0
      evaluate "KeepContactsMenuItem=ObjHdrVal("+StatusRegNameBase$+",""CONT_INSTALLED"")"

	  ! Test whether this is a 'pump' status register and if, determine the pumptype
      evaluate "if ObjHdrType("+StatusRegNameBase$+",""PUMPTYPE"")=1;" + \
               "PumpType=ObjHdrVal("+StatusRegNameBase$+",""PUMPTYPE"");endif"

	  if (PumpType <> 5) And (PumpType <> 7)! Not Capillary pump
	  	 KeepPurgeMenuItem = 0
	  	 KeepFCCMenuItem = 0
	  else
         NumRows = TabHdrVal(_Config, "ModuleInfo", "NumberOfRows")
         Found = 0
         For Loop = 1 To NumRows
           NameRef = TabVal(_Config, "ModuleInfo", Loop, "NameRef")
           PartNumber$ = TabText$(_Config, "Modules", NameRef, "PartNumber")
           If PartNumber$ = "G1377A" Then
             Found = 1
           EndIf
         Next Loop

         if Found = 0 then
            KeepFCCMenuItem = 0
		 endif
	  endif

	  if PumpType = 6 ! Prep Pump pump
         Clustered = 0
         evaluate "if ObjHdrType("+StatusRegNameBase$+",""CLUSTERED"")=1;" + \
                  "Clustered=ObjHdrVal("+StatusRegNameBase$+",""CLUSTERED"");endif"
   	     if Clustered = 1
	  	    KeepBottleMenuItem = 0
		 else
   	        KeepBottleMenuItem = 1
	     endif
	  else
	     KeepBottleMenuItem = 1
	  endif
   else
      KeepContactsMenuItem=0  !if HDR not there then Leo has no contacts
   endif
  Evaluate("Type$ = ObjHdrText$("+StatusRegNameBase$+", ""DRV_PRODUCT"")")
  if ((Type$="G1315D")or (Type$="G1365D"))   
    KeepContactsMenuItem=0
    KeepRunRecov=0
  endif
  if ((Type$="G1315C")or (Type$="G1365C"))
    KeepContactsMenuItem=0
  endif
  if ((Type$="G1314D")or (Type$="G1314E"))
    KeepContactsMenuItem=0
  endif

else
   KeepContactsMenuItem=1  !1050 modules always keep them
   KeepBottleMenuItem = 0
   KeepPurgeMenuItem = 0
endif

if DevLeoPump > 1
   KeepGuiMenuItem=1  !if more than 1 pump is configured, keep menu item
else
   KeepGuiMenuItem=0  !Remove Menu Item
endif

If DevLeoAfc > 3
    KeepAfc4 = 1
EndIf
If DevLeoAfc > 2
    KeepAfc3 = 1
EndIf
If DevLeoAfc > 1
    KeepAfc2 = 1
EndIf



KeepIllumination  = 1
KeepIllumination1 = 1
KeepIllumination2 = 1
KeepIllumination3 = 1
KeepIllumination4 = 1
First1200         = 55000 ! use -1 for testing with 1100 modules

If _OFFLINE = 0 Then
   NumRows = TabHdrVal(_CONFIG[1], MODULEINFO, NumberOfRows)
   For Loop = 1 To NumRows 
      NameRef       = TabVal  (_CONFIG[1], MODULEINFO, Loop   , nameRef)
      ModNumber     = TabVal  (_CONFIG[1], MODULEINFO, Loop   , number)
      SerialNumber$ = TabText$(_CONFIG[1], MODULEINFO, Loop   , serialNumber)
      Device$       = TabText$(_CONFIG[1], MODULES   , NameRef, Var)
      If SerialNumber$ <> "" Then
         ! test if third char is a letter or not
         ! if it is a letter than it's the new serial number pattern
         If SerialNumber$[3]<>"0" And Val(SerialNumber$[3])=0 Then
            SerNo = First1200+1 ! generate temporary dummy serial number
         else
            SerNo = Val(SerialNumber$[3:Len(SerialNumber$)])
         endif
      Else
         SerNo = First1200
      EndIf
      If (SerNo >= 0) And (SerNo < First1200) Then
         if MenuTab$ = "LeoALS"
            If Device$ = "LALS" Then
               KeepIllumination  = 0
            EndIf
            If Device$ = "LWLS" Then
               KeepIllumination  = 0
            EndIf
         EndIf
         if MenuTab$ = "LeoAFC"
            If Device$ = "LAFC" Then
               Evaluate "KeepIllumination" + Val$(ModNumber) + " = 0"
            EndIf
         EndIf
      EndIf
   Next Loop
Else
   if MenuTab$ = "LeoALS"
      KeepIllumination  = 0
   EndIf
   if MenuTab$ = "LeoAFC"
      KeepIllumination1 = 0
      KeepIllumination2 = 0
      KeepIllumination3 = 0
      KeepIllumination4 = 0
   EndIf
EndIf


for icnt=1 to imax
    if ObjHdrType(Menu[icnt],MenuTab$) = 4
       DelTab Menu[icnt], MenuTab$
    endif
    Evaluate "iExists=ObjHdrType("+SourceReg$+"[icnt],OriginalTab$)"
    if iExists = 99
       OriginalTab$=SrcMenuTab$
       Evaluate "iExists=ObjHdrType("+SourceReg$+"[icnt],OriginalTab$)"
    endif
    if iExists = 4
       Evaluate "CopyTab "+SourceReg$+"[icnt], OriginalTab$, Menu[icnt], MenuTab$"

       if DoRemove = 1
       	       if KeepRunRecov=0
       		  GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "RECOV"
       	       endif
	       if KeepIllumination = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU"
	       endif
	       if KeepIllumination1 = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU1"
	       endif
	       if KeepIllumination2 = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU2"
	       endif
	       if KeepIllumination3 = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU3"
	       endif
	       if KeepIllumination4 = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU4"
	       endif
	       if KeepContactsMenuItem = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTSA"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTSB"
	       endif
	       if KeepPurgeMenuItem = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONF"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONFA"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONFB"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "PURGE"
	       endif
	       if KeepFCCMenuItem = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "FCC"
	       endif
	       if KeepGuiMenuItem = 0 
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "GUIPMP"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "GUIPMPS"
	       endif
           if KeepBottleMenuItem = 0
              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "FLOW"
              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "AUX"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "STORE"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CTRL"

              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "FILLING"
           else
              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "FLOWA"
              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "FLOWB"
              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "AUXA"
              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "AUXB"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTSA"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTSB"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "STOREA"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "STOREB"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CTRLA"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CTRLB"

              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "FILLINGA"
              GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "FILLINGB"
           endif
	       if KeepReleaseVialMenuItem = 0
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "RELVIAL"
	       endif
	       if KeepPurgeSyringeMenuItem = 0
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "PURGESYR"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "INJFILLING"
	       endif
           If KeepAfc4 = 0
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CTRL4"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "RESET4"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "TEMPCTRL4"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS4"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU4"
           Else
              If ObjHdrVal (Leoafcstatus4[1], "THRM_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "TEMPCTRL4"
              EndIf
              If ObjHdrVal (Leoafcstatus4[1], "CONT_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS4"
              EndIf
           EndIf
           If KeepAfc3 = 0
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CTRL3"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "RESET3"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "TEMPCTRL3"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS3"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU3"
           Else
              If ObjHdrVal (Leoafcstatus3[1], "THRM_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "TEMPCTRL3"
              EndIf
              If ObjHdrVal (Leoafcstatus3[1], "CONT_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS3"
              EndIf
           EndIf
           If KeepAfc2 = 0
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CTRL2"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "RESET2"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "TEMPCTRL2"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS2"
	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ILLU2"
           Else
              If ObjHdrVal (Leoafcstatus2[1], "THRM_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "TEMPCTRL2"
              EndIf
              If ObjHdrVal (Leoafcstatus2[1], "CONT_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS2"
              EndIf
           EndIf
           If DevLeoAfc > 0
              If ObjHdrVal (Leoafcstatus1[1], "THRM_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "TEMPCTRL1"
              EndIf
              If ObjHdrVal (Leoafcstatus1[1], "CONT_INSTALLED") = 0 
    	          GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "CONTACTS1"
              EndIf
           EndIf
	   endif



       If (ModuleCount > 1) And (Instr(MenuTab$, "LeoThm") > 0)
          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "=", "METH")
          If iRow > -1
              Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
              Action$ = Action$ + "," + Val$(ModuleCount) 
              SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
          EndIf
	   EndIf

       If (Instr(MenuTab$, "LeoThm") > 0)
          if Check(Variable, _ClusteredTcc$) = 1 then
             if InStr(_ClusteredTcc$, Val$(ModuleCount)) > 0 then
             !if (InStr(_ClusteredTcc$, MenuTab$[Len(MenuTab$)]) > 0) Or (InStr(_ClusteredTcc$, Val$(ModuleCount)) > 0) then
		          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "=", "METH")
		          If iRow > -1
		              SetTabText Menu[icnt], MenuTab$, iRow, "Action", "ClusterTccMethod"
				      !DelTabRow Menu[icnt], MenuTab$, 2
                      GUIRemoveMenuRow "Menu" , icnt, MenuTab$, "ERRORINFO"
		          EndIf
			 endif
          endif
      endif
		


       !If (ModuleCount > 1) And \
          !((Instr(MenuTab$, "LeoDAD") > 0) Or \
          !(Instr(MenuTab$, "LeoVWD") > 0) Or \
          !(Instr(MenuTab$, "NucVWD") > 0) Or \
          !(Instr(MenuTab$, "LeoMWD") > 0) Or \
          !(Instr(MenuTab$, "LeoFLD") > 0) Or \
          !(Instr(MenuTab$, "NucDad") > 0) Or \
          !(Instr(MenuTab$, "NucMwd") > 0) Or \
          !(Instr(MenuTab$, "LeoRID") > 0))
          
        If (ModuleCount > 1) And \
          ((Instr(MenuTab$, val$(ModuleCount)) > 0))  ! module number higher than 1
          
          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "in", "SIGNAL")
          If iRow > -1
              Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
              Action$ = Action$ + "," + Val$(ModuleCount) 
              SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
          EndIf

          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "in", "CONTACTS")
          If iRow > -1
              Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
              Action$ = Action$ + "," + Val$(ModuleCount) 
              SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
          EndIf
            
          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "in", "CONFIG")
          If iRow > -1
              Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
              Action$ = Action$ + "," + Val$(ModuleCount) 
              SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
          EndIf
 
          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "in", "RECOV")
           If iRow > -1
               Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
               Action$ = Action$ + "," + Val$(ModuleCount) 
               SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
          EndIf

          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "in", "CTRL")
          If iRow > -1
              Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
              Action$ = Action$ + "," + Val$(ModuleCount) 
              SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
          EndIf

          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "in", "ERRORINFO")
          If iRow > -1
              Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
              Action$ = Action$ + "," + Val$(ModuleCount) 
              SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
          EndIf

          iRow = RowByText (Menu[icnt], MenuTab$, -1, "SearchKey", "in", "SPECMON")
          If iRow > -1
			  Mod$ = MenuTab$[4:6]
              Action$ = TabText$(Menu[icnt], MenuTab$, iRow, "Action")
			  Pos = InStr(Action$, Mod$)
			  If Pos > 0
                  Action$ = Action$[1:Pos] + MenuTab$[5:7] + """"
                  SetTabText Menu[icnt], MenuTab$, iRow, "Action", Action$
			  EndIf
          EndIf
       EndIf
       GOMRunTimeCorrectFloatingMenuHelpCalls "Menu" , icnt, MenuTab$ ,HelpSubSystem$ ,HelpOffset     
    endif
next icnt


endmacro


!############################################################################
name GUICopyDiagramMenuTabsNonModule

parameter  MenuTab$
parameter  ModuleCount
parameter  StatusRegNameBase$    default ""                             
parameter  HelpSubSystem$  default ""  !to override whats coded                                                
parameter  HelpOffset      default 0   !to override whats coded                                                
parameter  DoRemove		   default 1
parameter  SourceReg$	   default "LeoTemp"
 
   
local RegSizeSource, RegSizeDest
local icnt, imax                                                                  
local OriginalTab$
local iExists
local SrcMenuTab$


SrcMenuTab$ = MenuTab$

Evaluate "RegSizeSource=RegSize("+SourceReg$+")"   
RegSizeDest=RegSize(Menu)                 

if RegSizeDest < RegSizeSource
   imax=RegSizeDest
else
   imax=RegSizeSource
endif

if SourceReg$ = "Menu"
   imax = 1
endif
if GuiOffline = 0
   OriginalTab$=SrcMenuTab$
else
   OriginalTab$=SrcMenuTab$+"OC"   ! "OC" for Offline Copy menus table names
endif                                                                   



for icnt=1 to imax
    if ObjHdrType(Menu[icnt],MenuTab$) = 4
       DelTab Menu[icnt], MenuTab$
    endif
    Evaluate "iExists=ObjHdrType("+SourceReg$+"[icnt],OriginalTab$)"
    if iExists = 99
       OriginalTab$=SrcMenuTab$
       Evaluate "iExists=ObjHdrType("+SourceReg$+"[icnt],OriginalTab$)"
    endif
    if iExists = 4
       Evaluate "CopyTab "+SourceReg$+"[icnt], OriginalTab$, Menu[icnt], MenuTab$"
       GOMRunTimeCorrectFloatingMenuHelpCalls "Menu" , icnt, MenuTab$ ,HelpSubSystem$ ,HelpOffset     
    endif
next icnt


endmacro




!############################################################################
name GUIUpdateClusteredThmMenu

    local Dev
    local icnt
    local iRow

    on error print ""

    if Check(Variable, _ClusteredTcc$) = 1 then

        for icnt=1 to RegSize(Menu)
   
            if InStr(_ClusteredTcc$, "1") > 0 then
                iRow = RowByText (Menu[icnt], "LeoThm", -1, "SearchKey", "=", "METH")
                If iRow > -1
                    SetTabText Menu[icnt], "LeoThm", iRow, "Action", "ClusterTccMethod"
                    GUIRemoveMenuRow "Menu" , icnt, "LeoThm", "ERRORINFO"
                EndIf
            endif

            For Dev = 1 To DevLeoThm
                DelTab Menu[icnt], "LeoThm"+Val$(Dev)
                CopyTab Menu[icnt], "LeoThm", Menu[icnt], "LeoThm"+Val$(Dev)
                if InStr(_ClusteredTcc$, Val$(Dev)) > 0 then
                    iRow = RowByText (Menu[icnt], "LeoThm"+Val$(Dev), -1, "SearchKey", "=", "METH")
                    If iRow > -1
                        SetTabText Menu[icnt], "LeoThm"+Val$(Dev), iRow, "Action", "ClusterTccMethod"
                        GUIRemoveMenuRow "Menu" , icnt, "LeoThm"+Val$(Dev), "ERRORINFO"
                    EndIf
                endif
            Next Dev

        next icnt
    endif

endmacro



!############################################################################
name GUIConfigureModuleNumberMenus

parameter  Tab$
parameter  NumberOfModules
parameter  StatusRegNameBase$    default ""
parameter  HelpSubSystem$    default ""  !to override whats coded                                                
parameter  HelpOffset        default 0   !to override whats coded
parameter  DoRemove		     default 1
parameter  SourceReg$	     default "LeoTemp"
parameter  SrcMenuTab$       default ""

!assumes menu tables to be copied to reside in LeoTemp reg
!allows copying multiple module menus (from 1 to devxxx )
!does menu correction for missing contacts option in modules
!  NDR name : "CONT_INSTALLED" and search key row "CONTACTS"
!does menu correction for online help sub system call
!  this calls GOMRunTimeCorrectFloatingMenuHelpCalls
!assumes also that tablename with OC at end is also there for offline copy menus
!############################################################################

local  icnt

if SrcMenuTab$ = ""
   SrcMenuTab$ = Tab$
endif

!for instrument take only what is needed
if NumberOfModules = 1
   !without module number infos in menu items
   GUICopyDiagramMenuTabs  Tab$, 1, StatusRegNameBase$, HelpSubSystem$, HelpOffset, DoRemove, SourceReg$, SrcMenuTab$
else
   for icnt=1 to NumberOfModules 
      !with module number infos in menu items
      GUICopyDiagramMenuTabs  Tab$+val$(icnt), icnt, StatusRegNameBase$, HelpSubSystem$, HelpOffset, DoRemove, SourceReg$, SrcMenuTab$
   next icnt   
endif   

endmacro



             
             
!############################################################################
name GUIRemoveMenuTabMenuItem

parameter  MenuTabName$
parameter  ModuleCount
parameter  StatusRegNameBase$
parameter  OptionNdr$    
parameter  MenuSearchKey$
 
!############################################################################
   
local imax                                                                  
local KeepOptionMenuItem

imax=RegSize(Menu)                 

if StatusRegNameBase$ <> ""
   StatusRegNameBase$=StatusRegNameBase$+val$(ModuleCount)    
   evaluate "KeepOptionMenuItem=RegSize("+StatusRegNameBase$+")"
   if KeepOptionMenuItem > 0
      evaluate "KeepOptionMenuItem=ObjHdrType("+StatusRegNameBase$+","+OptionNdr$+")"
      if KeepOptionMenuItem = 1
         evaluate "KeepOptionMenuItem=ObjHdrVal("+StatusRegNameBase$+","+OptionNdr$+")"
      else   
         KeepOptionMenuItem=0  !if HDR not there then Leo does not have this option
      endif   
   else
      KeepOptionMenuItem=0  !if HDR not there then Leo does not have this option
   endif
else
   KeepOptionMenuItem=0
endif

if KeepOptionMenuItem = 0
   for icnt=1 to imax
       if ObjHdrType(Menu[icnt],MenuTabName$) = 4
          GUIRemoveMenuRow "Menu" , icnt, MenuTabName$, MenuSearchKey$
       endif
   next icnt
endif

endmacro





!############################################################################
name GUISetupMenuRegForConfiguration

!set menu reg is sorted order so floating menu tables can be easily
!be configured by using macro GUIConfigureModuleNumberMenus
!and  GUICopyDiagramMenuTabs . This way menu[1] is the FULL menu obj
!############################################################################
local CurrentDiagramMenuType$

!test the menu mode the system is in
CurrentDiagramMenuType$=ObjHdrText$(menu[1], "MenuType")

if CurrentDiagramMenuType$ <> "FULL"
   ! need to exchange the objects
   MoveObj Menu[2], Menu[1]
endif


endmacro




!############################################################################
name GUIConfigureSystemDiagramMenus

!menus 
!plus ExecHook  "GuiReConfigDet"
!############################################################################

local  icnt                         
local  DevCnt 
local  HelpSubSystem$
local CountLeoThm

local ID_ASTXDRIVERSMACFILES_METHOD_21
local ID_ASTXDRIVERSMACFILES_METHODINFO_22
local ID_ASTXDRIVERSMACFILES_INTEGRATE_23
local ID_ASTXDRIVERSMACFILES_IDENTIFY_24
local ID_ASTXDRIVERSMACFILES_REPORT_25
local ID_ASTXDRIVERSMACFILES_GLPSAVE_26
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_METHOD_21                   =  17021  
ID_ASTXDRIVERSMACFILES_METHODINFO_22               =  17022  
ID_ASTXDRIVERSMACFILES_INTEGRATE_23                =  17023  
ID_ASTXDRIVERSMACFILES_IDENTIFY_24                 =  17024  
ID_ASTXDRIVERSMACFILES_REPORT_25                   =  17025  
ID_ASTXDRIVERSMACFILES_GLPSAVE_26                  =  17026  
NLSFileName_astxmac$= "astxmac"

GuiNewDetectorOrderedHook
                         

!for future optimize: keep at 1. only menu[1],
!do load on demand of menu[2] only when requested

!need menu register first
if RegSize(Menu) < 2
   newobj Menu,1,0,0
   newobj Menu,1,0,0    
   !give it the menu type names
   SetObjHdrText menu[1], "MenuType", "FULL"
   SetObjHdrText menu[2], "MenuType", "SHORT"
endif

!juggle all the menu registers around to the destination
GUISetupMenuRegForConfiguration

!GOMLoadNLSMenuReg "LC", "LeoM", "LeoTemp"

DelReg LeoTemp
GOMLoadNLSMenuReg "LC", "LSam", "LeoTemp"

if ((devLeoAls > 0) or (Mrc_IsRcNetUi() > 0))
   GUICopyDiagramMenuTabsNonModule  "Sequence"    
   GUICopyDiagramMenuTabsNonModule  "SeqCurrVial"    
   GUICopyDiagramMenuTabsNonModule  "SeqData"      
   GUICopyDiagramMenuTabsNonModule  "SingleSample" 
   GUICopyDiagramMenuTabsNonModule  "DataDir"     
else
if devHPCE > 0
   HelpSubSystem$="HPCE"
   GUICopyDiagramMenuTabs  "Sequence"     , , , HelpSubSystem$, 4100
   GUICopyDiagramMenuTabs  "SeqCurrVial"  , , , HelpSubSystem$, 4100       
   GUICopyDiagramMenuTabs  "SeqData"      , , , HelpSubSystem$, 4102  
   GUICopyDiagramMenuTabs  "SingleSample" , , , HelpSubSystem$, 4101
   GUICopyDiagramMenuTabs  "DataDir"      , , , HelpSubSystem$, 4102
else
   !it is 1050 or 1090
   HelpSubSystem$="HPLC"
   GUICopyDiagramMenuTabs  "Sequence"     , , , HelpSubSystem$, 7990
   GUICopyDiagramMenuTabs  "SeqCurrVial"  , , , HelpSubSystem$, 7990       
   GUICopyDiagramMenuTabs  "SeqData"      , , , HelpSubSystem$, 7992  
   GUICopyDiagramMenuTabs  "SingleSample" , , , HelpSubSystem$, 7991
   GUICopyDiagramMenuTabs  "DataDir"      , , , HelpSubSystem$, 7992
endif
endif


DelReg LeoTemp
GOMLoadNLSMenuReg "LC", "LeoM", "LeoTemp"
!which is also ok for all single Leo DET and THM cases

!GUICopyDiagramMenuTabs  "Reprocess"
GUICopyDiagramMenuTabsNonModule  ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_METHOD_21)
GUICopyDiagramMenuTabsNonModule  ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_METHODINFO_22)

GUICopyDiagramMenuTabsNonModule  ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INTEGRATE_23)
GUICopyDiagramMenuTabsNonModule  ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_IDENTIFY_24)
GUICopyDiagramMenuTabsNonModule  ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_REPORT_25)
GUICopyDiagramMenuTabsNonModule  ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_GLPSAVE_26)
GUICopyDiagramMenuTabsNonModule  "ECM"


if (Mrc_IsRcNetUi() = 0)

!for instrument take only what is needed

  DevCnt=DevLeoPump
  if DevCnt > 1
     !in case more modules are configured so 1. one goes in GUI
     DevCnt=1
  endif
  GUIConfigureModuleNumberMenus  "LeoBottles"  , DevCnt , "LeoPumpStatus"
  GUIConfigureModuleNumberMenus  "LeoBottlesX" , DevCnt , "LeoPumpStatus",,,0,,"LeoBottles"
  GUIConfigureModuleNumberMenus  "LeoPump"     , DevCnt , "LeoPumpStatus"
  GUIConfigureModuleNumberMenus  "LeoPumpX"    , DevCnt , "LeoPumpStatus",,,0,,"LeoPump"
  GUIConfigureModuleNumberMenus  "LeoPumpSolv" , DevCnt , "LeoPumpStatus"
  GUIConfigureModuleNumberMenus  "LeoPumpSolvX", DevCnt , "LeoPumpStatus",,,0,,"LeoPumpSolv"

  DevCnt=DevLeoAls
  if DevCnt > 1
     !in case more modules are configured so 1. one goes in GUI
     DevCnt=1
  endif
  GUIConfigureModuleNumberMenus  "LeoALS" , DevCnt , "LeoAlsStatus"
  GUIRemoveMenuTabMenuItem       "LeoALS" , DevCnt , "LeoAlsStatus" ,  \
                                         "THRM_INSTALLED" , "TEMPCTRL"
  GUIRemoveMenuTabMenuItem       "LeoALS" , DevCnt , "LeoAlsStatus" ,  \
                                         "THRM_INSTALLED" , "TEMPCTRLSEP"

  if devLeoAfc > 0
      GUICopyDiagramMenuTabs "LeoAFC"
  endif

                                          
  if DevLeoTHM = 0
     GUICopyDiagramMenuTabs  "LeoNoThm"
  else
  if DevLeoClc = 0
     CountLeoThm = DevLeoThm
     if Check(Variable, _ClusteredTcc$) = 1 then
        if InStr(_ClusteredTcc$, "1") > 0 then
           CountLeoThm=1
        else
           if InStr(_ClusteredTcc$, "2") > 0 then
              CountLeoThm=2
           endif
        endif
     endif

     if CountLeoTHM > 1
        DelReg LeoTmp
        GOMLoadNLSMenuReg "LC", "LeoM", "LeoTemp"
     endif   
     GUIConfigureModuleNumberMenus  "LeoThm" , CountLeoTHM 
     GUIConfigureModuleNumberMenus  "LeoThm" , 1
  else
     GUIConfigureModuleNumberMenus  "LeoThm" , 1
  endif        
  endif        

  if DevLeoClc > 0
     GUICopyDiagramMenuTabs "LeoCLC"
  endif

  GuiDevGuiDets=0
  GuiDevNonGuiDets=0
  !recount them all

  ExecHook  "GuiReConfigDet"

  !calls  :  GUIReConfigureLeoDetectors
  !          GUIReConfigure1050Detectors
  !          GUIReConfigureADConv


else
   if Dev1946MSD > 0
      GUICheckProductMacDemandLoading "SGuiMsd.mac", "GUIReConfigure1946MSD", _AutoMSPath$
   endif
endif

DelReg LeoTemp

GUIAdaptFullShortMenus


endmacro






!############################################################################
name GUIAdaptFullShortMenus

parameter  menutype$  default ""  !"FULL" and "SHORT"  
                                  !or "" to be set as in "MenusForViews" tab


! this macro is called from the macro SwitchMenuInView (view.mac)
!############################################################################

if RegSize(Menu) > 0  
   if menutype$ = ""
      !test the menu mode the system is in by looking in the core menu handler table
      !in _config[1], "MenusForViews", "MenuCol"
      menutype$=GUIFindOutFullShortMenuState$()
   endif
   
   if menutype$ <> ""
      !the reg Menu contains the floating menus used for the system diagram
      !diagram always works with Menu[1] object (fastest way to exchange the menus)
      if ObjHdrText$(Menu[1], "MenuType") <> menutype$
         ! need to exchange the objects
         MoveObj Menu[2], Menu[1]
      endif
   endif

endif

endmacro


!############################################################################
name GUIPumpReconfiguration

parameter  LastPumpType  default -1

!callback from leo hotlink fiter for PUMP driver noticing Pump Type has changed
!
!when  Pump Type has changed throw away old solvents picture 
!
!set hotlinks at all times so it is correct when next switchview comes on
!or when Sysdigram is built anew by GUIShowSystemDiagramCode
!############################################################################

local PumpConfigGomIni$
local x

if Check(Variable, PumpLastGomIni$) = 0
   PumpLastGomIni$=""
endif

PumpConfigGomIni$=GUIBuildSolventsINI$(-1)                                                                                              

if PumpConfigGomIni$<>PumpLastGomIni$
   !redo pump solvents hotlinks if necessary
   GUIInstallSolventsHotlinks
endif   

!only do any destroying and building if System Diagram is there at all
if GomExist( , GUISystemDiagGOM$) = 1
   !! 
   !System GUI GOM is visible
   if PumpConfigGomIni$=PumpLastGomIni$
      if GomExist(GUISystemDiagGOM$, PumpConfigGomIni$) = 1
         return !nothing to do  --> exit
	  endif
   endif

   if GomExist(GUISystemDiagGOM$, PumpConfigGomIni$) = 1
      GomDelete GUISystemDiagGOM$, PumpConfigGomIni$
   endif   

   GUICopyDiagramMenuTabs "LeoPump"    , _GuiPump, "LeoPumpStatus",,,1,"MENU","LeoPumpX"
   GUICopyDiagramMenuTabs "LeoPumpSolv", _GuiPump, "LeoPumpStatus",,,1,"MENU","LeoPumpSolvX"
   GUICopyDiagramMenuTabs "LeoBottles" , _GuiPump, "LeoPumpStatus",,,1,"MENU","LeoBottlesX"
   Sleep 1
   GOMShowGUI GUISystemDiagGOM$, PumpConfigGomIni$, "DRIVERS" 
 
   evaluate "x = ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""RunState"")"
   if x = 1
      !move pump on off button out of sight
      GomSetVal GUISystemDiagGOM$, PumpConfigGomIni$, "PumpOnOff" , y , 1000
   endif             

   !!
endif   

PumpLastGomIni$=PumpConfigGomIni$

endmacro
    



