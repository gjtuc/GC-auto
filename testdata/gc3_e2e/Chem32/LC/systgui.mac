name GUIRunReprocessing
                                             
!############################################################################

!only do a da method run

DoRunDAMethod

endmacro




!############################################################################
name GUIBuildSamplingTrayINI$      
                                             
!############################################################################

local TrayType
local RightTray
local SamplingGomIni$

if DevLeoALS > 0
   TrayType=ObjHdrVal(LeoALSStatus1,"Act_Tray_A")

   if (TrayType = 10) or (TrayType = 13) 	!WK: New well plate sampler
      SamplingGomIni$="LWPSTr"
	  ! WK: Just to be sure ( the driver should have done that, but doesn't
      SetObjHdrVal LeoALSStatus1,"Act_Tray_B", 0
   Else 
     If TrayType = 12  ! New Automation Interface
       SamplingGomIni$="LAITr"
       SetObjHdrVal LeoALSStatus1,"Act_Tray_B", 0
     else
	   if TrayType > 40
	      SamplingGomIni$="L100ooTr"
	   else 
	      !not val$(TrayType) since we don't have generalized pictures
	      SamplingGomIni$="L"
	      if TrayType <= 0      
	         !before setting it to "oo" look into _config[1], Leo_Tray_A
	         !for last configuration
	         if ObjHdrType(_config[1], "Leo_Tray_A") = 99
	            setobjhdrval _config[1],Leo_Tray_A,100
	         endif   
	         TrayType=objhdrval(_config[1],Leo_Tray_A)
	         RightTray=ObjHdrVal(LeoALSStatus1,"Act_Tray_B")
	         if RightTray > 0  AND  ( TrayType = 100 OR TrayType = 10 OR TrayType = 12 or TrayType = 13 )
	            !then really something there, cannot accept a missing 100 tray
				!or missing plate tray (WK)
	            TrayType=0
	         endif
	      endif
	      if TrayType <= 0      
	         SamplingGomIni$=SamplingGomIni$+"oo"
	      else
		    if TrayType = 10 or TrayType=13	!WK: New well plate sampler
		     SamplingGomIni$=SamplingGomIni$+"WPS"
        Else 
        If TrayType = 12 ! Automation Interface
          SamplingGomIni$=SamplingGomIni$+"AI"
        else
	      if TrayType <= 15
	         SamplingGomIni$=SamplingGomIni$+"15"
	      else
	      if TrayType <= 40
	         SamplingGomIni$=SamplingGomIni$+"40"
	      else
	         SamplingGomIni$=SamplingGomIni$+"100"
	         SamplingGomIni$=SamplingGomIni$+"oo"
	      endif
	      endif
        endif
        endif
	      endif
	      if TrayType <> 10 AND TrayType <> 12 and TrayType<>13 And TrayType <= 40 
	         !WK: only then can come the 'normal' 2 tray parts
	         TrayType=ObjHdrVal(LeoALSStatus1,"Act_Tray_B")
	         if TrayType <= 0      
	            !before setting it to "oo" look into _config[1], Leo_Tray_B
	            !for last configuration
	            if ObjHdrType(_config[1], "Leo_Tray_B") = 99
	               setobjhdrval _config[1],Leo_Tray_B,40
	            endif   
	            TrayType=objhdrval(_config[1],Leo_Tray_B)
	         endif
	         if TrayType <= 0
	            SamplingGomIni$=SamplingGomIni$+"oo"
	         else   
	         if TrayType <= 15
	            SamplingGomIni$=SamplingGomIni$+"15"
	         else
	            SamplingGomIni$=SamplingGomIni$+"40"   
	         endif
	         endif
	      endif
	      if SamplingGomIni$ = "Loooo"
	         SamplingGomIni$ = "L0oo"
        EndIf
        SamplingGomIni$=SamplingGomIni$+"Tr"
     EndIf
     endif
   EndIf
 Else                        
   if Dev1090Inject = 1
      SamplingGomIni$="L1090Tr"
   else 
      if Dev1050Sampler = 1
         if Sampler = 21
            SamplingGomIni$="L21Tr"
         else
            if Sampler = 34
               SamplingGomIni$="L34Tr"
            else
               SamplingGomIni$="L121Tr"
            endif
         endif
      else
         if DevHPCE = 1
            SamplingGomIni$="Ce48Tr"
         else
            SamplingGomIni$="L100ooTr"     !just take this one as the most general form
         endif
      endif
   endif

endif

return SamplingGomIni$

endmacro



!############################################################################
name GUIBuildLeftTrayINI$
                                             
!############################################################################

local TrayType
local RightTray
local TrayGomIni$

if DevLeoALS > 0
   TrayType=ObjHdrVal(LeoALSStatus1,"Act_Tray_A")
   if TrayType = 0
      !before setting it to "oo" look into _config[1], Leo_Tray_A
      !for last configuration
      if ObjHdrType(_config[1], "Leo_Tray_A") = 99
         setobjhdrval _config[1],Leo_Tray_A,100
      endif   
      TrayType=objhdrval(_config[1],Leo_Tray_A)
      RightTray=ObjHdrVal(LeoALSStatus1,"Act_Tray_B")
      if RightTray > 0  AND  ( TrayType = 100 OR TrayType = 10 Or TrayType = 12 or TrayType = 13)
	     !then really something there, cannot accept a missing 100 tray
		 !or missing plate tray (WK)
         TrayType=0
      endif
   endif   
   if TrayType = 10	or TrayType = 13	
      TrayGomIni$="LVbaTray"	 ! WK: Vial bar on Wellplate Tray 
    Else  
     !If TrayType = 12          ! doesn't run
     !  TrayGomIni$="LVb2Tray"
     !else
	   if TrayType = 100
	      TrayGomIni$="L100Tray"
	   else   
	      if TrayType <= 0
	         TrayGomIni$="LooTray" !which does not exist
	      else
	         TrayGomIni$="L"
	         if TrayType <= 15
	            TrayGomIni$=TrayGomIni$+"15"
	         else
	            TrayGomIni$=TrayGomIni$+"40"
	         endif
	         TrayGomIni$=TrayGomIni$+"LTray"
	      endif
     EndIf
     !endif
   endif
else 
   if Dev1090Inject = 1
      TrayGomIni$="L1090_Tr"
   else 
      if Dev1050Sampler = 1
         if Sampler = 21
            TrayGomIni$="L21Tray"
         else
            if Sampler = 34
               TrayGomIni$="L34Tray"
            else
               TrayGomIni$="L21sTray"
            endif
         endif
      else
         if DevHPCE = 1
            TrayGomIni$="Ce48Tray"
         else
            TrayGomIni$="L100Tray"     !just take this one as the most general form
         endif
      endif
   endif
endif

return TrayGomIni$

endmacro




!############################################################################
name GUIBuildRightTrayINI$
                                             
!############################################################################

local TrayType
local TrayGomIni$
local LeftTray

if DevLeoALS > 0
   TrayType=ObjHdrVal(LeoALSStatus1,"Act_Tray_B")
   if TrayType = 0

      ! WK: Need to test whether the plate tray is configured or was 
      !     in previous configuration
      LeftTray = ObjHdrVal(LeoALSStatus1,"Act_Tray_A")
	  if ObjHdrType(_config[1], "Leo_Tray_A") = 99
	     setobjhdrval _config[1],Leo_Tray_A,100
	  endif   

      if ( LeftTray = 10 Or LeftTray = 12 or LeftTray = 13) OR \
         ( ( LeftTray = 0 ) AND ( ObjHdrVal(_config[1], "Leo_Tray_A") = 10 Or ObjHdrVal(_config[1], "Leo_Tray_A") = 10) )
		 ! WK: Wellplate Tray is identified by 
		 !     TrayLeft: 10   TrayRight: 0
		 !     For further work we 'simulate' the TrayRight
	     TrayType = 10	 
	  else
         !before setting it to "oo" look into _config[1], Leo_Tray_B
         !for last configuration
         if ObjHdrType(_config[1], "Leo_Tray_B") = 99
            setobjhdrval _config[1],Leo_Tray_B,100
         endif   

         TrayType=objhdrval(_config[1],Leo_Tray_B)

	  endif
   endif   
   if TrayType <= 0
      TrayGomIni$="LooTray" !which does not exist
   else
	  if TrayType = 10 or TrayType = 12 or TrayType = 13
       TrayGomIni$="LPltTray" !WK: New well plate sampler, Shows the 2 plates
                              ! the same for the Automation Interface
	  else
	      TrayGomIni$="L"
	      if TrayType <= 15
	         TrayGomIni$=TrayGomIni$+"15"
	      else
	         TrayGomIni$=TrayGomIni$+"40"
	      endif
	      TrayGomIni$=TrayGomIni$+"RTray"
	  endif
   endif
else 
   TrayGomIni$="L100Tray"     !just take this one
   if Dev1050Sampler = 1
      if Sampler <> 21  AND Sampler <> 34
         TrayGomIni$="L121Tray"
      endif
   endif
endif

return TrayGomIni$

endmacro



!############################################################################
name GUIBuildSequenceSamplingINI$
                                             
!############################################################################

if Dev1050Sampler > 0
   if Sampler = 21
      return "Lsequenw"  
   else
      if Sampler = 34
         return "Lsequenw"
      else
         return "Lsequewl"  
      endif
   endif
else
   if DevHPCE > 0
      return "Csequenc"
   else
      return "Lsequenc"
   endif
endif


endmacro





!############################################################################
name GUIBuildSingleSampleINI$
                                             
!############################################################################


if Dev1050Sampler > 0
   return "LSinglSW"
else
   if DevHPCE > 0
      return "CSingleS"
   else
      if _WellPlateSampler > 0
          return "LSinglWS"
      else
          return "LSingleS"
      endif
   endif   
endif

endmacro



!############################################################################
name GUIBuildLeoPumpPrefix$
                                             
parameter  PumpType  default  -1
!############################################################################

local Prefix$
local Cluster

if PumpType = -1
   !only read if not requested to build a specific one
   evaluate "PumpType=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+",""PumpType"")"
endif   
if PumpType > 0  AND PumpType < 10
   Prefix$="L"+val$(PumpType)
   if PumpType = 6
      evaluate "Cluster=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""Clustered"")"
      if Cluster <> 0
	     Prefix$ = Prefix$ +val$(Cluster)
      endif
   endif
else 
   !don't know what to do then
   Prefix$="L1"  
endif   

return Prefix$

endmacro


!############################################################################
name GUIBuildSolventsINI$

parameter  PumpType  default  -1
                                             
!############################################################################

local GomIni$

if DevLeoPump > 0
   GomIni$=GUIBuildLeoPumpPrefix$(PumpType)
   if GomIni$ <> ""
      GomIni$=GomIni$+"Solv"
   else
      GomIni$=GUIBuildLeoPumpPrefix$(0)+"Solv"  
   endif   
else 
   GomIni$=GUIBuildLeoPumpPrefix$(0)+"Solv"
endif

return GomIni$

endmacro




!############################################################################
name GUIBuildColumnINI$
                                             
!############################################################################

local ThmType
local GomIni$
local CountLeoThm
            
CountLeoThm=DevLeoThm
if DevLeoThm > 2
   CountLeoThm=2    !we don't give more for now
endif

GomIni$ = ""
if DevLeoClc > 0
   if CountLeoThm > 0
      GomIni$="L3Column"
   endif
else
   GomIni$="L"+val$(CountLeoThm)+"Column"
endif

return GomIni$

endmacro

!############################################################################
name GUIBuildClcINI$
                                             
!############################################################################

local GomIni$
            
!xxxCLC (new)
GomIni$="L1CLC"
!GomIni$="LCLC"

return GomIni$

endmacro






!############################################################################
name GUISetToolEvent
                                             
parameter  SubGom$
parameter  ToolName$
parameter  ToolAttribute$
parameter  RegName$     
parameter  HotlinkNdr$    default "???"                                    
parameter  CpVarName$     default "???"                                   
!############################################################################

if  HotlinkNdr$ <> "???"
    evaluate "GomSetToolEvent GUISystemDiagGOM$,SubGom$,ToolName$,ToolAttribute$,"\
           +RegName$+",HotlinkNdr$,"
else
if  CpVarName$ <> "???"
    evaluate "GomSetToolEvent GUISystemDiagGOM$,SubGom$,ToolName$,ToolAttribute$,"\
           +",,"+CpVarName$
else
   !generate error        
endif
endif

endmacro


!############################################################################
name GUISetSamplingToolEvent
                                             
parameter  SubGom$
parameter  ToolName$
parameter  ToolAttribute$
parameter  RegName$     
parameter  HotlinkNdr$    default "???"                                    
parameter  CpVarName$     default "???"                                   
!############################################################################

if  HotlinkNdr$ <> "???"
    evaluate "GomSetToolEvent GUISamplingDiagGOM$,SubGom$,ToolName$,ToolAttribute$,"\
           +RegName$+",HotlinkNdr$,"
else
if  CpVarName$ <> "???"
    evaluate "GomSetToolEvent GUISamplingDiagGOM$,SubGom$,ToolName$,ToolAttribute$,"\
           +",,"+CpVarName$
else
   !generate error        
endif
endif

endmacro



!############################################################################
name GUIInstallSequenceHotlinks
                                             
                                             
!############################################################################

local TrayGomIni$
local SamplingGomIni$
local TrayPartGomIni$

SamplingGomIni$ = GUIBuildSequenceSamplingINI$()
TrayGomIni$ = GUIBuildSamplingTrayINI$() 

if GUILastSequenceTrayGOM$ <> SamplingGomIni$
   if GUILastSequenceTrayGOM$ <> "" 
      !future just delete out all hotlinks to last sampling system 
      GOMDeleteToolEvent  GUISamplingDiagGOM$ , SamplingGomIni$
   endif   

   GUILastSequenceTrayGOM$=TrayGomIni$  !save this

   !for all:                      
   GUISetSamplingToolEvent  SamplingGomIni$, "SampleInfo", "elements", "Gui",  "SeqAct_SInf"
   GUISetSamplingToolEvent  SamplingGomIni$, "DiskSpace",  "image4",   "Gui",  "SeqDataSubDir"
   GUISetSamplingToolEvent  SamplingGomIni$, "Start",      "enable",     ,   ,   "TopEnableStart"
   GUISetSamplingToolEvent  SamplingGomIni$, "Stop",       "enable",     ,   ,   "TopEnableStop"
   
   GUISetSamplingToolEvent  SamplingGomIni$, "DiskSpace",  "elements", "Gui",  "DiskSpace"

   
   TrayGomIni$=GUISamplingDiagGOM$+"|"+SamplingGomIni$+"|"+TrayGomIni$

   !build left tray gom hotlinks
   TrayPartGomIni$=GUIBuildLeftTrayINI$()
   GomSetToolEvent TrayGomIni$, TrayPartGomIni$,\
                   "LeftTray", "elements", Gui,  "SeqTray1"

   !build right tray gom hotlinks
   TrayPartGomIni$=GUIBuildRightTrayINI$()
   GomSetToolEvent TrayGomIni$, TrayPartGomIni$,\
                   "RightTray", "elements", Gui,  "SeqTray2"
endif


endmacro
                            
                            
                            
                            
