!GuiPrepearDataFile

Evaluate "CpRequest "+CpName$(0)+",EditEventsExt"

endmacro


!############################################################################
name GuiEditEntireMethod                            

!############################################################################
                                  
Evaluate "CpRequest "+CpName$(0)+",EditEntireMethod"

endmacro


        
!############################################################################
name GuiCheckCalibReportType
     
!############################################################################
local  bNoCalib
local iii

local ID_ASTXDRIVERSMACFILES_NO_CALIBRATION_34
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_NO_CALIBRATION_34           =  17034  
NLSFileName_astxmac$= "astxmac"
!CalcType = TabHdrVal (_DAMethod[1], "QuantParm", "CalcType") ; 0 is area%
bNoCalib=0

if ObjHdrType(_DaMethod, "Compound") = 4
   if TabHdrVal(_DaMethod, "Compound","NumberOfRows") = 0
      bNoCalib=1
   endif
else   
   bNoCalib=1
endif

if bNoCalib = 1
   iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_CALIBRATION_34),3,Alert3Title$)
   return  0
endif

return 1
endmacro
        
!############################################################################
name GuiCalibUIEvaluate
     
parameter  CpCommand$  default ""
!############################################################################


local iii
local CalcType
local dummy
                                  
!GuiPrepearDataFile
!CAL_TLBFunction ReCalib,0

!macro parts taken from EditEntireMethod
!and EditDaMethod
! hide the GUI to prevent repeated (and slow) screen updates between the
if Check (Macro, GUIShowHide) = 1 then
   GUIShowHide 0
endif

if GuiCheckCalibReportType() = 1 then

   if TabHdrVal (_Config[1], "Features", "SignalDetails") = 1 then
      if ObjHdrType(_DaMethod, "Signal") = 4
         if TabHdrVal(_DaMethod, "Signal","NumberOfRows") = 0
            !bring up the signals dialog first to set these for the calibration table
            MenuCalSignals
         endif
      endif   
   endif


   SeeIfCalibUILoaded
   CalTabClosed = 0   !must be global
   on error dummy = 0
   CpStart "CPEEM"    ! CP for Edit Entire Method
   on error
   CpRequest "CPEEM", CpCommand$+"  ""CalTabClosed = 1"", 1"
   repeat ! wait until EditCalTab has executed the cmd given as parameter
       sleep 1  ! 1 second
   until CalTabClosed = 1
   CpRequest "CP", "CpTerminate ""CPEEM"""
   ! Calib U/I has no Cancel button, therefore no check for skip editing
endif

if Check (Macro, GUIShowHide) = 1 then
   GUIShowHide 1
endif

  
endmacro


!############################################################################
name GuiCheckForCalibTable

!############################################################################
local  bNoCalib, iii

local ID_ASTXDRIVERSMACFILES_A_CALIBRATION_35
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_A_CALIBRATION_35            =  17035  
NLSFileName_astxmac$= "astxmac"
bNoCalib=0

if ObjHdrType(_DaMethod, "Compound") = 4
   if TabHdrVal(_DaMethod, "Compound","NumberOfRows") = 0
      !tell to call the calibration table first
      bNoCalib=1
   endif
else   
   bNoCalib=1
endif

if bNoCalib = 1
   iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_A_CALIBRATION_35),3,Alert3Title$) 
   return  0
endif
              
return 1
endmacro


!############################################################################
name GuiRecalibrate  
parameter DataOrigin$  DEFAULT "RUN"  ! RUN or FILE                         

Evaluate "CpRequest "+CpName$(0)+",""DoGuiRecalibrate """""+DataOrigin$+""""""""

EndMacro

!############################################################################
name DoGuiRecalibrate  
parameter DataOrigin$  DEFAULT "RUN"  ! RUN or FILE                         


local iii
local CurrDataFile$

local ID_ASTXDRIVERSMACFILES_METHOD_USED_FO_36
local ID_ASTXDRIVERSMACFILES_RUN_THE_CALIBR_37
local ID_ASTXDRIVERSMACFILES_DATAFILE_OF_TH_38
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_METHOD_USED_FO_36           =  17036  
ID_ASTXDRIVERSMACFILES_RUN_THE_CALIBR_37           =  17037  
ID_ASTXDRIVERSMACFILES_DATAFILE_OF_TH_38           =  17038  
NLSFileName_astxmac$= "astxmac"

if GuiCheckCalibReportType() = 0 then
   return
endif   

if GuiCheckForCalibTable() = 0
   return
endif
              
if DataOrigin$ = "FILE"
   !give good sizeable style
   SetTabVal _config,"window",38,"DefWinStyle", 671  !temporary
   LoadFile
   if RegSize(Chromreg) > 0
      IntegSignals 
      if ObjHdrText$(Chromreg[1], "MethodFile") <> _MethFile$
         iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_METHOD_USED_FO_36) \
                   +Chr$(10)+chr$(13)+"Do you want to continue ? ",4,Alert4Title$)
         if iii=0
            Clearwin 38
            return
         endif   
      endif
   else
      Clearwin 38
      return
   endif   
else
   if RegSize(Chromreg) < 1
      iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_THE_CALIBR_37),3,Alert3Title$)
      return
   else                                  
      if _DataSubDir$ = ""
         CurrDataFile$=_DataPath$
      else
         CurrDataFile$=_DataPath$+_DataSubDir$+"\"
      endif
      CurrDataFile$=CurrDataFile$+_DataFile$
      if ObjHdrText$(Chromreg[1], "RawDataFile") <> CurrDataFile$
         iii=alert(ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DATAFILE_OF_TH_38),3,Alert3Title$)
         return
      endif
   endif
endif

!CASD_CheckAcqSignalDesc  test consitency

GuiCalibUIEvaluate   "RecalibrateDialog"

!clear possible recalibration report processing DONE state
GUIStartDAProgressDisplay "RESET"

if DataOrigin$ = "FILE"
   Clearwin 38
   !but leave data for print report/preview etc
endif

endmacro


        
!############################################################################
name GuiCalibrationTable
     
!############################################################################

if GuiCheckForCalibTable() = 0
   return
endif
              
Evaluate "CpRequest "+CpName$(0)+",""GuiCalibUIEvaluate """"EditCalTab"""""""

endmacro






    
!############################################################################
name GuiDemoSystemDiagram

parameter  RegPrefix$  default "DEMO"  ! "DEMO" can be used to switch demo to DEMOxxx regs
!############################################################################

if check ( macro, GuiDemoSystemDiagramCode ) = 0
   GUIProductMacDemandLoading  "SystGuiD.mac"
endif
if check ( macro, GuiDemoSystemDiagramCode ) = 1
   GuiDemoSystemDiagramCode  RegPrefix$
endif

endmacro 






!############################################################################
name GUIDeleteSamplingSubGom

!############################################################################

local SamplingGomIni$

!delete old GOM since a new MODE has a new picture 
      
!delete possible SequenceSampleGOM
SamplingGomIni$=GUIBuildSequenceSamplingINI$()
if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 1
   GomDelete  GUISamplingDiagGOM$,SamplingGomIni$
endif   
      
!delete possible SingleSampleGOM
SamplingGomIni$=GUIBuildSingleSampleINI$()
if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 1
   GomDelete  GUISamplingDiagGOM$,SamplingGomIni$
endif   
      
endmacro


!############################################################################
name GUISamplingAreaReconfiguration

parameter  RequestedNewMode$ default ""  !means reinstall last one used   
parameter  TrayChanged       default 0   !0 means no tray change, 1 when tray changed (Gui hotlink dll)
parameter  FiaMode           default -1  !0 means no change, 0 means turn back to no FIA display
                                         !1 means turn to FIA display

!callback from leo hotlink filter for ALS driver noticing Tray has changed
!
!checks for everything : SamplingMode, new tray type
!when  Tray has changed throw away old tray picture 
!only build new one if system diagram is on
!
!set hotlinks at all times so it is correct when next switchview comes on
!or when Sysdigram is built anew by GUIShowSystemDiagramCode
!
!or when a Mode switch is requested from Toolbar , here give name for new mode
!SingleSample, or Sequence, or Reprocess
!relies on the contents of   TabHdrText$(_config[1],CurrentViewTable$,"SamplingMode")
!to tell about last mode so no unneccessary rebuilds are done
!############################################################################

local SamplingGomIni$
local CurrentViewTable$                                                                                              
local TrayConfigGomIni$                      
local bNeedToRebuild
                                                                                              
!first find out if in Seq MODE
                          
CurrentViewTable$=TabHdrText$(_config[1], "Window", "CurrentView")
if CurrentViewTable$ = "" 
   CurrentViewTable$="TOP"
endif
CurrentViewTable$="View_"+CurrentViewTable$

if TrayChanged = 1
   !only this case came from GUI Hotlink 
   if RegSize(GUI) > 0
      !clear hotlink infos so UserInterface is not crooked
      !hotlink Dll will set new values after this mac has terminated
      SetObjHdrText  GUI, SeqTray1, ""
      SetObjHdrText  GUI, SeqTray2, ""
      SetObjHdrText  GUI, SeqTray3, ""
   endif
   if Dev1050Sampler = 1
      !since here might jump even to a different Sequence ini file
      SamplingGomIni$="lSequenw"
      if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 1
         GomDelete  GUISamplingDiagGOM$,SamplingGomIni$
      endif   
      SamplingGomIni$="lSequewl"
      if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 1
         GomDelete  GUISamplingDiagGOM$,SamplingGomIni$
      endif   
   endif
endif

!consider startup missing items
if RequestedNewMode$ = ""
   if ObjHdrType(_config[1],CurrentViewTable$) = 4
      if TabHdrType(_config[1],CurrentViewTable$,"CurrentTask") = 99
         SetTabHdrText  _config[1],CurrentViewTable$,"CurrentTask","TOPRUN"
      endif                        
      !anton sets this info before calling here
      RequestedNewMode$=TabHdrText$(_config[1],CurrentViewTable$,"CurrentTask")
   endif               
endif

RequestedNewMode$=CorrectCaseOfMode$(RequestedNewMode$)

if FiaMode = -1
   if check ( VARIABLE, _FIAON ) = 1
      if _FIAON = 1
         FiaMode=1
      else
         FiaMode=0
      endif
   else
      FiaMode=0
   endif
endif


if RequestedNewMode$ = "TOPRUN"  OR  RequestedNewMode$ = "TOPSEQ" 
   bNeedToRebuild=0

   !only do any destroying and building if System Diagram is there at all
   if GomExist( , GUISamplingDiagGOM$) = 1
      !! 
      !Sampling Area GUI GOM is visible
   
      if RequestedNewMode$="TOPRUN" 
         SamplingGomIni$=GUIBuildSingleSampleINI$()
         if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 0 
            bNeedToRebuild=1
         endif   
      endif
      if RequestedNewMode$="TOPSEQ" 
         SamplingGomIni$=GUIBuildSequenceSamplingINI$()
         if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 0
            bNeedToRebuild=1
         endif   
      endif
    

      if bNeedToRebuild = 1
         !!
         !new MODE is requested
         !delete old GOM since a new MODE has a new picture 
         
         GUIDeleteSamplingSubGom
         !!
      else
         !!
         !new and old MODE is same 
         !test if it is Sequence because then just tray might have changed
         if RequestedNewMode$ = "TOPSEQ"
            SamplingGomIni$=GUIBuildSequenceSamplingINI$()
            TrayConfigGomIni$=GUIBuildSamplingTrayINI$()
            if GUILastSequenceTrayGOM$ <> TrayConfigGomIni$
               !new tray type in ALS now, must delete old GOM
               if GUILastSequenceTrayGOM$ <> ""  \
                  AND  GomExist(GUISamplingDiagGOM$+"|"+SamplingGomIni$,GUILastSequenceTrayGOM$) = 1
                  GomDelete  GUISamplingDiagGOM$+"|"+SamplingGomIni$,GUILastSequenceTrayGOM$
               endif
            endif
         else
         if RequestedNewMode$ = "TOPRUN"
            if FiaMode = 1
               !here FIA comes in
               SamplingGomIni$=GUIBuildSingleSampleINI$()
               if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 1
                  GomDelete GUISamplingDiagGOM$,SamplingGomIni$
               endif   
            endif
         endif
         endif
         !!
      endif
   
      !only rebuild if Gom for this is not there 
      !covers also the case staying in Sequence MODE but the tray has changed
      !another special thing is FIA, is done externally but is under TOPRUN mode !
      if FiaMode = 0  OR  RequestedNewMode$ = "TOPSEQ"
         ! this is standard case for no FIA
         SamplingGomIni$=GUISamplingGomNameForMode$(RequestedNewMode$)
         if GomExist(GUISamplingDiagGOM$,SamplingGomIni$) = 0
            GOMShowGUI GUISamplingDiagGOM$, SamplingGomIni$ ,  "DRIVERS" 
         endif   
      endif   

      if RequestedNewMode$ = "TOPSEQ"
         !need to build sub goms
         TrayConfigGomIni$=GUIBuildSamplingTrayINI$()
         if GomExist(GUISamplingDiagGOM$+"|"+SamplingGomIni$,TrayConfigGomIni$) = 0
            GOMShowGUI GUISamplingDiagGOM$+"|"+SamplingGomIni$, TrayConfigGomIni$ ,  "DRIVERS" 
         endif
      endif
 
      !!
   endif   

   !successfully rebuilt (or had nothing to do since no picture there), 
   !store info now

   !redo sequence hotlinks if necessary
   if RequestedNewMode$ = "TOPSEQ"              !case sensitive compare
      !check if something changed in seq tray mode
      if GUILastSequenceTrayGOM$ <> SamplingGomIni$
         !need to redo hotlinks since tray has changed
    
         !GUILastSequenceTrayGOM$ set to new value after setting new hotlinks 
         GUIInstallSequenceHotlinks
      endif
      GuiSeqRunMode=1  !let LeoGui hotlink know in order to gray start stop correctly
   else      
      GuiSeqRunMode=0
   endif                
else   
   !its for other hooks
   !close whatever I had here because others don't know what I used here
   GUIDeleteSamplingSubGom
   GuiSeqRunMode=0
endif

!let other hook process also for closing
GuiExecHook  "GuiSampleTask" , RequestedNewMode$ +","+val$(TrayChanged) +","+val$(FiaMode)

!so this is in place also for addon sampling areas    
GUICheckFreeDiskSpace  !so init values are right, not after 15 min 1. polling
    
!??also do here since FIA changes come here directly ??
ExecHook "GuiMethSampLnks"  !do early since goes to a highly visible border


GUIStartDAProgressDisplay "RESET"

endmacro
    
    
    
!############################################################################
name GUIShowSamplingDiagramCode

parameter  RequestedTaskMode$ default ""  !means reinstall last one used
                                         !find out from view tbl hdr CurrentTask
                                         !values: TOPSEQ, TOPRUN
parameter  ShowType   default  0  ! 0 is show in switch view (test if applicable)
                                  ! 1 create and show , 2 destroy (does not remove sidebar), 
                                  ! 3 toggle (does create/remove sidebar),
                                  ! 4 show only in new mode if already there or 
                                  ! saved in view as to be there,
                                  ! 5 is close in CloseView macro (remove sidebar)
                                  ! 6 destroy (removes sidebar)
                                  
!setting via CP variable  GUISampleAreaStateForMenu
!############################################################################

local CurrentViewTable$                                                                                              
local bRedoSamplingArea
local OrigShowType                                                                                              

OrigShowType=ShowType

CurrentViewTable$=TabHdrText$(_config[1], "Window", "CurrentView")
if CurrentViewTable$ = "" 
   CurrentViewTable$="TOP"
endif
CurrentViewTable$="View_"+CurrentViewTable$

if ShowType = 4
   !look into  current view table hdr item SampleAreaOn
   if TabHdrVal(_config[1],CurrentViewTable$,"SampleAreaOn") = 1
      ShowType=0
   else
      ShowType=6
   endif
endif                       

if ShowType = 5
   ShowType=6
endif          

if ShowType = 0                                       
   if DevLeoAls+Dev1090Inject+Dev1050Sampler+DevHPCE = 0
   !if DevLeoAls = 0
      !in this case the diagram does not make sense in the view
      GUISampleAreaStateForMenu=1  !enabled and unchecked
      return 
   endif     
endif   

bRedoSamplingArea=1

if GomExist( , GUISamplingDiagGOM$) = 1
   if ShowType = 6 OR ShowType = 3
      GUISampleAreaStateForMenu=1  !enabled and unchecked
      GomDelete , GUISamplingDiagGOM$
      if OrigShowType <> 5
         !not in close view macro
         SetTabHdrVal  _config[1],CurrentViewTable$,"SampleAreaOn",0
      endif   
      bRedoSamplingArea=0         
   else   
   if ShowType = 2
      GUISampleAreaStateForMenu=1+2  !enabled and checked
      GUIDeleteSamplingSubGom
      bRedoSamplingArea=0
   endif                       
   endif                       
else
   if ShowType = 2 OR ShowType = 6 
      GUISampleAreaStateForMenu=1  !enabled and unchecked
      bRedoSamplingArea=0
   endif                       
endif   

if bRedoSamplingArea = 1
   !show it
   if RequestedTaskMode$ = ""
      !anton sets this info before calling here
      RequestedTaskMode$=View_CurrentTaskName$()
   endif

   !RequestedTaskMode$=CorrectCaseOfMode$(RequestedTaskMode$)

   !if RequestedTaskMode$ <> "UNKNOWN"
      !consider startup missing items
      GUISampleAreaStateForMenu=1+2  !enabled and checked

      if GomExist( , GUISamplingDiagGOM$) = 0
         GomShowGui , GUISamplingDiagGOM$, "DRIVERS"
      endif   

      if OrigShowType <> 5
         !not in close view macro
         SetTabHdrVal  _config[1],CurrentViewTable$,"SampleAreaOn",1
      endif   
      GUISamplingAreaReconfiguration  RequestedTaskMode$
      
   !!else let other hook process this   
   !endif

endif

ExecHook "GuiMethSampLnks"  !do early since goes to a highly visible border


endmacro
    
     
    
    
!############################################################################
name GUIDiagSwitchViewPreMac


!is an empty macro will be overloaded for each product type
!installs the menus for the GUI with the given names
!the problem is that the GUI windows are closed by GOM on view switch
!without letting outside macros world know (so checkmarks stay)
!this macro comes definitely as part of the PreView Macro which is after the 
!GUI window is destroyed
!############################################################################

if (Mrc_IsRcNetUi() = 0)

  if GomExist( , GUISystemDiagGOM$) = 1
    GUIDiagramStateForMenu=1+2  !enabled plus checked
  else
    GUIDiagramStateForMenu=1  !enabled and unchecked
  endif

  GuiUserCalledNrdyInfo$="" !clear bubble selection

endif

endmacro
    
    
   
    
!############################################################################
name GuiAlsRunModeInfo$

!explain the offline gray state for online module
!############################################################################

local   MessageText$   
local   iii
local   iSeqLine

local ID_ASTXDRIVERSMACFILES_SEQUENCE_PARAM_39
local ID_ASTXDRIVERSMACFILES_DATA_ACQUISITI_40
local ID_ASTXDRIVERSMACFILES_NO_RUN_IS_SETU_41
local ID_ASTXDRIVERSMACFILES_BLANK_RUN_IS_S_42
local ID_ASTXDRIVERSMACFILES_NO_RUN_IS_SETU_43
local ID_ASTXDRIVERSMACFILES_BLANK_RUN_IS_S_44
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_SEQUENCE_PARAM_39           =  17039  
ID_ASTXDRIVERSMACFILES_DATA_ACQUISITI_40           =  17040  
ID_ASTXDRIVERSMACFILES_NO_RUN_IS_SETU_41           =  17041  
ID_ASTXDRIVERSMACFILES_BLANK_RUN_IS_S_42           =  17042  
ID_ASTXDRIVERSMACFILES_NO_RUN_IS_SETU_43           =  17043  
ID_ASTXDRIVERSMACFILES_BLANK_RUN_IS_S_44           =  17044  
NLSFileName_astxmac$= "astxmac"

MessageText$=""


iii=ObjHdrVal(LeoAlsStatus1,"RunState")
if iii > 1
   !is online
   if GuiSeqRunMode = 1  AND  TabHdrVal(_sequence, "SeqParm" , "SeqMode") > 1
      MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SEQUENCE_PARAM_39)
   else
      if RUN_ACQ = 0
         MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_DATA_ACQUISITI_40)
      else
         !here it still can be blank RUN
         if GuiSeqRunMode = 1
            if _SeqCurrLine1 < 1
               iSeqLine=1
            else
               iSeqLine=_SeqCurrLine1
            endif
            if TabHdrVal(_sequence,"SeqTable1","NumberOfRows") < iSeqLine
               MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_RUN_IS_SETU_41)
            else
               if TabHdrVal(_sequence,"SeqTable1","NumberOfRows") >= iSeqLine  \
                  AND TabVal(_sequence,"SeqTable1",iSeqLine,"Vial") = -1
                  MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BLANK_RUN_IS_S_42)
               else   
                  MessageText$=""
                  if check ( VARIABLE, _FIAON ) = 1
                     if _FIAON = 1  AND  TabHdrVal(FIAREG,"FIATABLE","NumberOfRows") < 1
                        MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_RUN_IS_SETU_43)
                     endif
                  endif
               endif
            endif
         else
            if _ALSBOTTLE1 = -1
               MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BLANK_RUN_IS_S_44)
            else
               MessageText$=""
               if check ( VARIABLE, _FIAON ) = 1
                  if _FIAON = 1  AND  TabHdrVal(FIAREG,"FIATABLE","NumberOfRows") < 1
                     MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_RUN_IS_SETU_43)
                  endif
               endif
            endif
         endif
      endif
   endif            
endif

return  MessageText$

endmacro
    
   
    
!############################################################################
name GuiShowModuleNrdyInfo

parameter   ModuleName$    default ""      !  LINJ LPUMP LTHM1 LTHM2 
                                           !  MTH DA GLP
                                           !  Detector symbolic names are in 
                                           !  GuiDetecotors Hook table :
                                           !  already used are: LDAD1 LDAD2 LMWD1 LMWD2 LVWD1 LVWD2 LVWD3 LVWD4 
parameter   ModuleNumber   default 1
!############################################################################

local   InfoType$
local   MessageText$   
local   HelpNumber     
local   RegName$           
local   iii
local   iSeqLine
local   iDetNumber
local   ii

local ID_ASTXDRIVERSMACFILES_ERROR_NOT_SPEC_45
local ID_ASTXDRIVERSMACFILES_NOT_READY_COND_46
local ID_ASTXDRIVERSMACFILES_NO_ERRORS_305
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_ERROR_NOT_SPEC_45           =  17045  
ID_ASTXDRIVERSMACFILES_NOT_READY_COND_46           =  17046  
ID_ASTXDRIVERSMACFILES_NO_ERRORS_305               =  17305

NLSFileName_astxmac$= "astxmac"
RegName$=""
if ModuleName$= "LINJ" 
   RegName$="LeoAlsStatus"+val$(ModuleNumber)
else
if ModuleName$= "LPUMP" 
   RegName$="LeoPumpStatus"+val$(ModuleNumber)  
else
if ModuleName$= "LTHM" 
   RegName$="LeoThermostatStatus"+val$(ModuleNumber)  
   ModuleName$=ModuleName$+val$(ModuleNumber)
else
if ModuleName$= "LCLC" 
   RegName$="LeoChipCubeStatus"+val$(ModuleNumber)  
   ModuleName$=ModuleName$+val$(ModuleNumber)
else
if ModuleName$= "LAFC" 
   ! check AFC Status register for appropriate module
   For ii=1 To DevLeoAfc
       RegName$="LeoAfcStatus"+val$(ii)  
       evaluate "iii=ObjHdrVal("+RegName$+",NRDYState)"
       If iii = 1
          ModuleNumber = ii
       EndIf
   Next ii
   For ii=1 To DevLeoAfc
       RegName$="LeoAfcStatus"+val$(ii)  
       evaluate "iii=ObjHdrVal("+RegName$+",ErrorState)"
       If iii = 1
          ModuleNumber = ii
       EndIf
   Next ii

   RegName$="LeoAfcStatus"+val$(ModuleNumber)  
else
   ModuleName$=ModuleName$+val$(ModuleNumber)
   iDetNumber=GuiFindDetHookSymbolicName(ModuleName$)
   if iDetNumber > -1
      RegName$=TabText$ (Hook[1],"GuiDetectors",iDetNumber,"StatusRegName")
   endif   
endif
endif
endif
endif
endif



if RegName$ <> "" 
   MessageText$=""
   evaluate "iii=ObjHdrVal("+RegName$+",RunState)"
   !iii=2 powerfail  modules give text now
   evaluate "iii=ObjHdrVal("+RegName$+",ErrorState)"
   if iii = 1
      InfoType$="ERROR"
      evaluate "MessageText$=ObjHdrText$("+RegName$+",ErrorTextLong)" 
      if MessageText$=""
         evaluate "MessageText$=ObjHdrText$("+RegName$+",ErrorTextShort)" 
      endif
      if MessageText$=""
         MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ERROR_NOT_SPEC_45)
      endif
      evaluate "HelpNumber=ObjHdrVal("+RegName$+",ErrorHelpNr)"
   else
      evaluate "iii=ObjHdrVal("+RegName$+",NRDYState)"
      if iii = 1
         InfoType$="WARNING"
         evaluate "MessageText$=ObjHdrText$("+RegName$+",NRDYTextLong)" 
         if MessageText$=""
            evaluate "MessageText$=ObjHdrText$("+RegName$+",NRDYTextShort)" 
         endif
         if MessageText$=""
            MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NOT_READY_COND_46)
         endif
         evaluate "HelpNumber=ObjHdrVal("+RegName$+",NRDYHelpNr)"
      else                
         InfoType$="INFO" 
         HelpNumber=0
         MessageText$=""
         if ModuleName$= "LINJ" 
            !explain the offline gray state for online module
            MessageText$=GuiAlsRunModeInfo$()
         endif   
         if MessageText$ = ""
            MessageText$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NO_ERRORS_305)
         endif
      endif  
   endif  
   if MessageText$<> ""
      GuiUserCalledNrdyInfo$=ModuleName$
      GUIShowBubbleMessage  InfoType$, ModuleName$, MessageText$, HelpNumber
   endif
endif

endmacro
    
   
   
    
!############################################################################
name GuiCloseModuleNrdyInfoBubble

parameter   SubGomName$   
!############################################################################

GuiUserCalledNrdyInfo$=""
GomDelete GUISystemDiagGOM$, SubGomName$
    
endmacro
    
   
!GUIShowBubbleMessage "ERROR", "LAFC", "Hallo"    
!############################################################################
name GUIShowBubbleMessage

parameter   InfoType$      default "LAST"  !  ERROR  WARNING  WAITING  INFO  NONE  LAST
parameter   ModuleName$    default ""      !  LINJ LPUMP LTHM1 LTHM2 
                                           !  MTH DA GLP
                                           !  Detector symbolic names are in 
                                           !  GuiDetecotors Hook table :
                                           !  already used are: LDAD1 LDAD2 LMWD1 LMWD2 LVWD1 LVWD2 LVWD3 LVWD4 
parameter   MessageText$   default ""
parameter   HelpNumber     default  0

!callback from GUI hotlinks filter DLL in case an error has occured
!############################################################################

local  NdrName$
local  iii,icnt,xloc
local  iType                     
local  a$,b$
local  InfoGomName$
local  iDetectorNumber 
local  TextTool1$, TextTool2$, TextTool3$

local  errorvar



if GomExist( ,GUISystemDiagGOM$ ) = 1   
   InfoGomName$=""
   if InfoType$ = "LAST"
      InfoType$=   ObjHdrText$(Gui,"ModMsgType")
      ModuleName$= ObjHdrText$(Gui,"ModMsgModName")
      MessageText$=ObjHdrText$(Gui,"ModMsgText")
      HelpNumber=  ObjHdrVal  (Gui,"ModMsgHelpNo")
   else                         
      if 1=0
         !keep info for later reuse ; not needed
         SetObjHdrText  Gui,"ModMsgType",InfoType$
         SetObjHdrText  Gui,"ModMsgModName",ModuleName$
         SetObjHdrText  Gui,"ModMsgText",MessageText$
         SetObjHdrVal   Gui,"ModMsgHelpNo",HelpNumber
      endif
   endif
   if ModuleName$ = "LINJ"
      if InfoType$ = "NONE"  OR InfoType$ = "INFO"
         !no errors so explain the offline gray state for online module
         MessageText$=GuiAlsRunModeInfo$()
         if MessageText$ <> ""
            InfoType$="INFO" 
            HelpNumber=0   
         else   
            InfoType$ = "NONE"
         endif
      endif   
   endif
   if InfoType$ <> "NONE"  
      if ModuleName$ = "LINJ"  OR  ModuleName$ = "LPUMP"  \
         OR  ModuleName$ = "LTHM1" OR  ModuleName$ = "LTHM2" \
         OR  ModuleName$ = "LCLC1" \
         OR  ModuleName$ = "MTH"
         InfoGomName$="lsysinf1"
      else
      if ModuleName$ = "DA"  OR  ModuleName$ = "GLP"
         InfoGomName$="lsysinf3"
      else
      if ModuleName$ = "LAFC"
         InfoGomName$="lsysinf2"
      else   
         iDetectorNumber=GuiFindDetHookSymbolicName(ModuleName$)
         if iDetectorNumber > -1
            ModuleName$="DET"+val$(iDetectorNumber)
            InfoGomName$="lsysinf2"
         else
            InfoGomName$=""  
         endif
      endif                     
      endif
      endif                     
      if InfoGomName$ <> ""                    
         !delete other info GOM 

         on error   errorvar=1  !so in case multi CP yield between GomExist and SomShowGui
      
         if GomExist( GUISystemDiagGOM$, InfoGomName$ ) = 0
            !it's one or the other
            if GomExist( GUISystemDiagGOM$, "lsysinf1" ) = 1
               GomDelete GUISystemDiagGOM$, "lsysinf1"
            endif   
            if GomExist( GUISystemDiagGOM$, "lsysinf2" ) = 1
               GomDelete GUISystemDiagGOM$, "lsysinf2"
            endif   
            if GomExist( GUISystemDiagGOM$, "lsysinf3" ) = 1
               GomDelete GUISystemDiagGOM$, "lsysinf3"
            endif   
         endif   
     
         if GomExist( GUISystemDiagGOM$, InfoGomName$ ) = 0
            GomShowGui GUISystemDiagGOM$, InfoGomName$ , "DRIVERS"
         endif
         if HelpNumber <> 0
            GomSetVal  GUISystemDiagGOM$, InfoGomName$, "Help", "Enable", 1 !disabled
            GomSetText GUISystemDiagGOM$, InfoGomName$, "Help", "Command",   \
                                                  "Help.topic "+sprintf$(HelpNumber, "%ld") 
         else
            !move out very early
            GomSetVal  GUISystemDiagGOM$, InfoGomName$, "Help", "Enable", 0 !disabled
         endif                                         
         GomSetText GUISystemDiagGOM$, InfoGomName$, "BubbleMessage", "elements", \
                                                           ModuleName$+"|"+InfoType$
         !go by approximate str len of MessageText$ which text field to use
         !move others out of sight
         icnt=Len(MessageText$)
         if icnt < 20
            TextTool1$="MessageTextS"
            TextTool2$="MessageTextM"
            TextTool3$="MessageTextL"
         else
         if icnt < 35
            TextTool1$="MessageTextM"
            TextTool2$="MessageTextS"            
            TextTool3$="MessageTextL"
         else
            TextTool1$="MessageTextL"
            TextTool2$="MessageTextM"
            TextTool3$="MessageTextS"
         endif                                                  
         endif                                                  
         xloc=GomVal(  GUISystemDiagGOM$, InfoGomName$, TextTool1$, "X")
         if xloc = 1000
            xloc=GomVal(  GUISystemDiagGOM$, InfoGomName$, TextTool2$, "X")
            if xloc = 1000
               xloc=GomVal(  GUISystemDiagGOM$, InfoGomName$, TextTool3$, "X")
            endif
         endif
         GomSetVal  GUISystemDiagGOM$, InfoGomName$, TextTool1$, "X", xloc
         GomSetVal  GUISystemDiagGOM$, InfoGomName$, TextTool2$, "X", 1000
         GomSetVal  GUISystemDiagGOM$, InfoGomName$, TextTool3$, "X", 1000
         GomSetText GUISystemDiagGOM$, InfoGomName$, TextTool1$, "TextColor", \
                                                           InfoType$+"TextColor"
         GomSetText GUISystemDiagGOM$, InfoGomName$, TextTool1$, "BKColor",   \
                                                           InfoType$+"BKColor"
         GomSetText GUISystemDiagGOM$, InfoGomName$, TextTool1$, "text1", MessageText$ 

         on error   
      
      endif
   else   
      if GomExist( GUISystemDiagGOM$, "lsysinf1" ) = 1
         GomDelete GUISystemDiagGOM$, "lsysinf1"
      endif   
      if GomExist( GUISystemDiagGOM$, "lsysinf2" ) = 1
         GomDelete GUISystemDiagGOM$, "lsysinf2"
      endif   
      if GomExist( GUISystemDiagGOM$, "lsysinf3" ) = 1
         GomDelete GUISystemDiagGOM$, "lsysinf3"
      endif   
      !clear last info 
      SetObjHdrText  Gui,"ModMsgType","NONE"
      SetObjHdrText  Gui,"ModMsgModName",""
      SetObjHdrText  Gui,"ModMsgText",""
      SetObjHdrVal   Gui,"ModMsgHelpNo",0
      !GuiUserCalledNrdyInfo$=""   !to clear setting for this module only in hotlink DLL
   endif   
endif

endmacro


   
   



!-------------------------------------------------------------------------------
!
! Extensions for Fraction Collector (rl)
!
!-------------------------------------------------------------------------------

!-------------------------------------------------------------------------------
Name AfcGuiGetLoc$

	local sLoc$
    local sAfcName$
    local dNum


    dNum = ObjHdrVal (LeoAfcStatus1[1], "Act_Frac")

    If (dNum <= 0) Or (dNum > DevLeoAfc)
        dNum = 1
    EndIf

    sAfcName$ = sprintf$(dNum, "LEOAFCSTATUS%1d[1]")
    Evaluate ("sLoc$ = ObjHdrText$(" + sAfcName$ + ", ""ACT_APOS"" )")

	return sLoc$

EndMacro


Name AfcGuiOffline
	SetObjHdrText GUI, "leoafcstatus", "offline|" + AfcGuiGetLoc$() + "| "
EndMacro

Name AfcGuiReady
	SetObjHdrText GUI, "leoafcstatus", "ready|" + AfcGuiGetLoc$()	+ "| "
EndMacro

Name AfcGuiError
	SetObjHdrText GUI, "leoafcstatus", "error|" + AfcGuiGetLoc$() + "| "
EndMacro

Name AfcGuiPowerOn
	SetObjHdrText GUI, "leoafcstatus", "poweron|" + AfcGuiGetLoc$() +"| "
EndMacro

Name AfcGuiRunning

  local Module
  local sNewPos$
  local sCollectMode$
  local Collecting
  local CollectModeOn
  local Ret$
  local Mode

  local ID_ASTXDRIVERSMACFILES_OFF_47
  local ID_ASTXDRIVERSMACFILES_TIME_48
  local ID_ASTXDRIVERSMACFILES_VOL_49
  local ID_ASTXDRIVERSMACFILES_PEAK_50
  local NLSFileName_astxmac$

  ID_ASTXDRIVERSMACFILES_OFF_47                      =  17047  
  ID_ASTXDRIVERSMACFILES_TIME_48                     =  17048  
  ID_ASTXDRIVERSMACFILES_VOL_49                      =  17049  
  ID_ASTXDRIVERSMACFILES_PEAK_50                     =  17050  
  NLSFileName_astxmac$= "astxmac"
  
    sNewPos$ = AfcGuiGetLoc$()

		sCollectMode$ = ""
		CollectModeOn = 0
    
    If sActPictPos$ <> sNewPos$
        sActPictPos$ = sNewPos$
        dAfcPictRun = dAfcPictRun + 1
        If dAfcPictRun > 3
            dAfcPictRun = 0
        EndIf
    EndIf
    
    For Module=1 To DevLeoAfc
      Evaluate "Collecting = ObjHdrVal(LEOAFCSTATUS"+Val$(Module)+"[1], ""COLLECTING"" )"
      If (Collecting = 1)	Then
        CollectModeOn = 1
!ACT_TMOD2 beg
        Evaluate "Mode = ObjHdrVal(LEOAFCSTATUS"+Val$(Module)+"[1], ""ACT_TMOD2"" )"
!        Evaluate "Ret$ = SendModule$(LAFC"+Val$(Module)+", ""ACT:TMOD?"" )"
!        If (Ret$[1:2] = "RA")	Then
!          Mode = Val(Ret$[18])
          If Mode = 0 Then
          	sCollectMode$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OFF_47)
          EndIf
          If Mode = 1 Then
          	sCollectMode$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TIME_48)
          EndIf
          If Mode = 2 Then
          	sCollectMode$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_TIME_48)
          EndIf
          If Mode = 3 Then
          	sCollectMode$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_VOL_49)
          EndIf
          If Mode = 4 Then
          	sCollectMode$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PEAK_50)
          EndIf
!        Else
!          sCollectMode$ = "???"
!        EndIf
!ACT_TMOD2 end
        Module = DevLeoAfc
      EndIf
    Next Module

    If CollectModeOn = 0 Then
			sCollectMode$ = " "
		EndIf

    sNewPos$ = sNewPos$ + "|"

    If dAfcPictRun = 0
    	SetObjHdrText GUI, "leoafcstatus", "run|" + sNewPos$ + sCollectMode$
    EndIf
    If dAfcPictRun = 1
    	SetObjHdrText GUI, "leoafcstatus", "run1|" + sNewPos$ + sCollectMode$
    EndIf
    If dAfcPictRun = 2
    	SetObjHdrText GUI, "leoafcstatus", "run2|" + sNewPos$ + sCollectMode$
    EndIf
    If dAfcPictRun = 3
    	SetObjHdrText GUI, "leoafcstatus", "run3|" + sNewPos$ + sCollectMode$
    EndIf


EndMacro



!-------------------------------------------------------------------------------
Name AfcProcessStateEvent

    Parameter	EventCause$
    Parameter	EventLevel$
    Parameter	EventSubjName$
    Parameter	EventObj		DEFAULT 0
    Parameter	EventPartName$		DEFAULT ""
    Parameter	EventIndex		DEFAULT 0

    Local RunState
    Local NRdy
    Local ErrorState

    Local dTotalState ! 1=Red, 2=Yellow, 3=blue, 4=green, 5=grey
    Local dState
    Local i
    Local sAfcName$

    dTotalState = 5

    GuiAFCNrdyInfoMenu = 0

    For i=1 To DevLeoAfc

        sAfcName$ = sprintf$(i, "LEOAFCSTATUS%1d[1]");
        Evaluate ("RunState = ObjHdrVal(" + sAfcName$ + ", ""RunState"" )")
        Evaluate ("NRdy = ObjHdrVal(" + sAfcName$ + ", ""NRdyState"" )")
        Evaluate ("ErrorState = ObjHdrVal(" + sAfcName$ + ", ""ErrorState"" )")

        dState = 5
        If ErrorState = 1
            dState = 1
        Else
        	If NRdy = 1
                If RunState = 1
                    dState = 5
                Else
                    dState = 2
                EndIf
            Else

                !Run status:
                !1 = offline	7 = postrun	
                !2 = power off	8 = run
                !3 = power on	9 = injecting
                !4 = standby	10 = break
                !5 = prerun	11 = initializing
                !6 = preparing	12 = waiting
                If RunState = 1
                    dState = 5
                EndIf
                If RunState = 2
                    dState = 5
                EndIf
                If RunState = 3
                    dState = 2
                EndIf
                If RunState = 5
                    dState = 4
                EndIf
                If RunState = 6
                    dState = 4
                EndIf
                If RunState = 7
                    dState = 3
                EndIf
                If RunState = 8
                    dState = 3
                EndIf
                If RunState = 12
                    dState = 4
                EndIf
            EndIf
        EndIf

        If dState < dTotalState
            dTotalState = dState
        EndIf
    
    Next i

    If dTotalState = 1
        GuiAFCNrdyInfoMenu = 1
        AfcGuiError
        GuiShowModuleNrdyInfo "LAFC"
    EndIf
    If dTotalState = 2
        GuiAFCNrdyInfoMenu = 1
        AfcGuiPowerOn
    EndIf
    If dTotalState = 3
        If GuiUserCalledNrdyInfo$ = "LAFC"
            GuiCloseModuleNrdyInfoBubble "lsysinf2"
        EndIf
        AfcGuiRunning
    EndIf
    If dTotalState = 4
        If GuiUserCalledNrdyInfo$ = "LAFC"
            GuiCloseModuleNrdyInfoBubble "lsysinf2"
        EndIf
        AfcGuiReady
    EndIf
    If dTotalState = 5
        If GuiUserCalledNrdyInfo$ = "LAFC"
            GuiCloseModuleNrdyInfoBubble "lsysinf2"
        EndIf
        AfcGuiOffline
    EndIf




EndMacro


!-------------------------------------------------------------------------------
Name AfcGuiInit

	On error print

    GuiAFCNrdyInfoMenu = 0

    dAfcPictRun = 0
    sActPictPos$ = ""

    If DevLeoAfc > 0

    	NewObjHdrText GUI, "leoafcstatus"
    	GomSetToolEvent "LSysCont", "afraco", "pict", "Elements", GUI, "leoafcstatus"

        ! connecting to status of leoafc

        CpRequest CPGUI, "OnEvent ""LeoAfcStatus1[1].RunState"", ""AfcProcessStateEvent"" "
        CpRequest CPGUI, "OnEvent ""LeoAfcStatus1[1].NRdyState"", ""AfcProcessStateEvent"" "
        CpRequest CPGUI, "OnEvent ""LeoAfcStatus1[1].ErrorState"", ""AfcProcessStateEvent"" "
        !CpRequest CPGUI, "OnEvent ""LeoAfcStatus1[1].Act_Apos"", ""AfcProcessStateEvent"" "
        CpRequest CPGUI, "OnEvent ""LeoAfcStatus1[1].COLLECTING"", ""AfcProcessStateEvent"" "
!ACT_TMOD2
        CpRequest CPGUI, "OnEvent ""LeoAfcStatus1[1].ACT_TMOD2"", ""AfcProcessStateEvent"" "

        If DevLeoAfc > 1
            CpRequest CPGUI, "OnEvent ""LeoAfcStatus2[1].RunState"", ""AfcProcessStateEvent"" "
            CpRequest CPGUI, "OnEvent ""LeoAfcStatus2[1].NRdyState"", ""AfcProcessStateEvent"" "
            CpRequest CPGUI, "OnEvent ""LeoAfcStatus2[1].ErrorState"", ""AfcProcessStateEvent"" "
            !CpRequest CPGUI, "OnEvent ""LeoAfcStatus2[1].Act_Apos"", ""AfcProcessStateEvent"" "
            CpRequest CPGUI, "OnEvent ""LeoAfcStatus2[1].COLLECTING"", ""AfcProcessStateEvent"" "
!ACT_TMOD2
            CpRequest CPGUI, "OnEvent ""LeoAfcStatus2[1].ACT_TMOD2"", ""AfcProcessStateEvent"" "

            If DevLeoAfc > 2
                CpRequest CPGUI, "OnEvent ""LeoAfcStatus3[1].RunState"", ""AfcProcessStateEvent"" "
                CpRequest CPGUI, "OnEvent ""LeoAfcStatus3[1].NRdyState"", ""AfcProcessStateEvent"" "
                CpRequest CPGUI, "OnEvent ""LeoAfcStatus3[1].ErrorState"", ""AfcProcessStateEvent"" "
                !CpRequest CPGUI, "OnEvent ""LeoAfcStatus3[1].Act_Apos"", ""AfcProcessStateEvent"" "
                CpRequest CPGUI, "OnEvent ""LeoAfcStatus3[1].COLLECTING"", ""AfcProcessStateEvent"" "
!ACT_TMOD2
                CpRequest CPGUI, "OnEvent ""LeoAfcStatus3[1].ACT_TMOD2"", ""AfcProcessStateEvent"" "

								If DevLeoAfc > 3
								    CpRequest CPGUI, "OnEvent ""LeoAfcStatus4[1].RunState"", ""AfcProcessStateEvent"" "
								    CpRequest CPGUI, "OnEvent ""LeoAfcStatus4[1].NRdyState"", ""AfcProcessStateEvent"" "
								    CpRequest CPGUI, "OnEvent ""LeoAfcStatus4[1].ErrorState"", ""AfcProcessStateEvent"" "
								    !CpRequest CPGUI, "OnEvent ""LeoAfcStatus4[1].Act_Apos"", ""AfcProcessStateEvent"" "
								    CpRequest CPGUI, "OnEvent ""LeoAfcStatus4[1].COLLECTING"", ""AfcProcessStateEvent"" "
!ACT_TMOD2
								    CpRequest CPGUI, "OnEvent ""LeoAfcStatus4[1].ACT_TMOD2"", ""AfcProcessStateEvent"" "
								EndIf
            EndIf
        EndIf
    EndIf

    AfcProcessStateEvent "", "", ""

EndMacro




!############################################################################
name InitDebug_systgui

!bootstrap macro        
!it does something only when LeoALS and LeoPump are present
!initialized global vars
!installs the GUI protocol DLL
!preloads all picture DLLs
!installs all GOM hotlinks
!############################################################################




!############################################################################

if Check ( VARIABLE, DacTst ) = 0
   !for debugging under Dactst
   DacTst = 0
endif
if DacTst = 1
   !for dac test debugging
   DevLeoPump=1
   if RegSize(LeoPumpStatus1) < 1
      newobj LeoPumpStatus1,1,0,0
   endif
   if ObjHdrType(LeoPumpStatus1, "PumpType") = 99  
      SetObjHdrVal LeoPumpStatus1, "PumpType",2
   endif   
   if ObjHdrType(LeoPumpStatus1, "RunState") = 99  
      SetObjHdrVal LeoPumpStatus1, "RunState",5   !5= prerun
   endif   
   if ObjHdrType(LeoPumpStatus1, "Pressure_MAX") = 99  
      SetObjHdrVal LeoPumpStatus1, "Pressure_MAX",380
   endif   
   if ObjHdrType(LeoPumpStatus1, "Pressure_MIN") = 99  
      SetObjHdrVal LeoPumpStatus1, "Pressure_MIN",80
   endif   

   DevLeoAls=1
   if RegSize(LeoAlsStatus1) < 1
      newobj LeoAlsStatus1,1,0,0
   endif
   if ObjHdrType(LeoAlsStatus1, "Act_Tray_A") = 99
      SetObjHdrVal LeoAlsStatus1, "Act_Tray_A",100
   endif   
   if ObjHdrType(LeoAlsStatus1, "Act_Tray_B") = 99
      SetObjHdrVal LeoAlsStatus1, "Act_Tray_B",0
   endif   
   if ObjHdrType(LeoAlsStatus1, "PrepProgress") = 99
      SetObjHdrVal LeoAlsStatus1, "PrepProgress",0
   endif   
   if ObjHdrType(LeoAlsStatus1, "Act_Vial") = 99
      setobjhdrval  leoalsstatus1 , "Act_Vial" ,-7
   endif   
   if ObjHdrType(LeoAlsStatus1, "Act_COMMAND") = 99
      setobjhdrText  leoalsstatus1 , "Act_COMMAND" ,"hello"
   endif   
   if ObjHdrType(LeoAlsStatus1, "Act_Volume") = 99
      setobjhdrval  leoalsstatus1 , "Act_Volume" ,-17.6
   endif   
   DevLeoTHM=1
   if DevLeoTHM >= 1
      if RegSize(LeoThermostatStatus1) < 1
         newobj LeoThermostatStatus1,1,0,0
      endif
      !if ObjHdrType(LeoThermostatStatus1, "ThmType") = 99  
      !   SetObjHdrVal LeoThermostatStatus1, "ThmType",1
      !endif   
      if ObjHdrType(LeoThermostatStatus1, "TempDiffLimit") = 99
         setobjhdrval  LeoThermostatStatus1 , "TempDiffLimit" ,1
      endif   
      if ObjHdrType(LeoThermostatStatus1, "LeftTemp") = 99
         setobjhdrval  LeoThermostatStatus1 , "LeftTemp" ,17
      endif   
      if ObjHdrType(LeoThermostatStatus1, "RightTemp") = 99
         setobjhdrval  LeoThermostatStatus1 , "RightTemp" ,20
      endif   
   endif
   DevLeoDAD=1
   if DevLeoDAD = 1
      if RegSize(LeoDadStatus1) < 1
         newobj LeoDadStatus1,1,0,0
      endif
      if ObjHdrType(LeoDadStatus1, "UVLamp") = 99
         setobjhdrval  LeoDadStatus1 , "UVLamp" ,1
      endif   
      if ObjHdrType(LeoDadStatus1, "VisLamp") = 99
         setobjhdrval  LeoDadStatus1 , "VisLamp" ,1
      endif   
   endif
   DevNucDAD=1
   if DevNucDAD = 1
      if RegSize(NucDadStatus1) < 1
         newobj NucDadStatus1,1,0,0
      endif
      if ObjHdrType(NucDadStatus1, "UVLamp") = 99
         setobjhdrval  NucDadStatus1 , "UVLamp" ,1
      endif   
      if ObjHdrType(NucDadStatus1, "VisLamp") = 99
         setobjhdrval  NucDadStatus1 , "VisLamp" ,1
      endif   
   endif
   DevLeoMWD=1
   if DevLeoMWD = 1
      if RegSize(LeoMwdStatus1) < 1
         newobj LeoMwdStatus1,1,0,0
      endif
      if ObjHdrType(LeoMwdStatus1, "UVLamp") = 99
         setobjhdrval  LeoMwdStatus1 , "UVLamp" ,1
      endif   
      if ObjHdrType(LeoMwdStatus1, "VisLamp") = 99
         setobjhdrval  LeoMwdStatus1 , "VisLamp" ,1
      endif   
    EndIf
   DevNucMWD=1
   if DevNucMWD = 1
      if RegSize(NucMwdStatus1) < 1
         newobj NucMwdStatus1,1,0,0
      endif
      if ObjHdrType(NucMwdStatus1, "UVLamp") = 99
         setobjhdrval  NucMwdStatus1 , "UVLamp" ,1
      endif   
      if ObjHdrType(NucMwdStatus1, "VisLamp") = 99
         setobjhdrval  NucMwdStatus1 , "VisLamp" ,1
      endif   
   endif
   DevLeoVWD=1
   if DevLeoVWD = 1
      if RegSize(LeoVwdStatus1) < 1
         newobj LeoVwdStatus1,1,0,0
      endif
      if ObjHdrType(LeoVwdStatus1, "UVLamp") = 99
         setobjhdrval  LeoVwdStatus1 , "UVLamp" ,1
      endif   
   endif
   DevNucVWD=1
   if DevNucVWD = 1
      if RegSize(NucVwdStatus1) < 1
         newobj NucVwdStatus1,1,0,0
      endif
      if ObjHdrType(NucVwdStatus1, "UVLamp") = 99
         setobjhdrval  NucVwdStatus1 , "UVLamp" ,1
      endif   
   endif
   DevLeoRID=1
   if DevLeoRID = 1
      if RegSize(LeoRidStatus1) < 1
         newobj LeoRidStatus1,1,0,0
      endif
!      if ObjHdrType(LeoRidStatus1, "UVLamp") = 99
!         setobjhdrval  LeoRidStatus1 , "UVLamp" ,1
!      endif   
   endif
   Dev1050DAD=0
   Dev1050MWD=0
   Dev1050VWD=0
   Dev1046FLD=0
   Dev1049ECD=0
   adcdevice=1
   adctimetab=0
endif


   
   if DacTst = 1
      _DriverPath$="c:\drivers\leo\release\"  !release ist das beste dann stimmt alles ini und dll und 800
      !_ProductPath$="c:\drivers\leo\release\"
   endif

   
   !configure the GOM hotlinks and load all menus needed
   GUIReconfigureSystemDiagram
   
   !BUT DON'T SHOW ANYTHING
   



endmacro


