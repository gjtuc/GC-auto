!############################################################################
name GuiNewDetectorOrderedHook

!############################################################################
local Tab$

Tab$="GuiDetectors"
RemoveHook  Tab$
NewHook     Tab$     !"GuiDetectors"
SetTabVal  Hook[1], Tab$, 0, "Order",   1000  !is default order here

!additional information to be stored

NewTabHdrVal   Hook[1], Tab$, "ExecRow" ,  0    , , 3
NewTabHdrText  Hook[1], Tab$, "DetStackIniFile"

NewColText     Hook[1], Tab$, "SymbolicName"
NewColText     Hook[1], Tab$, "StatusRegName"
NewColText     Hook[1], Tab$, "MethListIniFile"
NewColText     Hook[1], Tab$, "MethListGuiNdr"
NewColText     Hook[1], Tab$, "ShortNameLabel"


endmacro


!############################################################################
name GuiSetDetectorOrderedHook

parameter Priority  default -1  ! the priority for execution order
parameter Command$              ! the command to be executed in the hook
                                ! must be unique for every detector number
parameter SymbolicName$      
parameter StatusRegName$
parameter MethListIniFile$
parameter MethListGuiNdr$
parameter ShortNameLabel$       !used in EMF warning quick listing
!############################################################################
local Tab$                           
local row

Tab$="GuiDetectors"
if SymbolicName$ <> ""
   row=RowByText(Hook[1], Tab$, , "SymbolicName", "i=" , SymbolicName$ ) 
else
   row=-1  !no name used since no bubble message feedback implemented
endif   
if row = -1                     
   SetHook Tab$,Command$,Priority
   row = RowByText (Hook[1], Tab$, , "Command", "i=",Command$)
   if row > -1
      SetTabText Hook[1],Tab$,row,"SymbolicName"   ,SymbolicName$
      SetTabText Hook[1],Tab$,row,"StatusRegName"  ,StatusRegName$
      SetTabText Hook[1],Tab$,row,"MethListIniFile",MethListIniFile$
      SetTabText Hook[1],Tab$,row,"MethListGuiNdr" ,MethListGuiNdr$
      SetTabText Hook[1],Tab$,row,"ShortNameLabel" ,ShortNameLabel$
   endif
!else ERROR   
endif   

endmacro


!############################################################################
name GuiFindDetHookSymbolicName

parameter  SymbolicName$
!returns the detector number
!############################################################################
local Tab$

Tab$="GuiDetectors"
return  RowByText(Hook[1], Tab$, , "SymbolicName", "i=" , SymbolicName$ ) 

endmacro


!############################################################################
name GuiTestForBit
                             
parameter  BitField
parameter  TestBit
!can be used to test if a bit is set or not
!############################################################################

local iii

iii=mod(BitField,TestBit*2)
if iii >= TestBit
   iii=1
else 
   iii=0
endif   
!print BitField,",",TestBit,",",iii

return iii

endmacro






!############################################################################
name LeoDefaultInitOfUnknownDetector
                             
parameter  RegName$                                             
parameter  ModuleNo                                             
!############################################################################

Local isize
local tempevalstr$

local ID_ASTXDRIVERSMACFILES_OFF_47
local NLSFileName_astxmac$

ID_ASTXDRIVERSMACFILES_OFF_47 = 17047
NLSFileName_astxmac$= "astxmac"

!print "isize=RegSize("+RegName$+")"
evaluate "isize=RegSize("+RegName$+")"
if isize < 1
   evaluate "newobj "+RegName$+" , 1,0,0"
endif

!need to set defaults since no driver set anything
!do this all to make hotlink filter work completely compatible as if module were there
   
tempevalstr$ = "SetObjHdrText  "+RegName$+", ""GUISTATUS"" , " + ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OFF_47)
print tempevalstr$
!evaluate "SetObjHdrText  "+RegName$+", ""GUISTATUS"" , " + ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OFF_47)
evaluate tempevalstr$

endmacro






!############################################################################
name GUIListingArea

parameter   ListingArea$      default "DefaultCase" ! "" means do as last selected
!############################################################################
local iii
local iMax
local a$
local OldListing$  
local CurrentViewTable$                                                                                              
                                                                                              
!first find out if in Seq MODE
                          
CurrentViewTable$="View_"+TabHdrText$(_config[1], "Window", "CurrentView") 

!consider startup missing items
OldListing$=""

if ObjHdrType(_config[1],CurrentViewTable$) = 4
   if TabHdrType(_config[1],CurrentViewTable$,"ListingArea") = 99
      SetTabHdrText  _config[1],CurrentViewTable$,"ListingArea",""
   endif   
   OldListing$=TabHdrText$(_config[1],CurrentViewTable$,"ListingArea")
endif               

if GomExist( , GUISystemDiagGOM$) = 0
   return
else
   if GomExist( GUISystemDiagGOM$,GUIQuickListGOM$) = 1
      GomDelete GUISystemDiagGOM$,GUIQuickListGOM$
      GomDeleteToolEvent GUISystemDiagGOM$,GUIQuickListGOM
   endif
endif

if (ListingArea$ = "UPDATE") OR (ListingArea$ = ""  AND  OldListing$ <> "")
   !restore last selection
   ListingArea$=OldListing$
   !put this also right in the combobox
   if GomExist( , GUISystemDiagGOM$, "Details") = 1
      iMax=GomVal( , GUISystemDiagGOM$, "Details", "MaxListSize")
      for iii=1 to iMax
          a$=GomText$( , GUISystemDiagGOM$, "Details", "Command"+val$(iii) )
          if InStr(a$,OldListing$) > 0 
             GomSetVal  , GUISystemDiagGOM$, "Details", "Selection" , iii
             iii=iMax+1
          endif
      next iii
   endif
endif

if ObjHdrType(_config[1],CurrentViewTable$) = 4
   SetTabHdrText _config[1],CurrentViewTable$,"ListingArea", ""
endif

if ListingArea$ = ""
   ListingArea$="NONE"
endif

iii=RowByText(Hook[1], "GuiQuickLst", , "RowID", "=" , ListingArea$ ) 
if iii > -1
   !since above setting of selection is case sensitive also require it here
   GuiExecVeneerHook   "GuiQuickLst" , ListingArea$
endif   


if ObjHdrType(_config[1],CurrentViewTable$) = 4
   SetTabHdrText _config[1],CurrentViewTable$,"ListingArea",ListingArea$ 
endif

endmacro


!############################################################################
name GuiShowModuleMethodListing

parameter  ProdArea$
parameter  QuickListGom$
parameter  IniFile$
parameter  GuiNdr$
parameter  yGomOffset   default  -100
!############################################################################

if IniFile$ <> "" AND  GuiNdr$ <> ""
   GomSetToolEvent QuickListGom$,  IniFile$, "MethodListing","elements",Gui, GuiNdr$
   if yGomOffset <>  -100
      GOMShowGUI QuickListGom$, IniFile$ , ProdArea$ , , , , yGomOffset  
   else
      GOMShowGUI QuickListGom$, IniFile$ , ProdArea$
   endif   
   GOMSetToolEvent  QuickListGom$, IniFile$ , "MethodListing", "ENABLE" , , ,MethLoadSaveIdle 
   if yGomOffset <>  -100
      yGomOffset=GOMVal(QuickListGom$,IniFile$, ,"y")+ \
                 GOMVal(QuickListGom$,IniFile$, ,"height")
   endif   
endif
return  yGomOffset
endmacro  




!############################################################################
name GuiShowQuickLcMethodListing
!############################################################################

local b$
local LeoType   
local Cluster   
local ProdArea$ 
local QuickListGom$
local yGomOffset
local Tab$
local Row, RowMax
local CountLeoThm

QuickListGom$=GUIQuickListGOM$          

if GomExist( , GUISystemDiagGOM$) = 1
   
      ProdArea$="DRIVERS"
      
      GOMShowGUI GUISystemDiagGOM$ , QuickListGom$, ProdArea$  
   
      QuickListGom$=GUISystemDiagGOM$+"|"+QuickListGom$
   
      b$="MthLAls"
      !the following are in 1. column
      if DevLeoAls > 0
         yGomOffset=GuiShowModuleMethodListing(ProdArea$,QuickListGom$,b$,"INJMETH1")
      else
         !reinit hotlinks to be sure in unknow NN module cases we are correct
         GomSetToolEvent QuickListGom$,  b$, "MethodListing","elements",   Gui, "INJMETH1"
         !GOMShowGUI QuickListGom$, b$ , ProdArea$  
         !GOMSetText QuickListGom$, b$ , "MethodListing", "CURSOR" , "ARROW"  
         !GOMSetVal  QuickListGom$, b$ , "MethodListing", "ENABLE" , 0 
      endif
      
      if DevLeoPump > 0
         evaluate "LeoType=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""PumpType"")"
         if LeoType < 1  OR LeoType > 9 
            !don't know what to do then
            !default for now
            LeoType=1 
         endif   
       
         if _PumpUseBar = 1
            b$="MthLPmp"+val$(LeoType)
         else
            b$="MthJPmp"+val$(LeoType)
         endif

         if LeoType = 6
            evaluate "Cluster=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""Clustered"")"
		    if Cluster = 1
               if _PumpUseBar = 1
                  b$="MthLPmpA"
               else
                  b$="MthJPmpA"
               endif
		    endif
		    if Cluster = 2
               if _PumpUseBar = 1
                  b$="MthLPmpB"
               else
                  b$="MthJPmpB"
               endif
		    endif
		 endif

         yGomOffset=GuiShowModuleMethodListing(ProdArea$,QuickListGom$,b$,"PumpMethod1")
      else
         LeoType=1 
         if _PumpUseBar = 1
            b$="MthLPmp"+val$(LeoType)
         else
            b$="MthJPmp"+val$(LeoType)
         endif
         !reinit hotlinks to be sure in unknow NN module cases we are correct
         GomSetToolEvent QuickListGom$,  b$, "MethodListing","elements",   Gui, "PumpMethod1"
         !GOMShowGUI QuickListGom$, b$ , ProdArea$  
         !GOMSetText QuickListGom$, b$ , "MethodListing", "CURSOR" , "ARROW"  
         !GOMSetVal  QuickListGom$, b$ , "MethodListing", "ENABLE" , 0  
      endif   
      
      !the following are in 2. column
      yGomOffset=0

      CountLeoThm = DevLeoThm
      if Check(Variable, _ClusteredTcc$) = 1 then
         if InStr(_ClusteredTcc$, "1") > 0 then
            CountLeoThm=0
         else
            if InStr(_ClusteredTcc$, "2") > 0 then
               CountLeoThm=1
            endif
         endif
      endif

      if CountLeoThm > 0
         b$="MthLThm1"
         yGomOffset=GuiShowModuleMethodListing(ProdArea$,QuickListGom$,b$,"ThmMeth1",yGomOffset)
         if CountLeoThm > 1
            b$="MthLThm2"
            yGomOffset=GuiShowModuleMethodListing(ProdArea$,QuickListGom$,b$,"ThmMeth2",yGomOffset)
            GomSetToolEvent QuickListGom$,  b$, "MethodListing","elements", Gui, "ThmMeth2"
         endif   
      endif

      Tab$="GuiDetectors"
      RowMax=TabHdrVal(Hook[1],Tab$,"numberOfRows")
      for Row=1 to RowMax
          b$=TabText$(Hook[1],Tab$,Row,"MethListIniFile")
          ndr$=TabText$(Hook[1],Tab$,Row,"MethListGuiNdr")
          yGomOffset=GuiShowModuleMethodListing(ProdArea$,QuickListGom$,b$,ndr$,yGomOffset)
      next Row


endif

endmacro


!############################################################################
name GuiShowQuickChemicalsListing
!############################################################################

local b$
local LeoType   
local Cluster
local ProdArea$ 
local QuickListGom$
local ElemList$
local iRows,iii,iInstalled
local ColName$                       
local ColTab$

QuickListGom$=GUIQuickListGOM$                                       

if GomExist( , GUISystemDiagGOM$) = 1
   
  
      ProdArea$="DRIVERS"

      GOMShowGUI GUISystemDiagGOM$ , QuickListGom$, ProdArea$  
   
      QuickListGom$=GUISystemDiagGOM$+"|"+QuickListGom$
   
   
      if DevLeoPump > 0
         evaluate "LeoType=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""PumpType"")"
         if LeoType > 0  AND LeoType < 10 
            !
         else 
            !don't know what to do then
            !default for now
            LeoType=1 
         endif   
       
         if _PumpUseBar = 1
            b$="LChmPmp"+val$(LeoType)
         else
            b$="JChmPmp"+val$(LeoType)
         endif
                  
         if LeoType = 6
            evaluate "Cluster=ObjHdrVal(LeoPumpStatus"+Val$(_GuiPump)+", ""Clustered"")"
            if Cluster = 1
               if _PumpUseBar = 1
                  b$="LChmPmpA"
               else
                  b$="JChmPmpA"
               endif
            endif
            if Cluster = 2
               if _PumpUseBar = 1
                  b$="LChmPmpB"
               else
                  b$="JChmPmpB"
               endif
	        endif
	     endif

         !reinit hotlinks to be sure we are correct
         GomSetToolEvent QuickListGom$,  b$, "ChemicalListing","elements",   Gui, "PumpMethod1"
         GOMSetToolEvent  QuickListGom$, b$ , "ChemicalListing", "ENABLE" , , ,TopEnableSaveMethod 
                                                                             !MethLoadSaveIdle
         GOMShowGUI QuickListGom$, b$ , ProdArea$  
      endif   

      if GuiOffline = 0
         !next show the installed columns
         ElemList$=""
         ColTab$="Columns"
         if ObjHdrType(_config[1],ColTab$) = 4
            iRows=TabHdrVal(_config[1],ColTab$,"numberofrows")
            for iii=1 to iRows
                iInstalled=TabVal(_config[1],ColTab$,iii,"ColInstalled")
                if iInstalled = 1
                   ColName$=TabText$(_config[1],ColTab$,iii,"ColDescription") 
                   if ColName$ <> ""
                      ElemList$=ElemList$+"COL"+val$(iii)+"|"+ColName$+"|"
                   endif
                endif   
            next iii
         endif
         if ElemList$ = ""
            ElemList$="COL1|"  !so at least something shows
         endif
         ElemList$=ElemList$+" | | | | | | | | | | | | | | | | "  !to clear old stuff
      
         b$="LChmCol"
         !reinit hotlinks to be sure we are correct
         !GomSetToolEvent QuickListGom$,  b$, "ChemicalListing","elements",   Gui, "PumpMethod1"
         GOMShowGUI QuickListGom$, b$ , ProdArea$  
         GomSetText QuickListGom$, b$ , "ChemicalListing", "elements", ElemList$
      endif   
   
endif
   
endmacro

!############################################################################
name GuiSetModuleEmfWarningListing

parameter  QuickListGom$
parameter  GomName$
parameter  ToolName$
parameter  StatusReg$
parameter  ModNameSymbol$     !is a symbolic name used in ini file
parameter  iModuleCount
!############################################################################
local  ii                         

ii=iModuleCount*2
GomSetText      QuickListGom$,  GomName$, ToolName$ , "Image"+val$(ii+1) , ModNameSymbol$
evaluate "GomSetToolEvent QuickListGom$,  GomName$, ToolName$ , ""Image""+val$(ii+2) , "+ \
         StatusReg$+", EmfWarning"
endmacro


!############################################################################
name GuiCheckLenOfEmfWarningListing$

parameter  VarName$      ! Name of the variable to be checked
parameter  VarValue      ! Value of the variable
!############################################################################
local RetCmd$

if VarValue < 18-1 then
  RetCmd$ = VarName$ + "=" + VarName$ + "+1"
else
  RetCmd$ = "return"
endif

return RetCmd$

endmacro

!############################################################################
name GuiShowEmfWarningListing

! NOTE: There won't listed be more than 18 modules
!############################################################################

local b$
local LeoType   
local ProdArea$ 
local QuickListGom$   
local iModuleCount                            
local ToolName$
local Tab$
local Row, RowMax
local RegName$, ShortName$
local iExist
local ret$

QuickListGom$=GUIQuickListGOM$          

if GomExist( , GUISystemDiagGOM$) = 1
   
  
      ProdArea$="DRIVERS"
      
      GOMShowGUI GUISystemDiagGOM$ , QuickListGom$, ProdArea$  
   
      QuickListGom$=GUISystemDiagGOM$+"|"+QuickListGom$
   
      b$="LEmfWarn"

      GOMShowGUI QuickListGom$, b$, ProdArea$  

      ToolName$="LeoModules"

      GOMShowGUI QuickListGom$, b$ , ProdArea$  
                
      !reinit hotlinks to be sure in unknow NN module cases we are correct
      GomDeleteToolEvent QuickListGom$,  b$,
      iModuleCount=0                              
      
      if DevLeoAls > 0
         GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoAlsStatus1","LINJ",\
                                       iModuleCount 
         !iModuleCount=iModuleCount+1
				 ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
				 evaluate ret$
      endif
      if DevLeoPump > 0
         if DevLeoPump = 1
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoPumpStatus1","LPUMP",\
                                          iModuleCount 
		 else
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoPumpStatus1","LPUMP1",\
                                          iModuleCount 
		 endif
         !iModuleCount=iModuleCount+1
         ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
         evaluate ret$
         if DevLeoPump > 1
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoPumpStatus2","LPUMP2",\
                                          iModuleCount 
            !iModuleCount=iModuleCount+1
            ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
            evaluate ret$
            if DevLeoPump > 2
               GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoPumpStatus3","LPUMP3",\
                                             iModuleCount 
               !iModuleCount=iModuleCount+1
               ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
               evaluate ret$
            endif
         endif
      endif

      ! DevLeoThm does not have EMF limits
      
      Tab$="GuiDetectors"
      RowMax=TabHdrVal(Hook[1],Tab$,"numberOfRows")
      for Row=1 to RowMax
          RegName$=TabText$(Hook[1],Tab$,Row,"StatusRegName")
          if RegName$ <> ""
             evaluate "iExist=RegSize("+RegName$+")"
             if iExist <> -1
                evaluate "iExist=ObjHdrType("+RegName$+",EMFWarning)"
                if iExist <> 99
                   !only modules that have an EMF in status reg
                   ShortName$=TabText$(Hook[1],Tab$,Row,"ShortNameLabel")
                   GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,RegName$,\
                                                 ShortName$,iModuleCount
                   !iModuleCount=iModuleCount+1
                   ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
                   evaluate ret$
                endif   
             endif   
          endif   
      next Row
      if DevLeoAfc > 0
         if DevLeoAfc = 1
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoAfcStatus1","LAFC",\
                                          iModuleCount 
		 else
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoAfcStatus1","LAFC1",\
                                          iModuleCount 
		 endif
         !iModuleCount=iModuleCount+1
         ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
         evaluate ret$
         if DevLeoAfc > 1
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoAfcStatus2","LAFC2",\
                                          iModuleCount 
            !iModuleCount=iModuleCount+1
            ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
            evaluate ret$
            if DevLeoAfc > 2
               GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoAfcStatus3","LAFC3",\
                                             iModuleCount 
               !iModuleCount=iModuleCount+1
               ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
               evaluate ret$
							 if DevLeoAfc > 3
							    GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoAfcStatus4","LAFC4",\
									                           iModuleCount 
							    !iModuleCount=iModuleCount+1
                  ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
                  evaluate ret$
               endif
            endif
         endif
      endif

      if DevLeoVlv > 0
         if DevLeoVlv = 1
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoValveStatus1","LVLV",\
                                          iModuleCount 
	  	 else
            GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,"LeoValveStatus1","LVLV1",\
                                          iModuleCount 
	  	 endif
         !iModuleCount=iModuleCount+1
         ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
         evaluate ret$
         if DevLeoVlv > 1
            For Row=2 To DevLeoVlv
            
                GuiSetModuleEmfWarningListing QuickListGom$,b$,ToolName$,\
                                              sprintf$(Row, "LeoValveStatus%d"),\
                                              sprintf$(Row, "LVLV%d"),\
                                              iModuleCount 
                !iModuleCount=iModuleCount+1
                ret$ = GuiCheckLenOfEmfWarningListing$ ("iModuleCount", iModuleCount)
                evaluate ret$
            
            Next Row
      
         endif
      endif


endif

endmacro



!############################################################################
name GuiShowQuickDAMethodListing
!############################################################################

local b$
local LeoType   
local ProdArea$ 
local QuickListGom$   
local iModuleCount                            
local ToolName$

QuickListGom$=GUIQuickListGOM$
                             
if GomExist( , GUISystemDiagGOM$) = 1
      ProdArea$="DRIVERS"
      GOMShowGUI GUISystemDiagGOM$ , QuickListGom$, ProdArea$  
      QuickListGom$=GUISystemDiagGOM$+"|"+QuickListGom$
      b$="LDaMeth"
      GOMShowGUI QuickListGom$, b$, ProdArea$  
      GUICondenseDAMethodParameters
      GOMSetToolEvent  QuickListGom$, b$ , "MethodListing", "ENABLE" , , ,TopEnableSaveMethod 
                                                                          !MethLoadSaveIdle
      
endif


endmacro


!############################################################################
name GUICondenseDAMethodParameters

!is an empty macro will be overloaded for each product type
!############################################################################

local A$       
local iii
local irow
local b$
local ProdArea$ 
local QuickListGom$
local DestPrinter
local DestScreen   
local DestFile  

QuickListGom$=GUISystemDiagGOM$+"|"+GUIQuickListGOM$
b$="LDaMeth"

if GomExist( QuickListGom$, b$) = 0
   return  !don't need this
endif

         
iii=TabHdrVal(_DAMethod[1], "RptParm", "Style")
irow=RowByVal(_config[1],"ReportStyle",,"Style","=",iii)
A$="RPTREPORT|RPTSTYLE|"
if irow > 0                              
   A$=A$+TabText$(_config[1],"ReportStyle",irow,"Title")+"|"
else
   A$=A$+" |"
endif
A$=A$+"RPTDEST|"
DestPrinter=TabHdrVal(_DAMethod[1],"RptParm","DestPrinter")
DestScreen=TabHdrVal(_DAMethod[1],"RptParm","DestScreen")
if DestPrinter > 0 AND DestScreen > 0
   A$=A$+"RPTPRINTERSCREEN|"
else
   if DestPrinter > 0 OR DestScreen > 0
      if DestPrinter > 0
         A$=A$+"RPTPRINTER|"
      endif
      if DestScreen > 0
         A$=A$+"RPTSCREEN|"
      endif
   else
      A$=A$+" |"
   endif
endif

DestFile=TabHdrVal(_DAMethod[1],"RptParm","DestFile")
if DestFile > 0 
   A$=A$+"RPTFILE|"+TabHdrText$(_DAMethod[1],"RptParm","FileName")+"|"
else
   A$=A$+" | |"
endif

A$=A$+"RPTQUANT|RPTBASEDON|"
iii=TabHdrVal(_DAMethod[1],"QuantParm","CalcBase")
if iii > 0
   A$=A$+"RPTPEAKHEIGHT|"
else
   A$=A$+"RPTPEAKAREA|"
endif
iii=TabHdrVal(_DAMethod[1],"QuantParm","CalcType")
A$=A$+"RPTCALCTYPE|"+"RPT"+val$(iii)+"|"
                                                                               
A$=A$+" | | | | | | | | | | | | | | " !be sure left over places are empty

GomSetText QuickListGom$, b$, "MethodListing","elements",A$

endmacro
    


