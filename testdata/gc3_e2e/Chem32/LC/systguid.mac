Name Mrc_DumpStatus

  local sTemp$
  local onoff$
  
  sFile$ = _TEMPPATH$ + "mrcstatus.txt"
  
  on error print
  delete sFile$, DONTASK
  on error

  print "print MRC Status"

  On Error return

  Open sFile$ for append as #42
  On Error

  if (_offline = 1)
    onoff$ = "offline"
  else
    onoff$ = "online "
  endif
  sTemp$ = Date$(0)  + " " + Time$(2, , "HH:mm:ss") + " " + onoff$ + " " + _Instname$
  Print #42, sTemp$
  Print #42, "-------------------------------------------------------------------------------"

  !print #42, "_ECM_DATA = ", _ecm_data
  
  print #42, "guisystemstatus$ = ", guisystemstatus$
  print #42, "ObjHdrText$(GUI, DiskSpace) = ", ObjHdrText$(GUI, "DiskSpace")
  print #42, "ObjHdrText$(GUI, Act_SInf) = ", ObjHdrText$(GUI, "Act_SInf")
  print #42, "ObjHdrText$(GUI, SeqAct_SInf) = ", ObjHdrText$(GUI, "SeqAct_SInf")
  print #42, "ObjHdrText$(GUI, SrDataSubDir) = ", ObjHdrText$(GUI, "SrDataSubDir")
  print #42, "ObjHdrText$(GUI, SeqDataSubDir) = ", ObjHdrText$(GUI, "SeqDataSubDir")
  print #42, "_SEQUENCEIDLE = ", _SEQUENCEIDLE
  print #42, "_SLAVEIDLE = ", _SLAVEIDLE
  print #42, "bManagerLevelAccess = ", bManagerLevelAccess
  print #42, "TopEnableStart = ", TopEnableStart
  print #42, "TopEnableStop = ", TopEnableStop
  print #42, "AS_IsPermitted_RunRun = ", AS_IsPermitted_RunRun
  print #42, "_HyperIdleLn = ", _HyperIdleLn
  print #42, "run_da = ", run_da
  print #42, "MrcDaRunStatus$ = ", MrcDaRunStatus$
  print #42, "TabHdrVal(_DAMethod[1], RptParm, Style ) = ", TabHdrVal(_DAMethod[1], "RptParm", "Style")
  print #42, "TabHdrVal(_DAMethod[1], QuantParm, CalcBase) = ", TabHdrVal(_DAMethod[1],"QuantParm","CalcBase")
  print #42, "TabHdrVal(_DAMethod[1], QuantParm , CalcType) = ", TabHdrVal(_DAMethod[1],"QuantParm","CalcType")
  print #42, "TabHdrText$(_config[1], MenusForViews, MenuCol) = ", TabHdrText$(_config[1], "MenusForViews", "MenuCol")
  print #42, "TabHdrText$(_config[1], view_top, CurrentTask) = ", TabHdrText$(_config[1], "view_top", "CurrentTask")

 
  Close #42

  textviewer "MRC Status", sFile$

endmacro


