  goto ENDDEMO1
endif       
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_A, 1.2 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_A, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_B, 1.6 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_B, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_C, 0.4 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_C, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_D, 0.2 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_D, 2.0 "
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_A, 0.8 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_A, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_B, 0.08"
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_B, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_C, 0.3 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_C, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_D, 0.2 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_D, 2.0 "
if _Abort = 1
  goto ENDDEMO1
endif       
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_A, 0.5 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_A, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_B, 0.00"
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_B, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_C, 0.2 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_C, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_D, 0.2 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_D, 2.0 "
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_A, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_A, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_B, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_B, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_C, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_C, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_D, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_D, 2.0 "
sleep 2

ENDDEMO1:

endmacro





!############################################################################
name GUITestInjVols

parameter  RegPrefix$  default ""  ! can be used to switch demo to DEMOxxx regs
parameter  RunInjProg  default 0
!############################################################################
local iii

evaluate "iii=RegSize ("+RegPrefix$+"leoALSstatus1)"
if iii < 1
   return
endif

on error iii=0
! in case no  RegPrefix$+"leoALSmethod1" is there
!hotlink DLL still runs on original  leoALSmethod1

evaluate "setobjhdrval "+RegPrefix$+"leoALSstatus1, nRdyState,    1 " 
!to make more visible where the action is
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoALSstatus1, nRdyState,    0 "

if RunInjProg = 0
setobjhdrval                          leoALSmethod1, InjectMode,     1
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    """" "

setobjhdrval                          leoALSmethod1, Injvolume,      1.8
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, Act_volume,     1.8"
sleep 2
setobjhdrval                          leoALSmethod1, Injvolume,      45.0
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, Act_volume,     45.0"
sleep 2
setobjhdrval                          leoALSmethod1, Injvolume,      138.1
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, Act_volume,     138.1"
sleep 2
setobjhdrval                          leoALSmethod1, Injvolume,      1317.5
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, Act_volume,     1317.5"
sleep 2
setobjhdrval                          leoALSmethod1, Injvolume,      617.5
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, Act_volume,     1.8"
sleep 2
setobjhdrval                          leoALSmethod1, Injvolume,      27.0
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, Act_volume,     27.0"
sleep 2
setobjhdrval                          leoALSmethod1, InjectMode,     2
sleep 2
!to cause update (for now ?)
!evaluate "setobjhdrval "+RegPrefix$+"leoALSstatus1, Act_volume,     27.0"
!sleep 4

else

evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, RunState,   5"
setobjhdrval                          leoALSmethod1, InjectMode,     3
sleep 3
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, RunState,   9"

sleep 2
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""DRAW"""
sleep 2
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""MIX"""
sleep 2
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""WAIT"""
sleep 2
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""NEEDLE"""
sleep 2
!evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""ENDREPEAT"""
!sleep 4
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""SYRINGE"""
sleep 2
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""EJECT"""
sleep 2
!evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    ""INJECT"""
!sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoALSstatus1, RunState,   5"
sleep 3
setobjhdrval                          leoALSmethod1, InjectMode,     1
sleep 2
evaluate "setobjhdrtext "+RegPrefix$+"leoALSstatus1, Act_Command,    """" "
sleep 2
endif
on error

endmacro



!############################################################################
name GUITestAllStatesAllModules

parameter  RegNamePrefix$  default ""
parameter  ModuleNumber  default  1 
parameter  WhichPart$  default "ALL"  
!############################################################################

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_POSTRUN_8                   =  17008  
ID_ASTXDRIVERSMACFILES_RUN_9                       =  17009  
ID_ASTXDRIVERSMACFILES_STARTUP_16                  =  17016  

if DevLeoPump > 0 
   GUITestAllStates RegNamePrefix$+"LeoPump", ModuleNumber , WhichPart$, , , "LPUMP"
endif   
if DevLeoThm > 0 
   GUITestAllStates RegNamePrefix$+"LeoThermostat", ModuleNumber , WhichPart$, , , "LTHM1" 
endif   
if Dev1946MSD > 0  
   if WhichPart$ <> ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
      GUITestAddonDetectorsAllStates  "MsdState1" , "MsdState1" , WhichPart$
   else   
      GUITestAddonDetectorsAllStates  "MsdState1" , "MsdState1" , ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_POSTRUN_8)
   endif
endif   
If DevLeoDAD > 0
   GUITestAllStates RegNamePrefix$+"LeoDAD", ModuleNumber , WhichPart$, , , "LDAD1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16)  
      GUITestDetLampsOn  RegNamePrefix$+"LeoDAD"
   endif
endif   
If DevNucDAD > 0 
   GUITestAllStates RegNamePrefix$+"NucDad", ModuleNumber , WhichPart$, , , "NDAD1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16)  
      GUITestDetLampsOn  RegNamePrefix$+"NucDAD"
   endif
endif   
if DevLeoMWD > 0 
   GUITestAllStates RegNamePrefix$+"LeoMWD", ModuleNumber , WhichPart$, , , "LMWD1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16) 
      GUITestDetLampsOn  RegNamePrefix$+"LeoMWD"
   endif
 EndIf   
If DevNucMWD > 0 
   GUITestAllStates RegNamePrefix$+"NucMWD", ModuleNumber , WhichPart$, , , "NMWD1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16) 
      GUITestDetLampsOn  RegNamePrefix$+"NucMWD"
   endif
endif   
if DevLeoVWD > 0 
   GUITestAllStates RegNamePrefix$+"LeoVWD", ModuleNumber , WhichPart$, , , "LVWD1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16) 
      GUITestDetLampsOn  RegNamePrefix$+"LeoVWD"
   endif
endif   
if DevNucVWD > 0 
   GUITestAllStates RegNamePrefix$+"nucVWD", ModuleNumber , WhichPart$, , , "NVWD1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16) 
      GUITestDetLampsOn  RegNamePrefix$+"NucVWD"
   endif
endif   
if DevLeoRID > 0 
   GUITestAllStates RegNamePrefix$+"LeoRID", ModuleNumber , WhichPart$, , , "LRID1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16) 
      GUITestDetLampsOn  RegNamePrefix$+"LeoRID"
   endif
endif   
if DevLeoFLD > 0 
   GUITestAllStates RegNamePrefix$+"LeoFLD", ModuleNumber , WhichPart$, , , "LFLD1"
   if WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16) 
      GUITestDetLampsOn  RegNamePrefix$+"LeoFLD"
   endif
endif   

if DevLeoALS > 0 
   GUITestAllStates RegNamePrefix$+"LeoAls", ModuleNumber , WhichPart$, , , "LINJ"
endif   

if Dev1946MSD > 0  AND  WhichPart$ = ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
   GUITestAddonDetectorsAllStates  "MsdState1" , "MsdState1" , WhichPart$
endif   

if 1 = 0 
   !this is not implemented in the drivers anyway
   GUITestAllStates RegNamePrefix$+"LeoDet", ModuleNumber , WhichPart$, "DAD1050Status", "Det"
   GUITestAllStates RegNamePrefix$+"LeoDet", ModuleNumber , WhichPart$, "VWD1050Status", "Det"
endif   

endmacro



!############################################################################
name GUITestDetLampsOn

parameter  RegNamePrefix$  default ""
parameter  ModuleNumber  default  1 
!############################################################################
local iii

   
RegNamePrefix$=RegNamePrefix$+"status"+val$(ModuleNumber)
evaluate "iii=RegSize ("+RegNamePrefix$+")"
if iii < 1
   return
endif

evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyState, 1 "
evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyType, 512 "
print "state=6  IGNITION"
sleep 2           

evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyState, 1 "
evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyType, 256 "
print "state=6  BALANCING"
sleep 2           
evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyType, 0 "
evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyState, 0 "

endmacro




!############################################################################
name GUITestDetBalancing

parameter  RegNamePrefix$  default ""
parameter  ModuleNumber  default  1 
!############################################################################
local iii

RegNamePrefix$=RegNamePrefix$+"status"+val$(ModuleNumber)
evaluate "iii=RegSize ("+RegNamePrefix$+")"
if iii < 1
   return
endif

evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyState, 1 "
evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyType, 256 "
print "state=6  BALANCING"
sleep 2           
evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyType, 0 "
evaluate "setobjhdrval  "+RegNamePrefix$+", nRdyState, 0 "

endmacro






!############################################################################
name GuiDemoSystemDiagramCode

parameter  RegPrefix$  default ""  ! "DEMO" can be used to switch demo to DEMOxxx regs
!############################################################################

local  Old_RUN_ACQ                      
local  Tab$
local  Module$
local  x
local  MsdState$ 
 
                      
SetAbort off

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_PRERUN_6                    =  17006  
ID_ASTXDRIVERSMACFILES_POSTRUN_8                   =  17008  
ID_ASTXDRIVERSMACFILES_RUN_9                       =  17009  
ID_ASTXDRIVERSMACFILES_NONE_17                     =  17017  



if Check ( VARIABLE, GUIDemoDiagramOn ) = 0 
   GUIDemoDiagramOn=0        !when 1 causes hplguh00.dll on installcmds 
                             !to set hotlinks on "Demo"+"LeoXXXStatus1" regs
                             !instead of "LeoXXXStatus1" regs
endif                 

Old_RUN_ACQ=RUN_ACQ


if RegPrefix$="DEMO"
   evaluate "x=RegSize(LeoPumpStatus"+Val$(_MainPump)+")"
   if x > 0
      evaluate "CopyObj LeoPumpStatus"+Val$(_MainPump)+"[1], DemoLeoPumpStatus1[1]"
   else
      !put in all necessary defaults
      newobj  DemoLeoPumpStatus1,1,0,0                    
      
      setobjhdrval  DemoLeoPumpStatus1 , "PUMPTYPE" ,   2

      setobjhdrval  DemoLeoPumpStatus1 , "RunState" ,   5
      setobjhdrval  DemoLeoPumpStatus1 , "nRdyState" ,  0
      setobjhdrval  DemoLeoPumpStatus1 , "ErrorState" , 0
      setobjhdrval  DemoLeoPumpStatus1 , "nRdyType" ,   0
      setobjhdrval  DemoLeoPumpStatus1 , "ErrorType" ,  0

      setobjhdrval  DemoLeoPumpStatus1 , "FLOW" ,          0
      setobjhdrval  DemoLeoPumpStatus1 , "PRESSURE" ,      0
      setobjhdrval  DemoLeoPumpStatus1 , "PRESSURE_MIN" ,  0
      setobjhdrval  DemoLeoPumpStatus1 , "PRESSURE_MAX" ,  0
      setobjhdrval  DemoLeoPumpStatus1 , "SOLV_RATIO_A" ,100
      setobjhdrval  DemoLeoPumpStatus1 , "SOLV_RATIO_B" ,  0 
      setobjhdrval  DemoLeoPumpStatus1 , "SOLV_RATIO_C" ,  0 
      setobjhdrval  DemoLeoPumpStatus1 , "SOLV_RATIO_D" ,  0 

   endif
   setobjhdrval  DemoLeoPumpStatus1 , "ACT_BOTTLE_A" ,  1
   setobjhdrval  DemoLeoPumpStatus1 , "ACT_BOTTLE_B" ,  1
   setobjhdrval  DemoLeoPumpStatus1 , "ACT_BOTTLE_C" ,  1
   setobjhdrval  DemoLeoPumpStatus1 , "ACT_BOTTLE_D" ,  1
   setobjhdrval  DemoLeoPumpStatus1 , "MAX_BOTTLE_A" ,  2
   setobjhdrval  DemoLeoPumpStatus1 , "MAX_BOTTLE_B" ,  2
   setobjhdrval  DemoLeoPumpStatus1 , "MAX_BOTTLE_C" ,  2
   setobjhdrval  DemoLeoPumpStatus1 , "MAX_BOTTLE_D" ,  2

   if RegSize(LeoALSStatus1) > 0
      CopyObj LeoALSStatus1[1], DemoLeoALSStatus1[1]
      CopyObj LeoALSMethod1[1], DemoLeoALSMethod1[1]
   else   
      !put in all necessary defaults
      newobj  DemoLeoALSStatus1,1,0,0                    

      setobjhdrval  DemoLeoALSStatus1 , "RunState" ,   5
      setobjhdrval  DemoLeoALSStatus1 , "nRdyState" ,  0
      setobjhdrval  DemoLeoALSStatus1 , "ErrorState" , 0
      setobjhdrval  DemoLeoALSStatus1 , "nRdyType" ,   0
      setobjhdrval  DemoLeoALSStatus1 , "ErrorType" ,  0

      setobjhdrval  DemoLeoALSStatus1 , "ACT_TRAY_A" ,   100
      setobjhdrval  DemoLeoALSStatus1 , "ACT_TRAY_A" ,   100

      setobjhdrtext DemoLeoALSStatus1 , "ACT_COMMAND" ,   ""
      setobjhdrval  DemoLeoALSStatus1 , "ACT_INJMODE" ,   1
      setobjhdrval  DemoLeoALSStatus1 , "ACT_VOLUME" ,   10.0
      setobjhdrval  DemoLeoALSStatus1 , "ACT_VIAL" ,     10

   endif
   if RegSize(LeoThermostatStatus1) > 0
      CopyObj LeoThermostatStatus1[1], DemoLeoThermostatStatus1[1]
   else   
      !put in all necessary defaults
      newobj  DemoLeoThermostatStatus1,1,0,0                    

      setobjhdrval  DemoLeoThermostatStatus1 , "RunState" ,   5
      setobjhdrval  DemoLeoThermostatStatus1 , "nRdyState" ,  0
      setobjhdrval  DemoLeoThermostatStatus1 , "ErrorState" , 0
      setobjhdrval  DemoLeoThermostatStatus1 , "nRdyType" ,   0
      setobjhdrval  DemoLeoThermostatStatus1 , "ErrorType" ,  0
   endif
   setobjhdrval  DemoLeoThermostatStatus1 , "LeftTemp"  ,35
   setobjhdrval  DemoLeoThermostatStatus1 , "RightTemp" ,35
