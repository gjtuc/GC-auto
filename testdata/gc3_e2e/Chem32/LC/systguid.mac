evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_D, 0.2 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_D, 2.0 "
