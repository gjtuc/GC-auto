evaluate "setobjhdrval  "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", Pressure,     370"
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", Pressure,     400"
sleep 2
print "state=  PRESSURE STABILIZING"
evaluate "setobjhdrval  "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", Pressure,     250"
if _Abort = 1
  goto ENDDEMO1
endif       
sleep 2
evaluate "setobjhdrval  "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", Pressure,     220"
sleep 2

print "state=  GRADIENT RUNNING"
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_A, 80.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_B, 20.0 "
if _Abort = 1
  goto ENDDEMO1
endif       
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_A, 65.3 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_B, 34.7 "
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_A, 65.3 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_B, 20.5 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_C, 14.2 "
if _Abort = 1
  goto ENDDEMO1
endif       
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_A, 65.3 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_B,  5.1 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_C, 14.2 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_D, 15.4 "
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_A,  0.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_B,100.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_C,  0.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_D,  0.0 "
sleep 2
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_A,  0.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", SOLV_RATIO_B, -1.0 "
