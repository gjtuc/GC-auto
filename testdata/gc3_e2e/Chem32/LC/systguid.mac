name GUIShowTrayDiagram

!test macro for faster detail testing
!else same as  GUIShowSystemDiagram
!############################################################################
                                       
local b$
local LeoType   
local ProdArea$
local DetNos

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_SEQUENCE_1                  =  17001  

GUISamplingAreaReconfiguration  ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_SEQUENCE_1)

                                       
if GomExist( , GUISystemDiagGOM$) = 0
   !!
   
   ProdArea$="DRIVERS"
   GOMShowGUI  , GUISystemDiagGOM$  , ProdArea$ , , GuiSystemDiagramWinNo        !later from LC or CORE 
   
   !NOTE: if any of GOMShowGUI did not find something , must set CRTxResolution to 800
   !and redo all since we garantee at 800 is ALL there
   
   GOMShowGUI GUISystemDiagGOM$, "LMethod"  , ProdArea$               !later from LC or CORE
   !GuiShowBubbleMessage "LAST"                                        !later from LC or CORE
   
   GOMShowGUI GUISystemDiagGOM$, "LInjPump" , ProdArea$ 

    

   GUISamplingAreaReconfiguration

endif

endmacro






!############################################################################
name GUITestModuleState

parameter  RegNamePrefix$ 
parameter  StateName$    default "DefaultCase"
parameter  NotReady      default  -1 
parameter  Error         default  -1 
parameter  NotReadyMsg$  default "??" 
parameter  ErrorMsg$     default "??"
parameter  ModuleNumber  default  1 

!does the same things as drivers would do in their status reg
!############################################################################

local iii

RegNamePrefix$=RegNamePrefix$+"status"+val$(ModuleNumber)

if StateName$ = ""
   StateName$="DefaultCase"
endif
on error goto DefaultCase
evaluate "GoTo "+ StateName$
   OFFLINE:;on error
     iii=1
     goto endswitch
   POWEROFF:;on error
     iii=2
     goto endswitch
   POWERON:;on error
     iii=3
     goto endswitch
   STANDBY:;on error
     iii=4
     goto endswitch
   OFF:;on error
     iii=4  !just more used to this name -> STANDBY
     goto endswitch
   PRERUN:;on error
     iii=5
     goto endswitch
   READY:;on error
     iii=5   !just more used to this name -> PRERUN
     goto endswitch
   PREPARING:;on error
     iii=6   
     goto endswitch
   DRAW:;on error
     iii=6   !just more used to this name -> PREPARING
     goto endswitch
   POSTRUN:;on error
     iii=7
     goto endswitch
   RUN:;on error
     iii=8
     goto endswitch
   INJECTING:;on error
     iii=9
     goto endswitch
   BREAK:;on error
     iii=10
     goto endswitch
   INITIALIZING:;on error
     iii=11
     goto endswitch
   DefaultCase:;on error
     iii=12
     goto endswitch
endswitch:

evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"  +val$(iii)
if NotReady <> -1
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",nRdyState," +val$(NotReady) 
endif   
if Error <> -1
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",ErrorState,"+val$(Error) 
endif   

print "state=", StateName$
sleep 1
  
endmacro


!############################################################################
name GUITestPrintStates

parameter  StateNumber
!############################################################################



local StateName$                      

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_OFFLINE_2                   =  17002  
ID_ASTXDRIVERSMACFILES_POWEROFF_3                  =  17003  
ID_ASTXDRIVERSMACFILES_POWERON_4                   =  17004  
ID_ASTXDRIVERSMACFILES_STANDBY_5                   =  17005  
ID_ASTXDRIVERSMACFILES_PRERUN_6                    =  17006  
ID_ASTXDRIVERSMACFILES_PREPARING_7                 =  17007  
ID_ASTXDRIVERSMACFILES_POSTRUN_8                   =  17008  
ID_ASTXDRIVERSMACFILES_RUN_9                       =  17009  
ID_ASTXDRIVERSMACFILES_INJECTING_10                =  17010  
ID_ASTXDRIVERSMACFILES_BREAK_11                    =  17011  
ID_ASTXDRIVERSMACFILES_INITIALIZING_12             =  17012  


on error goto DefaultCase
evaluate "GoTo State"+ val$(StateNumber)
   State1:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OFFLINE_2)
     goto endswitch
   State2:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_POWEROFF_3)
     goto endswitch
   State3:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_POWERON_4)
     goto endswitch
   State4:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STANDBY_5)
     goto endswitch
   State5:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRERUN_6)
     goto endswitch
   State6:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PREPARING_7)
     goto endswitch
   State7:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_POSTRUN_8)
     goto endswitch
   State8:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
     goto endswitch
   State9:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INJECTING_10)
     goto endswitch
   State10:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_BREAK_11)
     goto endswitch
   State11:;on error
     StateName$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_INITIALIZING_12)
     goto endswitch
   DefaultCase:;on error
     return
 endswitch:


print "state=", StateNumber , "    ", StateName$


endmacro


!############################################################################
name GUITestAllStates

parameter  RegNamePrefix$ 
parameter  ModuleNumber  default  1 
parameter  WhichPart$  default "ALL"  ! "ALL", ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRERUN_6) , "PREP_RUN" , ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9) , "ERRORS" , "STARTUP"
parameter  SimpleNdrSimulation$ default ""  ! give NDR to give the status to 
parameter  GuiProtocolPrefix$ default ""    ! prefix in protocol status text
parameter  ErrorModuleName$
!############################################################################

local iii,jjj

!           ACQ_STA_NOMODULE   // 0
!           ACQ_STA_OFFLINE,   // 1
!           ACQ_STA_POWEROFF,  // 2
!           ACQ_STA_POWERON,   // 3
!           ACQ_STA_STANDBY,   // 4
!           ACQ_STA_PRERUN,    // 5
!           ACQ_STA_PREPARING, // 6
!           ACQ_STA_POSTRUN,   // 7
!           ACQ_STA_RUN,       // 8
!           ACQ_STA_INJECTING, // 9
!           ACQ_STA_BREAK,     //   10
!           ACQ_STA_INITIALIZING // 11

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_OFFLINE_2                   =  17002  
ID_ASTXDRIVERSMACFILES_PRERUN_6                    =  17006  
ID_ASTXDRIVERSMACFILES_POSTRUN_8                   =  17008  
ID_ASTXDRIVERSMACFILES_RUN_9                       =  17009  
ID_ASTXDRIVERSMACFILES_ERROR_TEXT__PR_13           =  17013  
ID_ASTXDRIVERSMACFILES_STARTUP_16                  =  17016  
ID_ASTXDRIVERSMACFILES_NONE_17                     =  17017  



RegNamePrefix$=RegNamePrefix$+"status"+val$(ModuleNumber)

evaluate "iii=RegSize ("+ RegNamePrefix$ +")"

if iii > 0
evaluate  "SetObjHdrVal "+RegNamePrefix$+",nRdyState,"+val$(0) 
evaluate  "SetObjHdrVal "+RegNamePrefix$+",ErrorState,"+val$(0) 

if WhichPart$="ALL"  or WhichPart$="STARTUP"
for iii=1 to 4
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",UVLamp, 0"  !for detector demos
  GUITestPrintStates iii
  sleep 1
next iii
for iii=11 to 11
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  GUITestPrintStates iii
  sleep 1
next iii
for iii=5 to 5
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",UVLamp, 1"  !for detector demos
  GUITestPrintStates iii
  sleep 1
next iii
endif

if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRERUN_6) 
for iii=5 to 5
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  GUITestPrintStates iii
  sleep 1
next iii
endif


if WhichPart$="ALL"  or WhichPart$="PREP_RUN"
for iii=10 to 10
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  GUITestPrintStates iii
  sleep 2
next iii
for iii=6 to 6
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  GUITestPrintStates iii
  sleep 1
next iii
for iii=9 to 9
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  GUITestPrintStates iii
  if RegNamePrefix$[1:4] = "DEMO"
     for jjj=0 to 1000 
         sleep 2
         evaluate  "SetObjHdrVal "+RegNamePrefix$+",PrepProgress,"+val$(jjj)
         jjj=jjj+200
     next jjj
     sleep 2    
  else 
     sleep 10  !software does progress
  endif   
next iii
endif

if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
for iii=8 to 8
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  GUITestPrintStates iii
  sleep 1
next iii
endif

if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_POSTRUN_8)
for iii=7 to 7
  evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(iii)
  GUITestPrintStates iii
  sleep 1
next iii
endif

if WhichPart$="ALL"  or WhichPart$="ERRORS"
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",nRdyState,"+val$(0) 
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",ErrorState,"+val$(0) 

   evaluate  "SetObjHdrVal "+RegNamePrefix$+",nRdyState,"+val$(1) 
     print "state=  NRDY"
     sleep 1
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",nRdyState,"+val$(0) 
     sleep 1

   evaluate  "SetObjHdrVal "+RegNamePrefix$+",ErrorState,"+val$(1)
     print "state=  ERROR"
   GUIShowBubbleMessage "ERROR", ErrorModuleName$, \
       ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ERROR_TEXT__PR_13) , 2000
     sleep 3
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",nRdyState,"+val$(1) 
     sleep 1
   GUIShowBubbleMessage ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_NONE_17),
     sleep 1
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",ErrorState,"+val$(0) 
     sleep 1
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",nRdyState,"+val$(0) 
     sleep 1
   evaluate  "SetObjHdrVal "+RegNamePrefix$+",RunState,"+val$(5)
     print "state=  PRERUN"
     sleep 1
endif
else 
   !simulate on GUI hotlink NDR itself
   !difficlut to do in a generic way especially for the more complex protocols 
   if SimpleNdrSimulation$ <> "" 
      if WhichPart$="ALL"  or WhichPart$="PREP_RUN"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_STARTUP_16)
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_OFFLINE_2)
         sleep 1
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+"OFF"
         sleep 1
      endif
      if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRERUN_6) 
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+"READY"
         sleep 1
      endif
      if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
         sleep 1
      endif
      if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_POSTRUN_8)
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
         sleep 1
      endif
      if WhichPart$="ALL"  or WhichPart$="ERRORS"
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+"NRDY"
         sleep 1
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+"ERRORS"
         sleep 1
         SetObjHdrText GUI , SimpleNdrSimulation$ , GuiProtocolPrefix$+"READY"
         sleep 1
      endif

   endif
endif

endmacro


!############################################################################
name GUITestAddonDetectors

parameter  GuiReg$
parameter  GuiNdr$  default ""
parameter  NdrText$ default "DetReady"
!############################################################################

evaluate "setobjhdrtext  "+GuiReg$+","+GuiNdr$+","+NdrText$
sleep 2           

endmacro



!############################################################################
name GUITestAddonDetectorsAllStates  

parameter  GuiReg$
parameter  GuiNdr$  default ""
parameter  WhichPart$  default "ALL"  
!############################################################################
!mapp state to one of
!Symbols1=DetOff|DetNrdy|DetReady|DetRun|DetError|DetNN|DetOffline|DetBalance|DetRun0|DetRun1|DetRun2|DetRun3|DetRun4|DetRun5|DetRun6|DetRun7|DetRun8|DetRun9|DetRun10|DetIgnition|DetTune|DetRunScan|DetReadyScan

local iii

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_PRERUN_6                    =  17006  
ID_ASTXDRIVERSMACFILES_POSTRUN_8                   =  17008  
ID_ASTXDRIVERSMACFILES_RUN_9                       =  17009  
ID_ASTXDRIVERSMACFILES_ERROR_TEXT__PR_13           =  17013  



if WhichPart$="ALL"  or WhichPart$="STARTUP"
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetOffline"
   sleep 1
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetError"
   sleep 1
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetOff"
   sleep 1
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetNRdy"
   sleep 1
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetReady"
   sleep 1
endif

if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_PRERUN_6) 
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetReady"
   sleep 1
endif

if WhichPart$="ALL"  or WhichPart$="PREP_RUN"
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetBalance"
   print ObjHdrText$( MsdState1, MsdState1)
   sleep 1
endif

if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_RUN_9)
   for iii=0 to 10
       GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetRun"+val$(iii)
       print ObjHdrText$( MsdState1, MsdState1)
       sleep 1
   next iii    
endif

if WhichPart$="ALL"  or WhichPart$=ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_POSTRUN_8)
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetRun"
   print ObjHdrText$( MsdState1, MsdState1)
   sleep 1
endif

if WhichPart$="ALL"  or WhichPart$="ERRORS"
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetNrdy"
   sleep 2
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetError"
   sleep 1
   GUIShowBubbleMessage "ERROR", ErrorModuleName$, \
       ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_ERROR_TEXT__PR_13) , 2000
     sleep 3
   GUITestAddonDetectors  GuiReg$,GuiNdr$, "DetReady"
   sleep 1
endif

endmacro




!############################################################################
name GUITestAllDAStates


!############################################################################
NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_REPORT_25                   =  17025  

print "state=  RUNNING DATA EVALUATION"

GUIStartDAProgressDisplay   "INTEG"
sleep 2
GUIStartDAProgressDisplay   "QUANT"
sleep 2
GUIStartDAProgressDisplay   ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_REPORT_25)
sleep 2
GUIStartDAProgressDisplay   "GLPSAVE"
sleep 2
GUIStartDAProgressDisplay   "DONE"
sleep 1
GUIStartDAProgressDisplay   "RESET"
sleep 1


endmacro





!############################################################################
name GUITestShowTrayTestcombination

parameter TrayA
parameter TrayB

!must do GUISamplingAreaReconfiguration since in a one CP macro 
!############################################################################

setobjhdrval leoalsstatus1, act_tray_a, TrayA
setobjhdrval leoalsstatus1, act_tray_b, TrayB
setobjhdrtext _sequence , dummy, "DEMO"  !cause seq tray protocol to be rewritten
GUISamplingAreaReconfiguration ,1
sleep 2

endmacro




!############################################################################
name GUITestLeftTrayMemoryFilter

parameter LeftT
parameter RightT
!############################################################################

setverbose 1

NLSFileName_astxmac$= "astxmac"
ID_ASTXDRIVERSMACFILES_LEFT_TRAY_MUST_14           =  17014  

GUITestShowTrayTestcombination 100,0           
GUITestShowTrayTestcombination   0,0           
GUITestShowTrayTestcombination  LeftT,0           
GUITestShowTrayTestcombination  LeftT,RightT          
GUITestShowTrayTestcombination   0,RightT          
GUITestShowTrayTestcombination   0,0           
GUITestShowTrayTestcombination   0,RightT          
GUITestShowTrayTestcombination   0,0           
GUITestShowTrayTestcombination   0,RightT          
GUITestShowTrayTestcombination   0,0           
GUITestShowTrayTestcombination   0,RightT          
print ReadResource$(NLSFileName_astxmac$,ID_ASTXDRIVERSMACFILES_LEFT_TRAY_MUST_14)
GUITestShowTrayTestcombination   0,0           
GUITestShowTrayTestcombination   0,RightT          
GUITestShowTrayTestcombination   0,0           
GUITestShowTrayTestcombination   0,RightT          

endmacro

