if _Abort = 1
  goto ENDDEMO1
endif       
sleep 2

print "state=  SOLVENT CONSUMPTION"
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_A, 1.5 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_A, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_B, 1.8 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", MAX_BOTTLE_B, 2.0 "
evaluate "setobjhdrval "+RegPrefix$+"leoPUMPstatus"+Val$(_MainPump)+", ACT_BOTTLE_C, 0.5 "
