!############################################################################
name GuiDemoSystemDiagram1

parameter  RegPrefix$  default ""  ! "DEMO" can be used to switch demo to DEMOxxx regs
!############################################################################

local x

if RegPrefix$="DEMO"
   GUIDemoDiagramOn=1
   !Need to reinstall the hplguh00.dll so it hotlinks to DEMO regs
   evaluate "x = RegSize(LeoPumpStatus"+Val$(_MainPump)+")"
   if x > 0
      evaluate "CopyObj LeoPumpStatus"+Val$(_MainPump)+"[1], DemoLeoPumpStatus1[1]"
   endif
   if RegSize(LeoALSStatus1) > 0
      CopyObj LeoALSStatus1[1], DemoLeoALSStatus1[1]
      CopyObj LeoALSMethod1[1], DemoLeoALSMethod1[1]
   endif
   GUIInstallLeoHotlinkDll  1
endif

_debugPrint    "GUIDemoDiagramOn"  , , GUIDemoDiagramOn

GUITestPumpComposition  RegPrefix$

GUITestInjVols  RegPrefix$ , 1

GUITestAllStatesAllModules RegPrefix$, 1, "ERRORS"

GUITestAllTrays

if RegPrefix$="DEMO"
   GUIDemoDiagramOn=0
   !Need to reinstall the hplguh00.dll so it hotlinks to non DEMO regs
   GUIInstallLeoHotlinkDll  1
   if RegSize(DemoLeoPumpStatus1) > 0
      DelReg DemoLeoPumpStatus1
   endif
   if RegSize(DemoLeoALSStatus1) > 0
      DelReg DemoLeoALSStatus1
   endif
   if RegSize(DemoLeoALSMethod1) > 0
      !put back original values
      CopyObj DemoLeoALSMethod1[1], LeoALSMethod1[1]
      DelObj LeoALSMethod1[2]
      DelReg DemoLeoALSMethod1
   endif
endif

endmacro





