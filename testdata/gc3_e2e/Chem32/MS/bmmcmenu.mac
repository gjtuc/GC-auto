    !If ( instr( lMSDModel$, "6140A" ) < 1 ) then  ! Branch for Shasta
    macro _autopath$+ "..\MS\MSTNUtil.mac" 
    If ( pre6100() > 0 ) then  ! Branch for Shasta
        MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__INSTRUMENT_SE_275), \
