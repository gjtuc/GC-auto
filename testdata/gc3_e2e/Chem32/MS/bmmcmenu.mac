lDebug = 0
! Check for global variables:
     if check(variable, MS_SQ_SL) = 0 then    ! global variable doesn't exist yet
       msat_SetModelVars
     endif
! Get the instrument model e.g.: 6140A
    MSAcqInfo
    lMSDModel$ = ObjHdrText$( MSAcqInfo[1], "InstrumentType")
    If ( lDebug > 0 ) then
        Print "bmmcmenu: MS_SQ_SL:", MS_SQ_SL
        Print "bmmcmenu: MSD_46:",   MSD_46
        Print "bmmcmenu: MSDMODEL:", lMSDModel$
    Endif
!
! Set the instrument model
!
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),,,,,,9001,"msd",1000000
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_LOAD_MSTUNE_398), "mstn_DoGetTuneFile",, ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_LOAD_MSTUNE_PAR_401),,9110,"msd",1001000
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SAVE_MSTUNE_399), "mstn_DoSaveTuneFile tunefilepath$+tunefilename$",, ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SAVE_MSTUNE_PAR_402),,9003,"msd",1002000
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SAVE_MSTUNE_AS_400), "mstn_DoSaveTuneFile",, ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SAVE_MSTUNE_PAR_TO_403),,9082,"msd",1003000

   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),,"SEPARATOR",,,,,,1004000
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PRINT_MSTUNE_RPT_404),"mstn_DoGenReport",, ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_GENERATE_MSTUNE_RPT_405),mmcMenuEnable,9005,"msd",1005000
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PRINT_MSD_TUNE_147),"mstn_DoDispPrint",,ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PRINT_A_HARDCO_149),,9006,"msd",1006000
 ! MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), "&Printer Setup...","Device",,"Configure hardcopy output",,9007,"msd",1007000

   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),, "SEPARATOR",,,,,,1008000
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_RESET_DEFAULT_388),"MSTN_FreshTune",,ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_RESET_TUNE_DEFAULT_389),,9008,"msd",1009000
   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),, "SEPARATOR",,,,,,1010000

   MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_E_XIT_150), "ClosePhx",,  ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_EXIT_390),,9010,"msd",1012000

!
! Fill out the Menu Structure particulars with menu items:
! Added Tune menu item
!
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE_153),,,,,,9011,"msd",2000000
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE_153), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_C_HECK_TUNE_154),"msat_CheckTune",,ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_CHECK_MSD_PERF_156),mmcMenuEnableFS,9012,"msd",2001000
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE_153),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__AUTOTUNE_157),"SUBMENU",,ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_TUNE_THE_MSD_A_158),,9013,"msd",2002000
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE__AUTOTUN_159),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__DUAL_POLARITY_160),"msat_Auto",,ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PERFORM_A_DUAL_162),mmcMenuEnable,9013,"msd",2002100
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE__AUTOTUN_159),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__POSITIVE_POLA_163),"msat_Auto 1",,ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PERFORM_A_POSI_165),MSMANSHOW,9013,"msd",2002200
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE__AUTOTUN_159),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__NEGATIVE_POLA_166),"msat_Auto 2",,ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PERFORM_A_NEGA_168),MSMANSHOW,9013,"msd",2002300
    If MS_SQ_SL = 1 then        ! Auto tuning for Fast and Ultra Fast 
        If ( instr( lMSDModel$, "6140A" ) > 0 ) then ! Auto tuning for Ultra Fast Scan for SL-HT model
            MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE__AUTOTUN_159),\
                    ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_Dual_Ultra_439),"msat_Auto 3",,\
                    ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_Hel_DUAL_444),mmcMenuEnable,9013,"msd",2002400
            MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__TUNE__AUTOTUN_159),\
                    ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_Pos_Ultra_440),"msat_Auto 4",,\
                    ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_Hel_POSI_445),MSMANSHOW,9013,"msd",2002500
