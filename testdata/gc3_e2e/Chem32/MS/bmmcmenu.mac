                ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SELECT_NOT_TO_284),mstn_CalN,9015,"msd",4009300
    Else                                        ! Branch for Lassen
        ! Instrument --> Select Calibrant --> On
        MenuAdd ReadResource$("supportmacfiles", ID_SUPPORTMACFILES_Select_Cal_500),\
