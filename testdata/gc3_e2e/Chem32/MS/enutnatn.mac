            ID_TUNEMAC_CHECKING_VACUU_587                      =  17587  
            ID_TUNEMAC_CHECKING_TEMPE_588                      =  17588  
            ID_TUNEMAC_CALIBRANT_IS_T_589                      =  17589  
            ID_TUNEMAC_CHECKING_TUNE_590                       =  17590  
            ID_TUNEMAC_AUTOTUNE__NO_A_591                      =  17591  
            ID_TUNEMAC_LINKING_SKIMME_592                      =  17592  
            ID_TUNEMAC_DISABLING_LENS_593                      =  17593  
            ID_TUNEMAC_FINDING_TUNE_M_594                      =  17594  
            ID_TUNEMAC_OPTIMIZING_OCT_595                      =  17595  
            ID_TUNEMAC_GENERATING_POS_596                      =  17596  
            ID_TUNEMAC_SAVING_PROFILE_597                      =  17597  
            ID_TUNEMAC_GENERATING_NEG_598                      =  17598  
            ID_TUNEMAC_SAVING_PROFILE_599                      =  17599  
            ID_TUNEMAC_SAVING_NEGATIV_600                      =  17600  
            ID_TUNEMAC_SAVING_POSITIV_601                      =  17601  
            ID_TUNEMAC_LOADING_ATUNES_579                      =  17579  
            ID_TUNEMAC_POLARITY_SET_T_581                      =  17581  
            ID_TUNEMAC_SETTING_TO_THE_582                      =  17582  
            ID_TUNEMAC_CHECKING_TEMPE_588                      =  17588  
            ID_TUNEMAC_CALIBRANT_IS_T_589                      =  17589  
            ID_TUNEMAC_CHECKING_TUNE_590                       =  17590  
            ID_TUNEMAC_AUTOTUNE__NO_A_602                      =  17602  
            ID_TUNEMAC_LINKING_SKIMME_592                      =  17592  
            ID_TUNEMAC_DISABLING_LENS_593                      =  17593  
            ID_TUNEMAC_INITIALIZING_N_603                      =  17603  
            ID_TUNEMAC_INITIALIZING_N_604                      =  17604  
            ID_TUNEMAC_FINDING_TUNE_M_594                      =  17594  
            ID_TUNEMAC_GENERATING_NEG_598                      =  17598  
            ID_TUNEMAC_SAVING_PROFILE_597                      =  17597  
            ID_TUNEMAC_SAVING_NEGATIV_600                      =  17600  
            ID_TUNEMAC_WARNING__THE_M_605                      =  17605  
            ID_TUNEMAC_WARNING__THE_M_606                      =  17606  
            ID_TUNEMAC_AUTOTUNE_COMPL_607                      =  17607  
            ID_TUNEMAC_GAINCURVE_REG_1073                      =  18073
            
            lAtuneRegInit = 1
            MSGDisplay ON                                !* Make sure graphics turned on
            ! Start the timer
            ATuneTimer = time()
            if Check(Variable, AtuneTimerOn) = 0 then
              AtuneTimerOn = 0
            endif
            Print ReadResource$("tunemac",ID_TUNEMAC_____AUTOTUNE_S_575) \
                  + Date$(1, ATuneTimer) + " " + Time$(1, AtuneTimer)
            ! Autotune debugging flag
            if Check(Variable, AtuneDebug) = 0 then
              AtuneDebug = 0
            endif
            
            ! Check and load the GainCurve register if necessary:
            if RegSize(GainCurve) = -1 then
              !* Register not loaded.  Try loading the register from disk
              if filestat(mode,_tunepath$ + "GainCurve.reg") = 1 then
                LoadObj _tunepath$ + "GainCurve.reg",, GainCurve
              else
                ! GainCurve.reg has been deleted from this system
                title$= "Gain Curve Check"
                line1$= ReadResource$("tunemac",ID_TUNEMAC_GAINCURVE_REG_323)
                line2$= chr$(13) + chr$(13) \
                              +ReadResource$("tunemac",ID_TUNEMAC_GAINCURVE_REG_1073)
                              !+"Please restore file or reload ChemStation software."
                _button=alert(line1$ + line2$,3,title$)  
                ! CPL 03/06 Replace Atuneprint statement with Alert.
              stop
              endif
            endif            
                               
            if state > 2 then
            !* Warn the user about fast scan's wider peaks
            !* Ignore if 6100 series instrument CPL 05/09/2007
              if ( pre6100() <> 0 ) then
                FS_alert = msat_FSWarnDialog()   
                if FS_alert = 0 then     !* user hit cancel button
                  print ReadResource$("tunemac",ID_TUNEMAC_AUTOTUNE_CANCE_578)
                  return
                endif
              endif
            endif ! state > 2
            
            oldTuneFile$=tunefilename$                   !* Save current tune file
            msparm polarity,OldPolarity                  !* Save current polarity
            on error msat_AutoTuneErr
            mstn_AddAbortHandler "msat_AutoTuneAbortHdlr"
            
            if (state=0) or (state=1) or (state=3) or (state=4) then
              print ReadResource$("tunemac",ID_TUNEMAC_LOADING_ATUNES_579)
              MSGetTuneFile _tunepath$+"atunes.tun",0,,1   !* Load positive polarity, standard scan mode
              print ReadResource$("tunemac",ID_TUNEMAC_POLARITY_SET_T_580)
              mstn_ChangePolarity 0,0
            else
              print ReadResource$("tunemac",ID_TUNEMAC_LOADING_ATUNES_579)
              MSGetTuneFile _tunepath$+"atunes.tun",1,,1   !* Load negative polarity, standard scan mode
              print ReadResource$("tunemac",ID_TUNEMAC_POLARITY_SET_T_581)
              mstn_ChangePolarity 1,0
            endif
            
            msparm polarity,charge                       !* Save current polarity
            
            if check(macro,msat_InitTuneMix)=0 then
              macro _automspath$ + "enutnmix.mac"
            endif
            
            AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SETTING_TO_THE_582)
            srcMode$ = MSGetIonSrc$()
            ! If MM-ES+APCI source, put in APCI ionization mode if not otherwise defined
            if (srcmode$ = "MM-ES+APCI") then
            	mmcheck = MMBoardUpdate() !* Check instrument for MM source compatibility
              if mmcheck > 0 then
                mmcheck$ = ReadResource$("tunemac",ID_TUNEMAC_THIS_INSTRUMEN_583) \
            	    + chr$(13) \
            	    + ReadResource$("tunemac",ID_TUNEMAC_WITH_THE_MULTI_584)\
            	    + chr$(13)+ chr$(13) \
            	    + ReadResource$("tunemac",ID_TUNEMAC_PLEASE_CONTACT_585)
            	  _button = alert(mmcheck$, 2)
            	  msat_AutoCleanup
            	  stop
            	endif
        
              ! If source type is multimode source, check whether the tunemix register
              ! holds the ionization mode.  If it doesn't, use the default ionization mode.
              lIonMode$ = "MM-APCI"		! Default ionization mode for multimode source.
              lRegIndex = msat_SelectTuneMix( "auto" )
              If ( ObjHdrType( TuneMixReg[lRegIndex], "IonisationMode"  ) = 0 ) then
                lIonMode$ = ObjHdrText$( TuneMixReg[lRegIndex], "IonisationMode" )
              EndIf
              
              If ( lDebug > 0 ) or ( GetVerbose() > 0 ) then
                Print "MSAT_Auto: TuneMixReg Index =", lRegIndex
                Print "           IonMode =""" + lIonMode$ + """"
              EndIf
              
            	MSMode lIonMode$
            endif ! srcmode$ = "MM-ES+APCI"
            
            msat_SetMode charge !* Check for valid source/ionization modes
            
            if msat_srctype = 2 then                     !* Make sure lamp on if APPI
              MSSCQuery "config:src:appi:stat?", APPIstat$
              APPItemp$ = Substring$(APPIstat$,1,,",")
              if (val(APPItemp$) <> 1) then              !* Lamp is off, so turn it on
                msscwrite "config:src:appi:lamp 1"
                print ReadResource$("tunemac",ID_TUNEMAC_TURNING_ON_APP_586)
                sleep 15
              endif
            endif !msat_srctype = 2
            
            print msat_initTuneMixReg()       !* Updates the tunemix register to the default version
            
            !* Check for AtuneReg, if it doesn't exist, 
            !* or it can't be loaded from disk, then exit this macro 
            msat_CheckAtuneReg   ! Sets the global MSManShow for autotune menu
            lAtuneRegInit = MSManShow
            
            ! Obtain the correct index for tune parameters.
            TuneRegIndex = msat_SelectTuneMix("Auto")
            mstn_UpdateStatusBar                         !* Updates the window
            ! deselect 6th mass.  msat_ApplyTuneMix will determine whether 6th mass will be used
            MSMassValue 6,,,,0
                
            msat_AutotuneInit srcMode$,TuneRegIndex !* Loads correct index from tunemix register
            AtunePrint "Initializing masses and scan parameters."
            msat_ApplyTuneMix TuneRegIndex,,,1           !* Sets the masses and scan parameters
            
            ! CPL 10/20/09 Start  
            ! Set the abundance targets using msat_LoTarget & msat_HiTarget function calls
            
            LoAb = msat_LoTarget()
            HiAb = msat_HiTarget()
            
            ! CPL 10/20/09 End    
                
            ! CPL 05/10/07: Use source-specific target abundances for 6100 series
            ! Get the values for low and high abundance from the appropriate register
            lRegIndex = MSAT_SelectTuneMix( "auto" ) ! CPL 061115: Returns TuneMixReg Index
            If ( ObjHdrType( TuneMixReg[ lRegIndex ], "GainLowAbund" ) = 1 ) then
              LoAb = ObjHdrVal( TuneMixReg[ lRegIndex ], "GainLowAbund" )
            Endif
            If ( ObjHdrType( TuneMixReg[ lRegIndex ], "GainHighAbund" ) = 1 ) then
              HiAb = ObjHdrVal( TuneMixReg[ lRegIndex ], "GainHighAbund" )
            Endif
            If ( lDebug > 0 ) then
              Print "msat_Auto (Pos): LoAb, HiAb, lRegIndex =", LoAb, HiAb, lRegIndex
              Print "msat_Auto (Pos): SRCMode, MSat_SRCType =", SRCMode, MSat_SRCType
            Endif
            ! CPL 05/10/07: End
            
            ! CPL 05/03/10: Check the GainCurve register and initialize if necessary:
              if (RegSize(GainCurve) < 2) then
                print msat_InitGainCurveReg()  ! Initialize GainCurve register 
                ResetEMGain,,1                 ! Set GainCurve data register to default values
              else
                if (Data (GainCurve[Charge+2], 0,1)=0) then
                  ResetEMGain,,1               ! No data exists, set GainCurve data register to default values
                endif       
              endif 
            
            MSStepsize saveStepsize
            MSAverages saveAverage
            ! Make sure emgain is used
            MSUseEmv 0
            ! Start autotune with Gain of 1.0
            MSParm Gain,,1    
            
            AtunePrint ReadResource$("tunemac",ID_TUNEMAC_CHECKING_VACUU_587)
            msat_CheckVac                                 !check vacuum status
            
            AtunePrint ReadResource$("tunemac",ID_TUNEMAC_CHECKING_TEMPE_588)
            msat_CheckZones msat_srctype,TuneRegIndex     !check temp and pressure zones
               
            AtunePrint ReadResource$("tunemac",ID_TUNEMAC_CALIBRANT_IS_T_589)
            msat_CalSwitch 1                     !turn calibrant ON, based on installed source
            
            AtunePrint ReadResource$("tunemac",ID_TUNEMAC_CHECKING_TUNE_590)
            msat_CheckTune ,,,1,charge           !run Check Tune to see if tune looks good already
             
            ! Calculate the number of criteria that failed in CheckTune.
            NumCheckTuneFails = msat_PWFail + msat_MAFail
            if msat_ABFail > 0 then
              NumCheckTuneFails = NumCheckTuneFails + 1
            endif
            ! Gets the number of tune masses available, also represents highest mass number
            MSMassValue 0,NumMasses
            ! Set the checkPeaks flag
            if NumCheckTuneFails = 0 then
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_AUTOTUNE__NO_A_591)
              checkPeaks = 0      ! no adjustments needed
            else
              checkPeaks = 1      ! adjustments needed
            endif
            
            if checkPeaks = 1 then       ! No changes made unless it failed CheckTune
              ! Initialize strings: 
              a$=" "
              b$=" "
              c$=" "
              d$=" "
              e$=" "
              f$=" "
              MSDynamic list,a$,b$,c$,d$,e$,f$
              ! Create one long list of dynamic lenses 
              a$=a$+","+b$+","+c$+","+d$+","+e$+","+f$
              a$=ConvertText$(upper,a$)
               
              if (MSD_SL = 0) and (MSD_HT = 0) then
                AtunePrint ReadResource$("tunemac",ID_TUNEMAC_LINKING_SKIMME_592)
                MSUnlinkParms 0                     !* Link fragmentor and Skim1
              else
                ! Check to see if Lens2DC is in the list:
                b$=ConvertText$(upper,"Lens2DC")
                if instr(a$,b$) > 0 then            ! it has been dynamically ramped
                  MSDynamic Lens2DC,disable
                endif
                if (MSD_RF = 1) then
                ! Disable any Lens2RF parameters:             ! SL or HT model with Lens2RF
                ! Check to see if Amplitude is in the list:   (Must disable Amplitude before querying Enable)
                b$=ConvertText$(upper,"Lens2RFAmplitude")
                  if instr(a$,b$) > 0 then          ! it has been dynamically ramped
                    MSDynamic Lens2RFAmplitude,disable
                  endif
                ! Disable the Lens2RF check box if enabled:
                MSParm Lens2RFEnable,OldRFen
                  if OldRFen=1 then
                    AtunePrint ReadResource$("tunemac",ID_TUNEMAC_DISABLING_LENS_593)
                    MSParm Lens2RFEnable,,0
                  endif
                endif !(MSD_RF = 1)
              endif !(MSD_SL = 0) and (MSD_HT = 0)
            
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_FINDING_TUNE_M_594)
              msat_FindPeaks charge             !finds the peaks for calibrating
                
              if (MSD_46 = 1) then              ! if it's a G1946x MSD.
                if (charge = 0) then              ! only do octopole optimization in positive polarity
                  AtunePrint ReadResource$("tunemac",ID_TUNEMAC_OPTIMIZING_OCT_595)
                  msat_octopole
                endif
              else
                b$=ConvertText$(upper,"opolP")
                if instr(a$,b$) > 0 then        ! it has been dynamically ramped
                  MSDynamic opolP,disable
                endif
                MSParm opolP,,650               ! Octople set to 650 for SL & HT models
              endif !(MSD_46 = 1)
            
              if MSD_RF = 1 then                ! If it's an SL or HT model with Lens2RF,
                msat_RFOpt                      ! Optimize the Lens2RF parameters.
                msat_WOramp 0.65, 0.05          ! Readjust the peakwidths, (WO ramp only).
                MSProfile                       ! To make sure report has correct settings.
              endif
            
              msat_CheckGainCurve 1           ! Adjust the Gain/EMV curve
              msat_WOramp 0.65, 0.05          ! Readjust the peakwidths, (WO ramp only).
              msaxis
            endif !* if checkPeaks =1
            
            if charge = 0 then
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_GENERATING_POS_596)
              mstn_DoGenReport ,3                       !print report for atunes.tun for positive mode
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SAVING_PROFILE_597)
              msat_SaveAtune 0                          !saves profile and scan data in atune register
            else 
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_GENERATING_NEG_598)
              mstn_DoGenReport ,3                       !print report for atunes.tun for negative mode
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SAVING_PROFILE_599)
              msat_SaveAtune 0                          !saves profile and scan data in atune register
            endif
            
            if (state = 2) or (state = 5) then
            !* Negative mode only, standard or standard and fast scan selected.
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SAVING_NEGATIV_600) 
              MSSaveTuneFile "atunes.tun",1              !saves atunes.tun for negative mode      
              ! Perform the fast scan tune adjustment:
              if (MSD_SL = 1) and (state = 5) then
                msat_FastScan charge,TuneRegIndex,state
              else
                if (MSD_HT = 1) and (state = 5) then
                  msat_UltraFastScan charge,TuneRegIndex,state
                endif
              endif        
            else
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SAVING_POSITIV_601)
              MSSaveTuneFile "atunes.tun",0              !saves atunes.tun for positive mode
              ! Perform the fast scan tune adjustment:
              if (MSD_SL = 1) and ((state = 3) or (state = 4)) then
                msat_FastScan charge,TuneRegIndex,state
              else
                if (MSD_HT = 1) and ((state = 3) or (state = 4)) then
                  msat_UltraFastScan charge,TuneRegIndex,state
                endif      
              endif
            endif !(state = 2) or (state = 5)
            
            mstn_UpdateStatusBar                       !* Updates the window
            
            if (state=0) or (state=3) then
              msdynamic massoffset,disable           !* Disables massOffset to get initial value
              ! Saving positive tune massOffset value.
              msparm massOffset,oldMassOffset
              ! Saving positive tune widthOffset value.
              ! msdynamic widthOffset,read,1,x,y     !* Mass(x), value(y) of 1st point in dynamic ramp 
              msdynamic widthOffset,disable          !* Disables widthOffset to get initial value
              msparm widthOffset,oldWidthOffset
              ! Saving positive tune widthGain value.
              msparm widthGain,oldWidthGain
              ! Saving positive tune massGain Value.
              msparm massGain,oldMassGain
              if MSD_46 = 1 then
              ! Saving positive tune octopole knee value.
                msparm opolK,oldOpolK
              endif
              ! Saving positive tune octopole peak value.
              msparm opolP,oldOpolP
            
              ! Load negative polarity tune file
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_LOADING_ATUNES_579)
              MSGetTuneFile  _tunepath$+"atunes.tun",1,,1
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_POLARITY_SET_T_581)
              
              mstn_ChangePolarity 1,0                    !switch to negative polarity
              msparm polarity,charge
            
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SETTING_TO_THE_582)
              srcMode$ = MSGetIonSrc$()
              ! If MM-ES+APCI source, put in APCI ionization mode
              if (srcmode$ = "MM-ES+APCI") then
                ! The source is a multimode source. 
                ! The default ionization mode is MM-APCI. 
                ! If the tunemix register holds the ionization mode, use it.
                lIonMode$ = "MM-APCI"		! That is the default.
                lRegIndex = msat_SelectTuneMix( "auto" )
                if (ObjHdrType( TuneMixReg[lRegIndex], "IonisationMode" ) = 0) then
                  lIonMode$ = ObjHdrText$(TuneMixReg[lRegIndex], "IonisationMode")
                endIf
                        
                if ( lDebug > 0 ) or ( Getverbose() > 0 ) then
                  Print "MSAT_Auto: TuneMixReg Index =", lRegIndex
                  Print "           IonMode =""" + lIonMode$ + """"
                endIf
                
                MSMode lIonMode$
              endif ! srcmode$ = "MM-ES+APCI"
                    
              msat_SetMode charge !* Apply correct source and ionization mode
              TuneRegIndex = msat_SelectTuneMix("Auto")  !uses the correct register for getting the tunefile values
              !deselect 6th mass.  msat_ApplyTuneMix will determine whether 6th mass will be used
              MSMassValue 6,,,,0
            
              msat_AutotuneInit srcMode$,TuneRegIndex
              AtunePrint "Initializing masses and scan parameters."
              msat_ApplyTuneMix TuneRegIndex,,,1         !sets the masses and scan parameters
                   
              ! Check the GainCurve register and initialize if necessary:
              if (RegSize(GainCurve) < 2) then
                print msat_InitGainCurveReg()  ! Initialize GainCurve register 
                ResetEMGain,,1                 ! Set GainCurve data register to default values
              else
                if (Data (GainCurve[Charge+2], 0,1)=0) then
                  ResetEMGain,,1               ! No data exists, set GainCurve data register to default values
                endif       
              endif      
                                      
              !Make sure emgain is used
              MSUseEmv 0
              ! Start autotune with Gain of 1.0
              MSParm Gain,,1
              MSStepsize saveStepsize
              MSAverages saveAverage
            
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_CHECKING_TEMPE_588)
              msat_CheckZones msat_srctype,TuneRegIndex     !check temp and pressure zones
              
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_CALIBRANT_IS_T_589)
              msat_CalSwitch 1                           !turn calibrant ON, based on installed source
              
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_CHECKING_TUNE_590)
              msat_CheckTune ,,,1,charge                 !a quick look to see if tune looks good already
             
              ! Calculate the number of criteria that failed in CheckTune.
              NumCheckTuneFails = msat_PWFail + msat_MAFail
              if msat_ABFail > 0 then
                NumCheckTuneFails = NumCheckTuneFails + 1
              endif
              
              ! Gets the number of tune masses available, also represents highest mass number
              MSMassValue 0,NumMasses
      
              ! Set the checkPeaks flag
              if NumCheckTuneFails = 0 then
                AtunePrint ReadResource$("tunemac",ID_TUNEMAC_AUTOTUNE__NO_A_602)
                checkPeaks = 0      ! adjustments needed
              else
                checkPeaks = 1      ! adjustments needed
              endif
            
              if checkPeaks = 1 then       ! No changes made unless it failed CheckTune 
                ! Initialize strings: 
                a$=" "
                b$=" "
                c$=" "
                d$=" "
                e$=" "
                f$=" "
                MSDynamic list,a$,b$,c$,d$,e$,f$
                ! Create one long list of dynamic lenses 
                a$=a$+","+b$+","+c$+","+d$+","+e$+","+f$
                a$=ConvertText$(upper,a$)
            
                if (MSD_SL = 0) and (MSD_HT = 0) then
                  AtunePrint ReadResource$("tunemac",ID_TUNEMAC_LINKING_SKIMME_592)
                  MSUnlinkParms 0                          !* Link fragmentor and Skim1
                else
                  if (MSD_RF = 1) then
                    ! Disable any Lens2RF parameters:             ! SL model with Lens2RF
                    ! (Have to disable Amplitude before querying Enable)
                    ! Check to see if Amplitude is in the list:
                    b$=ConvertText$(upper,"Lens2RFAmplitude")
                    if instr(a$,b$) > 0 then            ! it has been dynamically ramped
                      MSDynamic Lens2RFAmplitude,disable
                    endif
                    ! Check to see if DC is in the list:
                    b$=ConvertText$(upper,"Lens2DC")
                    if instr(a$,b$) > 0 then            ! it has been dynamically ramped
                      MSDynamic Lens2DC,disable
                    endif
                    ! Disable the Lens2 RF, if enabled:
                    MSParm Lens2RFEnable,OldRFen
                    if OldRFen=1 then
                      AtunePrint ReadResource$("tunemac",ID_TUNEMAC_DISABLING_LENS_593)
                      MSParm Lens2RFEnable,,0
                    endif
                  endif !(MSD_RF = 1)
                endif ! (MSD_SL = 0) and (MSD_HT = 0)
            
                if lAtuneRegInit = 0 then     ! couldn't find AtuneReg at start of autotune
                  AtunePrint "Initializing tune parameters."
                  msat_ApplyTuneMix TuneRegIndex,1        !initialize all variables to default values
                endif
                
                !* Disable widthOffset and massOffset to apply values from positive tune.
                msdynamic widthOffset,disable              !makes sure WidthOffset is disabled to get one value
                msdynamic massOffset,disable               !make sure MassOffset is disabled to get one value
          
                ! Initializing negative tune widthOffset value from positive tune.
                msparm widthOffset,,oldWidthOffset        !start with good values for WidthOffset
          
                ! Initializing negative tune massOffset value from positive tune.
                msparm widthGain,,oldWidthGain             !start with good values for WidthGain
          
                ! Initializing negative tune widthGain value from positive tune.
                msparm massOffset,,oldMassOffset          !start with good values for MassOffset
            
                ! Initializing negative tune massGain value from positive tune.
                msparm massGain,,oldMassGain              !start with good values for MassGain
          
                ! Initializing octopole parameters.
                if (MSD_46 = 1) then
                  AtunePrint ReadResource$("tunemac",ID_TUNEMAC_INITIALIZING_N_603)
                  msparm opolK,,oldOpolK                   !* set OpolK
                  AtunePrint ReadResource$("tunemac",ID_TUNEMAC_INITIALIZING_N_604)
                  msparm opolP,,oldOpolP                   !* set OpolP
                else
                  b$=ConvertText$(upper,"opolP")
                  if instr(a$,b$) > 0 then        ! it has been dynamically ramped
                    MSDynamic opolP,disable
                  endif
                  MSParm opolP,,650               ! Octople set to 650 for SL & HT models
                endif ! (MSD_46 = 1) 
                  
                ! 10/20/09 CPL Start  
                ! Set the abundance targets using msat_LoTarget & msat_HiTarget function calls
                
                LoAb = msat_LoTarget()
                HiAb = msat_HiTarget()
                
                ! 10/20/09 CPL End                            
                      
                ! CPL 070510: Uses source-specific target abundances for 6100 series
                ! Get the values for low and high abundance from the appropriate register
                lRegIndex = MSAT_SelectTuneMix( "auto" ) ! CPL 061115: Returns TuneMixReg Index
                If ( ObjHdrType( TuneMixReg[ lRegIndex ], "GainLowAbund" ) = 1 ) then
                  LoAb = ObjHdrVal( TuneMixReg[ lRegIndex ], "GainLowAbund" )
                Endif
                If ( ObjHdrType( TuneMixReg[ lRegIndex ], "GainHighAbund" ) = 1 ) then
                  HiAb = ObjHdrVal( TuneMixReg[ lRegIndex ], "GainHighAbund" )
                Endif
              
                If ( lDebug > 0 ) then
                  Print "msat_Auto (Neg): LoAb, HiAb, lRegIndex =", LoAb, HiAb, lRegIndex
                  Print "msat_Auto (Neg): SRCMode, MSat_SRCType =", SRCMode, MSat_SRCType
                Endif
                ! CPL 070510: End
        
                AtunePrint ReadResource$("tunemac",ID_TUNEMAC_FINDING_TUNE_M_594)
                msat_FindPeaks charge,1            !finds the peaks for calibrating
            
                if MSD_RF = 1 then                 ! If it's an SL with Lens2RF,
                  msat_RFOpt                       !   optimize the L2 RF parameters.
                  msat_WOramp 0.65, 0.05           ! Readjust the peakwidths, (WO ramp only).
                  MSProfile                        ! To make sure report has correct settings.
                endif
          
                msat_CheckGainCurve 1
              endif !* if checkPeaks =1
            
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_GENERATING_NEG_598)
              mstn_DoGenReport ,3                  !print report for atunes.tun for negative mode
              !* Save Negative tables in last object; set parameter to 1
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SAVING_PROFILE_599)
              msat_SaveAtune 1                     !saves profile and scan data in atune register
            
              AtunePrint ReadResource$("tunemac",ID_TUNEMAC_SAVING_NEGATIV_600)
              MSSaveTuneFile "atunes.tun",1        !saves atunes.tun for negative mode
                  
              ! Perform the fast scan tune adjustment:
              if (MSD_SL = 1) and ((state=3) or (state=5)) then
                msat_FastScan charge,TuneRegIndex,state
              else
                if (MSD_HT = 1) and ((state=3) or (state=5)) then
                  msat_UltraFastScan charge,TuneRegIndex,state
                endif ! (MSD_HT = 1)
              endif !(MSD_SL = 1)
            
              ! alert user if multiplier getting high:
              if instr(GainMsg$,"Warning") > 0 then
                _button = Alert(ReadResource$("tunemac",ID_TUNEMAC_WARNING__THE_M_605) + chr$(13) + \
                          "Autotune completed, but system maintenance should be performed.",3)
                AtunePrint ReadResource$("tunemac",ID_TUNEMAC_WARNING__THE_M_606)
              endif
            endif    !* if (state=0) or (state=3)
            
            msat_AutoCleanup saveStepsize, saveAverage            
            AtunePrint ReadResource$("tunemac",ID_TUNEMAC_AUTOTUNE_COMPL_607)
            
            endmacro !msat_auto
            
            !===============================================================================================            
            !===============================================================================================
            name GetIonSource       ! Get numeric value for Ion Source
                                    ! -1 if it fails
                                    ! 0 = API_ES
                                    ! 1 = APCI
                                    ! 2 = APPI
                                    ! 3 = Multi mode
                                    ! 4 = Nano source  (6100 Series and above)
                                    ! 5 = ChipCube     (6100 Series and above)
                                    ! 6 = AJS-ES       (6100 Series and above)
            !===============================================================================================
            Local lSrcType$
            Local lDebug;   lDebug = 0 
            
                lSrcType$ = MSGetIonSrc$()        ! Which source is physically installed.
                lSrcType$ = ConvertText$( upper, lSrcType$ )
                If ( lDebug > 0 ) or ( GetVerbose() > 0 ) then
                    Print "GetIonSource(): Source type =", lSrcType$
                Endif
                If lSrcType$ = "AJS-ES" then
                    Return 6
                Endif   
                If lSrcType$ = "CHIPCUBE" then
                    Return 5
                Endif
                If lSrcType$ = "NANOESI" then
                    Return 4
                Endif
                If lSrcType$ = "MM-ES+APCI" then
            	Return 3
                Endif
                If lSrcType$ = "APPI" then
                    Return 2
                Endif
                If lSrcType$ = "APCI" then
                    Return 1
                Endif
                If lSrcType$ = "API_ES" then
                    Return 0
                Endif
                Return -1 
            endmacro    ! End of GetIonSource()
            
            !***********************************************************************************************
            !********* end of file *************************************************************************
