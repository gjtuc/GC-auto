!+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
!  These MACROs are the common macros that are called when tune is invoked.
!  They take care of testing for the current instrument configuration and
!  call the proper set of macros for tuning or diagnostics. IT IS STRONGLY 
!  RECOMMENDED THAT NO MODIFICATIONS BE MADE TO THESE MACROS.
!+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
!
!===============================================================================================
! MACROS:  
!         MSTN_AddAbortHandler         MSTN_Error   
!         MSTN_RemoveAbortHandler      MSTN_Error2
!         MSTN_RemoveAbortHdlrParam
!                                      MSTN_ExitRoutine
!         MSTN_CPSafeStart             MSTN_LastSlash
!         MSTN_CPSafeTerminate
!                                      MSTN_SelectFile$
!         MSTN_ChangeTitle             MSTN_ErrSelectFile
!         MSTN_DiffStr$                 
!                                      MSTN_UserStart 
!         MSTN_DoDispPrint             
!         MSTN_DoError                 MSTN_ViewFile      
!         MSTN_DoTrace                 MSTN_ViewTrace          
!     
!===============================================================================================
! GLOBAL VARIABLES:
!
!         _TunePath$       MSTN_ACQINPROG       SNAPSHOT    
!         FILEPROMPT       MSTN_AtuneError      TuneFileName$       
!         LASTPRINT$       MSTN_DoPrint         TUNESIZE          
!         MCTOCLOSEF       MSTrace              TuneTraceName$        
!         MSDATAFILE$      MSTuneTraceState     TuneTracePath$
!         MSFILEINSTRNUM   QUAD_MAX             TUNETYPE$
!         MSFILENUM        SCANNUMON            UNATTENDED  
!         MSManCalOpenF              
!                                           
!===============================================================================================
!
!===============================================================================================
NAME MSTN_AddAbortHandler

parameter handler$
! Routine to add a command or macro to the _abort$ string global
! This sets an abort handler
!====================================================================
  if check (Variable,_Abort$) = 1 then
       if _Abort$ = "" then
            _Abort$ = handler$
       else
            _Abort$ = handler$ + ";" + _Abort$
       endif
  else
       _Abort$ = handler$
  endif

ENDMACRO     !MSTN_AddAbortHandler



!====================================================================
NAME MSTN_RemoveAbortHandler
parameter hdlrName$
!  Routine to remove a substring from the _Abort$ string based on
!  whether hdlrName$ is in a substring of _Abort$
!====================================================================
local i, NewAbort$, current_handler$

  i = 1
  NewAbort$ = ""
  hdlrName$ = ConvertText$("upper",hdlrName$)
  if check (Variable,_Abort$) = 1 then
       current_handler$ = substring$(_Abort$,i,,";")
       while current_handler$ <> ""
            current_handler$ = ConvertText$("upper",current_handler$)
            if instr (current_handler$,hdlrName$) = 0
                 if len(NewAbort$) = 0 then
                      NewAbort$ = substring$(_Abort$,i,,";")  !current_handler$
                 else
                      NewAbort$ =  NewAbort$ + ";" + current_handler$
                 endif
            endif
            i = i + 1
            current_handler$ = substring$(_Abort$,i,,";")
       endwhile
       _Abort$ = NewAbort$
  endif

ENDMACRO     !MSTN_RemoveAbortHandler


!=========================================================================
name MSTN_RemoveAbortHdlrParam
parameter hdlrName$
!
!  Routine to remove a substring from the _Abort$ string based on
!  whether hdlrName$ is in a substring of _Abort$; differs from
!  MSTN_RemoveAbortHandler because this this does it based on a substring
!  for abort handlers that take parameters
!=========================================================================
local str$, i, NewAbort$
  
  i = 1
  hdlrName$ = ConvertText$("upper",hdlrName$)
  if check (Variable,_Abort$) = 1 then
    repeat
      str$ = ConvertText$("upper",substring$(_Abort$,i,,";"))
        i = i + 1
        if Instr(str$,hdlrName$)=0 AND str$ <> ""
          if len(NewAbort$) = 0 then
            NewAbort$ = str$
          else
          NewAbort$ =  NewAbort$ + ";" + str$
          endif
        endif
    until str$ = ""
    _Abort$ = NewAbort$
  endif
endmacro           !MSTN_RemoveAbortHdlrParam



!====================================================================
NAME MSTN_CPSafeStart
parameter name$
!====================================================================
local i, tmpname$

   i = 1
   tmpname$ = CPName$(i)
   while len(tmpname$) > 0
        if ConvertText$(upper,tmpname$) = ConvertText$(upper,name$) then
             return
        else
             i = i + 1
             tmpname$ = CPName$(i)
        endif
   endwhile 
   CPStart name$

ENDMACRO     !MSTN_CPSafeStart

!====================================================================
NAME MSTN_CPSafeTerminate
parameter name$
!====================================================================
local i, tmpname$

   i = 1
   tmpname$ = CPName$(i)
   while len(tmpname$) > 0
        if ConvertText$(upper,tmpname$) = ConvertText$(upper,name$) then
             CPTerminate name$
             return
        else
             i = i + 1
             tmpname$ = CPName$(i)
        endif
   endwhile 

ENDMACRO     !MSTN_CPSafeTerminate



