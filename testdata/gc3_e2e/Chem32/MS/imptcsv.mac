
! ==============================================================================
! Function Name:   vClearVariables
! Function Description:
!    This routine sets NULL to all of the global variables for the "Import CSV".
! Parameter Passed-In:
!    None.
! Function Return:
!    None.
! Revision History:
! 01/02/01 YD  First created.
! ==========================================================================
name vClearVariables

  ! The general global string buffer
  sBuf$ = ""

  ! The string buffer for the header names defined in the CSV file
  sHeader$ = "" 

  ! The string buffer for the header names in the stabhdr.txt or xtabhdr.txt file
  sTextHdr$ = "" 

  ! The string buffer for the header alias names
  sTextAlias$ = ""

  ! The string buffer for the compound names defined in the CSV file
  sCompName$ = ""

  ! The total number of header names defined in the CSV file
  iTotalCol = 0 

  ! The total number of header names in the stabhdr.txt or xtabhdr.txt file
  iTotalTextHdr = 0  

  ! The total number of compounds defined in the CSV file
  iTotalComp = 0 
   
  ! The total number of alias names.
  iAlias = 0

  ! The column names used inteally by the ChemStation
  sStable$ = ""
  sXtable$ = ""

endmacro


! ==============================================================================
! Function Name:   vInitVariables
! Function Description:
!    This routine sets the initial values to the global variables for the
!    "Import CSV".
! Parameter Passed-In:
!    None.
! Function Return:
!    None.
! Revision History:
! 01/02/01 YD  First created.
! ==========================================================================
name vInitVariables

  ! The general global string buffer
  sBuf$ = ""

  ! The string buffer for the header names defined in the CSV file
  sHeader$ = "" 

  ! The string buffer for the header names in the stabhdr.txt or xtabhdr.txt file
  sTextHdr$ = "" 

  ! The string buffer for the header alias names
  sTextAlias$ = ""

  ! The string buffer for the compound names defined in the CSV file
  sCompName$ = ""

  ! The total number of header names defined in the CSV file
  iTotalCol = 0 

  ! The total number of header names in the stabhdr.txt or xtabhdr.txt file
  iTotalTextHdr = 0  

  ! The total number of compounds defined in the CSV file
  iTotalComp = 0 
   
  ! The total number of alias names.
  iAlias = 0

  ! The column names used inteally by the ChemStation
  sStable$ = "LOCATION,SAMPLENAME,METHOD,INJVIAL,SAMPLETYPE,CALLEVEL,UPDATERF,UPDATERT,INTERVAL,AMOUNT,ISTDAMT,MULTIPLIER,DILUTION,DATAFILENAME,INJVOLUME,SAMPLEINFO,CALLINE,"
  sXtable$ = "LOCATION,SAMPLENAME,METHOD,INJVIAL,SAMPLETYPE,CALLEVEL,CALIBACTION,UPDATERT,INTERVAL,AMOUNT,ISTDAMT,MULTIPLIER,DILUTION,DATAFILENAME,INJVOLUME,SAMPLEINFO,SAMPLEID,CALLINE,"

endmacro


! ==============================================================================
! Function Name:   sFindCSVFile$
! Function Description:
!    This routine let user select a CSV file to be inported to the sequence table.
! Parameter Passed-In:
!    sMode$ - Specify if this is for the STANDARD or EXTENDED sequence table.
! Function Return:
!    The full path of the CSV file name.
! Revision History:
! 12/30/00 YD  First created.
! ==========================================================================
name sFindCSVFile$  
   parameter sMode$  default "STANDARD"
   local iRet
   local sPath$, sFile$
   local iType  
   local iLen

   on error print
   iType = 0  
   sPath$ = _SEQPATH$
   while (iType <> 1)
      sFile$ = ""
      if sMode$ = "EXTENDED"
         iRet = SelectFile(1, "Please select a CSV file for importing to DEF_LC.SE:", "CSV(*.CSV)", sPath$, sFile$, iType)
      else 
         iRet = SelectFile(1, "Please select a CSV file for importing to DEF_LC.S:", "CSV(*.CSV)", sPath$, sFile$, iType)         
      endif
      if (iRet = 0)
         return ""
      endif
      if (iRet = 2)
         if (iType = 1)
            return sPath$+sFile$
          else  
            iType = 0
         endif
      else
         ! iRet = SelectFile(1, "Please select a CSV file for importing to " + _SEQFILE$ + ":", "CSV(*.CSV)", sPath$, sFile$, iType)
         iType = 0             
      endif
   endwhile
   
endmacro


! ==============================================================================
! Function Name:   vClearnupTable
! Function Description:
!    This routine cleans up the sequence table.
! Parameter Passed-In:
!    sMode$ - Specify if this is for the STANDARD or EXTENDED sequence table.
! Function Return:
!    None.
! Revision History:
! 12/30/00 YD  First created.
! ==========================================================================
name vCleanupTable
    parameter sMode$ default "STANDARD"
    local iTabLen
    local i
    local sCol$
    local iMaxCol
    
    on error print
    if sMode$ = "EXTENDED"
       iMaxCol = 18
    else
       iMaxCol = 17
    endif
    
    DelTabRow _Sequence[1], SeqTable1, -1   
    iTabLen = TabHdrVal(_Sequence[1], SeqTable1, "NumberOfCol")
    if iTabLen > iMaxCol
       for i=18 to iTabLen
          sCol$ = TabColName$ (_Sequence[1], SeqTable1, i)
          DelTabCol _Sequence[1], SeqTable1, sCol$
       next i
    endif

endmacro 


! ==============================================================================
! Function Name:   vDisableSequenceMenu
! Function Description:
!    This routine disables some of the sequence menus, such as Sequence Table,
!    Sequence Parameters, New Sequence, Load Sequence, Save Sequence As,
!    Import from CSV, Partial Sequence.
! Function Return:
!    None.
! Revision History:
! 01/08/01 YD  First created.
! ==========================================================================
name vDisableSequenceMenu
    
    on error print
    
    MenuState "&Sequence", "Sequence Para&meters...", Insensitive  
    MenuState "&Sequence", "Sequence &Table...", Insensitive    
    MenuState "&Sequence", "Pa&rtial Sequence...", Insensitive    
    
    if iEnableExtSeq() = 1
        MenuState "&Sequence", "&New Sequence|&Standard", Insensitive   
        MenuState "&Sequence", "&New Sequence|&Extended", Insensitive  
        MenuState "&Sequence", "&Load Sequence|&Standard...", Insensitive   
        MenuState "&Sequence", "&Load Sequence|&Extended...", Insensitive 
        MenuState "&Sequence", "Save Sequence &As|&Standard...", Insensitive   
        MenuState "&Sequence", "Save Sequence &As|&Extended...", Insensitive 
        MenuState "&Sequence", "&Import from CSV|&Standard...", Insensitive   
        MenuState "&Sequence", "&Import from CSV|&Extended...", Insensitive                                            
    else
        MenuState "&Sequence", "&New Sequence", Insensitive   
        MenuState "&Sequence", "&Load Sequence...", Insensitive   
        MenuState "&Sequence", "Save Sequence &As...", Insensitive   
        MenuState "&Sequence", "&Import from CSV...", Insensitive   
    endif
    
endmacro 




! ==============================================================================
! Function Name:   vEnableSequenceMenu
! Function Description:
!    This routine enables some of the sequence menus, such as Sequence Table,
!    Sequence Parameters, New Sequence, Load Sequence, Save Sequence As,
!    Import from CSV, Partial Sequence.
! Function Return:
!    None.
! Revision History:
! 01/08/01 YD  First created.
! ==========================================================================
name vEnableSequenceMenu
    
    on error print
    
    MenuState "&Sequence", "Sequence Para&meters...", Sensitive  
    MenuState "&Sequence", "Sequence &Table...", Sensitive    
    MenuState "&Sequence", "Pa&rtial Sequence...", Sensitive    
    
    if iEnableExtSeq() = 1
        MenuState "&Sequence", "&New Sequence|&Standard", Sensitive   
        MenuState "&Sequence", "&New Sequence|&Extended", Sensitive  
        MenuState "&Sequence", "&Load Sequence|&Standard...", Sensitive   
        MenuState "&Sequence", "&Load Sequence|&Extended...", Sensitive 
        MenuState "&Sequence", "Save Sequence &As|&Standard...", Sensitive   
        MenuState "&Sequence", "Save Sequence &As|&Extended...", Sensitive 
        MenuState "&Sequence", "&Import from CSV|&Standard...", Sensitive   
        MenuState "&Sequence", "&Import from CSV|&Extended...", Sensitive                                            
    else
        MenuState "&Sequence", "&New Sequence", Sensitive   
        MenuState "&Sequence", "&Load Sequence...", Sensitive   
        MenuState "&Sequence", "Save Sequence &As...", Sensitive   
        MenuState "&Sequence", "&Import from CSV...", Sensitive   
    endif
    
endmacro 




! ===================================================================
! Function Name:  iIsSequenceRunning
! Function Description:
!     This routine checks if the sequence is currently running or
!     not.
! Function Return:
!     1 if sequence is currently running.
!     0 otherwise.
! Revision History:
! 01/08/01 YD  First created.
! ===================================================================
name iIsSequenceRunning

    if (Check(Variable, _SequenceOn)  = 1)
      if _SequenceOn = 1
         iRet = Alert ("Cannot import CSV to sequence table while sequence is running.", 3, "Import CSV")
         return 1
       endif
    endif 
    
    return 0
    
endmacro   


! ==============================================================
! Function Name:      ImportCSVFile  
! Function Description:
!     This is the main routine to do the "Import CSV" task.
! Parameter Passed-In:
!    sMode$ - A string for the standard or extended sequence
!             table. A valid string must be either "STANDARD"
!             or "EXTENDED". The default is "STANDARD".
!    sCSVFile$ - The name of the CSV file to be imported.
! Revision History:
! 12/15/00 YD  First created.
! ==============================================================
name ImportCSVFile
    parameter sMode$  default "STANDARD"
    parameter sCSVFile$  default ""    
    ! local sCSVFile$
    ! local sBuf$
    local iLines
    local iRet
    local iLen
    local iPos

    on error print  

    if iIsSequenceRunning() = 1
       return
    endif
    
    sMode$ = UpperCase$(sMode$)
    if (sMode$ <> "STANDARD") AND (sMode$ <> "EXTENDED")
        iRet = Alert ("Invalid string " + sMode$ + " for the parameter sMode.", 3, "ImportCSVFile")
        return
    endif 
    
    ! iRet = Alert ("Importing CSV will replacing the information stored in the current sequence table in " + _SEQFILE$ + ". Do you want to continue?", 4, "Import CSV")
    ! if iRet <> 1
    !     return
    ! endif

    ! sCSVFile$ = "" 
    sCSVFile$ = sRemoveLeadingBlanks$(sCSVFile$)
    if sCSVFile$ = ""
       sCSVFile$ = sFindCSVFile$(sMode$)
    endif
    
    if sCSVFile$ = ""
       return
    endif    
    
    if iCSVFileNameOK(sCSVFile$) <> 1
        iRet = Alert ("Error: Invalid CSV file name.", 3, "ImportCSVFile")
        return
    endif    
    
    if Check(VARIABLE, _SEQUENCECHANGED) = 1
       while _SEQUENCECHANGED <> 0
          iRet = Alert ("You have previously made some changes to the " + _SEQFILE$ + " file." + chr$(13) + chr$(10) + "Do you want to save this sequence file?", 5, "Import CSV")
          if iRet = -1
             return
          endif
          if iRet = 1
             SaveCurrentSequence
          endif
          if iRet = 0
             _SEQUENCECHANGED = 0
          endif
       endwhile
    endif 
    
    vInitVariables 
    
    vDisableSequenceMenu

    if sMode$ = "EXTENDED"
       SequenceNew "SE"
    else
       SequenceNew
    endif
    
    ! Open the user defined CSV file for read. #3 = CSV-file
    Open sCSVFile$ For Input As #3
    
    ! Check if we find the [Table] section in the CSV file.
    if iFindTableSection() <> 1
       iRet = Alert ("Error: Could not find the [Table] section in " + sCSVFile$ + ".", 3, "Import CSV")
       Close #3
       vClearVariables
       vEnableSequenceMenu
       on error
       return
    endif
    
    ! Check the CSV header names for errors. 
    message "Parsing the CSV headers..."
    if iCheckHeaders(sMode$) <> 1
       Close #3
       vClearVariables
       vEnableSequenceMenu             
       on error
       return
    endif 
    
    ! Clean up the current existing sequence table    
    message "Preparing the sequence table..."
    vCleanupTable sMode$        
        
    ! Need to setup the compound information
    if (sMode$ = "EXTENDED") AND (iTotalComp > 0)
       vUpdateExtHeader
    endif      

    ! vCleanupTable
    
    _SEQUENCECHANGED = 1
    iLines = 0
    while (sBuf$ <> "") AND (iLines < 999)
       sBuf$ = ""
       ! iLines = iLines + 1
       on error goto IMPORTCSVFILE1
       Input Using #3, "L", sBuf$
       if sBuf$ <> "" 
           on error print
           message "Processing sequence table line #" + VAL$(iLines+1) + " ..."
           if sMode$ = "STANDARD"
              vUpdateStdSeqTableRow sBuf$ 
           else
              vUpdateExtSeqTableRow sBuf$
           endif  
           iLines = iLines + 1           
       endif
    endwhile
    
IMPORTCSVFILE1:
     
    on error print
    
    if (sBuf$ <> "") AND (iLines >= 999)   
       on error print
       sBuf$ = ""
       ! Check if there are more lines to come-in
       Input Using #3, "L", sBuf$ 
       if (sBuf$ <> "")
          iRet = Alert ("Sequence Table only can handle 999 lines. The remaining lines in the CSV file will be truncated.", 2, "Import CSV")    
       endif
    endif
    
    Close #3     
    
    vClearVariables        
    vEnableSequenceMenu        

    if Check(VARIABLE, _SEQUENCECHANGED) = 1
       if _SEQUENCECHANGED <> 0
          iRet = Alert ("Please use the Sequence Table Editor under the Sequence menu to complete this Import CSV task.", 2, "Import CSV")
       endif
    endif   
    
    message "Please use the Sequence Table Editor to complete this Import CSV task."

endmacro



! ==============================================================================
! Function Name:   vUpdateExtHeader
! Function Description:
!    The original sHeader$ contains all the regular sequence table header names
!    as well as the compound names. This routine extracts the compound names
!    from the sHeader$, and put them into the sCompName$. In addition, this
!    routine also sets the "CompNames" table in the current sequence register
!    according to the information in the newly updated sCompName$.
! Function Return:  None.
! Revision History:
! 12/28/00 YD  First created.
! ==============================================================================
name vUpdateExtHeader
   local i  
   local iLen 
   local iIndex
   local sTedName$ 
   local sTabName$  
   local s1$, s2$

   on error print   
   if (iTotalCol <= 0)
     sCompName$ = sHeader$
     sHeader$ = ""
     return
   endif
   
   if (iTotalComp <= 0)
     sCompName$ = ""
     return
   endif
   
   iLen = LEN(sHeader$)
   if iLen <= 0
      return
   endif
   
   iIndex = 0
   i = 1
   while (iIndex < iTotalCol) AND (i <= iLen)
     if sHeader$[i] = ","
        iIndex = iIndex + 1
     endif
     i = i + 1
   endwhile
      
   sCompHdr$ = sHeader$[i:iLen]
   sHeader$ = sHeader$[1:(i-1)] 
     
   s1$ = sCompHdr$
   s2$ = sHeader$  
   
   if (ObjHdrType(_Sequence[1], "CompNames") = 4) 
       DelTabRow _Sequence[1], "CompNames", -1
   endif
   for i=1 to iTotalComp
       InsTabRow _Sequence[1], "CompNames", 
       sTabName$ = "Cmpd" + VAL$(i)
       sTedName$ = sGetNthTok$(sCompHdr$, i)
       SetTabText _Sequence[1], "CompNames", i, "TabName", sTabName$
       SetTabText _Sequence[1], "CompNames", i, "TedName", sTedName$ 
       NewColText _Sequence[1], SeqTable1, sTabName$, , 0, 13            
   next i

   return   

endmacro


! ==============================================================================
! Function Name:  vUpdateStdSeqTableRow
! Function Description:
!    Given a buffer (sBuf$) that contains a line of sequence information,
!    this routine appends a new row in the current sequence table, and
!    imports these information into this sequence row.
!    This routine is written for the standard sequence table only.
! Parameter Passed-In: sBuf$ - A string that contains one sequence line 
!                              under the [Table] section of the ginve CSV
!                              file.
! Function Returns:   None.
! Revision History:
! 12/28/00 YD  First created.
! ==============================================================================
name vUpdateStdSeqTableRow
   parameter sBuf$ default ""
   local iLen
   local i
   local sTok$
   local sCol$
   local iRow
   local sAlias$
   local iRet

   on error print
   iLen = LEN(sBuf$)
   if iLen < 1 
      ! we have nothing to do
      return
   endif

   if iTotalCol <= 0
     ! we have nothing to do.
     return
   endif

   InsTabRow _Sequence[1], SeqTable1,
   for i=1 to iTotalCol
     sTok$ = sGetNthTok$(sBuf$,i) 
     sAlias$ = sGetNthTok$(sHeader$, i) 
     sCol$ = sGetSeqHdr$(sAlias$)
     if sCol$ = ""
        ! This situation should never happen.
        iRet = Alert ("Error: Invalid sequence header name " + sAlias$ + " in the CSV file.", 3, "Import CSV")
        return
     endif
     iRow = TabHdrVal(_Sequence[1], SeqTable1, "NumberOfRows") 
     vUpdateStdSeqTblCol sCol$, sTok$, iRow
   next i

   return

endmacro
          
          
! ==============================================================================
! Function Name:  vUpdateExtSeqTableRow
! Function Description:
!    Given a buffer (sBuf$) that contains a line of sequence information,
!    this routine appends a new row in the current sequence table, as well as
!    the "CompNames" table, and imports these information into this sequence 
!    row.
!    This routine is written for the extended sequence table only.
! Parameter Passed-In: sBuf$ - A string that contains one sequence line 
!                              under the [Table] section of the ginve CSV
!                              file.
! Function Returns:   None.
! Revision History:
! 12/28/00 YD  First created.
! ==============================================================================
name vUpdateExtSeqTableRow
   parameter sBuf$ default ""
   local iLen
   local i
   local sTok$
   local sCol$
   local iRow
   local sAlias$
   local iRet

   on error print
   iLen = LEN(sBuf$)
   if iLen < 1
      return
   endif

   if iTotalCol <= 0
     ! Let's update the compound names
     goto UPDATEEXTSEQCOMP
   endif

   InsTabRow _Sequence[1], SeqTable1,   
   for i=1 to iTotalCol
     sTok$ = sGetNthTok$(sBuf$,i) 
     sAlias$ = sGetNthTok$(sHeader$, i) 
   
     sCol$ = sGetSeqHdr$(sAlias$)
     if sCol$ = ""  
        ! This should never happen.
        iRet = Alert ("Error: Invalid sequence header name " + sAlias$ + " in the CSV file.", 3, "Import Extended CSV")
        return
     endif
     iRow = TabHdrVal(_Sequence[1], SeqTable1, "NumberOfRows") 
     vUpdateExtSeqTblCol sCol$, sTok$, iRow
   next i 
   
UPDATEEXTSEQCOMP:

   if iTotalComp <= 0
     ! we don't need to do anything.
     return
   endif
   
   ! Now, lets update the compound names
   for i=1 to iTotalComp
     sTok$ = sGetNthTok$(sBuf$,iTotalCol+i) 
     sTabName$ = TabText$ (_Sequence[1], "CompNames", i, "TabName")
     iRow = TabHdrVal(_Sequence[1], SeqTable1, "NumberOfRows") 
     vUpdateExtSeqTblCol sTabName$, sTok$, iRow
   next i    

   return

endmacro
          
          

! ==============================================================================
! Function Name:   vUpdateVial
! Function Description:
!      This routine updates the vial location information in the sequence table.
!      WPS is supported in this routine.
! Parameter Passed-In:
!    sTok$ - The vial number string
!    iRow  - The row number in the sequence table.
! Function Return:   None.
! Revision History:
! 12/29/00 YD  First created.
! ==============================================================================
name vUpdateVial 
  parameter sTok$ default ""
  parameter iRow default 0 
  local sNum 
  local iRet

  on error print
  if iRow <= 0
    return
  endif  
  
  if (sTok$ = "") OR (sTok$ = "0") OR (sTok$[1] = "-") OR (InStr(sTok$, ".")>=1)
    iRet = Alert ("Invalid vial location " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + "." + chr$(13) + chr$(10) + "A defaul value 1 will be used.", 2, "Import CSV")
    SetTabVal _Sequence[1], SeqTable1, iRow, "Vial", 1
    return
  endif 
  
  ! Added WPS support.
  if Check(FUNCTION, GetPlatePosNumber) = 1
     sNum = GetPlatePosNumber(sTok$)
     if sNum <= 0
       iRet = Alert ("Invalid vial location " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + "." + chr$(13) + chr$(10) + "A defaul value 1 will be used.", 2, "Import CSV")
       SetTabVal _Sequence[1], SeqTable1, iRow, "Vial", 1
     else
       SetTabVal _Sequence[1], SeqTable1, iRow, "Vial", sNum     
     endif  
     return
  endif

  SetTabVal _Sequence[1], SeqTable1, iRow, "Vial", VAL(sTok$)

  return

endmacro



! ==============================================================================
! Function Name:   vUpdateMethod
! Function Description:
!      This routine updates the method name information in the sequence table.
!      WPS is supported in this routine.
! Parameter Passed-In:
!    sTok$ - The vial number string
!    iRow  - The row number in the sequence table.
! Function Return:   None.
! Revision History:
! 12/29/00 YD  First created.
! ==============================================================================
name vUpdateMethod 
  parameter sTok$ default ""
  parameter iRow default 0 
  local iPos 
  local iRet

  on error print
  if iRow <= 0
    return
  endif

  if sTok$ = ""
    iRet = Alert ("Invalid method name is specified for the sequence table line #" + VAL$(iRow) + ". DEF_LC.M will be used.", 2, "Import CSV")
    sTok$ = "DEF_LC"
  endif
       
  iPos = InStr(UpperCase$(sTok$), ".M")
     
  if iPos >= 1
     sTok$ = sTok$[1:(iPos - 1)]
  endif
  
  if filestat(MODE, _METHPATH$ + sTok$ + ".M") <> 2
    iRet = Alert ("The method name " + sTok$ + ".M specified for the sequence table line #" + VAL$(iRow) + " does not exist. DEF_LC.M will be used.", 2, "Import CSV")
    sTok$ = "DEF_LC" 
  endif

  SetTabtext _Sequence[1], SeqTable1, iRow, "Method", sTok$

  return

endmacro


! ==============================================================================
! Function Name:   sRemoveLeadingBlanks$
! Function Description:
!      This routine removes all the leading blanks in the given string.
! Parameter Passed-In:
!    sBuf$ - The buffer contains the string.
! Function Return:   A new string with all the leading blanks to be removed.
! Revision History:
! 12/29/00 YD  First created.
! ==============================================================================
name sRemoveLeadingBlanks$
  parameter sBuf$ default ""
  local iLen
  local i

  on error print  
  iLen = LEN(sBuf$)
  if iLen <= 0
     return ""
  endif
  
  ! if iLen >= 1
  !   while (sBuf$[1] = " ") AND (iLen >= 1)
  !     if iLen = 1
  !        return ""
  !     else
  !        sBuf$ = sBuf$[2:iLen]
  !     endif
  !     iLen = LEN(sBuf$)
  !   endwhile
  ! endif 
  
  for i=1 to iLen
      if sBuf$[i] <> " "
          goto SREMOVE1
      endif
  next i

  
SREMOVE1:
  if i > iLen
     return ""
  else
     return sBuf$[i:iLen]
  endif
   
endmacro 
 
 

! ==============================================================================
! Function Name:   vUpdateCalLine
! Function Description:
!      This routine updates the CalLine column in the sequence table for
!      the given row.
!      Note: I don't know if the sequenc for the LCMS ever use this column
!            or not since the LCMS user won't be able to access this column
!            through Sequence Table Editor at all.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateCalLine 
  parameter sTok$ default ""
  parameter iRow default 0 
  local iLen   
  local i
  local iRet

  on error print
  if iRow <= 0
    return
  endif 
   
  sTok$ = sRemoveLeadingBlanks$(sTok$) 
  
  i = VAL(sTok$)
  iLen = LEN(sTok$)
  
  if iLen > 0
    if (i < 1) OR (i > 9) OR (iLen > 1)
      iRet = Alert ("Invalid CalLine " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + ". Blank string will be used.", 2, "Import CSV")
      sTok$ = ""
    endif
  endif
  
  SetTabtext _Sequence[1], SeqTable1, iRow, "CalLine", sTok$

  return

endmacro



! ==============================================================================
! Function Name:   vUpdateInjVial
! Function Description:
!      This routine updates the InjVial column in the sequence table for the
!      given row.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateInjVial 
  parameter sTok$ default ""
  parameter iRow default 0 
  local iRet
  
  on error print  
  if iRow <= 0
    return
  endif

  if (sTok$ = "") OR (VAL(sTok$) <= 0) OR (InStr(sTok$, ".") >= 1) OR (VAL(sTok$) > 99)
    iRet = Alert ("Invalid InjVial " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + ". A defaul value 1 will be used.", 2, "Import CSV")
    sTok$ = "1"
  endif

  SetTabVal _Sequence[1], SeqTable1, iRow, "InjVial", VAL(sTok$)

  return

endmacro



! ==============================================================================
! Function Name:   vUpdateInjVolume
! Function Description:
!      This routine updates the InjVolume column in the sequence table for the
!      given row.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateInjVolume 
  parameter sTok$ default ""
  parameter iRow default 0 
  local iRet

  on error print
  if iRow <= 0
    return
  endif

  if sTok$ <> ""
    if (VAL(sTok$) <= 0) OR (InStr(sTok$, ".") >= 1)
      iRet = Alert ("Invalid InjVolume " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + ". A blank will be used for this field.", 2, "Import CSV")
      sTok$ = ""
    endif
  endif

  SetTabText _Sequence[1], SeqTable1, iRow, "InjVolume", sTok$

  return

endmacro



! ==============================================================================
! Function Name:   vUpdateStdSampleType
! Function Description:
!      This routine updates the SampleType column in the standard sequence table 
!      for the given row.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateStdSampleType 
  parameter sTok$ default ""
  parameter iRow default 0 
  local sUtok$ 
  local iRet

  on error print
  if iRow <= 0
    return
  endif
  
  sUtok$ = UpperCase$(sTok$)

  if sUtok$ = "CALIBRATION"
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 3
      return
  endif
  
  if sUtok$ = "CONTROL SAMPLE"
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 4
      return
  endif   
  
  if (sUtok$ <> "SAMPLE")
    iRet = Alert ("Invalid SampleType " + sTok$ + " is specified in for the sequence table line #" + VAL$(iRow) + ". A defaul type SAMPLE will be used.", 2, "Import Standard CSV")
  endif   
  
  SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 1

  return

endmacro


! ==============================================================================
! Function Name:   vUpdateExtSampleType
! Function Description:
!      This routine updates the SampleType column in the extended sequence table 
!      for the given row.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateExtSampleType 
  parameter sTok$ default ""
  parameter iRow default 0 
  local sUtok$ 
  local iRet

  on error print
  if iRow <= 0
    return
  endif
  
  sUtok$ = UpperCase$(sTok$)  
  
  if (sUtok$ = "UNKNOWN") OR (sUtok$ = "1")
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 1
      return
  endif  
  
  if (sUtok$ = "STANDARD") OR (sUtok$ = "3")
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 3
      return
  endif    
 
  if (sUtok$ = "QUALITY CONTROL") OR (sUtok$ = "4")
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 4
      return
  endif
  
  if (sUtok$ = "BLANK") OR (sUtok$ = "6")
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 6
      return
  endif    
  
  if (sUtok$ = "DOUBLE BLANK") OR (sUtok$ = "7")
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 7
      return
  endif  
  
  if (sUtok$ = "SOLVENT") OR (sUtok$ = "8")
      SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 8
      return
  endif  

  iRet = Alert ("Invalid SampleType " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + ". A defaul type UNKNOWN will be used.", 2, "Import Extended CSV")
         
  SetTabVal _Sequence[1], SeqTable1, iRow, "SampleType", 1

  return

endmacro



