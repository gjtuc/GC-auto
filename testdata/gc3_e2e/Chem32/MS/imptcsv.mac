! ==============================================================================
! Function Name:   vUpdateExtSeqTblCol
! Function Description:
!      Given a column name, the row number, and the content to be updated, this
!      routine calls the appropriate routine to complete this task. This routine
!      is written for the extended sequence table only.
! Parameter Passed-In:
!    sCol$ - The column name.
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateExtSeqTblCol 
   parameter sCol$ default ""
   parameter sTok$ default ""
   parameter iRow default 0
   local iLenCol
   local iLenTok

   on error print
   if LEN(sCol$) <= 0
      return
   endif

   if iRow <= 0
     return
   endif 

   if UpperCase$(sCOl$) = "LOCATION"
      vUpdateVial sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "METHOD"
      vUpdateMethod sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "CALLINE"
      vUpdateCalLine sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "INJVIAL"
      vUpdateInjVial sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "INJVOLUME"
      vUpdateInjVolume sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "SAMPLETYPE"
      vUpdateExtSampleType sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "CALLEVEL"
      vUpdateCalLevel sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "CALIBACTION"
      vUpdateCalibAction sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "UPDATERT"
     ! sTok$ = "1"
     vUpdateUpdateRT sTok$, iRow
     return
   endif

   if UpperCase$(sCol$) = "INTERVAL"
      vUpdateInterval sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "DATAFILENAME"
      vUpdateDataFilename sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "SAMPLENAME"
      vUpdateSampleName sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "AMOUNT"
      vUpdateAmount sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "MULTIPLIER"
      vUpdateMultiplier sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "ISTDAMT"
      vUpdateISTDAmt sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "DILUTION"
      vUpdateDilution sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "SAMPLEINFO"
      vUpdateSampleInfo sTok$, iRow
      return
   endif 
   
   if UpperCase$(sCOl$) = "SAMPLEID"
      vUpdateSampleID sTok$, iRow
      return
   endif   
   
   if (InStr(UpperCase$(sCol$), "CMPD") = 1)
      vUpdateCompound sTok$, sCol$, iRow
      return   
   endif

   return

endmacro




! ==============================================================================
! Function Name:   vUpdateStdSeqTblCol
! Function Description:
!      Given a column name, the row number, and the content to be updated, this
!      routine calls the appropriate routine to complete this task. This routine
!      is written for the standard sequence table only.
! Parameter Passed-In:
!    sCol$ - The column name.
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateStdSeqTblCol 
   parameter sCol$ default ""
   parameter sTok$ default "" 
   parameter iRow default 0
   local iLenCol
   local iLenTok

   on error print
   if LEN(sCol$) <= 0
      return
   endif
   
   if iRow <= 0
      return
   endif

   if UpperCase$(sCOl$) = "LOCATION"
      vUpdateVial sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "METHOD"
      vUpdateMethod sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "CALLINE"
      vUpdateCalLine sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "INJVIAL"
      vUpdateInjVial sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "INJVOLUME"
      vUpdateInjVolume sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "SAMPLETYPE"
      vUpdateStdSampleType sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "CALLEVEL"
      vUpdateCalLevel sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "UPDATERF"
      vUpdateUpdateRF sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "UPDATERT"
      vUpdateUpdateRT sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "INTERVAL"
      vUpdateInterval sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "DATAFILENAME"
      vUpdateDataFilename sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "SAMPLENAME"
      vUpdateSampleName sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "AMOUNT"
      vUpdateAmount sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "MULTIPLIER"
      vUpdateMultiplier sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "ISTDAMT"
      vUpdateISTDAmt sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "DILUTION"
      vUpdateDilution sTok$, iRow
      return
   endif

   if UpperCase$(sCol$) = "SAMPLEINFO"
      vUpdateSampleInfo sTok$, iRow
      return
   endif

   return

endmacro



! ==============================================================================
! Function Name:   iCSVFileNameOK
! Function Description:
!      This routine checks if the given CSV file name is OK or not.
! Parameter Passed-In:
!    sCSVFile$ - The given CSV file name to be checked.
! Function Return:   1 - The CSV file exist    0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name iCSVFileNameOK
    parameter sCSVFile$ default ""

    on error print

    if sCSVFile$ = ""
        return 0
    endif  
    
    if InStr(UpperCase$(sCSVFile$), ".CSV") <= 1
        return 0
    endif

    if FileStat(MODE, sCSVFile$) <> 1
        return 0
    endif

    return 1
endmacro



! ==============================================================================
! Function Name:   iFindTableSection
! Function Description:
!      The routine tries to find out if the [Table] section exists in the CSV
!      file or not.
!      Note: Assuming the device #3 is opened for the CSV file handler.
! Parameter Passed-In:
!      None.
! Function Return:   1 - [Table] section exists   0 - Otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name iFindTableSection
    local iLines

    sBuf$ = ""
    iLines = 0
    on error goto FINDTABLE1
    while (InStr(UpperCase$(sBuf$), "[TABLE]") <> 1) AND (iLines < 1100)
       sBuf$ = ""
       iLines = iLines + 1
       Input Using #3, "L", sBuf$
    endwhile

FINDTABLE1:

    on error print
    
    if (InStr(UpperCase$(sBuf$), "[TABLE]") <> 1)
        return 0
    else
        return 1
    endif

endmacro


! ==============================================================================
! Function Name:   iGetTotalTok
! Function Description:
!      Given a buffer that contains a group of string tokens seperated by ",", this
!      routine finds the total number of tokens in the buffer.
! Parameter Passed-In:
!    sBuf$ - The buffer contains a group of tokens to be checked.
! Function Return:   The total number of tokens in this buffer.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name iGetTotalTok
  parameter sBuf$ default ""
  local iLen
  local iTotal
  local i

  on error print  
  iLen = LEN(sBuf$)
  if iLen <= 0
    return 0
  endif
  
  iTotal = 0
  for i=1 to iLen
    if sBuf$[i] = ","
       iTotal = iTotal + 1
    endif
  next i

  return iTotal

endmacro



! ==============================================================================
! Function Name:   iCheckHeaders
! Function Description:
!      This routine first gets the header name line from the user-defined CSV 
!      file, which should be the first string line below the [Table] section.
!      Next, it gets the standard header name informtion from the stabhdr.txt
!      or xtabhdr.txt (depending if this Import CSV task is for the STANDARD
!      or EXTENDED sequence). Finally, it checks the user-defined header names
!      from the CSV file againt the ones defined in the stabhdr.txt or 
!      xtabhdr.txt file.  
!      Note:  Assuming CSV file is opened with the handle = #3.
! Parameter Passed-In:
!    sMode$ - Valid string is either "STANDARD" or "EXTENDED"
! Global variables are used:
!     sHeader$ -  Contains the header names from the user defined CSV file.
!     sTextHdr$ - Contains the header names from the standard/extended header 
!                 text file.
!     sTextAlias$ - Contains the alias header names for the user defined CSV file.
! Function Return:   1 - Header names are OK    0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name iCheckHeaders
    parameter sMode$ default "STANDARD"
    local iLines
    local iLen

    on error print

    sBuf$ = ""
    iLines = 0
    
    while (sBuf$ = "") AND (iLines < 50)
       sBuf$ = ""
       iLines = iLines + 1
       on error goto CHECKHEADERS1
       Input Using #3, "L", sBuf$
       if sBuf$ <> ""
          sHeader$ = UpperCase$(sBuf$)
          if sHeader$[LEN(sHeader$)] <> ","
            sHeader$ = sHeader$ + ","
          endif 
          iTotalCol = iGetTotalTok(sHeader$) 
       endif
    endwhile
 
CHECKHEADERS1:
 
    if (iLines >= 50) AND (sHeader$ = "")
        return 0
    endif  
    
    on error print

    if iGetTextHdr(sMode$) <> 1
       return 0
    endif

    if iCompareHeader(sMode$) <> 1
        return 0
    endif
        
    return 1

endmacro



! ==============================================================================
! Function Name:   iCompareHeader
! Function Description:
!      This routine compares the user-defined header names from the CSV file
!      againt the ones defined by the stabhdr.txt or xtabhdr.txt.
! Parameter Passed-In:
!    sMode$ - Valid string is either "STANDARD" or "EXTENDED"
! Function Return:   1 - Header names are OK    0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name iCompareHeader
   parameter sMode$ default "STANDARD"

   on error print
   if (sMode$ <> "STANDARD") AND (sMode$ <> "EXTENDED")
      return 0
   endif

   if sMode$ = "STANDARD"
      if iCompareStdHdr() = 1
          return 1
      else
          return 0
      endif
   else
      if iCompareExtHdr() = 1
          return 1
      else
          return 0
      endif
   endif

   return 0

endmacro


! ==============================================================================
! Function Name:   sRemoveBlanks$
! Function Description:
!      Given a string, this routine removes all the leading and trailing blanks.
! Parameter Passed-In:
!    sBuf$ - The string to be processed.
! Function Return:   A string that has leading and trailing blanks to be removed.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name sRemoveBlanks$
  parameter sBuf$ default ""
  local iLen
  local iBeg
  local iEnd
 
  on error print 
  iLen = LEN(sBuf$)
  if iLen < 1
     return ""
  endif
  
  iBeg = 1
  while (sBuf$[iBeg] = " ") AND (iBeg <= iLen)
     iBeg = iBeg + 1
  endwhile

  if iBeg > iLen
    return ""
  endif
  
  iEnd = iLen
  while (sBuf$[iEnd] = " ") AND (iEnd >= iBeg)
      iEnd = iEnd - 1
  endwhile
  
  if iEnd < iBeg
     return ""
  endif
  
  return sBuf$[iBeg:iEnd]
  
endmacro

 
 
! ==============================================================================
! Function Name:   iCheckTextHdr
! Function Description:
!      This routine checks if the stabhdr.txt or xtabhdr.txt got corrupted or
!      not.
! Parameter Passed-In:
!    sMode$ - Valid string is either "STANDARD" or "EXTENDED"
! Global variables are used:
!     sTextHdr$ - Contains the header names from the standard/extended header 
!                 text file.
!     sXtable$ -  Contains all the valid header names in the extended sequence
!                 table. 
!     sStable$ -  Contains all the valid header names in the standard sequence
!                 table.
! Function Return:   1 - Header names are OK    0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name iCheckTextHdr
   parameter sMode$ default "STANDARD" 
   local iRet   
 
   on error print
     
   if iTotalTextHdr <= 0
      return 0   
   endif

   sTextHdr$ = UpperCase$(sTextHdr$)
      
   if sMode$ = "EXTENDED"
      if sXtable$ <> sTextHdr$
         iRet = Alert ("Error: Corrupted " + _AutoMSPath$ + "xtabhdr.txt file.", 3, "Import CSV")
         return 0
      else
         return 1 
      endif
   else
      if sStable$ <> sTextHdr$ 
         iRet = Alert ("Error: Corrupted " + _AutoMSPath$ + "stabhdr.txt file.", 3, "Import CSV")      
         return 0
      else
         return 1   
      endif
   endif
   
   return 0

endmacro 
 
 

! ==============================================================================
! Function Name:   iGetTextHdr
! Function Description:
!      This routine gets the header names from the stabhdr.txt or xtabhdr.txt
!      file. The header name information will be put into the sTextHdr$ and
!      sTextAlias$ global variables.
! Parameter Passed-In:
!    sMode$ - Valid string is either "STANDARD" or "EXTENDED"
! Global variables are used:
!     sTextHdr$ - Contains the header names from the standard/extended header 
!                 text file.
!     sTextAlias$ -  Contains all the valid alias header names in from the
!                    standard/extended header text file. 
! Function Return:   1 - sucessful    0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name iGetTextHdr 
    parameter sMode$ default "STANDARD"
    local sCSVTextFile$
    local sTok$
    local sTok0$
    local sTok1$ 
    local iPos 
    local iLen
    local iRet    
    
    on error print 
    ! This should never happen
    if check(VARIABLE, _AutoMSPath$) <> 1
       _AutoMSPath$ = _EXEPATH$[1:10] + "MS\"
    endif
    ! if Len(_EXEPATH$) < 10
    !    return 0
    ! endif 
    if sMode$ = "EXTENDED"
       sCSVTextFile$ = _AutoMSPath$ + "xtabhdr.txt"
    else
       sCSVTextFile$ = _AutoMSPath$ + "stabhdr.txt"    
    endif

    if FileStat(MODE, sCSVTextFile$) <> 1
        iRet = Alert ("Error: Could open " + sCSVTextFile$ + " file.", 3, "Import CSV")
        return 0
    endif

    on error return 0
    
    sTextHdr$ = "" 
    sTextAlias$ = ""   
    sTok$ = "a"
    iTotalTextHdr = 0    
    
    Open sCSVTextFile$ For Input As #4
    
    on error print

    while sTok$ <> ""
       sTok$ = ""
       on error goto GETHDREXIT
       
       Input Using #4, "L", sTok$
       if sTok$ = ""
           goto GETHDREXIT
       endif 
       sTok$ = UpperCase$(sTok$)
       iTotalTextHdr = iTotalTextHdr + 1
       iPos = InStr(sTok$, ",")
       if iPos = 1
          iRet = Alert ("Error: Invalid header name in " + sCSVTextFile$ + ".", 3, "Import CSV") 
          on error print
          Close #4 
          sTextHdr$ = ""
          sTextAlias$ = ""
          iTotalTextHdr = 0
          return 0
       endif
       if iPos > 1
          sTextHdr$ = sTextHdr$ + sTok$[1:(iPos-1)] + ","
          iLen = LEN(sTok$)
          if (iPos+1) > iLen
             sTextAlias$ = sTextAlias$ + sTok$[1:(iPos - 1)] + ","
          else
             sTok0$ = sTok$[(iPos+1):iLen]
             sTok0$ = sRemoveBlanks$(sTok0$)
             if sTok0$ = ""
                 sTextAlias$ = sTextAlias$ + sTok$[1:(iPos - 1)] + ","             
             else
                 sTextAlias$ = sTextAlias$ + sTok0$ + ","
             endif
          endif
       else
          sTextAlias$ = sTextAlias$ + sTok$ + ","
          sTextHdr$ = sTextHdr$ + sTok$ + ","
       endif
       
    endwhile

GETHDREXIT:
     
    on error print
    
    Close #4
             
    if sTextAlias$ <> sTextHdr$
       iAlias = 1  
    else
       iAlias = 0
    endif
    
    if iCheckTextHdr(sMode$) <> 1
        return 0
    else
        return 1
    endif

endmacro



! ==============================================================================
! Function Name:   sGetSeqHdr$
! Function Description:
!      Given an Alias name, this routine returns the corresponding real header
!      name in the sequence table.
! Parameter Passed-In:
!    sAlias$ - An Alias name
! Global variables are used:
!     sTextHdr$ - Contains the header names from the standard/extended header 
!                 text file.
!     sTextAlias$ -  Contains all the valid alias header names in from the
!                    standard/extended header text file. 
! Function Return:   The corresponding real header name in the sequence table.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name sGetSeqHdr$
  parameter sAlias$ default ""
  local iLen
  local iIndex
  local sSeqHdr$
  
  on error print
  iLen = LEN(sAlias$)
  if iLen <= 0
    return ""
  endif
   
  ! Get the index of the sTextAlias$ buffer for that Alias name. 
  if iAlias = 1
     iIndex = iGetIndex(sTextAlias$, sAlias$)
     if iIndex <= 0
        return ""
     endif
  
    ! Get the real name.
    sSeqHdr$ = ""
    sSeqHdr$ = sGetNthTok$(sTextHdr$, iIndex)

    return sSeqHdr$
  else
    return sAlias$
  endif

endmacro



! ==============================================================================
! Function Name:   iCompareStdHdr
! Function Description:
!      This routine checks if each of the user-defined header names from the 
!      CSV file matches the ones defined in the stabhdr.txt.
! Parameter Passed-In:
!      None.   
! Global Variable:
!      iTotalCol - The total number of header names defined in the CSV file.
! Function Return:   1 - Header names are OK    0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name iCompareStdHdr
    local sTok$
    local sErr$  
    local i
    local iPos
    local iRet
    local iLen    

    on error print 
  
    if iTotalCol <= 0
       return 1
    endif
    
    for i=1 to iTotalCol  
       sTok$ = ""
       sTok$ = sGetNthTok$(sHeader$, i) + ","
       iLen = LEN(sTok$)    
       if iLen <= 1
         goto STDCOMPAREERR
       endif
       if InStr(sTextAlias$, sTok$) <= 0
       ! if iPos <= 0
          goto STDCOMPAREERR
       endif         
       ! if sTextAlias$[(iPos+iLen)] <> ","
       !       goto STDCOMPAREERR
       ! endif         
     next i 
     
     return 1
  
 STDCOMPAREERR:   
    sErr$ = "Error: Unrecognized header column " + sTok$ + " in the given standard CSV file."
    iRet = Alert (sErr$, 3, "Import Standard CSV") 
    ! print sTextAlias$
    ! show
    return 0           
 
endmacro
           
           

! ==============================================================================
! Function Name:   iCompareExtHdr
! Function Description:
!      This routine checks if each of the user-defined header names from the 
!      CSV file matches the ones defined in the xtabhdr.txt.  
!      This routine also updates the iToatlCol and iTotalComp global variables.
! Parameter Passed-In:
!      None.
! Global Variable:
!      iTotalCol - The total number of header names defined in the CSV file.
!      iTotalComp - The total number of compound names defined in the CSV file.
!      sHeader$ - The header names from the CSV file.
!      sTextAlias$ - The header alias names from the xtabhdr.txt file.
!      sTextHdr$ - The header names from the xtabhdr.txt file.
! Function Return:   1 - Header names are OK    0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================
name iCompareExtHdr
    local sTok$
    local sTok1$
    local sErr$  
    local i
    local iPos 
    local iTotal 
    local j
    local iLen
    local iRet    

    on error print 
  
    if iTotalCol <= 0
       return 1
    endif
     
    iTotal = iTotalCol
    iTotalComp = 0
    
    for i=1 to iTotal  
       sTok$ = ""
       sTok$ = sGetNthTok$(sHeader$, i) + ","
       iLen = LEN(sTok$)    
       if iLen <= 1
         goto EXTCOMPAREERR
       endif 
       ! if sTok$[iLen] <> ","
       !    sTok$ = sTok$ + ","
       ! endif
       iPos = InStr(sTextAlias$, sTok$)
       if iPos <= 0
          iTotalComp = iTotalCol - i + 1
          iTotalCol = i - 1  
          goto EXTCHECKCOMP
       endif         
     next i 
     
     return 1
     
EXTCHECKCOMP:
     ! Check compound names
     for j=i to iTotal
        ! Get the rest of the compound names from the sHeader$ buffer
        sTok$ = sGetNthTok$(sHeader$, j) + ","
        iLen = LEN(sTok$)
        if iLen <= 1
           goto EXTCOMPAREERR
        endif 
        ! if sTok$[iLen] <> ","
        !    sTok$ = sTok$ + ","
        ! endif
        if InStr(sTextAlias$, sTok$) > 0
        ! if iPos > 0
          ! The compound name should not occur in the alias list.
          goto EXTCOMPOUNDERR
        endif
        ! if sTextAlias$ <> sTextHdr$
        if iAlias = 1
           iPos = InStr(sTextHdr$, sTok$)
           if iPos > 0
             goto EXTCOMPOUNDERR
           endif                          
        endif
     next j         
     
     return 1

EXTCOMPOUNDERR:
    iLen = LEN(sTok$)
    if iLen > 1
      if sTok$[iLen] = ","
         sTok$ = sTok$[1:(iLen-1)]
      endif
    endif
    sErr$ = "Error: Invalid user-defined compound name " + sTok$ + " in the given extended CSV file." + chr$(13) + chr$(10) + chr$(10)
    sErr$ = sErr$ + "Please make sure that the user-defined compound name is appended at the end of the standard header names in your CSV file."
    iRet = Alert (sErr$, 3, "Import Extended CSV")
    return 0
  
EXTCOMPAREERR:   
    sErr$ = "Error: Unrecognized header column " + sTok$ + " in the given extended CSV file."
    iRet = Alert (sErr$, 3, "Import Extended CSV")
    return 0           
 
endmacro
           
           

! ==============================================================================
! Function Name:   sGetNthTok$
! Function Description:
!      This routine returns the Nth token in the given string.
!      Note: Each token in a given string is seperated by the ",". The last
!            char. of this string should be ","
! Parameter Passed-In:
!      sString$ - The string that consists of tokens. Each token is seperated
!                 by the ","
! Function Return:   The Nth token in the sString$. NULL will be returned when
!                    error occurred.
! Revision History:
! 12/30/00 YD  First created.
! ============================================================================ 
name sGetNthTok$
    parameter sString$ default ""
    parameter iNthCol  default 0
    local iLen
    local i
    local sTok$
    local sTemp$
    local iIndex
    local iPos
    local iFirst
    local iSecond

    on error print

    if iNthCol <= 0
       return ""
    endif

    iLen = LEN(sString$)
    if iLen <= 1
       return ""
    endif
    if sString$[iLen] <> ","
      sString$ = sString$ + ","
    endif

    if iNthCol = 1
       iPos = InStr(sString$, ",")
       if iPos <= 1
          return ""
       else
          return sString$[1:(iPos - 1)]
       endif
    endif

    sTemp$ = sString$
    for i=1 to iNthCol
            iIndex = InStr(sTemp$, ",")        
            if iIndex <= 0
                return ""
            endif
            iLen = LEN(sTemp$)
            if (iLen <= iIndex) AND (i < iNthCol)
               return ""
            endif
            if iIndex = 1
                 sTok$ = ""
            else
                 sTok$ = sTemp$[1:(iIndex - 1)]
            endif
            if (i < iNthCol)
                sTemp$ = sTemp$[(iIndex+1): iLen]
            else
                sTemp$ = ""
            endif
    next i   
    
    return sTok$

! For performance testing only.    
if i=-25    
    
    iFirst = 1
    i = 0
    on error return ""
    while (i < (iNthCol-1)) AND (iFirst <= iLen)
       if sString$[iFirst] = ","
         i = i + 1
       endif
       iFirst = iFirst + 1
    endwhile
    
    if iFirst > iLen
       return ""
    endif
    
    iSecond = iFirst
    while (iSecond<=iLen) AND (sString$[iSecond] <> ",")
      iSecond = iSecond + 1
    endwhile
    
    if iSecond > iLen
       return ""
    else
       return sString$[iFirst:(iSecond-1)]
    endif
    
endif       
    
   
endmacro



! ==============================================================================
! Function Name:   iGetIndex
! Function Description:
!      Given a sString$, in which has a set of tokens that are seperated by
!      ",", and a token, this routine returns the index of this token stored
!      in this string.
!      Note: Each token in a given string is seperated by the ",". The last
!            char. of this string should be ","
! Parameter Passed-In:
!      sString$ - The string that consists of tokens. Each token is seperated
!                 by the "," 
!      sName$   - The token string
! Function Return:   The index. 0 will be returned when error occurred.
! Revision History:
! 01/02/00 YD  First created.
! ============================================================================ 
name iGetIndex
    parameter sString$ default ""
    parameter sName$  default ""
    local iFirst
    local iIndex
    local iLen
    local i
    local iName
    local sBuf$

    on error print
    iName = LEN(sName$)
    
    if iName <= 0
       return 0
    endif
    
    if sName$[iName] <> ","
       sName$ = sName$ + ","
       iName = iName + 1
    endif
    sName$ = UpperCase$(sName$)

    iLen = LEN (sString$)
    if iLen <= 0
       return 0
    endif
    
    if sString$[iLen] <> ","
       sString$ = sString$ + ","
    endif
    
    sBuf$ = sString$
    iLen = LEN(sBuf$)
    
    iFirst = InStr(UpperCase$(sString$), sName$)
    if iFirst < 1
       return 0
    endif
    if iFirst = 1
       return 1
    endif
    if iFirst > iLen
       return 0
    endif
    iIndex = 1
    for i=1 to iFirst
       if sString$[i:i] = ","
            iIndex = iIndex + 1
       endif
    next i
    return iIndex

endmacro




