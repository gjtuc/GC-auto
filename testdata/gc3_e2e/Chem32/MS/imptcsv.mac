name vUpdateSampleName 
  parameter sTok$ default ""
  parameter iRow default 0 
  local iLen 
  local iRet

  on error print
  if iRow <= 0
    return
  endif
  
  sTok$ = sRemoveLeadingBlanks$(sTok$)   
  iLen = LEN(sTok$)
  
  if (iLen = 0) OR (sTok$ = " ")
     SetTabText _Sequence[1], SeqTable1, iRow, "SampleName", ""
     return
  endif

  if iLen > 16
    iRet = Alert ("SampleName " + sTok$ + " for the sequence table line #" + VAL$(iRow) + " will be truncated to " + sTok$[1:16] + ".", 2, "Import CSV")
    SetTabText _Sequence[1], SeqTable1, iRow, "SampleName", sTok$[1:16]
    return
  endif
  
  SetTabText _Sequence[1], SeqTable1, iRow, "SampleName", sTok$

  return

endmacro



