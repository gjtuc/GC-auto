! ==============================================================================
! Function Name:   vUpdateUpdateRF
! Function Description:
!      This routine updates the UpdateRF column in the sequence table for the
!      given row.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateUpdateRF
  parameter sTok$ default ""
  parameter iRow default 0 
  local sUtok$
  local iRet

  on error print
  if iRow <= 0
    return
  endif
   
  sTok$ = sRemoveLeadingBlanks$(sTok$)   
  sUtok$ = UpperCase$(sTok$)
  
  if (sUtok$ = "AVERAGE") OR (sTok$ = "1")
      SetTabVal _Sequence[1], SeqTable1, iRow, "UpdateRF", 1
      return
  endif
  
  if (sUtok$ = "NO UPDATE") OR (sTok$ = "0")
      SetTabVal _Sequence[1], SeqTable1, iRow, "UpdateRF", 0
      return
  endif 
  
  if (sUtok$ = "REPLACE") OR (sTok$ = "2")
      SetTabVal _Sequence[1], SeqTable1, iRow, "UpdateRF", 2
      return
  endif  
  
  if (sUtok$ = "BRACKET") OR (sTok$ = "3")
      SetTabVal _Sequence[1], SeqTable1, iRow, "UpdateRF", 3
      return
  endif 

  if (sUtok$ = "DELTA%") OR (sTok$ = "4")
      SetTabVal _Sequence[1], SeqTable1, iRow, "UpdateRF", 4
      return
  endif 
             
  iRet = Alert ("Invalid UpdateRF " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + ".", 2, "Import Standard CSV")
  
  SetTabVal _Sequence[1], SeqTable1, iRow, "UpdateRF", 1

  return

endmacro  


 
 
