! ==============================================================================
! Function Name:   iIsDataFilenameOK
! Function Description:
!      This routine checks if the given data file name is OK or not.
!      Note: Blank is OK in the sequence table.
! Parameter Passed-In:
!    sName$ - The data file name to be checked.
! Function Return:   1 - OK     0 - otherwise.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name iIsDataFilenameOK 
  parameter sName$ default "'"
  local iLen
  local iExt
  
  on error print
  
  iLen = LEN(sName$)
  
  if (iLen = 0) OR (sName$ = " ")
      return 1
  endif
  
  if (InStr(sName$, "'")>0) OR (InStr(sName$, "<")>0) OR (InStr(sName$, ">")>0) OR (InStr(sName$, "`")>0) OR (InStr(sName$, "^")>0) OR (InStr(sName$, "!")>0) OR (InStr(sName$, "@")>0) OR (InStr(sName$, "%")>0) OR (InStr(sName$, "~")>0)
      return 0
  endif

  iExt = InStr(sName$, ".")        
        
  !  check filename length                         or check extention length
  !  ((no ext and len > 8) or (ext starts at > 9)) or (ext exists and longer than 3)
  if ( ((iExt = 0) AND (iLen > 8)) OR (iExt > 9) ) OR ( (iExt > 0) AND ((iLen-iExt) > 3) ) then
     return 0
  endif
  
  return 1
 
endmacro
 

! ==============================================================================
! Function Name:   vUpdateDataFilename
! Function Description:
!      This routine updates the DataFilename column in the sequence table for the
!      given row.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the sequence table.
!    iRow  - The current sequence table row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateDataFilename 
  parameter sTok$ default ""
  parameter iRow default 0 
  local iLen
  local iExt
  local iRet

  on error print
  if iRow <= 0
    return
  endif

  sTok$ = sRemoveLeadingBlanks$(sTok$)    
  iLen = LEN(sTok$)
  
  if (iLen = 0) OR (sTok$ = " ")
     SetTabText _Sequence[1], SeqTable1, iRow, "DataFilename", ""
     return
  endif

  if iIsDataFilenameOK(sTok$) <> 1
    iRet = Alert ("Invalid DataFilename " + sTok$ + " is specified for the sequence table line #" + VAL$(iRow) + ". A defaul NULL string will be used.", 2, "Import CSV")
    SetTabText _Sequence[1], SeqTable1, iRow, "DataFilename", ""
    return
  endif 
  
  iExt = InStr(sTok$, ".")
  if iExt >= 1
     sTok$ = sTok$[1:(iExt-1)]     
  endif  
  
  SetTabText _Sequence[1], SeqTable1, iRow, "DataFilename", sTok$

  return

endmacro



