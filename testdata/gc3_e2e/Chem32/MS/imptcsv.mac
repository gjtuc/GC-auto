! ==============================================================================
! Function Name:   vUpdateCompound
! Function Description:
!      This routine updates the CompNames table in the _Sequence register.
! Parameter Passed-In:
!    sTok$ - The information from the CSV file to be put in the CompNames table.
!    sCol$ - The column number in the CompNames table.
!    iRow  - The row number in processing.
! Function Return:   None.
! Revision History:
! 12/30/00 YD  First created.
! ==============================================================================
name vUpdateCompound
  parameter sTok$ default ""
  parameter sCol$ default "" 
  parameter iRow default 0  
  local iLen
  local sTedName$
  local iRowIndex
  local iRet  

  on error print
  if iRow <= 0
    return
  endif
  
  if sCol$ = ""
    return
  endif

  sTok$ = sRemoveLeadingBlanks$(sTok$)      
  if (sTok$ = "") OR (sTok$ = " ")
     SetTabText _Sequence[1], SeqTable1, iRow, sCol$, ""  
     return
  endif
  
  if sTok$ = "0"
     SetTabText _Sequence[1], SeqTable1, iRow, sCol$, "0"  
     return  
  endif
  
  if (VAL(sTok$) <= 0) OR (LEN(sTok$) > 10)
    iRowIndex = RowByText (_Sequence[1], "CompNames", , "TabName", "i=", sCol$)
    sTedName$ = TabText$ (_Sequence[1], "CompNames", iRowIndex, "TedName")
    iRet = Alert ("Invalid value " + sTok$ + " for compound " + sTedName$ + " is specified for the sequence table line #" + VAL$(iRow) + ". This field will be left blank.", 2, "Import Extended CSV")
    sTok$ = ""
  endif 
  
  SetTabText _Sequence[1], SeqTable1, iRow, sCol$, sTok$

  return

endmacro  
         
         
