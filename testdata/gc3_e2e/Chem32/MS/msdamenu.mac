!******************************************************************************
!*
!* FILE:  msdamenu.mac
!*
!* DESCRIPTION:  Data Analysis menus for Triathlon.
!*
!* $Header: /cag/triath1b/partsmac/da/msdamenu.mac 1.76 2000-10-31 14:43:25-08 robertcl Exp $ 
! Revision History:
! 01/19/99 YD  Added multiple mass spectra support in Tabulate Mass Spectrum
!                     by calling a new function SPECMS_vTabulateSpectrum
! 01/22/99 YD  Added Link/Unlink mode under the Spectra pull-down menu
! 02/24/99 YD  Added _DecSetsUnlinked variable using as a flag in DECONV-
!                     Unlinked mode.
! 05/11/99 YD  Changed the accelerator key for the Overlay Base Peak from O
!                      to k.
! 07/04/00 YD  Added support for the extended sequence table for LCMS by
!                     adding both standard and extended sequence menu items.
! 07/14/00 YD  Added menu for the Analyst.
!                     Added CS->WIFF converter menu item 
! 08/30/00 YD  Added code to block the extended sequence when Analyst is
!                     not installed.
! 09/07/00 YD  Added _AnalystInstalled and _AnalystDataPath$ variables and their
!                     related calls.
! 10/30/00 YD  Changed "Run WIFF Converter" to "Run File Translator"
! 11/29/05 LL  Added globalization changes.
!******************************************************************************!

! YD

_DecSetsUnlinked=0

_SpectraLink=1
on error SetObjHdrVal _Config[1], "SpectraLink", 1
_SpectraLink = ObjHdrVal (_Config[1], "SpectraLink")
on error

if ( CHECK(VARIABLE,LDMS_IntegMenuState)=0 ) then
  LDMS_IntegMenuState=0x03
endif

! File Menu
! =========
menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),,"SEPARATOR",,,,,,2003250
menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_EXTRACT__IONS_320),"DAUI_MenuExtractIons",,\
        ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_EXTRACT_EIC_FR_322),,,,2003260
if (TabHdrText$(_Config[1],MenusForViews,MenuCol) = "FullMenuFile") then
  menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_OVERLAY_BASE_P_323), "LDMS_LoadBP",,\
          ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_OVERLAY_BASE_P_325),,,,2003270
endif
menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE_125),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__SUBTRACT_BACK_326),"LDMS_Bsb",,\
          ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SUBTRACT_BACKG_328),,,,2003280
menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FILE__PRINT_329),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_TABULAR__MASS_330),"SPECMS_PrintSpectrum",,\
        ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PRINT_MASS_SPE_332),,,,2029350

