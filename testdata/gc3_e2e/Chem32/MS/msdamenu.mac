        ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_BATCH_CONVERT_338),,,,2006401


!
! Graphics Menu
! =============
IF _HPCE=0 THEN
    menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__GRAPHICS_339), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__FIA_DISPLAY_O_340),"FIADAOptions",,\
        ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_EDIT_THE_FIA_D_342),,,,6001100
    menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__GRAPHICS_339), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SHOW_FIA__TABL_343),"FIAShowTable",,\
        ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_EDIT_THE_FIA_D_342),,,,6001100
ENDIF
!
! Integration Menu
! ================
if (TabHdrText$(_Config[1],MenusForViews,MenuCol) = "FullMenuFile") then
   ! Full menu, add smooth near end, just before Update to Enh Integ.
   menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__INTEGRATION_345),,"SEPARATOR",,,,,,6117010
   menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__INTEGRATION_345),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SMOOT_H_346), \
      "MS_DoManualSmooth" ,, ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SMOOTH_ALL_SIG_348),,,,6117020
else
   ! Short menu, add smooth just after Auto Integ.
   menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__INTEGRATION_345),,"SEPARATOR",,,,,,6105010
   menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__INTEGRATION_345),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SMOOT_H_346), \
      "MS_DoManualSmooth",, ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SMOOTH_ALL_SIG_348),,,,6105020
endif


!
! Spectra Menu
! ============
if (TabHdrText$(_Config[1],MenusForViews,MenuCol) = "ShortMenuFile") then
  menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__SPECTRA_349),,"SEPARATOR",,,,,,6414000
endif

