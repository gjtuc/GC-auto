  ! Menu item to install Peptide Tools and display main dialog box
  menuadd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES__SPECTRA_349),ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PEPTOOLS_422),"PTA_MWCalc",,\
          ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_PROTEIN_PEPTID_382), PTA_MenuState,,,6414720	

  ! To disable peptide tools menu item for B.01.01, Now working in B.02.01 JAM
  ! PTA_MenuState = 0
