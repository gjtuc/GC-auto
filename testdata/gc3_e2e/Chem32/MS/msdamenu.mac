! For MS Library Search
if Check (VARIABLE,_NISTMS)=1 then
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SPECTRA_LIB_425), ,SEPARATOR
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SPECTRA_LIB_425), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_MS_CRE_426),"MSSrchExport MSReg[1]"  ,," "
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SPECTRA_LIB_425), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_MS_CLOSE_427),"MSSrchGotoNist" ,," "
  MenuAdd ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_SPECTRA_LIB_425), ReadResource$("supportmacfiles",ID_SUPPORTMACFILES_MS_DEF_428),"print MSSrchEditDefault()"     ,," "
endif

! 06/30/00 YD  Added support for the extended sequence table
! 08/30/00 YD  Blocked all the extended sequence menu items if Analyst is not installed.
! 09/07/00 YD  Added _AnalystInstalled and _AnalystDataPath$ variables and the related calls.
_AnalystInstalled = 0
_AnalystDataPath$ = ""
if Check(SYSTEM_VARIABLE, _FEATURES$) = 1
      if (UpperCase$(_FEATURES$) = "LCMS") AND (Check(FUNCTION, AnalystInstalled) = 1) 
        if AnalystInstalled() = 1    
            _AnalystInstalled = 1
            _AnalystDataPath$ = GetAnalystDataPath$()
