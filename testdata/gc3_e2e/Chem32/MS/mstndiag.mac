Local  ID_TUNEMAC_VACUUM_TEST_CO_975
ID_TUNEMAC_LC_MSD_VACUUM_974                       =  17974  
ID_TUNEMAC_VACUUM_TEST_CO_975                      =  17975  
  _DiagTuneFile$ = tuneFileName$
  AbortStr$ = ";AbortVacTest"
  
  ! set abort macro
