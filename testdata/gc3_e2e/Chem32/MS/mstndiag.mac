endmacro

!****************************************************************************
!****************************************************************************
NAME AbortSigTest
!****************************************************************************
  dgMSSigTestCleanup

  ! clean up abort variable
  DeleteAbortCmd ";AbortSigTest"
  
endmacro
!***************************************************************************

!****************************************************************************
!***************************************************************************
!****************************************************************************
NAME printTestResult 
!
!  This will print the test result.  If DiagTestResult isn't present, it 
!  will try to copy result_reg over and hopefully print that.
!  If it can't find the print procedure, it returns a 0.  If it can't find 
!  any of the test registers, a -1 is returned; if the procedure was found,
!  then 1 is returned.
!
!****************************************************************************

  if regSize(DiagTestResult) < 1 then
     if regSize(Result_Reg) > 0 then
         copyObj Result_Reg, DiagTestResult
     else 
         RETURN -1
     endif
  endif

  if ObjHdrType(DiagTestResult,"PrintProcedure") = 0 then
     evaluate ObjHdrText$(DiagTestResult, "PrintProcedure")
     RETURN 1
  else
     RETURN 0
  endif

endmacro
!****************************************************************************

!****************************************************************************
!****************************************************************************
!****************************************************************************
NAME PrintTest
!
!  This is a shorthand call to PrintTestResult() for command-line work.
!
!****************************************************************************

Local  ID_TUNEMAC_TEST_PRINTED_976
Local  ID_TUNEMAC_TEST_COULD_NOT_977
ID_TUNEMAC_TEST_PRINTED_976                        =  17976  
ID_TUNEMAC_TEST_COULD_NOT_977                      =  17977  
  if PrintTestResult() = 1 then
     print ReadResource$("tunemac",ID_TUNEMAC_TEST_PRINTED_976)
  else
     print ReadResource$("tunemac",ID_TUNEMAC_TEST_COULD_NOT_977)
  endif
  
endmacro

!****************************************************************************
!***************************************************************************
NAME DeleteAbortCmd
PARAMETER Cmd$ 
!****************************************************************************
LOCAL  LenCmd, LenAbort, Pos

   ! delete clean up macro from _abort$ string
   Pos = InStr(_abort$,Cmd$)
   if Pos  >0 THEN
      LenAbort = Len(_abort$)
      LenCmd  =Len(Cmd$)
      if Pos = 1 THEN
         if LenAbort = LenCmd then
            _abort$ = ""
         else
            _abort$ = _abort$[Pos+LenCmd:LenAbort]
         endif
      else
         _abort$ = _abort$[1:Pos-1] + _abort$[Pos-1+LenCmd:LenAbort]
      endif
   endif
  
endmacro
!****************************************************************************

!****************************************************************************
!****************************************************************************
!****************************************************************************
NAME Vent
! This macro calls the diagnosis view Vent panel
!****************************************************************************

   dgMSpumpGUI 0, 1

endmacro
!****************************************************************************

!****************************************************************************
!****************************************************************************
!****************************************************************************
NAME Pumpdown
! This macro calls the diagnosis view Vent panel
!****************************************************************************

   dgMSpumpGUI 0, 2

endmacro
!****************************************************************************

!****************************************************************************
!****************************************************************************
!****************************************************************************
NAME InitDiagWindows
! This macro is part of Init_Diagnose (diagnose.mac).  Normally, this is
! executed when first entering diagnosis view.
!****************************************************************************

  IF CHECK(Variable,DIAG_WinStart) = 0 THEN
    DIAG_WinStart = TabHdrVal(_CONFIG[1], WINDOW, NumberOfRows) + 1
    DIAG_WinEnd = DIAG_WinStart + 10
    InsTabRow _config[1],window,DIAG_WinStart:DIAG_WinEnd
    SetTabVal _CONFIG, WINDOW, DIAG_WinStart:DIAG_WinEnd, XAxisStyle, 1
    SetTabVal _CONFIG, WINDOW, DIAG_WinStart:DIAG_WinEnd, YAxisStyle, 2
    DIAG_WinEnd = DIAG_WinEnd - 4 ! DIAG_WinEnd + 1: used for draw printouts
              ! DIAG_WinEnd + 2: used for real-time plot
              ! DIAG_WinEnd + 3: used for test clipboard
              ! DIAG_WinEnd + 4: used for diagnosis GOM panel (DiagTop)
    ! Set up window table for test clipboard
    SetTabVal _CONFIG, WINDOW, DIAG_WinEnd + 3, DefWXLow   , .05
    SetTabVal _CONFIG, WINDOW, DIAG_WinEnd + 3, DefWXHigh  , .95
    SetTabVal _CONFIG, WINDOW, DIAG_WinEnd + 3, DefWYLow   , .227
    SetTabVal _CONFIG, WINDOW, DIAG_WinEnd + 3, DefWYHigh  , .9   
    SetTabVal _CONFIG, WINDOW, DIAG_WinEnd + 3, HelpContext, 9580
    ! Set up help index for on-line monitor
    SetTabVal _CONFIG, WINDOW, DIAG_WinEnd + 2, HelpContext, 7100
    ! Set up view table for diagnosis GUI
    DelTabRow _CONFIG[1], VIEW_DIAGNOSE, -1
    InsTabRow _CONFIG, VIEW_DIAGNOSE
    SetTabVal _CONFIG, VIEW_DIAGNOSE, 1, WinNum, DIAG_WinEnd + 4
    SetTabVal _CONFIG, VIEW_DIAGNOSE, 1, Visible, 1 
  ELSE ! Clean-up view table
    FOR i = DIAG_WinStart TO DIAG_WinEnd + 3
      RowNo = RowByVal(_CONFIG, VIEW_DIAGNOSE,, "WinNum", "=", i)
      IF  RowNo > 0 THEN
   DelTabRow _CONFIG, VIEW_DIAGNOSE, RowNo
      ENDIF
    NEXT i
    RowNo = RowByVal(_CONFIG, VIEW_DIAGNOSE,, "WinNum", "=", DIAG_WinEnd + 4)
    IF RowNo < 0 THEN ! restore Diagnosis GUI
      InsTabRow _CONFIG, VIEW_DIAGNOSE
      RowNo = TabHdrVal(_CONFIG, VIEW_DIAGNOSE, NumberOfRows)
      SetTabVal _CONFIG, VIEW_DIAGNOSE, RowNo, WinNum, DIAG_WinEnd + 4
      SetTabVal _CONFIG, VIEW_DIAGNOSE, RowNo, Visible, 1 
      SetTabText _CONFIG, WINDOW, DIAG_WinEnd + 4, Command, \
                 "dgStartDiagnosisGUI"
      SetTabVal  _CONFIG, WINDOW, DIAG_WinEnd + 4, HelpContext, 8700
    ELSE 
      SetTabVal _CONFIG, VIEW_DIAGNOSE, RowNo, Visible, 1 
    ENDIF 
  ENDIF
  
  SetTabText _CONFIG, WINDOW, DIAG_WinEnd + 4, Command, "dgStartDiagnosisGUI"
  SetTabVal  _CONFIG, WINDOW, DIAG_WinEnd + 4, HelpContext, 8700

endmacro
!****************************************************************************
print "MS diagnosis extensions v. " + mstnDiagVer$ + " loaded."
!********* end of file ******************************************************
