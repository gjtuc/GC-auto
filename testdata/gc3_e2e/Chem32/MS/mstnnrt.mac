ID_TUNEMAC_NEBULIZER_ZONE_47                       =  17047  
ID_TUNEMAC_THIS_FUNCTION_1080                      =  18080

  if EventNumber = -1 then
    MSSCQuery "msc:nrt:stat? pdb",s$
    MSSCQuery "msc:nrt:nv? pdb,datetime",d$
    state$=substring$(s$,1,,",")
    stat$=substring$(s$,2,,",")
    wrn$=substring$(s$,3,,",")
    flt$=substring$(s$,4,,",")
  else
    MSSCQuery "msc:nrt:event? pdb,"+val$(EventNumber),s$
    d$=substring$(s$,1,," ")+" "+substring$(s$,2,," ")
    s$=substring$(s$,4,," ")
    stat$=substring$(s$,1,,"/")
    wrn$=substring$(s$,2,,"/")
    flt$=substring$(s$,3,,"/")
  endif
  MSSCQuery "msc:nrt:id? tpc",nodeid$
  
  leak=0
  status=val(stat$)
  warning=val(wrn$)
  fault=val(flt$)
  if (fault<0) then
    fault=fault+65536*65536
    leak=1
  endif
  print
  if EventNumber = -1 then
    print ReadResource$("tunemac",ID_TUNEMAC_1)
  else
    print ReadResource$("tunemac",ID_TUNEMAC_2)
  endif
