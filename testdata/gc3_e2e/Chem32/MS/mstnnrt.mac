! mstnNRT.mac  
!
! This file contains some utilities to quickly access some parameters in the
! LC/MSD Non-Real Time subsystem.  These utilities can be divided into
! three groups: 
!
! A. Power distribution board (includes flow and temperature control)
! B. Vacuum system control
! C. CDS (calibrant delivery system) control
!
!  
! Power Distribution, flow and temperature control
!   pdbfault       Retrieve status or event log information from the power 
!                  distribution board (PDB).  
!   pdblog         Extract PDB log information into a text file 
!   msZoneTimeout  Set timeout values for flow and temperature control zones
!   msZonePID      Sets the flow and temperature control constants
!
! Vacuum system control
!   vacinfo        Display turbo status, speed, power, and pressure 
!   tpcfault       Retrieve status or event log information from the turbo 
!                  pump controller. 
!   tpclog         Extract Turbo controller log information into a text file 
!   tpcinfo        Display turbo speed and power 
!   turboson       Turn the turbo pumps on (for diagnostic purposes only)
!   turbosoff      Turn the turbo pumps off (for diagnostic purposes only)
!   rpon           Turn the rough pump on (for diagnostic purposes only)
!   rpoff          Turn the rough pump off (for diagnostic purposes only)
!   autopumpdown   Disables or enables autopumpdown feature
!   forepres       Display the stage 1 pressure 
!   highpres       Display the stage 4 pressure 
!
! CDS control
!   leakCal       Calibrates leak sensor.
!   clearLeakCal  Clears leak sensor calibration value (disables leak sensor)
!   getLeakCal    Returns the current leak calibration value
!
!
!*****************************************************************************

 NRTver$ = "$Header: /cag/DRIVERS/sprite1b/macros/tune/mstnnrt.mac 1.8 2007-06-14 09:10:00-08 clove Exp $"
 verIx = instr(NRTver$, ".mac ") + 5
 NRTver$ =  NRTver$[verIx:VerIx + instr(NRTver$[VerIx:len(NRTver$)]," ") - 1] 
 remove verIx

! A. Power distribution board (includes flow and temperature control)

!******************************************************************************
NAME pdbfault
PARAMETER EventNumber default -1
! Retrieves the specified entry from the power distribution board event log.
! If no EventNumber is specified, the current state is displayed.  Previous
! events are indexed by number, from 0 to 9, with 0 being the most recent.
! Note: the date and time are set to GMT or Universal time.
!******************************************************************************
LOCAL flt$,wrn$,stat$,state$, nodeid$
LOCAL status,warning,fault,leak

Local  ID_TUNEMAC_1
Local  ID_TUNEMAC_2
Local  ID_TUNEMAC_HARDWARE_REV_3
Local  ID_TUNEMAC_5
