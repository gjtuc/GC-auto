  fault=div(fault,2)
  fault=div(fault,2)
  fault=div(fault,2)
  !if mod(fault,2)=1 then
  if (leak=1) then
    print ReadResource$("tunemac",ID_TUNEMAC_LEAK_DETECTED_31)
