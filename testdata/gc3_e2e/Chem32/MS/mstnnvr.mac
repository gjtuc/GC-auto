   ! Two rows for iButton
  if pre6100() = 0 then
    InsTabRow MSDNVR, NVRAMTab, 12:13
    SetTabText MSDNVR, "NVRAMTab", 12, "Parameter", "Instrument iButton Serial Number"
    SetTabText MSDNVR, "NVRAMTab", 12, "SCParmName", "ibuttonsn"
