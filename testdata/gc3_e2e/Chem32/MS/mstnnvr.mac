NAME nvrSaveToLog
! Save shipping info to file for rework sheet to access. For production 
! use only.
!***************************************************************************!
LOCAL x_SNLog$, x_QPolP$, x_QPolN$, x_MSValveP$, x_SNum$, x_QuadNum$, x_MfgDate$

Local  ID_TUNEMAC_FILE_255
Local  ID_TUNEMAC__CONTAINS_INFO_256
Local  ID_TUNEMAC_SHIPPING_INFOR_257
ID_TUNEMAC_FILE_255                                =  17255  
ID_TUNEMAC__CONTAINS_INFO_256                      =  17256  
ID_TUNEMAC_SHIPPING_INFOR_257                      =  17257  
   if Check(Variable, PRTestVer$) = 0 then
      RETURN
   endif
   
   ON ERROR
   
   if RegSize(MSDNVR) = -1 then
      RETURN
   endif

   x_SNLog$ = "C:\MSSERIAL.LOG"

   !Initialize all variables before reading.
   x_SNum$ = "x"
   x_QuadNum$ = "x"
   x_MfgDate$ = "x"
   x_QPolP$ = "x"
   x_QPolN$ = "x"
   x_MSValveP$ = "x"

   x_SNum$ =    GetNVR$("serialnum")  !Read serial number.
   x_QuadNum$ = GetNVR$("quadnum") !Read quad number.
   x_MfgDate$ = GetNVR$("mfgdate") !Read Mfg date.
   x_QPolP$ =   GetNVR$("quadpolp")  !Read quad polarity for positive ion (0/1).
   x_QPolN$ =   GetNVR$("quadpoln")  !Read quad polarity for negative ion (0/1)
   x_MSValveP$ = GetNVR$("msvalvep") !Read Injection valve present (0/1)

   !Save above variables to file.
   open x_SNLog$ for append as #7
   if filestat(size, x_SNLog$) = 0 then !new
      print #7, ReadResource$("tunemac",ID_TUNEMAC_FILE_255) + x_SNLog$ + \
           ReadResource$("tunemac",ID_TUNEMAC__CONTAINS_INFO_256)
      print #7, "MSID,Serial#,Quad#,+ionQPol,-ionQPol,InjValve,MfgDate"   
   endif
   if check(variable, M_MSID$) > 0 then
      print using #7, "~%,%,%,%,%,%,%\", M_MSID$, x_SNum$, x_QuadNum$,  \
                       x_QPolP$, x_QPolN$, x_MSValveP$, x_MfgDate$
   else
      print using #7, "~%,%,%,%,%,%,%\", "UNKNOWN", x_SNum$, x_QuadNum$, \
                      x_QPolP$, x_QPolN$, x_MSValveP$, x_MfgDate$
   endif
   close #7
   print ReadResource$("tunemac",ID_TUNEMAC_SHIPPING_INFOR_257)

endmacro !nvrSaveToLog

!***************************************************************************!
!***************************************************************************!
NAME AppendSemiColon$
PARAMETER InString$
! If the string isn't empty, a "; " is appended 
!
!***************************************************************************!

   if len(InString$) > 0 then
      InString$ = InString$ + "; "
   endif
   
   RETURN InString$

endmacro                ! appendSemiColon
!***************************************************************************!


!***************************************************************************!
!***************************************************************************!
!***************************************************************************!
NAME MMBoardUpdate
! Checks to see if G1946-60250 analyzer board and PDB have had the chip updates
! to support the Multimode source.
!
! CPL 04/25/2006 Added mmcheck logic for G61x0A series LC/MSD
!
!***************************************************************************!
Local AnRev,AnRev$,PDBfw$,mmcheck
 
 if (pre6100() = 1) then
  ! Check analyzer board firmware:
   MSSCQuery "sens? mainboard", AnRev$
   AnRev = val(AnRev$)
   print AnRev
    if AnRev < 57354 then
        mmcheck = 1
    else
        mmcheck = 0
    endif

  ! Check the PDB firmware:
   PDBfw$ = nvr68332Rev$()
   print PDBfw$
    if val(PDBfw$) < 1.60 then
      mmcheck = mmcheck + 1
    else
      mmcheck = mmcheck + 0
    EndIf
  Else
    mmcheck = 0
  EndIf
  
  return mmcheck

endmacro                ! MMBoardUpdate
!***************************************************************************!

 verIx = instr(NVRver$, ".mac ") + 5
 NVRver$ =  NVRver$[verIx:VerIx + instr(NVRver$[VerIx:len(NVRver$)]," ") - 1] 
 remove verIx
 
 print "mstnNVR.mac v. " + NVRver$ + " loaded."
