    SetTabText MSDNVR, "NVRAMTab", 49, "SCParmName", "vapormaxd"
    SetTabText MSDNVR, "NVRAMTab", 49, "Comparison", "<>"
    SetTabText MSDNVR, "NVRAMTab", 49, "ReadFunction", "scqStr$(""msc:parm? vapormaxd"")"    
  else
    return
  endif


   NewObjHdrText MSDNVR, "ModifDate" , ""
   NewObjHdrText MSDNVR, "MacroRev" , "1.64"
   NewObjHdrText MSDNVR, "BackupDate" , ""
   NewObjHdrText MSDNVR, "RestoreDate" , ""

   ! Generate DDTNVRTab table
   NewTab MSDNVR, "DDTNVRTab"
   ! Define columns
   NewColText MSDNVR, "DDTNVRTab", "Title", ""
   NewColVal  MSDNVR, "DDTNVRTab", "Control", 2
   NewColText MSDNVR, "DDTNVRTab", "EnumStrings", ""
   NewColVal  MSDNVR, "DDTNVRTab", "Width", 0
   NewColText MSDNVR, "DDTNVRTab", "Format", ""
   NewColVal  MSDNVR, "DDTNVRTab", "Justify", 0
   NewColText MSDNVR, "DDTNVRTab", "Source", ""
   InsTabRow MSDNVR, DDTNVRTab, 1:8

   ! Get header items for DDTNVRTab table
   NewTabHdrVal MSDNVR, "DDTNVRTab", "DispRowNum", 1,, 3
   NewTabHdrText MSDNVR, "DDTNVRTab", "RowNumTitle", "#"
   NewTabHdrVal MSDNVR, "DDTNVRTab", "RowNumWidth", 5,, 3
   NewTabHdrText MSDNVR, "DDTNVRTab", "RowFormat", "%d"
   NewTabHdrText MSDNVR, "DDTNVRTab", "TitleFont", ""
   NewTabHdrText MSDNVR, "DDTNVRTab", "ElemFont", ""
   NewTabHdrVal MSDNVR, "DDTNVRTab", "FixedCols", 1,, 3
   NewTabHdrVal MSDNVR, "DDTNVRTab", "WindowClass", 1,, 3

   ! Set table contents
   ! Title column
   SetTabText MSDNVR, "DDTNVRTab", 1, "Title", "Parameter"
   SetTabText MSDNVR, "DDTNVRTab", 2, "Title", "keyword"
   SetTabText MSDNVR, "DDTNVRTab", 3, "Title", "Actual"
   SetTabText MSDNVR, "DDTNVRTab", 5, "Title", "Expected"
   SetTabText MSDNVR, "DDTNVRTab", 6, "Title", "ReadFunction"
   SetTabText MSDNVR, "DDTNVRTab", 7, "Title", "SetFunction"
   SetTabText MSDNVR, "DDTNVRTab", 8, "Title", "MinRev"
   ! End of Title column

   ! Control column
   ! End of Control column

   ! EnumStrings column
   ! End of EnumStrings column

   ! Width column
   SetTabVal  MSDNVR, "DDTNVRTab", 1, "Width", 30
   SetTabVal  MSDNVR, "DDTNVRTab", 2, "Width", 10
   SetTabVal  MSDNVR, "DDTNVRTab", 3, "Width", 20
   SetTabVal  MSDNVR, "DDTNVRTab", 4, "Width", 4
   SetTabVal  MSDNVR, "DDTNVRTab", 5, "Width", 20
   SetTabVal  MSDNVR, "DDTNVRTab", 6, "Width", 30
   SetTabVal  MSDNVR, "DDTNVRTab", 7, "Width", 30
   SetTabVal  MSDNVR, "DDTNVRTab", 8, "Width", 8
   ! End of Width column

   ! Format column
   SetTabText MSDNVR, "DDTNVRTab", 1, "Format", "%s"
   SetTabText MSDNVR, "DDTNVRTab", 2, "Format", "%s"
   SetTabText MSDNVR, "DDTNVRTab", 3, "Format", "%s"
   SetTabText MSDNVR, "DDTNVRTab", 4, "Format", "%s"
   SetTabText MSDNVR, "DDTNVRTab", 5, "Format", "%s"
   SetTabText MSDNVR, "DDTNVRTab", 6, "Format", "%s"
   SetTabText MSDNVR, "DDTNVRTab", 7, "Format", "%s"
   SetTabText MSDNVR, "DDTNVRTab", 8, "Format", "%s"
   ! End of Format column

   ! Justify column
   ! End of Justify column

   ! Source column
   SetTabText MSDNVR, "DDTNVRTab", 1, "Source", "Parameter"
   SetTabText MSDNVR, "DDTNVRTab", 2, "Source", "SCParmName"
   SetTabText MSDNVR, "DDTNVRTab", 3, "Source", "ParmValue"
   SetTabText MSDNVR, "DDTNVRTab", 4, "Source", "Comparison"
   SetTabText MSDNVR, "DDTNVRTab", 5, "Source", "Expected"
   SetTabText MSDNVR, "DDTNVRTab", 6, "Source", "ReadFunction"
   SetTabText MSDNVR, "DDTNVRTab", 7, "Source", "SetFunction"
   SetTabText MSDNVR, "DDTNVRTab", 8, "Source", "MinRev"
   ! End of Source column

   NewObjHdrVal  MSDNVR, "version",2
   ! Object #1 done

endmacro         ! end CreateMSDNVR
