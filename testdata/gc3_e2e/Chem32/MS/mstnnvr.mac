   SetTabText MSDNVR, "NVRAMTab", 35, "SetFunction", "MSSCWrite ""zone:name dgasflow; pset %s"""
   SetTabText MSDNVR, "NVRAMTab", 36, "SetFunction", "MSSCWrite ""zone:name nebpres; pset %s"""
   SetTabText MSDNVR, "NVRAMTab", 37, "SetFunction", "MSSCWrite ""zone:name vapor; pset %s"""
   SetTabText MSDNVR, "NVRAMTab", 39, "SetFunction", "MSZonePID 4,,,,,""%s"",1"
   SetTabText MSDNVR, "NVRAMTab", 40, "SetFunction", "MSZonePID 3,,,,,""%s"",1"
   SetTabText MSDNVR, "NVRAMTab", 41, "SetFunction", "MSZonePID 7,,,,,""%s"",1"
