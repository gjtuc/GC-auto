    SetTabText MSDNVR, "NVRAMTab", 13, "Comparison", "<>"
    SetTabText MSDNVR, "NVRAMTab", 13, "ReadFunction", "scqStr$(""config:src:ibsn?"")"
  else
    return
  endif
  
  ! New Parameters for 6100 'Orion' instruments
  if (MSModelOptions = 26) OR (MSModelOptions = 27) then
    InsTabRow MSDNVR, NVRAMTab, 48:49
    SetTabText MSDNVR, "NVRAMTab", 48, "Parameter", "SGas Heater AC Line Voltage"
    SetTabText MSDNVR, "NVRAMTab", 48, "SCParmName", "pwrid"
    SetTabText MSDNVR, "NVRAMTab", 48, "Comparison", "<>"
