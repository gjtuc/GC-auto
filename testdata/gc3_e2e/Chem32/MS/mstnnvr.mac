   SetTabText MSDNVR, "NVRAMTab", 49, "SetFunction", "MSzoneTimeout 2, %s, , 1"
   SetTabText MSDNVR, "NVRAMTab", 52, "SetFunction", "MSSCWrite ""msc:parm:pset cdsdonps, %s """
