   SetTabText MSDNVR, "NVRAMTab", 29, "SetFunction", "MSSCWrite ""msc:parm:pset quadfreq, %s"""
   SetTabText MSDNVR, "NVRAMTab", 30, "SetFunction", "MSSCWrite ""msc:parm:pset quadpolp, %s"""
   SetTabText MSDNVR, "NVRAMTab", 31, "SetFunction", "MSSCWrite ""msc:parm:pset quadpoln, %s"""
