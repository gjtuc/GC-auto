  ! End of ReadFunction column for 6100 series instruments
Endif 

   ! SetFunction column
   SetTabText MSDNVR, "NVRAMTab", 5, "SetFunction", "MSSCWrite ""config:id:desc serialnum, '%s'"""
   SetTabText MSDNVR, "NVRAMTab", 6, "SetFunction", "MSSCWrite ""config:id:desc prodnum, '%s'"""
