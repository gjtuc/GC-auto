   SetTabText MSDNVR, "NVRAMTab", 16, "MinRev", "PRS2.02.00"
   SetTabText MSDNVR, "NVRAMTab", 20, "MinRev", "6.2"
   SetTabText MSDNVR, "NVRAMTab", 22, "MinRev", "PRSW1.1.01"
   SetTabText MSDNVR, "NVRAMTab", 27, "MinRev", "LOG01,CAL"
   ! End of MinRev column
   
   ! New Parameters for 6100 'Sirius' instruments
  if pre6100() = 0 then
    InsTabRow MSDNVR, NVRAMTab, 10:11
    SetTabText MSDNVR, "NVRAMTab", 10, "Parameter", "Solvent Divert Valve Installed"
    SetTabText MSDNVR, "NVRAMTab", 10, "SCParmName", "DV 0/1"
    SetTabText MSDNVR, "NVRAMTab", 10, "ReadFunction", "scqStr$(""config:info:opts:desc? 7"")"
    
    SetTabText MSDNVR, "NVRAMTab", 11, "Parameter", "Fast Switching Capillary Installed"
    SetTabText MSDNVR, "NVRAMTab", 11, "SCParmName", "rescaplry"
    SetTabText MSDNVR, "NVRAMTab", 11, "ReadFunction", "scqStr$(""config:id:desc? rescaplry"")"
  else
    return
