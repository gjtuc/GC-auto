   SetTabText MSDNVR, "NVRAMTab", 75, "ReadFunction", "scqStr$(""msc:parm:pset? emf_cexa"")"
   SetTabText MSDNVR, "NVRAMTab", 76, "ReadFunction", "scqStr$(""msc:parm:pset? emf_cexb"")"
