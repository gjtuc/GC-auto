   SetTabText MSDNVR, "NVRAMTab", 54, "SetFunction", "MSSCWrite ""msc:parm:pset cdsdofp2, %s"""
   SetTabText MSDNVR, "NVRAMTab", 55, "SetFunction", "MSSCWrite ""msc:parm:pset cdsdoncd, %s"""
   SetTabText MSDNVR, "NVRAMTab", 57, "SetFunction", "MSSCWrite ""msc:parm:pset mald0, %s"""
   SetTabText MSDNVR, "NVRAMTab", 58, "SetFunction", "MSSCWrite ""msc:parm:pset mald1, %s"""
   SetTabText MSDNVR, "NVRAMTab", 59, "SetFunction", "MSSCWrite ""msc:parm:pset mald2, %s"""
   SetTabText MSDNVR, "NVRAMTab", 62, "SetFunction", "MSSCWrite ""msc:parm:pset emvgain0, %s"""
   SetTabText MSDNVR, "NVRAMTab", 63, "SetFunction", "MSSCWrite ""msc:parm:pset emvgain1, %s"""
