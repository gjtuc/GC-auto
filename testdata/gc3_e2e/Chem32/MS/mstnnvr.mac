!*******************************************************************************
NAME CreateMSDNVR
! CPL 01/10/2007 Add Installed Ion Source, Pos & Neg Gain Coefficients
!                Update descriptions for Manual Inject Valve, SmartCard FW Rev
! CPL 12/10/2009 Change "config:id:desc? prodnum" query to "config:inst? modl" query.
!                Add support for 6100 series 'Orion' instruments
!*******************************************************************************
LOCAL c$
LOCAL ID_TUNEMAC_ABSENT_191
ID_TUNEMAC_ABSENT_191                              = 17191

   ! Create object #1
   NewObj MSDNVR, 1,0,0

   ! Generate NVRAMTab table
   NewTab MSDNVR, "NVRAMTab"
   ! Define columns
   NewColText MSDNVR, "NVRAMTab", "Parameter", ""
   NewColText MSDNVR, "NVRAMTab", "SCParmName", ""
   NewColText MSDNVR, "NVRAMTab", "ParmValue", ""
