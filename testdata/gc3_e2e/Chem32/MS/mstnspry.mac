  APPINeg_Flow$ = SPrintF$(msat_GetDefault(NegTuneMixIx, "DryingGas"), "%3.1f")
  APPIPos_Pressure$ = SPrintF$(msat_GetDefault(PosTuneMixIx, "Neb_Pres"), "%2.0f")
  APPINeg_Pressure$ = SPrintF$(msat_GetDefault(NegTuneMixIx, "Neb_Pres"), "%2.0f")
  APPIPos_VCap$ = SPrintF$(msat_GetDefault(PosTuneMixIx, "Vcap"), "%3.0f")
  APPINeg_VCap$ = SPrintF$(msat_GetDefault(NegTuneMixIx, "Vcap"), "%3.0f")

