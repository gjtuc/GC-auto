  APPINeg_Vaporizer$ = SPrintF$(msat_GetDefault(NegTuneMixIx, "Vaporizer"), "%3.0f")
  APPIPos_Temp$ = SPrintF$(msat_GetDefault(PosTuneMixIx, "GasTemp"), "%3.0f")
