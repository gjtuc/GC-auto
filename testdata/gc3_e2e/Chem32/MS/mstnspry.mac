    textXPos = 5
    textYPos = YMAXPOS * 0.10

    textXLen = 100
    textYLen = 50
   
    editXLen = 40
    editYLen = 11
   
    xPos2 = xPos2 + 2
    yPosOffset = 20
   
    !VAPORIZER
    yPos  = yPos + yGap
    StaticText textXPos, textYPos, textXLen, textYLen, "Vaporizer (deg C):", "R"
    EditBox xPos1, yPos, editXLen, editYLen, APPIPos_Vaporizer$
    EditBox xPos2, yPos, editXLen, editYLen, APPINeg_Vaporizer$


    !DRYING GAS TEMP
    yPos  = yPos + yPosOffset
    StaticText textXPos, yPos, textXLen, textYLen, "Drying Gas Temp (deg C):", "R"
    EditBox xPos1, yPos, editXLen, editYLen, APPIPos_Temp$
    EditBox xPos2, yPos,editXLen, editYLen,  APPINeg_Temp$

    !DRYING GAS FLOW
    yPos  = yPos + yPosOffset
    StaticText  textXPos, yPos, textXLen, textYLen, "Drying Gas Flow (liter/min):", "R"
    EditBox xPos1, yPos, editXLen, editYLen, APPIPos_Flow$
    EditBox xPos2, yPos, editXLen, editYLen, APPINeg_Flow$

    !NEBULIZER PRESSURE
    yPos  = yPos + yPosOffset
    StaticText textXPos, yPos, textXLen, textYLen, "Nebulizer Pressure (psig):", "R"
    EditBox xPos1, yPos,editXLen, editYLen, APPIPos_Pressure$
    EditBox xPos2, yPos, editXLen, editYLen, APPINeg_Pressure$
  
    !CAPILLARY VOLTAGE	 
    yPos  = yPos + yPosOffset
    StaticText textXPos, yPos, textXLen, textYLen, "VCap (V):", "R"
    EditBox xPos1, yPos, editXLen, editYLen, APPIPos_VCap$
    EditBox xPos2, yPos,editXLen, editYLen,APPINeg_VCap$

   !---------------------------------
   !DEFINE UPDATE OPTION BOX HERE.
   !---------------------------------

    xPos = xPos1 - 4
    yPos = yPos + yPosOffset 

    xPosOffSet = 20
    xLen = (2 * editXLen) + xPosOffset 
    yLen = 35
    title$ = "Update LC/MSD Parameters"
    GroupBox xPos, yPos, xLen, yLen, title$

    xPos = xPos + 8
    yPos = yPos + 15
    xLen = 90
    yLen = 10
    text$ = "Update All Tune Files"
    CheckBox xPos, yPos, xLen, yLen, text$, bCheck, bEnable

   !------------------------------
   !DEFINE ACTION BUTTONS
   !------------------------------

    xPos = 35
    yPos = YOptionBox + 55

    xLen = 42
    yLen = 15
    offset = 60 
   
    !OK BUTTON
    OKButton xPos, yPos, xLen, yLen, "OK"  

    !CANCEL BUTTON.
    xPos = xPos + offset
    CancelButton xPos, yPos, xLen, yLen, "Cancel"  
  
    !HELP BUTTON.
    xPos = xPos + offset
    ExecPushButton xPos, yPos, xLen, yLen, "&Help",CP2, "Help " + sprintf$(HelpIndex,"%f")


  EndDialog
  
  
!ENFORCE ALL FIELDS TO BE ENTERED WHEN OK BUTTON IS PUSHED.
  bDone=0
  while (bDone = 0) do
print "Got to Point1"
    _button=ShowDialog("APPIDialog",HelpIndex)
Print "Got to Point2"
   MSTN_CPSafeStart "CP2"

    bDone = 1
    if (_button = 1) then !*** OK BUTTON IS PRESSED ***!
      if (APPIPos_Vaporizer$ = "") or (APPINeg_Vaporizer$ = "") or \
         (APPIPos_Temp$ = "") or (APPINeg_Temp$ = "") or \
         (APPIPos_Flow$ = "") or (APPINeg_Flow$ = "") or (APPIPos_Pressure$ = "") or \
         (APPINeg_Pressure$ = "") or (APPIPos_VCap$ = "") or (APPINeg_VCap$ = "") then
        print alert("Valid numbers must be entered for all fields.",2)
       bDone = 0
      endif
    endif
  endwhile


!PROCESS THE CANCEL BUTTON 
  if _button = 0 then   
    RemoveDialog "APPIDialog"
    return
  endif

!PROCESS THE OK BUTTON 
  if _button = 1 then
     
    !UPDATE CURRENT & TUNE MIX REGISTER 
    EdUpdSetpoint "APPI"
    EdUpdTuneMix "APPI"

    if (bCheck = 1) then	!*** UPDATE ALL TUNE FILES ***!
      EdUpdAllTune "APPI"
      Text$ = "All tune files with APPI mode, current setpoints and "
    else
      Text$ = ""
    endif
    print Text$ + "TuneMix register updated."

    return
  endif

!CLEANUP
  RemoveDialog "APPIDialog"
  remove APPIPos_Vaporizer$
  remove APPINeg_Vaporizer$
  remove APPIPos_Temp$
  remove APPINeg_Temp$
  remove APPIPos_Flow$
  remove APPINeg_Flow$
  remove APPIPos_Pressure$
  remove APPINeg_Pressure$
  remove APPIPos_VCap$
  remove APPINeg_VCap$

  return  

endmacro !EditAPPI

!***************************************************************************!
 name Edit_Spray
!
! Description: Main dialog box to let user choose editing APCI, APPI
!              or API-ES setpoints.
!
!***************************************************************************!
local XMAXPOS, YMAXPOS	!Dialog box dimensions.
local xPos, yPos, xLen, yLen	!Generic coordinates
local xGap, YGap		!Horiz & vert margins between objects.
local dselect		! option box default selection
local but1$			! option box button 1
local but2$			! option box button 2
local title$		! option box title
 

!DEFINE CONSTANTS HERE.

  XMAXPOS = 145
  YMAXPOS = 97	
  xGap = 18
  yGap = 16	   

  if dialogExists("APCIESIDialog") > 0 Then
    RemoveDialog "APCIESIDialog"
  endif

!DEFINE DIALOG BOX 
  BeginDialog "APCIESIDialog", 0, 0, XMAXPOS, YMAXPOS,\
              "Spray Chamber Parameter Editor"

    !---------------------------------
    !DEFINE APCI/API-ES OPTION BOX HERE 
    !---------------------------------
    
     !OPTION BOX SPEC
    dSelect = 1
     xPos = XMAXPOS * 0.06
     yPos = YMAXPOS * 0.05
     xLen = 127; yLen = 60
     title$ = "Select Spray Chamber Type"
     GroupBox xPos, yPos, xLen, yLen, title$
     OptionGroup dSelect
   
     
     !OPTION 1
     but1$ = "G1947A APCI Ionization"
     xPos = xPos + 12
     yPos = yPos + 15
     xLen = 130
     yLen = 10
     OptionButton xPos, yPos, xLen, yLen, but1$
   
     !OPTION 2
     but2$ = "G1948A API-ES Ionization"
     yPos = yPos + 14
     OptionButton xPos, yPos, xLen, yLen, but2$
   
     !OPTION 3
     but3$ = "G1971A APPI Ionization"
     yPos = yPos + 14
     OptionButton xPos, yPos, xLen, yLen, but3$

    !---------------------------------
    !Define OK and CANCEL buttons here.
    !---------------------------------
   
     xLen = 42; yLen = 15
   
     !OK BUTTON.
     xPos = XMAXPOS * 0.15
     yPos = yPos + yLen + yGap 
     OKButton xPos, yPos, xLen, yLen, "OK" 

     !CANCEL BUTTON.
     xPos = xPos + xLen + xGap
     CancelButton xPos, yPos, xLen, yLen, "Cancel"  	  
 
  EndDialog

  _button=ShowDialog("APCIESIDialog") 

!IF CANCEL IS SELECTED IN MAIN MENU, LOOP WILL BE SKIPPED AND EXIT.
  while (_button > 0) do
    !ENSURE ALL TUNE FILES ARE WRITABLE
!    execwait "attrib -r " + _tunepath$+"*.* /s"	

    cmdpath$ = chr$(34) + _tunepath$ +  chr$(34)
	execwait "attrib -r " + cmdpath$ + "*.* /s"	

    if (dselect = 1) then	
      EditAPCI
    else 
      if (dselect = 2) then	
        EditESI
      else 
        EditAPPI     ! deselect = 3
      endif
    endif
    
    !IF CANCEL OR HELP IS SELECTED IN THE APCI, APPI, OR API-ES DIALOG
    !IT WILL RETURN TO THE MAIN DIALOG BOX 
    if (_button = 0) or (_button = 4) then
      _button=ShowDialog("APCIESIDialog")
      else
      _button = 0	
    endif
  endwhile

  RemoveDialog "APCIESIDialog"

endmacro !Edit_Spray


!*************************************************************************

if Check(Variable, PRTestVer$) = 1 or Check(Variable, mstnUtilVer$) = 1 then
   print "mstnspry.mac v. " + EdSprayver$ + " loaded."
endif

