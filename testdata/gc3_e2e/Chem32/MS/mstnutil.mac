! PURPOSES IS PROHIBITED WITHOUT THE PRIOR WRITTEN CONSENT OF  
! AGILENT TECHNOLOGIES.
!
!                     RESTRICTED RIGHTS LEGEND                          
!                                                                       
! Use, duplication, or disclosure by the Government is subject to       
! restrictions as set forth in subdivision (b) (3) (ii) of the Rights in  
! Technical Data and Computer Software clause at 52.227-7013.           
!                                                                       
! AGILENT TECHNOLOGIES                                               
! Life Sciences and Chemical Analysis Solutions           
! 5301 Stevens Creek Blvd
! Santa Clara, CA 95051-7201
! United States
!
!+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
!  These MACROs are the common macros that are called when tune is invoked.
!  They take care of testing for the current instrument configuration and
!  call the proper set of macros for tuning or diagnostics. IT IS STRONGLY 
!  RECOMMENDED THAT NO MODIFICATIONS BE MADE TO THESE MACROS.
!+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
!
! Macros:
!   MSutil        : Load the entire macro set
!   InitMStnUtils : Initialize data subdir, check versions
!   MStnPrintError: Error message output 
!   
! EM Gain utilities:
!   ResetEMGain  : Sets EM gain calibration curve to default
!   SetGain      : Adjusts gain curve to give Gain of 1 at specified EMV
!
! Quad frequency utilities
!   QF           : Reports quad frequencies
!   SetQF        : Set quad frequency 
!   DipQF        : Dip and report quad frequency
!   burnQF       : burns current quad freq to NVRAM
!
! Quad temperature utilities
!   QT           : reads quad temperature and setpoints
!   SetQT        : sets quad temp setpoint
!   BurnQT       : burns a quad power-on setpoint
!   FastHeatQT   : rapid quadrupole temperature equilibration
!
! Quad polarity utilities
!   QP           : read or set quad polarity
!   burnQP       : burns quad polarities to NVRAM
!   psetqpol     : burns quad polarities to NVRAM
!
! Firmware identification utilities
!   SCid         : SmartCard rev & serial number query
!   MSid         : read or set MS serial number
!   PDBid        : Read pdb firmware rev
!   SBid         : Read SICB-LON board firmware rev
!   TCid         : Read turbo controller firmware rev
!   LONversion   : Formatted display of all LON node info
!   CheckVer$    : Displays software, firmware, macro and SC code versions
!
! General utilities
!   ShowRF       : Display RF drive & power at specified mass setting
!   Recapture    : Repetitive MSCapture command.
!   HED          : read or set HED
!   RampHED      : ramps mass 3 by default, 0 means all masses
!   Set_Lag      : calculate and store mass axis lag factors
!   flt          : execute dgMSreportFault
!   SCFault$     : returns a full fault string in 16 words
!   scqStr$      : returns a substring from an MSSCQuery
!   PrintErrTable: Prints out the MSDLogBook register error table 
!   MSlight      : Status light test utility
!   PSDelay      : Read or set polarity switching delay
!   burnPSDelay  : Store new default polarity switching delay
!   pre6100()    : = 1 if a model G1946 or G1956 is connected,
!                  otherwise the return value is 0
!   CDSshort     : Shortens waiting time for calibrant switches / flushing
!                  set only. Instruments returns to default after power cycle
!
! Global Variables set:
!   mstnUtilVer$ : Version string for this macro file
!   SCq$         : response string from an MSSCQuery (global)
!   SCid$        : SmartCard *idn? string
!   PDBid$       : PDB firmware rev
!   SBid$        : SICB-LON firmware rev
!   TCid$        : Turbo controller firmware rev
!
  mstnUtilVer$ = "$Header: /cag/DRIVERS/sprite1b/macros/tune/mstnutil.mac 1.23 2007-06-14 09:10:00-08 clove Exp $"
  verIx = instr(mstnUtilVer$, ".mac ") + 5
  mstnUtilVer$ =  mstnUtilVer$[verIx:VerIx + instr(mstnUtilVer$[VerIx:len(mstnUtilVer$)]," ") - 1] 
  remove verIx
!
!*******************************************************************************
name msUtil
! Reloads the rest of the MS utilities set 
! ***************************************************************** 

   On Error Print _ErrMsg$
      
   !2-22-02pdr(PVCS1717) faster startup, execute this upon switch to diagnosis: macro _AutoMSPath$ + "mstndiag.mac"
   macro _AutoMSPath$ + "enutnrmp.mac"
   macro _AutoMSPath$ + "mstnNRT.mac"
   macro _AutoMSPath$ + "mstnNVR.mac"
   macro _AutoMSPath$ + "mix_util.mac"
   macro _AutoMSPath$ + "edit_mix.mac"
   macro _AutoMSPath$ + "mstnspry.mac"

   InitMStnUtils 

   RETURN
   
endmacro
!************************************************************************!

!************************************************************************!
!************************************************************************!
!************************************************************************!
name InitMStnUtils
! Initialization for MStn Utilities
! 
!************************************************************************!


Local  ID_TUNEMAC_CAN_T_LOAD_FIL_308
Local  ID_TUNEMAC_SOFTWARE_FIRMW_310

Local  ID_TUNEMAC_LC_MSD_UTILITI_311
Local  ID_TUNEMAC___IN_OFFLINE_S_312
Local  ID_TUNEMAC_ERROR_EXECUTIN_313
ID_TUNEMAC_CAN_T_LOAD_FIL_308                      =  17308  
ID_TUNEMAC_SOFTWARE_FIRMW_310                      =  17310  

ID_TUNEMAC_LC_MSD_UTILITI_311                      =  17311  
ID_TUNEMAC___IN_OFFLINE_S_312                      =  17312  
ID_TUNEMAC_ERROR_EXECUTIN_313                      =  17313  
   On Error goto InitmstnUtilsErr

   ! Initialize string
   if Check(Variable, _Abort$) = 0 then
      _abort$ = " "
   endif

   ! Instrument initialization
   MSLogData ,1    ! Enable data logging
    
   ! Run the version check macro
   if _offline = 0 then
      if Check(Macro, CheckVer$) = 0 then
         On Error Print ReadResource$("tunemac",ID_TUNEMAC_CAN_T_LOAD_FIL_308) + _AutoMSPath$ + " verschk.mac"
         macro _AutoMSPath$ + " verschk.mac"
         On Error goto InitmsUtilsErr
      endif
      print ReadResource$("tunemac",ID_TUNEMAC_SOFTWARE_FIRMW_310) + CheckVer$(0)
      print ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_UTILITI_311) + MStnUtilVer$
   else
      print ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_UTILITI_311) + MStnUtilVer$ + \
            ReadResource$("tunemac",ID_TUNEMAC___IN_OFFLINE_S_312)
   endif
   
   RETURN
   
InitMStnUtilsErr:
   MStnPrintError
   print ReadResource$("tunemac",ID_TUNEMAC_ERROR_EXECUTIN_313) + MStnUtilVer$
   RETURN

endmacro        ! InitMStnUtils

!************************************************************************!
!************************************************************************!
name MStnPrintError
PARAMETER command$ default ""
! Writes an error message to the status line and evaluates a command
!************************************************************************!

  print _ErrMacro$ + ": " + _ErrMsg$ + " occurred at line " + \
         val$(_ErrLine) + " in " + _ErrFile$ + ", cmd/fct " + _ErrCmd$

  evaluate command$
  
  RETURN

endmacro
!************************************************************************!

! ---- EM gain utilities ------------------------------------------------!

!************************************************************************!

!************************************************************************!
name ResetEMGain
parameter PosGainMass default 623.03
parameter NegGainMass default 602.98
parameter Auto default 0 ! 1= called from another macro
! Restores default EM gain parameters
!************************************************************************!
LOCAL curve1$,curve2$,curve3$,curvenum,title$,count,_button,result,CurrPol

Local  ID_TUNEMAC_DO_YOU_WANT_TO_314
Local  ID_TUNEMAC_SELECT_WHICH_C_315
Local  ID_TUNEMAC_WRITING_VALUES_316
Local  ID_TUNEMAC_THIS_WILL_TAKE_317
Local  ID_TUNEMAC_EM_GAIN_CURVE_318
Local  ID_TUNEMAC_CAN_T_CHANGE_E_319
Local  ID_TUNEMAC_979

ID_TUNEMAC_DO_YOU_WANT_TO_314                      =  17314  
ID_TUNEMAC_SELECT_WHICH_C_315                      =  17315  
ID_TUNEMAC_WRITING_VALUES_316                      =  17316  
ID_TUNEMAC_THIS_WILL_TAKE_317                      =  17317  
ID_TUNEMAC_WRITING_VALUES_316                      =  17316  
ID_TUNEMAC_EM_GAIN_CURVE_318                       =  17318  
ID_TUNEMAC_CAN_T_CHANGE_E_319                      =  17319  
ID_TUNEMAC_979                                     =  17979  

On Error goto ResetEMGainErr  
! Check ion polarity and scan mode:
  MsParm IonPolarity,CurrPol
    if CurrPol > 1 then
      killit=Alert(ReadResource$("tunemac",ID_TUNEMAC_979),3,"Gain Calibration Curve")
      stop
    endif
    
  if _OffLine = 0 then
    if Auto = 0 then
      if Alert(ReadResource$("tunemac",ID_TUNEMAC_DO_YOU_WANT_TO_314), \
               4, "ResetEMGain") = 1 then
        curve1$ = "Positive"; curve2$ = "Negative"; curve3$ = "Positive and Negative"
        !* Choose which curve to reset
        if DialogExists("DlgGetCurve") <> 0
          !* Force the system to build a new dialog box
          RemoveDialog "DlgGetCurve"
        endif
      !==== Build Dialog ====
      curvenum = 1                         !* Initialize to first curve
      title$  = "Reset Gain Curve"

      BeginDialog "DlgGetCurve", 150, 80, 182, 100,title$
         statictext   10, 10, 125, 12, ReadResource$("tunemac",ID_TUNEMAC_SELECT_WHICH_C_315)
         OptionGroup curvenum
         OptionButton 10, 25, 60, 12, curve1$
         count = 1                         !* Assume at least one curve
         if curve2$ <> "NONE"
           OptionButton 10, 40, 80, 12, curve2$
           count = count + 1
         endif
         if curve3$ <> "NONE"
           OptionButton 10, 55, 90, 12, curve3$
           count = count + 1
         endif
         OKButton  10,80,50,14
         CancelButton 66,80,50,14
      EndDialog

        if count>1 then
          _button = ShowDialog("DlgGetCurve")
        else
          _button = 1
        endif
        if _button <> 1 then      ! User cancelled out
          curvenum = -1
        endif
      RemoveDialog "DlgGetCurve"
      else
        print ReadResource$("tunemac",ID_TUNEMAC_EM_GAIN_CURVE_318)
        Return
      endif   !* if Alert("Do you...
    else  
      curvenum = (CurrPol + 1)
    endif  !* if Auto = 0
      
      ! Load and/or initialize the GainCurve register:
        if RegSize(GainCurve) = -1 then
        !* Register not loaded.  Try loading the register from disk
          if filestat(mode,_tunepath$ + "GainCurve.reg") = 1 then
            LoadObj _tunepath$ + "GainCurve.reg",, GainCurve
          else
            ! GainCurve.reg has been deleted from this system
              title$= "Gain Curve Check"
              line1$= ReadResource$("tunemac",ID_TUNEMAC_GAINCURVE_REG_323)
              line2$= chr$(13) + chr$(13) +"Please restore file or reload ChemStation software."
              _button=alert(line1$ + line2$,3,title$)  ! CPL 03/06 Replace Atuneprint statement with Alert.
              stop
          endif
        endif
        
        !* Initialize the Gain Curve register, if necessary 
        if (RegSize(GainCurve) > -1) and (RegSize(GainCurve) < 2) then
          print msat_InitGainCurveReg()
        endif

      EmvGain0=8.5                 ! Default Pos/Neg Slope, m
      EmvGain1=-62.08              ! Default Pos/Neg Intercept ("Offset"), b
      EmvGain2=0                   ! Dummy value; may remove later
      
      SetAbort Off                 !* Don't let user abort until calibration
                                   !* done and burned into SmartCard
                                   
      If (curvenum = 1) Or (curvenum = 3) Then        ! Reset positive curve      
        ! Initialize parameters
          CurrPol = 0
          m = EmvGain0                 ! Default Slope
          b = EmvGain1                 ! Default Intercept
          ve6=Exp((Ln(1)-b)/m)         ! Default EMV from Slope and Intercept values
          v_1=2500
          Gain_1=Exp(m*Ln(v_1)+b)*1e6  ! Build default Gain Curve, 1st point
          v_2=2200
          Gain_2=Exp(m*Ln(v_2)+b)*1e6  ! Build default Gain Curve, 2nd point
          v_3=1900          
          Gain_3=Exp(m*Ln(v_3)+b)*1e6  ! Build default Gain Curve, 3rd point
          v_4=1600          
          Gain_4=Exp(m*Ln(v_4)+b)*1e6  ! Build default Gain Curve, 4th point
          v_5=1300          
          Gain_5=Exp(m*Ln(v_5)+b)*1e6  ! Build default Gain Curve, 5th point    
          
        ! Set the values in SmartCard NVRAM
          print ReadResource$("tunemac",ID_TUNEMAC_WRITING_VALUES_316) + \
          ReadResource$("tunemac",ID_TUNEMAC_THIS_WILL_TAKE_317)
          MSSCWrite "msc:parm:pset emvgain0," + val$(EmvGain0)
          MSSCWrite "msc:parm:pset emvgain1," + val$(EmvGain1)
          MSSCWrite "msc:parm:pset emvgain2," + val$(EmvGain2)
        ! write to memory as well
          MSSCWrite "msc:parm emvgain0," + val$(EmvGain0)
          MSSCWrite "msc:parm emvgain1," + val$(EmvGain1)
          MSSCWrite "msc:parm emvgain2," + val$(EmvGain2)
          
        WinUpdate Off  
        ! Update Positive Gain Curve Register
          nPoints = 5  ! Set the number of columns in the gain data object to 5
          NewObj GainCurve[CurrPol+2], 2, 1, nPoints !* Create new gain data object
          SetObjHdrText GainCurve[CurrPol+2], "Title", "Positive Gain Curve"
          DelObj GainCurve[CurrPol+3]               ! Get rid of the old data object
          msat_UpdateGainCurveReg CurrPol,PosGainMass,ve6,m,b,v_1,Gain_1,v_2,Gain_2, \
            v_3,Gain_3,v_4,Gain_4,v_5,Gain_5
        WinUpdate On    
          
        ! Annotate the Gain Curve register:
          msat_AnnotGainCurve CurrPol
      
        ! Save the gain curve:
          saveobj GainCurve,_TunePath$+"GainCurve.reg",new
      
        ! Display the Gain-EMV curve on the screen, if not called by autotune:
          if Auto = 0 then
            if curvenum = 1 then
              msat_DispGainCurve,,CurrPol
            endif
          endif
        endif
      If (curvenum = 2) Or (curvenum = 3) Then        ! Reset negative curve
        ! Initialize parameters
          CurrPol = 1
          m = EmvGain0                 ! Default Slope
          b = EmvGain1                 ! Default Intercept
          ve6=Exp((Ln(1)-b)/m)         ! Default EMV from Slope and Intercept values
          v_1=2500
          Gain_1=Exp(m*Ln(v_1)+b)*1e6  ! Build default Gain Curve, 1st point
          v_2=2200
          Gain_2=Exp(m*Ln(v_2)+b)*1e6  ! Build default Gain Curve, 2nd point
          v_3=1900          
          Gain_3=Exp(m*Ln(v_3)+b)*1e6  ! Build default Gain Curve, 3rd point
          v_4=1600          
          Gain_4=Exp(m*Ln(v_4)+b)*1e6  ! Build default Gain Curve, 4th point
          v_5=1300          
          Gain_5=Exp(m*Ln(v_5)+b)*1e6  ! Build default Gain Curve, 5th point
          
        ! Set the values in SmartCard NVRAM
        print ReadResource$("tunemac",ID_TUNEMAC_WRITING_VALUES_316) + \
              "This will take a few moments.  Please wait."
          MSSCWrite "msc:parm:pset emvgain0n," + val$(EmvGain0)
          MSSCWrite "msc:parm:pset emvgain1n," + val$(EmvGain1)
          MSSCWrite "msc:parm:pset emvgain2n," + val$(EmvGain2)
        ! write to memory as well
          MSSCWrite "msc:parm emvgain0n," + val$(EmvGain0)
          MSSCWrite "msc:parm emvgain1n," + val$(EmvGain1)
          MSSCWrite "msc:parm emvgain2n," + Val$(EmvGain2)
        
        WinUpdate Off  
        ! Update Negative Gain Curve Register
          nPoints = 5  ! Set the number of columns in the gain data object to 5
          NewObj GainCurve[CurrPol+2], 2, 1, nPoints !* Create new gain data object
          SetObjHdrText GainCurve[CurrPol+2], "Title", "Negative Gain Curve"
          DelObj GainCurve[CurrPol+3]               ! Get rid of the old data object
          msat_UpdateGainCurveReg CurrPol,NegGainMass,ve6,m,b,v_1,Gain_1,v_2,Gain_2, \
            v_3,Gain_3,v_4,Gain_4,v_5,Gain_5
        WinUpdate On  
          
        ! Annotate the Gain Curve register:
          msat_AnnotGainCurve CurrPol
      
        ! Save the gain curve:
          saveobj GainCurve,_TunePath$+"GainCurve.reg",new
      
        ! Display the Gain-EMV curve on the screen, if not called by autotune:
          if Auto = 0 then
            if curvenum = 2 then
              msat_DispGainCurve,,CurrPol
            else 
              msat_DispGainCurve 0,1
            endif
          endif
      endif
      setabort on
  else
    print ReadResource$("tunemac",ID_TUNEMAC_CAN_T_CHANGE_E_319)
  endif  !* if _OffLine = 0
WinUpdate
  RETURN

ResetEMGainErr:
   On Error Print
   MStnPrintError
   RETURN

endmacro

!************************************************************************!
!************************************************************************!
name SetGain
PARAMETER targEMV default 1485
PARAMETER Auto default 0
! Gain compensation: shifts gain curve for the current polarity so that the
!                    specified target EMV will correspond to a Gain of 1.0.
!                    The target EMV will be clipped to 1400 and 2700 volts.
!
! 10/19/09  CPL Change EMV lower limit to 1000V and upper limit to 2800V. 
! 
!************************************************************************!
! Local oldGain, oldEMV, oldUseEMV, oldEMV$, tempEMV
Local  text$, tempEMV, OOR, CurrPol
Local  CurrSlope$
Local  ID_TUNEMAC_THE_MAXIMUM_AL_320
Local  ID_TUNEMAC_THE_MINIMUM_AL_321
Local  ID_TUNEMAC_SHIFTGAIN_ABOR_322
Local  ID_TUNEMAC_CAN_T_CHANGE_E_319
Local  ID_TUNEMAC_GAINCURVE_REG_323
Local  ID_TUNEMAC_DONE_BURNING_G_324
Local  ID_TUNEMAC_SLOPE_OF_LN_LN_709
Local  ID_TUNEMAC_979

ID_TUNEMAC_979                                     =  17979  
ID_TUNEMAC_THE_MAXIMUM_AL_320                      =  17320  
ID_TUNEMAC_THE_MINIMUM_AL_321                      =  17321  
ID_TUNEMAC_SHIFTGAIN_ABOR_322                      =  17322  
ID_TUNEMAC_CAN_T_CHANGE_E_319                      =  17319  
ID_TUNEMAC_GAINCURVE_REG_323                       =  17323  
ID_TUNEMAC_DONE_BURNING_G_324                      =  17324
ID_TUNEMAC_SLOPE_OF_LN_LN_709                      =  17709
  
   On Error goto SetGainErr  
   
   text$ = ""   
   OOR = 0

   if (_OffLine = 0)  then   
    ! Check for ion polarity and FastScan mode:
      MsParm IonPolarity,CurrPol
    if CurrPol > 1 then
      killit=Alert(ReadResource$("tunemac",ID_TUNEMAC_979),3,"Gain Calibration Curve")
      stop
    endif
   
     if (targEMV > 2800) then
       text$ = text$ + chr$(13) + ReadResource$("tunemac",ID_TUNEMAC_THE_MAXIMUM_AL_320)
       tempEMV = 2800
       OOR = 1
     endif
     if (targEMV < 1000) then
       text$ = text$ + chr$(13) + ReadResource$("tunemac",ID_TUNEMAC_THE_MINIMUM_AL_321)
       tempEMV = 1000
       OOR = 1
     endif
     if OOR = 1 then
       if Alert(text$, 4, "ShiftGain") = 0 then
         print ReadResource$("tunemac",ID_TUNEMAC_SHIFTGAIN_ABOR_322)
         RETURN
       else
         targEMV = tempEMV                    ! Accepts clipped value
       endif
     endif
   else
      print ReadResource$("tunemac",ID_TUNEMAC_CAN_T_CHANGE_E_319)
      RETURN
   endif
   
   !* Check and load the GainCurve register if necessary:
      if RegSize(GainCurve) = -1 then
      !* Register not loaded.  Try loading the register from disk
        if filestat(mode,_tunepath$ + "GainCurve.reg") = 1 then
          LoadObj _tunepath$ + "GainCurve.reg",, GainCurve
        else
        ! GainCurve.reg has been deleted from this system
            title$= "Gain Curve Check"
            line1$= ReadResource$("tunemac",ID_TUNEMAC_GAINCURVE_REG_323)
            line2$= chr$(13) + chr$(13) +"Please restore file or reload ChemStation software."
            _button=alert(line1$ + line2$,3,title$)  ! CPL 03/06 Replace Atuneprint statement with Alert.
            stop
        endif
      endif 
        
   !* Check the GainCurve register and initialize if necessary:
      if (RegSize(GainCurve) < 2) then
        print msat_InitGainCurveReg()  ! Initialize GainCurve register 
        ResetEMGain,,1                 ! Set GainCurve data register to default values
      else
        if (Data (GainCurve[CurrPol+2], 0,1)=0) then
          ResetEMGain,,1               ! No data exists, set GainCurve data register to default values
        endif       
      endif
      
   ! Get the current slope:
   curr_m = TabVal(GainCurve[1],CurveInfo,CurrPol+1,"Slope")
   print Readresource$("tunemac",ID_TUNEMAC_SLOPE_OF_LN_LN_709), curr_m

   ! Calculate and burn the new gain curve
     new_b = -(curr_m*ln(targEMV))        ! New intercept value, keep existing slope
    
   SetAbort Off                 !* Don't let user abort until calibration
                                !* done and burned into SmartCard and Gain Curve Register.
     ! Burn new intercept values in SmartCard NVRAM and Gain Curve Register.
       if CurrPol = 0 then
         SCintercept$ = "emvgain1"
       else
         SCintercept$ = "emvgain1n"
       endif
       b1$ = """msc:parm:pset "+SCintercept$+","""+" + val$(new_b)"
         evaluate "MSSCWrite " + b1$                               ! Intercept ("Offset")
       b2$ = """msc:parm "+SCintercept$+","""+" + val$(new_b)"
         evaluate "MSSCWrite " + b2$

   WinUpdate Off          
     ! Create data object for shifted Gain Curve:
        nPoints = 5  ! Set the number of points in the Gain Curve to 5
          NewObj GainCurve[CurrPol+2], 2, 1, nPoints
            if (CurrPol = 0) then
              SetObjHdrText GainCurve[CurrPol+2], "Title", "Positive Gain Curve"
            else
              SetObjHdrText GainCurve[CurrPol+2], "Title", "Negative Gain Curve"
            endif
       
   ! Update Gain Curve data object CPL 03/31/06
     numcols = DataCols(GainCurve[CurrPol+3])
      for i=1 to numcols
        thisEMV = Data(GainCurve[CurrPol+3],0,i)
        thisGain = Data(GainCurve[CurrPol+3],1,i)
        SetData GainCurve[CurrPol+2],0,i,thisEMV 
        SetData GainCurve[CurrPol+2],1,i,thisGain
      next i
   
     ve6 = targEMV  ! Set Ve6 to targEMV value
     SetTabVal GainCurve[1], "CurveInfo",CurrPol+1,"Offset",new_b
     SetTabVal GainCurve[1], "CurveInfo",CurrPol+1,"Ve6",ve6
   ! Update the Maximum Gain header value:
    if CurrPol = 0 then
      SetObjHdrVal GainCurve[1], "PosGainMax", Data(GainCurve[CurrPol+2], 1, 5)
    else
      SetObjHdrVal GainCurve[1], "NegGainMax", Data(GainCurve[CurrPol+2], 1, 5)
    endif
     DelObj GainCurve[CurrPol+3]  ! Get rid of the old data object
   WinUpdate On
          
    ! Annotate the Gain Curve register:
      msat_AnnotGainCurve CurrPol
  
    ! Save the gain curve:
      saveobj GainCurve,_TunePath$+"GainCurve.reg",new
  
    ! Display the Gain-EMV curve on the screen, if not called by autotune:
      if Auto = 0 then
        msat_DispGainCurve,,CurrPol
    endif
     setabort on
     Print ReadResource$("tunemac",ID_TUNEMAC_DONE_BURNING_G_324)

   RETURN
   
SetGainErr:
   On Error Print
   MStnPrintError
   RETURN   
   
endmacro

!************************************************************************!
!---- Quad Frequency utilities ------------------------------------------!
!************************************************************************!
name QF
! Reports current quad frequency
! 
!************************************************************************!
LOCAL qf1$, qf2$

Local  ID_TUNEMAC_CURRENT_QUAD_F_325
Local  ID_TUNEMAC_POWER_ON_SETTI_326
ID_TUNEMAC_CURRENT_QUAD_F_325                      =  17325  
ID_TUNEMAC_POWER_ON_SETTI_326                      =  17326  
   SCTimeout = 30
   MSSCQuery "msc:parm? quadfreq", qf1$
   MSSCQuery "msc:parm:pset? quadfreq", qf2$
   Print SPrintF$(val(qf1$),ReadResource$("tunemac",ID_TUNEMAC_CURRENT_QUAD_F_325)) + \
         SPrintF$(val(qf2$),ReadResource$("tunemac",ID_TUNEMAC_POWER_ON_SETTI_326)) 
   REMOVE SCTimeout

endmacro   !  QF

!************************************************************************!
!************************************************************************!
name SetQF
PARAMETER quadfreq default 0
! Sets current quad frequency
! 
!************************************************************************!

Local  ID_TUNEMAC_MUST_SPECIFY_A_327
ID_TUNEMAC_MUST_SPECIFY_A_327                      =  17327  
   On Error MStnPrintError
   
   if quadfreq = 0 then
      Print ReadResource$("tunemac",ID_TUNEMAC_MUST_SPECIFY_A_327)
      RETURN
   endif

   MSSCWrite "msc:parm quadfreq," + val$(quadfreq)
   QF          ! read and report quad frequencies

endmacro   !  SetQF

!************************************************************************!
!************************************************************************!
name DipQF
! Sets and reads the quad frequency
! Note: does not burn the frequency; use burnQF to store in instrument
!************************************************************************!
LOCAL qf1$, qf2$

Local  ID_TUNEMAC_QUAD_FREQUENCY_328
Local  ID_TUNEMAC_NEW_QUAD_FREQU_330
ID_TUNEMAC_QUAD_FREQUENCY_328                      =  17328  
ID_TUNEMAC_NEW_QUAD_FREQU_330                      =  17330  
   On Error goto DipQFerror

   SCTimeout = 30
   MSSCQuery "msc:parm? quadfreq", qf1$
   MSSCWrite "cal:mass:rf"
   MSSCQuery "msc:parm? quadfreq", qf2$

   if qf1$ = qf2$ then 
      Print ReadResource$("tunemac",ID_TUNEMAC_QUAD_FREQUENCY_328), qf2$, " Hz"
   else     
      Print ReadResource$("tunemac",ID_TUNEMAC_NEW_QUAD_FREQU_330), qf2$, " Hz"
   endif

   Remove SCTimeout
   
   RETURN
   
DipQFerror:
   On Error Print
   REMOVE SCTimeOut
   MStnPrintError
   
   RETURN

endmacro   !  dipQF

!************************************************************************!
!************************************************************************!
name BurnQF
! Burns the current quad frequency into NVRAM
!************************************************************************!
LOCAL qf$

Local  ID_TUNEMAC_POWER_ON_QUAD_331
ID_TUNEMAC_POWER_ON_QUAD_331                       =  17331  
   On Error goto BurnQFerror

   SCTimeout = 30
   MSSCQuery "msc:parm? quadfreq", qf$
   MSSCWrite "msc:parm:pset quadfreq,", qf$
   print ReadResource$("tunemac",ID_TUNEMAC_POWER_ON_QUAD_331), qf$, " Hz"
   
   Remove SCTimeout
   
   RETURN

endmacro   !  burnQF 

!************************************************************************!
! ---- Quad Temperature utilities ---------------------------------------!
!************************************************************************!
name QT 
! Reads quad temperature
!
!************************************************************************!
LOCAL qt, qtSet$, qtPset$

Local  ID_TUNEMAC_QUAD_TEMP_332
ID_TUNEMAC_QUAD_TEMP_332                           =  17332  
    MSZone quad, qt
    MSSCQuery "zone:name quad; set?", qtset$
    MSSCQuery "zone:name quad; pset?", qtPset$
    print ReadResource$("tunemac",ID_TUNEMAC_QUAD_TEMP_332), qt, "; setpoint: ", qtSet$, \
          "; power-on setpoint: ", qtPset$,  " (şC)"

endmacro

!************************************************************************!
!************************************************************************!
name SetQT                    ! Downloads quad temp 
PARAMETER NewTemp default -1
!
!************************************************************************!
LOCAL NewTemp$

Local  ID_TUNEMAC_SPECIFY_A_QUAD_334
Local  ID_TUNEMAC_QUAD_TEMPERATU_335
ID_TUNEMAC_SPECIFY_A_QUAD_334                      =  17334  
ID_TUNEMAC_QUAD_TEMPERATU_335                      =  17335  
   if NewTemp = -1 then
      print ReadResource$("tunemac",ID_TUNEMAC_SPECIFY_A_QUAD_334)
   else
      MSSCWrite "zone:name quad; set " + val$(NewTemp)
      MSSCQuery "zone:name quad; set?", NewTemp$
      print ReadResource$("tunemac",ID_TUNEMAC_QUAD_TEMPERATU_335) + NewTemp$ + " şC"
   endif

endmacro

!************************************************************************!
!************************************************************************!
name BurnQT
PARAMETER NewTemp  default -1
!
!************************************************************************!
LOCAL newTemp$

Local  ID_TUNEMAC_SPECIFY_A_POWE_337
Local  ID_TUNEMAC_POWER_ON_QUAD_338
ID_TUNEMAC_SPECIFY_A_POWE_337                      =  17337  
ID_TUNEMAC_POWER_ON_QUAD_338                       =  17338  
   if NewTemp  < 0 then 
      Print ReadResource$("tunemac",ID_TUNEMAC_SPECIFY_A_POWE_337)
   else
      MSSCWrite "zone:name quad; pset " + val$(NewTemp)
      MSSCWrite "zone:name quad; set "  + val$(NewTemp)
      MSSCQuery "zone:name quad; pset?", NewTemp$
      Print ReadResource$("tunemac",ID_TUNEMAC_POWER_ON_QUAD_338) + NewTemp$ 
   endif

endmacro

!************************************************************************!
!************************************************************************!
Name FastHeatQT	!  Macro for Fast Quadrupole Temperature Equlibration
Parameter   pRunTime Default 90
!   Version B.03.01,SR1 Release
!   Turns off turbo pump for up to 90 minutes to accelerate quad heating.  
!   During macro execution, the Quad Shroud and Estimated Quad Rod temperatures are plotted.
!   After selected time period, the turbo is turned on and the macro is ended. 

    Local i, lRefTime,lQShroud,lQTemp,lTimeScale,lUpdate,lbutton
    Local lout$		! holds outout string
    Local lT1LabelT$, lT2LabelT$, sEnterTime$, sTemp$;
    Local ID_TUNEMAC__MIN___TIME_RE_544
    Local ID_TUNEMAC_Time_1136
    Local ID_TUNEMAC_CELSIUS_1137
    Local ID_TUNEMAC_QUAD_SHROUD_1138
    Local ID_TUNEMAC_QUAD_ROD_1139
    Local ID_TUNEMAC_ENTER_TIME_1140
    Local ID_TUNEMAC_MACRO_CANCELLED_1141
    Local ID_TUNEMAC_MACRO_COMPLETED_1142
    
    ID_TUNEMAC__MIN___TIME_RE_544     = 17544
    ID_TUNEMAC_Time_1136              = 18136 ! "Time(sec)"
    ID_TUNEMAC_CELSIUS_1137           = 18137 ! "Celsius"
    ID_TUNEMAC_QUAD_SHROUD_1138       = 18138 ! "Quad Shroud Temperature"
    ID_TUNEMAC_QUAD_ROD_1139          = 18139 ! "Quad Rod Temperature (Estimated)"
    ID_TUNEMAC_ENTER_TIME_1140        = 18140 ! "Enter a time value from 15 to 90 minutes"
    ID_TUNEMAC_MACRO_CANCELLED_1141   = 18141 ! "Macro Cancelled"
    ID_TUNEMAC_MACRO_COMPLETED_1142   = 18142 ! "Macro Completed"
    
    lT1LabelT$ = ReadResource$("tunemac",ID_TUNEMAC_QUAD_SHROUD_1138)
    lT2LabelT$ = ReadResource$("tunemac",ID_TUNEMAC_QUAD_ROD_1139)
    sEnterTime$ = ReadResource$("tunemac",ID_TUNEMAC_ENTER_TIME_1140)
 
    If ( regsize( CheckQT ) > 0 ) then
        delobj CheckQT
    EndIf
    
    msscwrite "msc:parm quadto,80"
    Repeat  
    lbutton = INPUT( sEnterTime$, pRunTime )
    If lbutton = 1 Then
      If (pRunTime < 15) OR (pRunTime > 90 ) then
        lbutton = Alert (sEnterTime$, 3, sEnterTime$)
    !Until (pRunTime >= 15)
      Else 
        lTimeScale = pRunTime*60 !Convert to seconds
        lUpdate = pRunTime*6 !Update display every 10 seconds
      Endif
    Else
      Print ReadResource$("tunemac",ID_TUNEMAC_MACRO_CANCELLED_1141)
      Stop
    EndIf
    Until ((pRunTime >= 15) AND (pRunTime <= 90))
    TurbosOff ! Macro call to mstnnrt.mac
    SetQT 100 ! Macro call to mstnutil.mac
    
    i = 0
    MSZone Quad, lQShroud ! Read quad temperature
    lQTemp = lQShroud
    newobj CheckQT,2,2,lUpdate ! Setup matrix register to store quad temperature data
    SetDataVal CheckQT, 0, Step, 10 ! Set the time interval to 10 seconds
    SetData CheckQT, 1, 1, lQShroud ! Set Y1-axis (shroud) value to current temperature
    SetData CheckQT, 2, 1, 30 ! Set Y2-axis (quad) initial value to 30 degrees (cold)
    Draw 3, CheckQT,,25:105,0,1,0	! Scale the graph from 25 to 105 deg C
    SetDataText CheckQT, 0, AxisTitle, ReadResource$("tunemac",ID_TUNEMAC_Time_1136) !X-axis time
    SetDataText CheckQT, 1, AxisTitle, ReadResource$("tunemac",ID_TUNEMAC_CELSIUS_1137) !Y-axis temperature
      Dummy = NewTextAnn (CheckQT[1], "*" + lT1LabelT$,20,102,4,8,8,0xff0000,0,,3,"Arial") !Quad shroud
      Dummy = NewTextAnn (CheckQT[1], "*" + lT2LabelT$,20,99,4,8,8,0x0000ff,0,,3,"Arial") !Quad rods
    lRefTime = Time()
    While i < (lUpdate) do
        Sleep 10
        i = i + 1
        MSZone Quad, lQShroud !Read quad shroud temperature
        sTemp$ = sprintf$(lTimeScale/60,"%.2f") + ReadResource$("tunemac",ID_TUNEMAC__MIN___TIME_RE_544)        
        sTemp$ = sTemp$ + sprintf$((lTimeScale - i*10)/60,"%.2f")
        sTemp$ = sTemp$ + "  " + lT1LabelT$ + " = "
        Print sTemp$, lQShroud
        
        ! Note, the following is an approximation of the Quad rod temperature from cold (30 deg C)
        lQTemp = (-2.2e-12)*(i*i*i*i*i) + (3.23e-9)*(i*i*i*i) - (2.1e-6)*(i*i*i) + (7e-4)*(i*i) + 30 !CPL 12/07/06
        SetData CheckQT, 0, i, (Time() - lRefTime) !Update X-axis time
        SetData CheckQT, 1, i, lQShroud !Update Y1-axis (shroud) temperature
        SetData CheckQT, 2, i, lQTemp !Update Y2-axis (rod) temperature
    EndWhile
    msscwrite "msc:parm quadto,50"
    TurbosOn ! Macro call to mstnnrt.mac
    Print ReadResource$("tunemac",ID_TUNEMAC_MACRO_COMPLETED_1142)
Endmacro ! FastHeatQT

!************************************************************************!
! ---- Quad Polarity Utilities ------------------------------------------!
!************************************************************************!
name QP                         ! quad polarity
PARAMETER NewQP default -1      ! by default, only reports 
                                ! quad polarity
                                ! qp 1 or qp 0 sets quad polarity
!************************************************************************!
local a$, text$, IonPol

Local  ID_TUNEMAC__IS_NOT_A_VALI_339
Local  ID_TUNEMAC_QUAD_POLARITY_340
Local  ID_TUNEMAC___USE_BURNQP_T_341
ID_TUNEMAC__IS_NOT_A_VALI_339                      =  17339  
ID_TUNEMAC_QUAD_POLARITY_340                       =  17340  
ID_TUNEMAC___USE_BURNQP_T_341                      =  17341  
   MSParm IonPolarity, IonPol

   if NewQP <> 1 and NewQP <> 0 and NewQP <> -1 then
      Print NewQP, ReadResource$("tunemac",ID_TUNEMAC__IS_NOT_A_VALI_339)
      RETURN
   endif

   if NewQP <> -1 then
      if IonPol = 0 then                                ! positive ion value
         MSSCWrite "msc:parm quadpolp," + val$(NewQP) 
      else                                              ! negative ion value
         MSSCWrite "msc:parm quadpoln," + val$(NewQP)
      endif
      MSSCWrite "msc:parm quadpol," + val$(NewQP)
   endif

   if IonPol = 0 then
      MSSCQuery "msc:parm? quadpolp",a$ ! report quad polarity
   else
      MSSCQuery "msc:parm? quadpoln",a$
   endif

   Text$ =  ReadResource$("tunemac",ID_TUNEMAC_QUAD_POLARITY_340) + a$ 
   if NewQP <> -1 then
      Text$ = Text$ + ReadResource$("tunemac",ID_TUNEMAC___USE_BURNQP_T_341)
   endif
   
   Print Text$
   RETURN

endmacro

!************************************************************************!
!************************************************************************!
name BurnQP
PARAMETER PosIonQP default -1, NegIonQP default -1
! This macro is an alias for PSetQPol, which stores quad polarity in 
! non-volatile memory.
!
!    Quad polarity is 0 or 1
!    PosIonQP:  for positive ion polarity
!    NegIonQP:  for negative ion polarity
!
! Example:  To set quad polarity to negative for both pos and neg
!      ion polarity, after loading the macro type on the command line:
!
!    BurnQP 1,1
!
!************************************************************************!

Local  ID_TUNEMAC_QUAD_POLARITY_342
Local  ID_TUNEMAC_SYNTAX__BURNQP_343
ID_TUNEMAC_QUAD_POLARITY_342                       =  17342  
ID_TUNEMAC_SYNTAX__BURNQP_343                      =  17343  
   if (PosIonQP = -1) and (NegIonQP = -1) then
      Print ReadResource$("tunemac",ID_TUNEMAC_QUAD_POLARITY_342) + \
            ReadResource$("tunemac",ID_TUNEMAC_SYNTAX__BURNQP_343)
      RETURN
   endif

   PSetQPol PosIonQP, NegIonQP
   RETURN

endmacro

!************************************************************************!
!************************************************************************!
name PSetQPol
PARAMETER pos_set default -1, neg_set default -1
! This macro stores quad polarity in non-volatile memory.
!
!    Quad polarity is 0 or 1
!    pos_set:  for positive ion polarity
!    neg_set:  for negative ion polarity
!
! Example:  To set quad polarity to negative for both pos and neg
!      ion polarity, after loading the macro type on the command line:
!
!   PSetQPol 1,1
!
!************************************************************************!
LOCAL text$ 
Local  ID_TUNEMAC_QUAD_POLARITY_342
Local  ID_TUNEMAC_SYNTAX__PSETQP_344
Local  ID_TUNEMAC_POS__ION_QUAD_345
Local  ID_TUNEMAC_POS__ION_QUAD_346
Local  ID_TUNEMAC_NEG__ION_QUAD_347
Local  ID_TUNEMAC_NEG__ION_QUAD_348
ID_TUNEMAC_QUAD_POLARITY_342                       =  17342  
ID_TUNEMAC_SYNTAX__PSETQP_344                      =  17344  
ID_TUNEMAC_POS__ION_QUAD_345                       =  17345  
ID_TUNEMAC_POS__ION_QUAD_346                       =  17346  
ID_TUNEMAC_NEG__ION_QUAD_347                       =  17347  
ID_TUNEMAC_NEG__ION_QUAD_348                       =  17348  
 
   if (pos_set = -1) and (neg_set = -1) then
      Print ReadResource$("tunemac",ID_TUNEMAC_QUAD_POLARITY_342) + \
            ReadResource$("tunemac",ID_TUNEMAC_SYNTAX__PSETQP_344)
      RETURN
   endif

   SCTIMEOUT = 60        ! 60 sec. timeout
   if (pos_set = 0) or (pos_set = 1) then
      MSSCWrite ":msc:parm quadpolp," + val$(pos_set)
      MSSCWrite ":msc:parm:pset quadpolp," + val$(pos_set)
      text$ = ReadResource$("tunemac",ID_TUNEMAC_POS__ION_QUAD_345) + val$(pos_set) + "; "
   else
      text$ = ReadResource$("tunemac",ID_TUNEMAC_POS__ION_QUAD_346) 
   endif
   if (neg_set = 0) or (neg_set = 1) then
      MSSCWrite ":msc:parm quadpoln," + val$(neg_set)
      MSSCWrite ":msc:parm:pset quadpoln," + val$(neg_set)
      text$ = text$ + ReadResource$("tunemac",ID_TUNEMAC_NEG__ION_QUAD_347) + val$(neg_set)
   else
      text$ = text$ + ReadResource$("tunemac",ID_TUNEMAC_NEG__ION_QUAD_348)
   endif

   Remove SCTimeout
   
   print text$   
   RETURN

endmacro

!************************************************************************!
! ---- Firmware identification utilities --------------------------------!
!************************************************************************!
name MSID                          ! Read or set MS serial number
parameter newSerialNum$ default "" ! reads MS serial number by default
! Sets the global variable MSid$
!************************************************************************!
local a$

Local  ID_TUNEMAC_LC_MSD_SERIAL_349
ID_TUNEMAC_LC_MSD_SERIAL_349                       =  17349  
   if newSerialNum$ <> "" then     
      MSSCWrite "config:id:desc serialnum, '" + newSerialNum$ + "'"
   endif

   MSSCQuery "config:id:desc? serialnum", MSID$  
   MSID$ = ConvertText$(TRIM, MSID$)
   print ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_SERIAL_349) + MSID$

endmacro

