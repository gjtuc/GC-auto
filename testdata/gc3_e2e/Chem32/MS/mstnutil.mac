!************************************************************************!
!************************************************************************!
name LONversion
!  Formatted printout of lon node revisions.  Output to status line is
!  only readily useful if ListMessages is ON 
!************************************************************************!
LOCAL datetime$,tpcid$,cgid$,igid$,sbid$,pdbid$, oldmsecho
LOCAL tpcswrev$,cgswrev$,igswrev$,sbswrev$,pdbswrev$
LOCAL tpchwrev$,cghwrev$,ighwrev$,sbhwrev$,pdbhwrev$
LOCAL km2488d$,km2488e$

   ! Save ms_echo state
Local  ID_TUNEMAC_ID_STRINGS_FRO_354
Local  ID_TUNEMAC_ERROR_COMMUNIC_355
Local  ID_TUNEMAC___CONVECTRON_G_356
Local  ID_TUNEMAC______FIRMWARE_357
Local  ID_TUNEMAC_ERROR_COMMUNIC_358
Local  ID_TUNEMAC___ION_GAUGE_359
Local  ID_TUNEMAC_ERROR_COMMUNIC_360
Local  ID_TUNEMAC___TURBO_INTERF_361
Local  ID_TUNEMAC_ERROR_COMMUNIC_362
Local  ID_TUNEMAC___POWER_DIST_B_363
Local  ID_TUNEMAC_ERROR_COMMUNIC_364
Local  ID_TUNEMAC___SICB_LON_INT_365
Local  ID_TUNEMAC_THIS_FUNCTION_1080 

ID_TUNEMAC_ID_STRINGS_FRO_354                      =  17354  
ID_TUNEMAC_ERROR_COMMUNIC_355                      =  17355  
ID_TUNEMAC___CONVECTRON_G_356                      =  17356  
ID_TUNEMAC______FIRMWARE_357                       =  17357  
ID_TUNEMAC_ERROR_COMMUNIC_358                      =  17358  
ID_TUNEMAC___ION_GAUGE_359                         =  17359  
ID_TUNEMAC______FIRMWARE_357                       =  17357  
ID_TUNEMAC_ERROR_COMMUNIC_360                      =  17360  
ID_TUNEMAC___TURBO_INTERF_361                      =  17361  
ID_TUNEMAC______FIRMWARE_357                       =  17357  
ID_TUNEMAC_ERROR_COMMUNIC_362                      =  17362  
ID_TUNEMAC___POWER_DIST_B_363                      =  17363  
ID_TUNEMAC______FIRMWARE_357                       =  17357  
ID_TUNEMAC_ERROR_COMMUNIC_364                      =  17364  
ID_TUNEMAC___SICB_LON_INT_365                      =  17365  
ID_TUNEMAC______FIRMWARE_357                       =  17357 
ID_TUNEMAC_THIS_FUNCTION_1080                      =  18080 

If ( pre6100() = 0 ) then
  print ReadResource$("tunemac",ID_TUNEMAC_THIS_FUNCTION_1080)
EndIf
 
   if Check(Variable, ms_echo) = 0 then
      ms_echo = 0
   endif
   oldmsecho = ms_echo
   ms_echo = 0

   !Initialize rev strings
   km2488d$ = "PRH1.00.00"
   km2488e$ = "PRH1.00.01"

   Print ""
   Print "********************************************************************"
   Print "--------------------------------------------------------------------"
   Print ReadResource$("tunemac",ID_TUNEMAC_ID_STRINGS_FRO_354)
   MSSCQuery "msc:nrt:id? cg",cgid$
   MSSCQuery "msc:nrt:id? ig",igid$
   MSSCQuery "msc:nrt:id? tpc",tpcid$
   MSSCQuery "msc:nrt:id? pdb",pdbid$
   MSSCQuery "msc:nrt:id? sb",sbid$
   print "--------------------------------------------------------------------"

   ! Get date and time for this query
   msscquery "msc:nrt:nv? pdb,datetime",datetime$

   ! Extract revision strings from the node's ID string
   cgswrev$ = substring$(cgid$,6,,",")
   cghwrev$ = substring$(cgid$,5,,",")
   igswrev$ = substring$(igid$,6,,",")
   ighwrev$ = substring$(igid$,5,,",")
   tpcswrev$ = substring$(tpcid$,6,,",")
   tpchwrev$ = substring$(tpcid$,5,,",")
   pdbswrev$ = substring$(pdbid$,6,,",")
   pdbhwrev$ = substring$(pdbid$,5,,",")
   sbswrev$ = substring$(sbid$,6,,",")
   sbhwrev$ = substring$(sbid$,5,,",")

   ! Print out Hardware Rev and Firmware Rev of LON nodes
   if len(cgswrev$) = 0 or len(cghwrev$) = 0 then
      Print ReadResource$("tunemac",ID_TUNEMAC_ERROR_COMMUNIC_355)
   endif
   Print ReadResource$("tunemac",ID_TUNEMAC___CONVECTRON_G_356)+\
         substring$(cgid$,5,,",")+\
         ReadResource$("tunemac",ID_TUNEMAC______FIRMWARE_357)+cgswrev$

   if len(igswrev$) = 0 or len(ighwrev$) = 0 then
      Print ReadResource$("tunemac",ID_TUNEMAC_ERROR_COMMUNIC_358)
   endif
   Print ReadResource$("tunemac",ID_TUNEMAC___ION_GAUGE_359)+\
         substring$(igid$,5,,",")+\
         ReadResource$("tunemac",ID_TUNEMAC______FIRMWARE_357)+igswrev$

   if len(tpcswrev$) = 0 or len(tpchwrev$) = 0 then
      Print ReadResource$("tunemac",ID_TUNEMAC_ERROR_COMMUNIC_360)
   endif
   Print ReadResource$("tunemac",ID_TUNEMAC___TURBO_INTERF_361)+\
         substring$(tpcid$,5,,",")+\
         ReadResource$("tunemac",ID_TUNEMAC______FIRMWARE_357)+tpcswrev$

   if len(pdbswrev$) = 0 or len(pdbhwrev$) = 0 then
      Print ReadResource$("tunemac",ID_TUNEMAC_ERROR_COMMUNIC_362)
   endif
   Print ReadResource$("tunemac",ID_TUNEMAC___POWER_DIST_B_363)+\
         substring$(pdbid$,5,,",")+\
         ReadResource$("tunemac",ID_TUNEMAC______FIRMWARE_357)+pdbswrev$

   if len(sbswrev$) = 0 or len(sbhwrev$) = 0 then
      Print ReadResource$("tunemac",ID_TUNEMAC_ERROR_COMMUNIC_364)
   endif
   Print ReadResource$("tunemac",ID_TUNEMAC___SICB_LON_INT_365)+\
         sbhwrev$+\
         ReadResource$("tunemac",ID_TUNEMAC______FIRMWARE_357)+sbswrev$
   Print "--------------------------------------------------------------------"

   ms_echo = oldmsecho

   RETURN

endmacro   ! lonversion

!************************************************************************!
!************************************************************************!
name CheckVer$       ! Print out all versions 
PARAMETER ListMessagesOn default 1
! Returns "completed" or "failed: communication error."
! If ListMessWin is 0, then the listmessages window is not popped up.
!
!************************************************************************!
local Result$, swID$, ProdNum$, oldmsecho

Local  ID_TUNEMAC____LC_MSD_VERS_366
Local  ID_TUNEMAC_CHEMSTATION_SO_367
Local  ID_TUNEMAC_MS_UTILITIES_R_368
Local  ID_TUNEMAC_LC_MSD_MODEL_369
Local  ID_TUNEMAC_LC_MSD_SERIAL_370
Local  ID_TUNEMAC_SMARTCARD_CODE_371
Local  ID_TUNEMAC_ANALYZER_BOARD_372
Local  ID_TUNEMAC_I_O_BOARD_FIRM_373
ID_TUNEMAC____LC_MSD_VERS_366                      =  17366  
ID_TUNEMAC_CHEMSTATION_SO_367                      =  17367  
ID_TUNEMAC_MS_UTILITIES_R_368                      =  17368  
ID_TUNEMAC_LC_MSD_MODEL_369                        =  17369  
ID_TUNEMAC_LC_MSD_SERIAL_370                       =  17370  
ID_TUNEMAC_SMARTCARD_CODE_371                      =  17371  
ID_TUNEMAC_ANALYZER_BOARD_372                      =  17372  
ID_TUNEMAC_I_O_BOARD_FIRM_373                      =  17373  
   On Error goto CheckVerErr
   if listMessagesOn = 1 then
      ListMessages on
   endif

   ! Save ms_echo state
   if Check(Variable, ms_echo) = 0 then
      ms_echo = 0
   endif
   oldmsecho = ms_echo
   ms_echo = 0

   print ""
   print "~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~"
   print ReadResource$("tunemac",ID_TUNEMAC____LC_MSD_VERS_366)
   print "~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~"
   print ""
   ! get software rev
   print ReadResource$("tunemac",ID_TUNEMAC_CHEMSTATION_SO_367) + _Version$
   ! print msUtil rev
   print ReadResource$("tunemac",ID_TUNEMAC_MS_UTILITIES_R_368) + MStnUtilVer$
   SCid 0
   print ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_MODEL_369) + SubString$(SCid$,2,,",")
   print ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_SERIAL_370) + SubString$(SCid$,3,,",")
   print ReadResource$("tunemac",ID_TUNEMAC_SMARTCARD_CODE_371) + SubString$(SCid$,4,,",")
   print ""
   print ReadResource$("tunemac",ID_TUNEMAC_ANALYZER_BOARD_372) + nvrAnRev$()
   print ReadResource$("tunemac",ID_TUNEMAC_I_O_BOARD_FIRM_373) + nvrIORev$()
   LONVersion
   print ""

   RETURN " completed"
   
CheckVerErr:
   On Error print
   MStnPrintError
   RETURN " failed: communication error."

   ms_echo = oldmsecho

endmacro

!************************************************************************!
! ---- General utilities ------------------------------------------
!************************************************************************!
name showRF
PARAMETER mz default 1000, count default 3
! displays the RF drive, RF forward power and RF reflected power
! at a given mass setting.  
!************************************************************************!


Local  ID_TUNEMAC_M_Z_374
ID_TUNEMAC_M_Z_374                                 =  17374  
ID_TUNEMAC_M_Z_374                                 =  17374  
   MSSetRFPA mz
   sleep 2

   while count > 0 
      msscquery "sens? rfdrive", rfdrive$
      ! msscquery "sens? rfpowerf", rfpowerf$
      ! msscquery "sens? rfpowerr", rfpowerr$
      print ReadResource$("tunemac",ID_TUNEMAC_M_Z_374), mz, ";  RF Drive: ", rfdrive$
      ! print ReadResource$("tunemac",ID_TUNEMAC_M_Z_374), mz, "RF Drive: ", rfdrive$, "; Forward power: ", \
      !       rfpowerf$, "; Reverse power: ", rfpowerr$
      sleep 1
      count = count - 1
   endwhile

endmacro   ! end showRF

!************************************************************************!
!*****************************************************************************
name recapture
PARAMETER mz default 622.03, CapPer default 100, do_prof default 1
PARAMETER nPts default 10000
! Infinite loop of captures.  A profile is done before the first 
! capture if the third parameter is non-zero.  The macro is stopped
! using the abort menu item
!*****************************************************************************
LOCAL OldLogDataState

   ! Turn on logging
Local  ID_TUNEMAC_CAPTURE__RSD_378
ID_TUNEMAC_CAPTURE__RSD_378                        =  17378  
   MSLogData oldLogDataState ,1
   MSSCQuery "cap:per?", OldCapPer$
   CapPer = CapPer / 1e6   ! convert to seconds from microseconds
   MSSCWrite "cap:per " + val$(CapPer)
 
   ! Do an MSOn if specified
   if do_prof <>0 then
      MSProfile -1
   endif

   while 1=1 do
      MSCapture mz, nPts
      if capMean <> 0 then
         print ReadResource$("tunemac",ID_TUNEMAC_CAPTURE__RSD_378)+val$((capStdDev/CapMean)*100)
      endif
   endwhile
   MSLogData OldLogDataState 

endmacro   ! end recapture

!*****************************************************************************
!************************************************************************!
name HED                          ! reads or sets HED voltage
PARAMETER newVoltage default -1   ! by default, only reports 
                                  ! anything over 10000 sets to 10000
!************************************************************************!
LOCAL MaxHED, newHEDV

Local  ID_TUNEMAC_HED_SET_TO_379
ID_TUNEMAC_HED_SET_TO_379                          =  17379  
   MSParmInfo HED,,, MaxHED

   if newVoltage > MaxHED then
      newVoltage = MaxHED
   endif

   if newVoltage > -1 then
      MSParm HED,, newVoltage     ! Turns on to default
   endif

   MSParm HED, newHEDV              ! reports HED voltage
   Print ReadResource$("tunemac",ID_TUNEMAC_HED_SET_TO_379), newHEDV, " volts."
   RETURN

endmacro

!************************************************************************!
!************************************************************************!
name RampHED                
PARAMETER massNumber default -1   ! Ramps mass 3 by default 
                                  ! 0 means all masses
!************************************************************************!
LOCAL isMassSelected

   ! parameter checking
   if massNumber - floor(massNumber) <> 0  ! in case they asked for an m/z value
Local  ID_TUNEMAC_PLEASE_SPECIFY_381
ID_TUNEMAC_PLEASE_SPECIFY_381                      =  17381  
      print ReadResource$("tunemac",ID_TUNEMAC_PLEASE_SPECIFY_381) + \
            "selected masses." 
      RETURN
   endif
   
   ! anything over six gives the default
   if massNumber >  6 or massNumber < -1 then
      massNumber = -1
   endif
   
   ! Default 
   if massNumber = -1 then
      massNumber =  3
   endif

   ! Make sure the mass is selected
   if massNumber <> 0 then
      MSMassValue massNumber,,, isMassSelected
      MSMassValue massNumber,,,, 1
   endif

   if massNumber = 0 then
      MSSIMRamp HED                  ! all currently selected masses
   else
      MSSIMRamp HED, massNumber      ! indicated mass number
   endif
   
   if massNumber <> 0 then
      MSMassValue massNumber,,,, isMassSelected
   endif
   
   RETURN

endmacro

!************************************************************************!
!************************************************************************!
name Set_Lag
PARAMETER MassNumber default 2
PARAMETER Threshold default 1e4
! Determines the mass axis lag factors (scanning down) using a specified
! m/z value.  By default, massNumber 2 is used.  If the signal is 
! < Threshold in profile scan, then the macro aborts.
!
! Preconditions:
! There should be a strong, stable signal before calculating the lag factors
!************************************************************************!
LOCAL MALD0$, MALD1$, MALD2$, RetStr$, i, oldAverages, oldSamples, text$
LOCAL MassSel1, MassSel2, MassSel3, MassSel4, MassSel5, MassSel6
LOCAL Mass

Local  ID_TUNEMAC_INSUFFICIENT_S_382
Local  ID_TUNEMAC_CALCULATING_MA_383
Local  ID_TUNEMAC_MASS_LAG_FACTO_384
Local  ID_TUNEMAC___MALD1___4_2E_385
Local  ID_TUNEMAC___MALD2___4_2E_386
ID_TUNEMAC_INSUFFICIENT_S_382                      =  17382  
ID_TUNEMAC_CALCULATING_MA_383                      =  17383  
ID_TUNEMAC_MASS_LAG_FACTO_384                      =  17384  
ID_TUNEMAC___MALD1___4_2E_385                      =  17385  
ID_TUNEMAC___MALD2___4_2E_386                      =  17386  
   On Error goto Set_LagErr

   if (massNumber < 1) or (massNumber > 6) then
         massNumber = 2
   endif
   
   ! Turn off all masses except selected mass
   for i = 1 to 6
      if i = massNumber then
         text$ = "MSMassValue i, Mass,, MassSel" + val$(i) + ", 1"
         evaluate text$
      else
         text$ = "MSMassValue i,,, MassSel" + val$(i) + ", 0"
         evaluate text$
      endif
   next i
   
   MSAverages oldAverages, 9
   MSSamples  oldSamples, 20
   MSProfile 
   
   if (PeakMax2 < Threshold) then
      i = Alert(SPrintF$(Mass, ReadResource$("tunemac",ID_TUNEMAC_INSUFFICIENT_S_382)), 3, \
                "Set Lag")
      goto Set_LagExit
   endif
   Mass = BasePeak2
   
   SCTimeOut = 60

   Print SPrintF$(Mass,ReadResource$("tunemac",ID_TUNEMAC_CALCULATING_MA_383))

   MSSCWrite "cal:mass:lag " + val$(Mass)

   MSSCWrite "msc:parm:name MALD0"
   MSSCQuery "msc:parm:act? ", MALD0$
   MSSCWrite "msc:parm:name MALD1"
   MSSCQuery "msc:parm:act? ", MALD1$
   MSSCWrite "msc:parm:name MALD2"
   MSSCQuery "msc:parm:act? ", MALD2$

   RetStr$ = SPrintF$(val(MALD0$), ReadResource$("tunemac",ID_TUNEMAC_MASS_LAG_FACTO_384)) + \
             SPrintF$(val(MALD1$), ReadResource$("tunemac",ID_TUNEMAC___MALD1___4_2E_385)) + \
             SPrintF$(val(MALD2$), ReadResource$("tunemac",ID_TUNEMAC___MALD2___4_2E_386))
   
   if Check(Variable, PRTestVer$) = 1 then
      Archive_Header "SETLAG"
      Archive_Data "MASS", val$(mass)
      Archive_Data "FACTOR0", MALD0$
      Archive_Data "FACTOR1", MALD1$
      Archive_Data "FACTOR2", MALD2$
      Archive
   endif

   i = Alert(RetStr$, 2, "Set Lag")

Set_LagExit:
   Remove SCTimeOut

   ! Restore mass settings
   for i = 1 to 6
      text$ = "MSMassValue i,,,, MassSel" + val$(i)
      evaluate text$
   next i

   MSAverages , oldAverages
   MSSamples,   oldSamples
   
   RETURN
   
Set_LagErr:
   On Error Print
   MStnPrintError
   goto Set_LagExit

endmacro

!************************************************************************!
!************************************************************************!
name SCFault$
! Returns the 256-bit fault string broken up into 16 words
!************************************************************************!
LOCAL faultIn4, faultOut$, pos

   MSSCQuery "msc:flt:stat:full?", faultIn$
   ! Strip leading 0x
   FaultOut$ = "Fault: 0x "
   for i = 1 to 16
      pos = ((i-1)*4)+3
      FaultOut$ = FaultOut$ + FaultIn$[pos:pos+3] + ", "
   next i 

   RETURN FaultOut$[1:len(FaultOut$)-1]

endmacro
!************************************************************************!

!************************************************************************!
!************************************************************************!
!************************************************************************!
name flt
! shortcut for dgMSReportFault
! 
!************************************************************************!
  
   if check(macro, dgMSReportFault) = 0 then
      LoadMacroMcxOrMac _AutoMSPath$ + "hpmsdiag"
   endif 
   
   dgMSReportFault

endmacro
!************************************************************************!

!************************************************************************!
!************************************************************************!
!************************************************************************!
name scqStr$
PARAMETER queryStr$, field default 0
!
! Returns the response from the supplied SCQuery string.  If field is 
! specified, will return the field (comma separated) requested.  
!
! 12/10/2009 CPL Updated for 6100 series 'Orion' instruments
!************************************************************************!
LOCAL scqResp$

Local  ID_TUNEMAC__HAS_OCCURRED_387
ID_TUNEMAC__HAS_OCCURRED_387                       =  17387  

   ! To handle Non-Real Time (NRT) errors from 61xx series LC/MS instruments
   if (msmodeloptions > 13) AND (msmodeloptions < 27) then
     if Instr(queryStr$, "msc:nrt") > 0 then
       return "N/A"
     endif
   endif

   On Error goto SCqStrErr

   evaluate "MSSCQuery """ + queryStr$ + """, scqResp$"
   if field > 0 then
      scqResp$ = SubString$(scqResp$, field, , ",")
   endif
 
   RETURN scqResp$
   
   scqStrErr: 
   print _ErrMsg$ + ReadResource$("tunemac",ID_TUNEMAC__HAS_OCCURRED_387) + queryStr$ + ")"
   RETURN "ERROR"

endmacro

!************************************************************************!
!************************************************************************!
name PrintErrTable
PARAMETER filename$ default ""
!  This will print out the MSDLogBook register Error table, with formatted
!  time stamp.  If no filename is supplied, it will go to the printer.
!
!************************************************************************!
LOCAL i, filenum, MfgEnv, a$

Local  ID_TUNEMAC_MSD_LOGBOOK_ER_389
Local  ID_TUNEMAC_ERROR_LOGBOOK_390
ID_TUNEMAC_MSD_LOGBOOK_ER_389                      =  17389  
ID_TUNEMAC_ERROR_LOGBOOK_390                       =  17390  
   if filename$ = "" then
      filenum = 5
   else 
      filenum = 7
   endif
   
   MfgEnv = Check(Variable, PRTestVer$)
   MSID
   
   on error print
   close #filenum
   endjob
   on error goto PrintErrTableErr

   if filenum = 5 and MfgEnv = 1 then
      MfgHeaderMain "MSD Logbook Error table"
   else
      open filename$ for output as #filenum
      print #filenum, ReadResource$("tunemac",ID_TUNEMAC_MSD_LOGBOOK_ER_389) + MSID$ + \
                      "    " + Time$()
      print #filenum,  ""
   endif

   if ObjHdrType(MSDLogBook, Error) <> 4 then
      print #filenum, ReadResource$("tunemac",ID_TUNEMAC_ERROR_LOGBOOK_390)
   else
      for i = 1 to TabHdrVal(MSDLogBook, Error, "NumberOfRows")
        print #filenum, Time$(,TabVal(MSDLogBook, Error, i, "Time"))
        print #filenum, "   " + TabText$(MSDLogBook, Error, i, "EventMessage") 
        if (filenum = 5) and (yLoc() > YlogMax() - 3) then
           FormFeed
           if Check(Variable, PRTestVer$) = 1 then
              MfgHeaderPrint
           endif
         endif
      next i
   endif
   
PrintErrTableExit:
   On Error print
   EndJob
   close #filenum

   if filenum <> 5 then
!       a$ = "notepad.exe " + FileName$
 
       a$ = "notepad.exe" + chr$(34) + FileName$ + chr$(34) 	 
       execnowait a$, 1
   endif

   RETURN   
      

PrintErrTableErr:   
   On Error Print
   MStnPrintError
   goto PrintErrTableExit
   
endmacro

!************************************************************************!
!************************************************************************!
name MSLight
PARAMETER PrintReport default 0
! This status light macro requires visual inspection of the display panel.
! It sets the light to a color and asks the user to visually verify if the
! color displaying on the panel is correct or not.
!
! The data values correspond to colors on the Sprite display board.
! All of these data words are send to address 3.
!
! Color     Data Word   Blinking
! --------------------------------------
! Off       0x0007
! Green     0x0002      0x000A
! Yellow    0x0000      0x0008
! Red       0x0005      0x000D
!
! There are also other combinations that produce dim green (0x0003 &
! 0x0006), light orange (0x0001), orange (0x0004), but the fundamental
! colors are the ones above that need to be tested.
!************************************************************************!
LOCAL statusOff, statusGrn, statusYel, statusRed, MfgEnv, resp
LOCAL statusOff$, statusGrn$, statusYel$, statusRed$, msg$
LOCAL Disp$

   ! Initialization
Local  ID_TUNEMAC_THE_STATUS_LIG_391
Local  ID_TUNEMAC_IS_THE_STATUS_392
Local  ID_TUNEMAC_IS_STATUS_LIGH_393
Local  ID_TUNEMAC_EVALUATING_STA_394
Local  ID_TUNEMAC_GENERATING_REP_395
Local  ID_TUNEMAC_LC_MSD_STATUS_396
Local  ID_TUNEMAC_STATUS_LIGHT_P_397
Local  ID_TUNEMAC_LC_MSD_STATUS_398
Local  ID_TUNEMAC_STATUS_LIGHT_399

Local  ID_TUNEMAC_LC_MSD_STATUS_400
ID_TUNEMAC_THE_STATUS_LIG_391                      =  17391  
ID_TUNEMAC_IS_THE_STATUS_392                       =  17392  
ID_TUNEMAC_IS_STATUS_LIGH_393                      =  17393  
ID_TUNEMAC_EVALUATING_STA_394                      =  17394  
ID_TUNEMAC_GENERATING_REP_395                      =  17395  
ID_TUNEMAC_LC_MSD_STATUS_396                       =  17396  
ID_TUNEMAC_STATUS_LIGHT_P_397                      =  17397  
ID_TUNEMAC_LC_MSD_STATUS_398                       =  17398  
ID_TUNEMAC_STATUS_LIGHT_399                        =  17399  
ID_TUNEMAC_LC_MSD_STATUS_396                       =  17396  
ID_TUNEMAC_LC_MSD_STATUS_400                       =  17400  
   statusOff = 0
   statusGrn = 0
   statusYel = 0
   statusRed = 0
   statusOff$ = "PASS"
   statusGrn$ = "PASS"
   statusYel$ = "PASS"
   statusRed$ = "PASS"
   MfgEnv = Check(Variable, PRTestVer$)
   Disp$ = ""
   msg$ = "The status light test requires visual inspection " + chr$(13) + \
          "of the status light." + chr$(13)
   print  ReadResource$("tunemac",ID_TUNEMAC_THE_STATUS_LIG_391)

   ! Off Status
   msscwrite "msdc:mse 3,7"
   sleep 1
   print msg$
   statusoff = Alert(msg$ + "Is the status light OFF?",5)
   if (statusOff = -1) then
      goto LabelDone
   endif

   ! Green Status
   msscwrite "msdc:mse 3,2"
   sleep 1
   statusGrn = Alert(msg$ + "Is the status light GREEN?",5)
   if (statusGrn = -1) then
      goto LabelDone
   endif

   ! Yellow Status
   msscwrite "msdc:mse 3,0"
   sleep 1
   statusYel = alert(msg$ + ReadResource$("tunemac",ID_TUNEMAC_IS_THE_STATUS_392),5)
   if (statusYel = -1) then
      goto LabelDone
   endif

   ! Red Status
   msscwrite "msdc:mse 3,5"
   sleep 1
   statusRed = alert(msg$ + ReadResource$("tunemac",ID_TUNEMAC_IS_STATUS_LIGH_393),5)
   if (statusRed = -1) then
      goto LabelDone
   endif


   ! Evaluate Each Status
   print ReadResource$("tunemac",ID_TUNEMAC_EVALUATING_STA_394)
   if (statusOff = 0) then
      statusOff$ = "FAIL"
      Disp$ = "OFF "
   endif
   if (statusGrn = 0) then
      statusGrn$ = "FAIL"
      Disp$ = Disp$ + "GREEN "
   endif
   if (statusYel = 0) then
      statusYel$ = "FAIL"
      Disp$ = Disp$ + "YELLOW "
   endif
   if (statusRed = 0) then
      statusRed$ = "FAIL"
      Disp$ = Disp$ + "RED "
   endif

   ! Generate report
   print ReadResource$("tunemac",ID_TUNEMAC_GENERATING_REP_395)

   if (printreport = 0) then  ! display report on screen
      if ((statusOff + StatusGrn + statusYel + StatusRed) < 4) then
         resp = alert(ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_STATUS_396) + chr$(13) + Disp$,2)
      else
         resp = alert(ReadResource$("tunemac",ID_TUNEMAC_STATUS_LIGHT_P_397),2)
      endif
   else           ! print report to printer
      if MfgEnv = 1 then
         MfgHeaderMain "Status Light Test"
      else
         GetCurrentPrinterSetup                    !3-02PR utilize current printer setup
!!         On Error Print
!!         EndJob
!!         Close #5
         if DevNum() <> 5 then
            On Error CloseDeviceBeforeOpenDevice   !3-02PR close only if error on OpenDevice
            OpenDevice "Printer" as #5
         endif
         On Error Print
         BeginJob
         print #5, ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_STATUS_398) + MSID$ + \
                         "   " + Time$()
         print #5,  ""
      endif

      print #5, ReadResource$("tunemac",ID_TUNEMAC_STATUS_LIGHT_399)
      print #5, " "
      print using #5, "%%%%%%   %%%%%%/","Color","Status"
      print       #5, "---------------"
      print using #5, "%%%%%%   %%%%%%/","Off", statusOff$
      print using #5, "%%%%%%   %%%%%%/","Green", statusGrn$
      print using #5, "%%%%%%   %%%%%%/","Yellow", statusYel$
      print using #5, "%%%%%%   %%%%%%/","Red", statusRed$ 
      On Error print
      close #5
      EndJob
   endif

LabelDone:
   if ((statusOff + StatusGrn + statusYel + StatusRed) < 4) then
      print ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_STATUS_396)+Disp$
   else
      print ReadResource$("tunemac",ID_TUNEMAC_LC_MSD_STATUS_400)
   endif
   
   RETURN

endmacro

!**************************************************************************
!************************************************************************!
name PSDelay                    ! Polarity switching delay
PARAMETER NewPSDelay default -1 ! by default, only reports the delay
                                ! Use burnPSDelay to change power-on default
!************************************************************************!
local a$, b$, text$

Local  ID_TUNEMAC_ERROR__POLARIT_401
Local  ID_TUNEMAC_CURRENT_POLARI_402
Local  ID_TUNEMAC_POWER_ON_POLAR_404
Local  ID_TUNEMAC_MSD__POLARITY_406
Local  ID_TUNEMAC__MSEC_405
ID_TUNEMAC_ERROR__POLARIT_401                      =  17401  
ID_TUNEMAC_CURRENT_POLARI_402                      =  17402  
ID_TUNEMAC_POWER_ON_POLAR_404                      =  17404  
ID_TUNEMAC_MSD__POLARITY_406                       =  17406  
ID_TUNEMAC__MSEC_405                               =  17405  
   if NewPSDelay <> -1 then    
      if NewPSDelay < 0 then 
         Print ReadResource$("tunemac",ID_TUNEMAC_ERROR__POLARIT_401)
         RETURN
      else
         MSSCWrite "msc:parm mpst, " + val$(NewPSDelay)
      endif
   endif

   MSSCQuery "msc:parm? mpst", a$
   MSSCQuery "msc:parm:pset? mpst", b$
   Print ReadResource$("tunemac",ID_TUNEMAC_CURRENT_POLARI_402) + a$ + " mSec; " + \
         ReadResource$("tunemac",ID_TUNEMAC_POWER_ON_POLAR_404) + b$ + " mSec."

   ! Make a logbook entry
   WriteToLogbook ReadResource$("tunemac",ID_TUNEMAC_MSD__POLARITY_406) + \
                  val$(NewPSDelay) + ReadResource$("tunemac",ID_TUNEMAC__MSEC_405)

   ! Change ChemStation variable for delay (in seconds)
   
   MSCFGPOLSWITCH = val(a$) * 0.001 

   RETURN

endmacro       ! PSDelay

!************************************************************************!
!************************************************************************!
name IonDelay                    ! Ionization switching delay
PARAMETER NewIonDelay default -1 ! by default, only reports the delay
                                ! Use burnIonDelay to change power-on default
!************************************************************************!
local a$, b$, text$

Local  ID_TUNEMAC_ERROR__IONIZAT_407
Local  ID_TUNEMAC_CURRENT_IONIZA_408
Local  ID_TUNEMAC_MSD__IONIZATIO_409
ID_TUNEMAC_ERROR__IONIZAT_407                      =  17407  
ID_TUNEMAC_CURRENT_IONIZA_408                      =  17408  
ID_TUNEMAC_MSD__IONIZATIO_409                      =  17409  
   if NewIonDelay <> -1 then    
      if NewIonDelay < 0 then 
         Print ReadResource$("tunemac",ID_TUNEMAC_ERROR__IONIZAT_407)
         RETURN
      else
         MSSCWrite "msc:parm ionst, " + val$(NewIonDelay)
      endif
   endif

   MSSCQuery "msc:parm? ionst", a$
   MSSCQuery "msc:parm:pset? ionst", b$
   Print ReadResource$("tunemac",ID_TUNEMAC_CURRENT_IONIZA_408) + a$ + " mSec; " + \
         "power-on ionization switching delay: " + b$ + " mSec."

   ! Make a logbook entry
   WriteToLogbook ReadResource$("tunemac",ID_TUNEMAC_MSD__IONIZATIO_409) + \
                  val$(NewIonDelay) + " mSec."

   ! Change ChemStation variable for delay (in seconds)
   
   MSCFGIONSWITCH = val(a$) * 0.001 

   RETURN

endmacro       ! IonDelay

!************************************************************************!
!************************************************************************!
name BurnPSDelay
PARAMETER NewPSDelay default -1   ! Polarity switching delay
! Stores a new polarity switching delay value to non-volatile RAM
!************************************************************************!

Local  ID_TUNEMAC_ERROR__POLARIT_401
Local  ID_TUNEMAC_CURRENT_POLARI_402
ID_TUNEMAC_ERROR__POLARIT_401                      =  17401  
ID_TUNEMAC_CURRENT_POLARI_402                      =  17402  
   if NewPSDelay <> -1 then    
      if NewPSDelay < 0 then 
         Print ReadResource$("tunemac",ID_TUNEMAC_ERROR__POLARIT_401)
         RETURN
      else
         MSSCWrite "msc:parm:pset mpst, " + val$(NewPSDelay)
      endif
  endif

   MSSCQuery "msc:parm? mpst", a$
   MSSCQuery "msc:parm:pset? mpst", b$
   Print ReadResource$("tunemac",ID_TUNEMAC_CURRENT_POLARI_402) + a$ + " mSec; " + \
         "power-on polarity switching delay: " + b$ + " mSec."
   RETURN

endmacro

!************************************************************************!
!************************************************************************!
name BurnIonDelay
PARAMETER NewIonDelay default -1   ! Ionization switching delay
! Stores a new ionization switching delay value to non-volatile RAM
!************************************************************************!

Local  ID_TUNEMAC_ERROR__IONIZAT_407
Local  ID_TUNEMAC_CURRENT_IONIZA_408
ID_TUNEMAC_ERROR__IONIZAT_407                      =  17407  
ID_TUNEMAC_CURRENT_IONIZA_408                      =  17408  
   if NewIonDelay <> -1 then    
      if NewIonDelay < 0 then 
         Print ReadResource$("tunemac",ID_TUNEMAC_ERROR__IONIZAT_407)
         RETURN
      else
         MSSCWrite "msc:parm:pset ionst, " + val$(NewIonDelay)
      endif
  endif

   MSSCQuery "msc:parm? ionst", a$
   MSSCQuery "msc:parm:pset? ionst", b$
   Print ReadResource$("tunemac",ID_TUNEMAC_CURRENT_IONIZA_408) + a$ + " mSec; " + \
         "power-on ionization switching delay: " + b$ + " mSec."
   RETURN

endmacro

!************************************************************************!
!****************************************************************************!
name MSTNCpTerminate 

PARAMETER CpProcess$ default ""

!
! Description: Macro will get the CP given by CpProcess$ if it is currently active.
!              otherwise no action will be taken and no error will be generated.
!  
!****************************************************************************!
LOCAL CpXY$, i

  i = 1   
  CpXY$ = CpName$(i)
  while CpXY$ <> "" do
      if UpperCase$(CpXY$) = UpperCase$(CpProcess$) then
     CpTerminate CpProcess$
     return
   else
     i = i + 1
      CpXY$ = CpName$(i)
   endif
  endwhile

  return

endmacro !MSTNCpTerminate

!*******************************************************************************
Name Pre6100
! Function returns 1 if an MSD model G1946 or G1956 is connected.
! Otherwise the function returns 0.
!
! Test if register MSAcqInfo exist. If not, try to load it.
! If it fails, return 0
! Check if header variable InstrumentType exists. If not return 0
! Test if InstrumentType is 1946 or 1956. If not, return 0. If yes, return 1
!*******************************************************************************
Local lModel$
    If ( regsize( MSAcqInfo ) < 1 ) then
	MSAcqInfo
    Endif
    If ( regsize( MSAcqInfo ) < 1 ) then
        Return 0                             !----->
    Endif
    If ( ObjHdrType( MSAcqInfo, InstrumentType ) <> 0 ) then
        Return 0                             !----->
    Endif
    lModel$ = ObjHdrText$( MSAcqInfo[1], "InstrumentType")
    If ( instr( lModel$, "1946") > 0 ) OR ( instr( lModel$, "1956" ) > 0 ) then
        Return 1                             !----->
    Else
        Return 0                             !----->
    Endif
Endmacro ! pre6100()
!===============================================================================
Name CDSshort  ! Makes waiting time for calibrant switching short (ueff 060830)
               ! Original waiting time is restored when MSD reboots.
    MSSCWrite "MSC:PARM:SET CDSDONPS,3"
    MSSCWrite "MSC:PARM:SET CDSDONCD,1"
    MSSCWrite "MSC:PARM:SET CDSDOFP2,1"
    MSSCWrite "MSC:PARM:SET CDSDOFP1,1"
    MSSCWrite "MSC:PARM:SET CDSDOFRS,1"
EndMacro ! CDSshort
