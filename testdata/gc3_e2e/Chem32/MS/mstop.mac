! 11/11/05 BW  Added support for Lassen models
! 02/10/06 CPL Update header information
!*************************************************************************************
!############################################################################
name MSTop_MultiFIAHook
!  Puts a Hook to PostAcq.
!  In this manner the varaiable _MULTIFIAON is set to 0 every-time the method
!  runs successfully. If there is an error or any user abort condition, we
!  can check if this variable has been reset. If not reset the user can be
!  posted with their own abort message....
!############################################################################
      _MULTIFIAON = 0
     
endmacro ! MSTop_MultiFIAHook
!############################################################################
!
!############################################################################
name MSTop_LoadCPCom
	LOCAL sname$ , mychannel
        local i, sFile$, iTotal
!  Loads HPCOM_01.DLC if not already loaded.
!  Used for LCMS CP System Variables
!############################################################################
      if _OFFLINE = 1 then 
	 iTotal = 0
      	 for i=1 to 9
             sFile$ = _TEMPPATH$ + "\seqinfo.00" + val$(i) 
        	if FileStat (Mode, sFile$) <> -1
           	    iTotal = iTotal + 1
        	endif
      	 next i
              if iTotal > 1 then
	          return
      	      endif
	 sname$ = ""
	 sname$ = ProfileString$(("PCS,"+val$(_Instrument)),"_DDEOnline")
	      if sname$ = "" then
	          _CpCom = InstallCmds(_AutoMSPath$ + "HPCOM_01.DLC")
        	  _InitCpOleSrv " "
	      else
	          On Error goto COM_LABEL
		  mychannel = DDeInitiate( sname$,"cpnowait")
		  DDeTerminate mychannel	
	      endif
      else

      COM_LABEL:
        _CpCom = InstallCmds(_AutoMSPath$ + "HPCOM_01.DLC")
        _InitCpOleSrv " "
      endif
      On Error
endmacro ! MSTop_LoadCPCom
!############################################################################
!
!############################################################################
name MSTop_CheckLoadDLC
!  Loads HPMDUI01.DLC if not already loaded.
!  Used for LCMS CP System Variables
!############################################################################
   if Check(FUNCTION, EdMSDAParms) = 0
      DAUI_Cmds = InstallCmds(_AutoMSPath$ + "HPMDUI01.DLC")
   endif
endmacro ! MSTop_CheckLoadDLC
name About_Triathlon
!############################################################################
! Load DLC if needed
  MSTop_CheckLoadDLC
  AboutLCMS
  return
endmacro
!############################################################################
!
!############################################################################
name MSOnlyConfigCheck
!  Checks if the MSD is the only module configured.
!  Used in top.mac in macro GotoStandby.
!############################################################################
  local var$ 
  if (TabHdrVal(_config[1],ModuleInfo,NumberOfRows) = 1) then
    var$ = TabText$(_config[1], \
                    Modules,     \
			        TabVal(_config[1],ModuleInfo,1,"nameRef"), \
			        "var" )
	if var$ = "MSD" then
	  return(1)
	endif
  endif
  return(0)
endmacro ! MSOnlyConfigCheck
!############################################################################
!
!############################################################################
name LoadMacroMcxOrMac
  parameter File$                    ! file to be loaded without extension
  parameter StartMacro$ default ""   ! Macro to be executed after loading
! Loads an mcx file, if it exists. Otherwise it tries to load a mac file.
!############################################################################
  if filestat(MODE, File$ + ".mcx") = 1   ! exists - is a file
    print "Loading " + File$ + ".mcx..."
    ! evaluate "macro " + File$ + ".mcx"
     cmdpath$ = "macro " + chr$(34) + File$ + ".mcx" +chr$(34)
     evaluate cmdpath$
  else  ! mcx file does not exist try mac file (without test)
    print "Loading " + File$ + ".mac..."
    ! evaluate "macro " + File$ + ".mac"
     cmdpath$ = "macro " + chr$(34) + File$ + ".mac" +chr$(34)
     evaluate cmdpath$
  endif
  Evaluate StartMacro$
endmacro
!############################################################################
!
!############################################################################
name MSTopClose
! This is the LC/MS close macro.
!############################################################################
   !* Check if exit from Manual MS Calibrate view 
   if tabhdrtext$(_config[1],"Window","CurrentView") = "MSDC" then
     if check(macro,mstn_ExitRoutine) = 1 then
       mstn_ExitRoutine
     endif  
   endif  
   MSAcqClose
endmacro
